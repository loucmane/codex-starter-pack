#!/usr/bin/env python3
"""Codex diff-aware guard for S:W:H:E validation and workflow enforcement."""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, Iterable, List, Optional, Sequence, Tuple

REPO_ROOT = Path(__file__).resolve().parent.parent
SESSIONS_PREFIX = Path("sessions")
WORK_TRACKING_PREFIX = Path("docs/ai/work-tracking/active")
GUARDED_WORKTRACKING_FILES = {"TRACKER.md"}
SWHE_PATTERN = re.compile(r"\[S:(?P<S>[^|\]]+)\|W:(?P<W>[^|\]]+)\|H:(?P<H>[^|\]]+)\|E:(?P<E>[^\]]+)\]")
PLACEHOLDER_HANDLERS = {"VOID", "searching", "H:VOID", "VOID→registry"}
PLACEHOLDER_HANDLERS_LOWER = {value.lower() for value in PLACEHOLDER_HANDLERS}

PLAN_CURRENT = REPO_ROOT / "plans" / "current"
TRACKER_ACTIVE = REPO_ROOT / "docs/ai/work-tracking/active/20250920-codex-migration-ssot-ACTIVE/TRACKER.md"
PLAN_REQUIRED_STEPS = ("plan-step-scope", "plan-step-implement", "plan-step-verify")
EMERGENCY_PATTERN = re.compile(r"\*\*Emergency Bypass\*\*:\s*(true|false)", re.IGNORECASE)

@dataclass
class ValidationIssue:
    path: Path
    message: str
    entry: Optional[str] = None

    def render(self) -> str:
        prefix = f"{self.path.as_posix()}: {self.message}"
        if self.entry:
            return f"{prefix} | entry: {self.entry}"
        return prefix


def run_git_status(include_untracked: bool) -> List[Path]:
    try:
        result = subprocess.run(
            ["git", "status", "--porcelain"],
            cwd=str(REPO_ROOT),
            check=True,
            capture_output=True,
            text=True,
        )
    except subprocess.CalledProcessError as exc:
        raise SystemExit(f"git status failed: {exc}")

    changed: List[Path] = []
    for line in result.stdout.splitlines():
        if not line.strip():
            continue
        status = line[:2]
        path_fragment = line[3:]
        if "->" in path_fragment:
            path_fragment = path_fragment.split("->", 1)[1].strip()
        if status == "??" and not include_untracked:
            continue
        if status.strip() == "D":
            # Deleted file; no validation required
            continue
        changed.append((REPO_ROOT / path_fragment).resolve())
    return sorted(set(changed))


def parse_front_matter_text(text: str) -> Dict[str, str]:
    if not text.startswith("---"):
        return {}
    parts = text.split("---", 2)
    if len(parts) < 3:
        return {}
    front_matter = parts[1]
    data: Dict[str, str] = {}
    for raw_line in front_matter.strip().splitlines():
        if not raw_line.strip() or raw_line.strip().startswith("#"):
            continue
        if ":" not in raw_line:
            continue
        key, value = raw_line.split(":", 1)
        data[key.strip()] = value.strip()
    return data


def derive_expected_session(meta: Dict[str, str]) -> Optional[str]:
    if "session_id" in meta:
        parts = meta["session_id"].split("-")
        if len(parts) >= 3:
            return "".join(parts[:3])
        return meta["session_id"].replace("-", "")
    if "date" in meta:
        return meta["date"].replace("-", "")
    return None


def handler_path_exists(handler_value: str) -> bool:
    handler_value = handler_value.strip()
    if handler_value.startswith("templates/"):
        relative = Path(handler_value)
        candidates = [REPO_ROOT / relative, REPO_ROOT / (relative.with_suffix(".md"))]
        for candidate in candidates:
            if candidate.exists():
                return True
        return False
    # Non-template handlers (e.g., H:searching) handled separately
    return True


def validate_swhe_entries(path: Path, text: str, expected_session: Optional[str]) -> List[ValidationIssue]:
    issues: List[ValidationIssue] = []
    matches = list(SWHE_PATTERN.finditer(text))
    if not matches:
        issues.append(ValidationIssue(path, "No S:W:H:E entries detected"))
        return issues

    for match in matches:
        entry_text = match.group(0)
        s_val = match.group("S").strip()
        w_val = match.group("W").strip()
        h_val = match.group("H").strip()
        e_val = match.group("E").strip()

        if not s_val:
            issues.append(ValidationIssue(path, "Empty S field", entry_text))
        if not w_val:
            issues.append(ValidationIssue(path, "Empty W field", entry_text))
        if not h_val:
            issues.append(ValidationIssue(path, "Empty H field", entry_text))
        if not e_val:
            issues.append(ValidationIssue(path, "Empty E field", entry_text))

        if expected_session and s_val not in {expected_session, "current"} and not s_val.startswith("VOID"):
            issues.append(ValidationIssue(path, f"S field '{s_val}' does not match session '{expected_session}'", entry_text))

        handler_key = h_val.lower()
        if handler_key in PLACEHOLDER_HANDLERS_LOWER:
            issues.append(ValidationIssue(path, "Handler still in placeholder state", entry_text))
        elif h_val.startswith("templates/") and not handler_path_exists(h_val):
            issues.append(ValidationIssue(path, "Referenced handler path not found", entry_text))

        if e_val.lower() in {"pending", "searching"}:
            issues.append(ValidationIssue(path, "Evidence still marked as pending/searching", entry_text))

    return issues


def resolve_plan_path() -> Optional[Path]:
    if not PLAN_CURRENT.exists():
        return None
    try:
        target = PLAN_CURRENT.resolve()
    except FileNotFoundError:
        return None
    return target if target.exists() else None


def parse_plan_table(text: str) -> Dict[str, Dict[str, str]]:
    steps: Dict[str, Dict[str, str]] = {}
    for line in text.splitlines():
        stripped = line.strip()
        if not stripped.startswith('|'):
            continue
        if not stripped.lstrip('|').startswith('plan-step-'):
            continue
        cells = [cell.strip() for cell in stripped.strip('|').split('|')]
        if len(cells) < 4:
            continue
        step_id = cells[0]
        description = cells[1] if len(cells) > 1 else ''
        evidence = cells[-2] if len(cells) >= 3 else ''
        status = cells[-1].lower()
        steps[step_id] = {
            'description': description,
            'evidence': evidence,
            'status': status,
        }
    return steps


def validate_plan(plan_path: Path) -> List[ValidationIssue]:
    issues: List[ValidationIssue] = []
    try:
        plan_text = plan_path.read_text(encoding='utf-8')
    except FileNotFoundError:
        issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'Plan file missing'))
        return issues

    steps = parse_plan_table(plan_text)
    for required in PLAN_REQUIRED_STEPS:
        if required not in steps:
            issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), f"Missing row for {required}"))

    scope = steps.get('plan-step-scope')
    if scope and 'completed' not in scope['status']:
        issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'plan-step-scope must be completed before work'))

    emergency_match = EMERGENCY_PATTERN.search(plan_text)
    emergency_required = bool(emergency_match and emergency_match.group(1).lower() == 'true')
    if emergency_required and 'plan-step-emergency' not in steps:
        issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'Emergency bypass declared but plan-step-emergency row missing'))

    implement = steps.get('plan-step-implement')
    if implement and not implement['description']:
        issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'plan-step-implement description is empty'))

    verify = steps.get('plan-step-verify')
    if verify and not verify['description']:
        issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'plan-step-verify description is empty'))

    if 'Plan Version' not in plan_text:
        issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'Plan header missing Plan Version entry'))

    scope_index = plan_text.find('## Scope')
    if scope_index == -1:
        issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'Plan missing ## Scope section'))
    else:
        scope_end = plan_text.find('

', scope_index + 1)
        if scope_end == -1:
            scope_section = plan_text[scope_index:]
        else:
            scope_section = plan_text[scope_index:scope_end]
        if '-' not in scope_section:
            issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'Scope section missing bullet list of files/components'))

    if '## Continuation' not in plan_text:
        issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'Plan missing ## Continuation section'))

    if not EMERGENCY_PATTERN.search(plan_text):
        issues.append(ValidationIssue(plan_path.relative_to(REPO_ROOT), 'Plan header missing Emergency Bypass field'))

    return issues


def validate_tracker_alignment(plan_steps: Iterable[str]) -> List[ValidationIssue]:
    issues: List[ValidationIssue] = []
    try:
        tracker_text = TRACKER_ACTIVE.read_text(encoding='utf-8')
    except FileNotFoundError:
        issues.append(ValidationIssue(TRACKER_ACTIVE.relative_to(REPO_ROOT), 'Tracker file missing'))
        return issues

    for step in plan_steps:
        checkbox_unchecked = f'- [ ] {step}'
        checkbox_checked = f'- [x] {step}'
        if checkbox_unchecked not in tracker_text and checkbox_checked not in tracker_text:
            issues.append(ValidationIssue(TRACKER_ACTIVE.relative_to(REPO_ROOT), f'Tracker missing checkbox for {step}'))
    return issues


def evaluate_file(path: Path) -> List[ValidationIssue]:
    try:
        text = path.read_text(encoding="utf-8")
    except FileNotFoundError:
        return []

    metadata = {}
    if path.relative_to(REPO_ROOT).parts[0] == "sessions":
        metadata = parse_front_matter_text(text)
    expected_session = derive_expected_session(metadata)
    issues = validate_swhe_entries(path.relative_to(REPO_ROOT), text, expected_session)
    return issues


def guard_validate(args: argparse.Namespace) -> int:
    changed_files = run_git_status(args.include_untracked)
    relevant: List[Path] = []
    for file_path in changed_files:
        try:
            relative = file_path.relative_to(REPO_ROOT)
        except ValueError:
            continue
        if relative.suffix != ".md":
            continue
        if relative.parts[0] == "sessions":
            relevant.append(file_path)
        elif (relative.parts[:len(WORK_TRACKING_PREFIX.parts)] == WORK_TRACKING_PREFIX.parts
              and relative.name in GUARDED_WORKTRACKING_FILES):
            relevant.append(file_path)

    if not relevant:
        print("No relevant markdown files changed; guard passes by default.")
        return 0

    all_issues: List[ValidationIssue] = []
    for candidate in relevant:
        all_issues.extend(evaluate_file(candidate))

    plan_path = resolve_plan_path()
    if plan_path is None:
        all_issues.append(ValidationIssue(Path('plans/current'), 'Active plan symlink missing or invalid'))
    else:
        all_issues.extend(validate_plan(plan_path))
        all_issues.extend(validate_tracker_alignment(PLAN_REQUIRED_STEPS))

    if all_issues:
        print("Guard validation failed:")
        for issue in all_issues:
            print(f"  - {issue.render()}")
        return 1

    print("Guard validation passed: all S:W:H:E entries look compliant.")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Codex diff-aware guard")
    subparsers = parser.add_subparsers(dest="command", required=True)

    validate_parser = subparsers.add_parser("validate", help="Validate S:W:H:E compliance in changed files")
    validate_parser.add_argument("--include-untracked", action="store_true", help="Include untracked markdown files")
    validate_parser.set_defaults(func=guard_validate)

    return parser


def main(argv: Optional[Sequence[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
