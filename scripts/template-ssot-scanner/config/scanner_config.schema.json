{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/schemas/template-ssot-scanner/scanner_config.schema.json",
  "title": "Template SSOT Scanner Configuration",
  "description": "Portable scanner configuration contract for validation rules, scan scope, allowlists, blocklists, profiles, and environment overlays.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "validation_rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Configuration schema version. Version 1.0.0 reflects the Task 4.1 scanner configuration contract."
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "scan_scope": {
      "$ref": "#/$defs/scan_scope"
    },
    "validation_rules": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/validation_rule"
      }
    },
    "allowlists": {
      "$ref": "#/$defs/pattern_groups"
    },
    "blocklists": {
      "$ref": "#/$defs/pattern_groups"
    },
    "profiles": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/profile"
      }
    },
    "environment_overlays": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "scan_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "$ref": "#/$defs/string_list"
        },
        "exclude": {
          "$ref": "#/$defs/string_list"
        },
        "config_dirs": {
          "$ref": "#/$defs/string_list"
        },
        "scannable_suffixes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\.[A-Za-z0-9]+$"
          },
          "uniqueItems": true
        },
        "checkpointing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "interval": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "validation_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "severity"
      ],
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ]
        },
        "priority": {
          "$ref": "#/$defs/rule_priority"
        },
        "threshold": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "enabled": {
          "type": "boolean"
        },
        "auto_fix": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "pattern_groups": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pattern_entry"
          }
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pattern_entry"
          }
        }
      }
    },
    "pattern_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pattern",
        "kind",
        "reason"
      ],
      "properties": {
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "glob",
            "regex"
          ]
        },
        "rules": {
          "$ref": "#/$defs/string_list"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "expires": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "extends": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Optional base profile or overlay name to inherit before applying overrides."
        },
        "merge_strategy": {
          "type": "string",
          "enum": [
            "deep_merge",
            "replace"
          ]
        },
        "overrides": {
          "$ref": "#/$defs/partial_config"
        }
      }
    },
    "partial_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scan_scope": {
          "$ref": "#/$defs/scan_scope"
        },
        "validation_rules": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/validation_rule_patch"
          }
        },
        "allowlists": {
          "$ref": "#/$defs/pattern_groups"
        },
        "blocklists": {
          "$ref": "#/$defs/pattern_groups"
        }
      }
    },
    "validation_rule_patch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ]
        },
        "priority": {
          "$ref": "#/$defs/rule_priority"
        },
        "threshold": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "enabled": {
          "type": "boolean"
        },
        "auto_fix": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "rule_priority": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ],
      "description": "Rule-engine priority. It maps to scanner output severities without changing the existing error/warning/info finding contract."
    }
  }
}
