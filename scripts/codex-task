        "- Wizard design note under `designs/`",
        "- Tracker/session entries for kickoff and implementation progress",
        "- Stored test and guard evidence once the wizard implementation lands",
        "",
        "## Emergency Bypass Protocol",
        "- No bypass authorized.",
    ]


def handle_wizard_kickoff(args: argparse.Namespace) -> None:
    now = datetime.now().astimezone()
    task_id = args.task or _prompt_with_default("Task ID")
    task_meta = _load_task_metadata(task_id)
    title = args.title or _prompt_with_default("Task title", task_meta["title"])
    slug = _slugify(args.slug or _prompt_with_default("Task slug", _slugify(title)))
    goals = args.goal or _default_goals_for_title(title)
    source = args.task_source or f"Guided kickoff for Task {task_id}"
    task_file_relative = task_meta["path"]
    handler_target = args.handler_target or task_file_relative
    work_context = f"task{task_id}-{slug}"
    branch = subprocess.run(
        ["git", "branch", "--show-current"],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
        check=False,
    ).stdout.strip() or f"feat/task-{task_id}-{slug}"
    _validate_branch_for_task(branch, task_id)

    scaffold_args = argparse.Namespace(
        task=task_id,
        slug=slug,
        title=title,
        goal=goals,
        force=args.force,
        dry_run=args.dry_run,
    )
    handle_work_tracking_scaffold(scaffold_args)

    session_id = _next_session_id(now)
    session_dir = SESSIONS_DIR / now.strftime("%Y") / now.strftime("%m")
    session_path = session_dir / f"{session_id}-task{task_id}-{slug}.md"
    plan_path = PLAN_CURRENT.parent / f"{now.strftime('%Y-%m-%d')}-task{task_id}-{slug}.md"
    tracker_relative = (WORK_TRACKING_BASE / f"{now.strftime('%Y%m%d')}-task{task_id}-{slug}-ACTIVE" / "TRACKER.md").relative_to(REPO_ROOT).as_posix()

    session_lines = _build_session_lines(
        session_id=session_id,
        now=now,
        task_id=task_id,
        title=title,
        branch=branch,
        source=source,
        task_file_relative=task_file_relative,
        work_context=work_context,
        tracker_relative=tracker_relative,
    )
    plan_lines = _build_plan_lines(
        session_id=session_id,
        task_id=task_id,
        title=title,
        work_context=work_context,
        handler_target=handler_target,
        tracker_relative=tracker_relative,
        task_file_relative=task_file_relative,
        branch=branch,
    )

    if args.dry_run:
        print(f"Would create session {session_path.relative_to(REPO_ROOT)}")
        print(f"Would create plan {plan_path.relative_to(REPO_ROOT)}")
        return

    session_dir.mkdir(parents=True, exist_ok=True)
    _write_file_lines(session_path, session_lines)
    _write_file_lines(plan_path, plan_lines)
    _symlink_to(SESSIONS_DIR / "current", session_path)
    _symlink_to(PLAN_CURRENT, plan_path)
    _write_session_state(session_path.name, now)
    tracker_path = REPO_ROOT / tracker_relative
    tracker_lines = _load_file_lines(tracker_path)
    for entry in _build_tracker_entries(now, task_id, work_context, tracker_relative):
        tracker_lines = _insert_progress_entry(tracker_lines, PROGRESS_HEADING_TRACKER, entry)
    _write_file_lines(tracker_path, tracker_lines)
    handle_plan_sync(argparse.Namespace(plan=plan_path.relative_to(REPO_ROOT).as_posix(), tracker=tracker_relative, dry_run=False))
    _run_checked_command(["task-master", "set-status", f"--id={task_id}", "--status=in-progress"])
    _run_checked_command(["task-master", "generate"])
    print(f"Created session: {session_path.relative_to(REPO_ROOT)}")
    print(f"Created plan: {plan_path.relative_to(REPO_ROOT)}")
    print(f"Repointed {SESSIONS_CURRENT_REL}, {PLANS_CURRENT_REL}, and {SESSION_STATE_REL}")


def _resolve_plan_path(override: Optional[str] = None) -> Path:
    if override:
        candidate = (REPO_ROOT / override).resolve()
        if not candidate.exists():
            raise TaskError(f"Plan file not found: {candidate}")
        return candidate

    if not PLAN_CURRENT.exists():
        raise TaskError("Active plan symlink missing; create plan with templates/workflows/processes/plan-template.md")

    resolved = PLAN_CURRENT.resolve()
    if not resolved.exists():
        raise TaskError(f"Active plan target missing: {resolved}")
    return resolved


def _is_between_sessions_state() -> bool:
    """Return true when the repository is intentionally between sessions."""

    if PLAN_CURRENT.exists() or PLAN_CURRENT.is_symlink():
        return False

    current_session_link = SESSIONS_DIR / "current"
    if current_session_link.exists() or current_session_link.is_symlink():
        return False

    if not SESSION_STATE_PATH.exists():
        return False

    try:
        state = json.loads(SESSION_STATE_PATH.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return False

    return state.get("current") in {None, ""}


def _resolve_tracker_path(override: Optional[str] = None) -> Path:
    if override:
        candidate = (REPO_ROOT / override).resolve()
        if not candidate.exists():
            raise TaskError(f"Tracker file not found: {candidate}")
        return candidate
    return _get_tracker_path()


def _parse_plan_table(text: str) -> Dict[str, Dict[str, str]]:
    steps: Dict[str, Dict[str, str]] = {}
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line.startswith("|"):
            continue
        cells = [cell.strip() for cell in line.strip("|").split("|")]
        if not cells or not cells[0].startswith("plan-step-"):
            continue
        if len(cells) < 4:
            raise TaskError(f"Malformed plan table row: {raw_line}")
        step_id = cells[0]
        description = cells[1] if len(cells) > 1 else ""
        evidence = cells[-2] if len(cells) >= 3 else ""
        status = cells[-1].lower()
        steps[step_id] = {
            "description": description,
            "evidence": evidence,
            "status": status,
        }
    return steps


def _ensure_plan_steps_present(steps: Dict[str, Dict[str, str]]) -> None:
    missing = [step for step in PLAN_REQUIRED_STEPS if step not in steps]
    if missing:
        raise TaskError(f"Plan is missing required rows: {', '.join(missing)}")


def _load_tracker_text(tracker_path: Path) -> str:
    return tracker_path.read_text(encoding="utf-8")


def _tracker_has_checkbox(tracker_text: str, step_id: str, checked: bool) -> bool:
    token = "- [x]" if checked else "- [ ]"
    return f"{token} {step_id}" in tracker_text


def _validate_tracker_alignment(steps: Dict[str, Dict[str, str]], tracker_text: str) -> None:
    issues: List[str] = []
    for step_id, data in steps.items():
        status = data.get("status", "").strip().lower()
        has_checked = _tracker_has_checkbox(tracker_text, step_id, True)
        has_unchecked = _tracker_has_checkbox(tracker_text, step_id, False)
        if not has_checked and not has_unchecked:
            issues.append(f"Tracker missing checkbox for {step_id}")
            continue

        if status in PLAN_STATUS_COMPLETE and not has_checked:
            issues.append(f"Tracker checkbox for {step_id} should be checked (status {status})")
        elif status in PLAN_STATUS_INCOMPLETE and not has_unchecked:
            issues.append(f"Tracker checkbox for {step_id} should remain unchecked (status {status})")
        elif status in PLAN_STATUS_PASSIVE and not has_unchecked:
            issues.append(f"Tracker checkbox for {step_id} should remain unchecked (status {status})")
    if issues:
        raise TaskError("; ".join(issues))


def _compute_sha256(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _load_plan_sync_entries() -> List[Dict[str, str]]:
    if not PLAN_SYNC_LOG.exists():
        return []
    try:
        data = json.loads(PLAN_SYNC_LOG.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"Plan sync log is not valid JSON: {exc}")
    if not isinstance(data, list):
        raise TaskError("Plan sync log root must be a list")
    return data


def _write_plan_sync_entries(entries: List[Dict[str, str]]) -> None:
    PLAN_STATE_DIR.mkdir(parents=True, exist_ok=True)
    PLAN_SYNC_LOG.write_text(json.dumps(entries, indent=2) + "\n", encoding="utf-8")


def handle_plan_sync(args: argparse.Namespace) -> None:
    if not args.plan and not args.tracker and _is_between_sessions_state():
        print("No active plan; repository is between sessions. Plan sync skipped.")
        return

    plan_path = _resolve_plan_path(args.plan)
    tracker_path = _resolve_tracker_path(args.tracker)

    plan_text = plan_path.read_text(encoding="utf-8")
    steps = _parse_plan_table(plan_text)
    _ensure_plan_steps_present(steps)

    tracker_text = _load_tracker_text(tracker_path)
    _validate_tracker_alignment(steps, tracker_text)

    plan_hash = _compute_sha256(plan_path)
    tracker_hash = _compute_sha256(tracker_path)

    rel_plan = plan_path.relative_to(REPO_ROOT).as_posix()
    entries = _load_plan_sync_entries()
    entry = {
        "plan": rel_plan,
        "plan_hash": plan_hash,
        "tracker_hash": tracker_hash,
        "synced_at": datetime.now().astimezone().isoformat(),
    }

    if args.dry_run:
        print(json.dumps(entry, indent=2))
        return

    entries.append(entry)
    _write_plan_sync_entries(entries)
    print(f"Plan sync recorded for {rel_plan}")
def _parse_front_matter(path: Path) -> Dict[str, str]:
    text = path.read_text(encoding="utf-8")
    if not text.startswith("---"):
        return {}
    parts = text.split("---", 2)
    if len(parts) < 3:
        return {}
    front_matter = parts[1]
    data: Dict[str, str] = {}
    for raw_line in front_matter.strip().splitlines():
        if not raw_line.strip() or raw_line.strip().startswith("#"):
            continue
        if ":" not in raw_line:
            continue
        key, value = raw_line.split(":", 1)
        data[key.strip()] = value.strip()
    return data


def _resolve_current_session(explicit: Optional[str] = None) -> Path:
    if explicit:
        candidate = (REPO_ROOT / explicit).resolve()
        if not candidate.exists():
            raise TaskError(f"Specified session file not found: {candidate}")
        return candidate

    current_link = SESSIONS_DIR / "current"
    if current_link.exists():
        return current_link.resolve()

    # Fallback: find most recent session markdown in sessions directory.
    candidates = sorted(SESSIONS_DIR.glob("**/*.md"))
    if not candidates:
        raise TaskError(f"No session files located under {SESSIONS_DIR.relative_to(REPO_ROOT).as_posix()}/.")
    return candidates[-1]


def _resolve_active_work_tracking(explicit: Optional[str] = None) -> Path:
    if explicit:
        target = (WORK_TRACKING_BASE / explicit).resolve()
        if not target.exists():
            raise TaskError(f"Work-tracking folder not found: {target}")
        return target

    candidates = [p for p in WORK_TRACKING_BASE.iterdir() if p.is_dir() and p.name.endswith("-ACTIVE")]
    if not candidates:
        raise TaskError(f"No ACTIVE work-tracking folder found under {WORK_TRACKING_ACTIVE_REL}/.")
    if len(candidates) > 1:
        names = ", ".join(p.name for p in candidates)
        raise TaskError(f"Multiple ACTIVE work-tracking folders found ({names}); specify one via --folder.")
    return candidates[0]


def _get_tracker_path(explicit: Optional[str] = None) -> Path:
    folder = _resolve_active_work_tracking(explicit)
    tracker = folder / "TRACKER.md"
    if not tracker.exists():
        raise TaskError(f"Tracker file missing at {tracker}")
    return tracker


def _derive_session_value(meta: Dict[str, str]) -> str:
    if "session_id" in meta:
        session_id = meta["session_id"].strip()
        if session_id:
            parts = session_id.split("-")
            if len(parts) >= 3:
                return "".join(parts[:3])
            return session_id.replace("-", "")
    if "date" in meta:
        return meta["date"].replace("-", "")
    raise TaskError("Unable to derive session value from metadata; ensure front matter includes session_id or date.")


def _ensure_no_active_conflict(ignore_existing: bool) -> None:
    if ignore_existing:
        return
    active = [p for p in WORK_TRACKING_BASE.iterdir() if p.is_dir() and p.name.endswith("-ACTIVE")]
    if active:
        names = ", ".join(sorted(p.name for p in active))
        raise TaskError(
            f"Active work-tracking folder(s) already exist ({names}). Archive them first or pass --force to scaffold."
        )


def handle_work_tracking_scaffold(args: argparse.Namespace) -> None:
    now = datetime.now().astimezone()
    date_prefix = now.strftime("%Y%m%d")
    iso_today = now.date().isoformat()
    slug = _slugify(args.slug)
    task_token = f"task{args.task}"
    folder_name = f"{date_prefix}-{task_token}-{slug}-ACTIVE"
    folder_path = WORK_TRACKING_BASE / folder_name

    if folder_path.exists():
        raise TaskError(f"Work-tracking folder already exists: {folder_path}")

    _ensure_no_active_conflict(args.force)

    if args.dry_run:
        print(f"Would create {folder_path.relative_to(REPO_ROOT)}")
        return

    folder_path.mkdir(parents=True)
    (folder_path / "designs").mkdir()
    reports_base = folder_path / "reports" / slug
    reports_base.mkdir(parents=True)

    title = args.title or args.slug.replace('-', ' ').title()
    goals = args.goal or ["Document alignment prerequisites", "Implement alignment workflow and guard", "Capture evidence"]

    tracker_lines = [
        f"# Task {args.task} {title} Tracker",
        "",
        f"**Started**: {iso_today}",
        "**Status**: ACTIVE",
        f"**Last Updated**: {iso_today}",
        "",
        "## Goals",
    ] + [f"- [ ] {goal}" for goal in goals] + [
        "",
        "## Progress Log",
        "",
        "## Plan Compliance Checklist",
        "- [ ] plan-step-scope — Define alignment prerequisites and scope",
        "- [ ] plan-step-implement — Update workflow/guard/docs and capture tests",
        "- [ ] plan-step-verify — Evidence stored, documentation updated",
        "- [ ] plan-step-emergency (if applicable)",
        "",
        "## Dependencies & Notes",
        f"- Session log: {SESSIONS_CURRENT_REL}",
    ]
    _write_file_lines(folder_path / "TRACKER.md", tracker_lines)

    timestamp = now.strftime("%Y-%m-%d %H:%M %Z")
    changelog_lines = [
        f"# Task {args.task} {title} – Changelog",
        "",
        f"- {timestamp} — Initialized active work-tracking folder.",
    ]
    _write_file_lines(folder_path / "CHANGELOG.md", changelog_lines)

    for doc_name, template in WORK_TRACKING_DEFAULT_DOCS.items():
        content = template.format(today=iso_today, task=args.task, title=title)
        (folder_path / doc_name).write_text(content, encoding='utf-8')

    print(f"Created active work-tracking folder: {folder_path.relative_to(REPO_ROOT)}")


def handle_work_tracking_archive(args: argparse.Namespace) -> None:
    folder = _resolve_active_work_tracking(args.folder)
    now = datetime.now().astimezone()
    iso_today = now.date().isoformat()
    timestamp = now.strftime("%Y-%m-%d %H:%M %Z")

    if args.dry_run:
        print(f"Would archive {folder.relative_to(REPO_ROOT)}")
        return

    tracker_path = folder / "TRACKER.md"
    if tracker_path.exists():
        lines = _load_file_lines(tracker_path)
        if not _replace_line_with_prefix(lines, "**Status**:", "**Status**: COMPLETED"):
            lines.insert(3, "**Status**: COMPLETED")
        if not _replace_line_with_prefix(lines, "**Last Updated**:", f"**Last Updated**: {iso_today}"):
            lines.insert(4, f"**Last Updated**: {iso_today}")
        _write_file_lines(tracker_path, lines)

    changelog_path = folder / "CHANGELOG.md"
    if changelog_path.exists():
        lines = _load_file_lines(changelog_path)
        lines.append(f"- {timestamp} — Archived active work-tracking folder.")
        _write_file_lines(changelog_path, lines)

    handoff_path = folder / "HANDOFF.md"
    if handoff_path.exists():
        lines = _load_file_lines(handoff_path)
        lines.append(f"- Archived on {timestamp} — Folder moved to archive and tracker marked COMPLETED.")
        _write_file_lines(handoff_path, lines)

    archive_base = WORK_TRACKING_BASE.parent / "archive"
    archive_base.mkdir(parents=True, exist_ok=True)
    target_name = folder.name.replace("-ACTIVE", "-COMPLETED")
    target_path = archive_base / target_name
    if target_path.exists():
        raise TaskError(f"Archive destination already exists: {target_path}")

    shutil.move(str(folder), str(target_path))
    print(f"Archived work-tracking folder to {target_path.relative_to(REPO_ROOT)}")



def handle_work_tracking_audit(args: argparse.Namespace) -> None:
    today = datetime.now().date().isoformat()
    today_prefix = today.replace('-', '')
    issues: List[str] = []
    warnings: List[str] = []

    if not WORK_TRACKING_BASE.exists():
        issues.append("Active work-tracking directory missing")
    else:
        active_folders = [p for p in WORK_TRACKING_BASE.iterdir() if p.is_dir() and p.name.endswith('-ACTIVE')]
        if not active_folders:
            warnings.append("No ACTIVE work-tracking folders present")
        else:
            if len(active_folders) > 1:
                names = ", ".join(p.name for p in active_folders)
                issues.append(f"Multiple ACTIVE folders detected: {names}")
            for folder in active_folders:
                prefix = folder.name.split('-', 1)[0]
                if prefix != today_prefix:
                    warnings.append(
                        f"Active folder {folder.name} has prefix {prefix}; today's prefix is {today_prefix} (ensure multi-day reuse is intentional)"
                    )
                tracker_path = folder / 'TRACKER.md'
                if tracker_path.exists():
                    try:
                        tracker_text = tracker_path.read_text(encoding='utf-8')
                    except FileNotFoundError:
                        tracker_text = ''
                    if today not in tracker_text or 'serena/memory' not in tracker_text.lower():
                        warnings.append(
                            f"Tracker for {folder.name} missing Serena memory entry for {today}; capture memory and log via presets."
                        )

    current_symlink = SESSIONS_DIR / 'current'
    if not current_symlink.exists() or not current_symlink.is_symlink():
        current_state = object()
        try:
            current_state = json.loads(SESSION_STATE_PATH.read_text(encoding='utf-8')).get('current')
        except (FileNotFoundError, json.JSONDecodeError):
            pass
        if current_state in {None, ''}:
            warnings.append(f"{SESSIONS_CURRENT_REL} symlink missing because repository is between sessions")
        else:
            issues.append(f"{SESSIONS_CURRENT_REL} symlink missing")
    else:
        target = current_symlink.resolve()
        if target.exists():
            try:
                relative = target.relative_to(SESSIONS_DIR)
            except ValueError:
                warnings.append(f"{SESSIONS_CURRENT_REL} points outside {SESSIONS_DIR.relative_to(REPO_ROOT).as_posix()}/: {target}")
            else:
                session_date = relative.name[:10]
                if session_date != today:
                    warnings.append(
                        f"{SESSIONS_CURRENT_REL} points to {relative} (date {session_date}); consider starting a new session for {today}"
                    )
        else:
            issues.append(f"{SESSIONS_CURRENT_REL} target missing: {target}")

    if issues:
        print("Audit issues detected:")
        for issue in issues:
            print(f"- {issue}")
    if warnings:
        print("Audit warnings:")
        for warning in warnings:
            print(f"- {warning}")
    if not issues and not warnings:
        print("Audit passed: no issues found.")
    if issues:
        sys.exit(1)


def _insert_progress_entry(lines: List[str], heading: str, entry_line: str) -> List[str]:
    try:
        heading_index = next(idx for idx, line in enumerate(lines) if line.strip() == heading)
    except StopIteration as exc:
        raise TaskError(f"Heading '{heading}' not found in target document.") from exc

    last_entry_index: Optional[int] = None
    for idx in range(heading_index + 1, len(lines)):
        line = lines[idx]
        if line.startswith("##") or line.startswith("###"):
            break
        if line.startswith("- "):
            last_entry_index = idx

    insert_at = heading_index + 1 if last_entry_index is None else last_entry_index + 1
    lines.insert(insert_at, entry_line)
    return lines


def handle_sessions_update(args: argparse.Namespace) -> None:
    session_path = _resolve_current_session(args.session_file)
    metadata = _parse_front_matter(session_path)
    session_value = args.session or _derive_session_value(metadata)

    timestamp = args.time or datetime.now().strftime(DEFAULT_TIME_FORMAT_SESSION)
    work = args.work
    handler = args.handler
    evidence = args.evidence
    note = args.note

    swhe = f"[S:{session_value}|W:{work}|H:{handler}|E:{evidence}]"
    entry = f"- **[{timestamp}]** — {swhe} {note}"

    if args.dry_run:
        print(entry)
        return

    lines = _load_file_lines(session_path)
    updated = _insert_progress_entry(lines, PROGRESS_HEADING_SESSION, entry)
    _write_file_lines(session_path, updated)
    print(f"Updated session log: {session_path}")


def _ensure_progress_heading(lines: List[str]) -> List[str]:
    heading = "## Progress Log"
    if heading in (line.strip() for line in lines):
        return lines
    if lines and not lines[-1].endswith("\n"):
        lines[-1] = lines[-1] + "\n"
    lines.extend(["\n", f"{heading}\n", "\n"])
    return lines


def handle_work_tracking_update(args: argparse.Namespace) -> None:
    work_folder = _resolve_active_work_tracking(args.folder)

    preset = getattr(args, "preset", None)
    handler_value = args.handler

    if preset:
        doc_name, default_handler = WORK_TRACKING_PRESETS[preset]
        target_name = doc_name
        if handler_value.lower() == "auto":
            handler_value = default_handler
    else:
        target_name = args.document if args.document.endswith(".md") else f"{args.document}.md"

    target_path = work_folder / target_name
    if not target_path.exists():
        template = WORK_TRACKING_DEFAULT_DOCS.get(target_name)
        today = datetime.now().date().isoformat()
        title_token = args.work.replace('-', ' ').title()
        task_match = re.search(r"(\d+)", args.work)
        task_value = task_match.group(1) if task_match else args.work
        if template:
            content = template.format(today=today, task=task_value, title=title_token)
        else:
            content = f"# {title_token}\n\n## Progress Log\n"
        target_path.write_text(content, encoding='utf-8')

    session_path = _resolve_current_session(args.session_file)
    metadata = _parse_front_matter(session_path)
    session_value = args.session or _derive_session_value(metadata)

    timestamp = args.time or datetime.now().strftime(DEFAULT_TIME_FORMAT_TRACKER)
    swhe = f"[S:{session_value}|W:{args.work}|H:{handler_value}|E:{args.evidence}]"
    entry = f"- **{timestamp}** — {swhe} {args.note}"

    if args.dry_run:
        print(entry)
        return

    lines = _load_file_lines(target_path)
    lines = _ensure_progress_heading(lines)
    updated = _insert_progress_entry(lines, PROGRESS_HEADING_TRACKER, entry)
    _write_file_lines(target_path, updated)
    print(f"Updated work-tracking log: {target_path}")


def _resolve_scanner(tool: str) -> Path:
    mapping = {
        "scanner": SCANNER_PATH / "scanner.py",
        "analyze": SCANNER_PATH / "analyze_references.py",
        "duplicates": SCANNER_PATH / "find_duplicates.py",
        "migration": SCANNER_PATH / "migration_detector.py",
        "fixes": SCANNER_PATH / "generate_fixes.py",
        "safe-reorg": SCANNER_PATH / "safe_reorganize.py",
    }
    if tool not in mapping:
        valid = ", ".join(sorted(mapping.keys()))
        raise TaskError(f"Unknown scanner tool '{tool}'. Valid options: {valid}")
    target = mapping[tool]
    if not target.exists():
        raise TaskError(f"Scanner script not found at {target}")
    return target


def _meta_guard_message() -> str:
    return (
        "Meta Workflow Guard failed. Ensure your plan includes the meta workflow assets, "
        "branch matches policy (e.g., feat/task<id>-description), and run plan sync. "
        "See templates/engine/enforcement/meta-workflow-guard-remediation.md for remediation steps."
    )


def handle_scanner_run(args: argparse.Namespace) -> None:
    script_path = _resolve_scanner(args.tool)
    extra_args = getattr(args, "scanner_args", [])
    cmd = [sys.executable, str(script_path)] + extra_args
    print("Running:", " ".join(cmd))
    result = subprocess.run(cmd, cwd=str(REPO_ROOT))
    if result.returncode != 0:
        raise TaskError(f"Scanner command failed with exit code {result.returncode}")

    if args.log_note:
        log_kwargs = {
            "work": args.work,
            "handler": args.handler,
            "evidence": args.evidence,
            "note": args.log_note,
            "session_file": args.session_file,
            "session": args.session,
            "time": args.time,
            "dry_run": args.dry_run,
        }
        handle_sessions_update(argparse.Namespace(**log_kwargs))
        handle_work_tracking_update(argparse.Namespace(
            work=args.work,
            handler=args.handler,
            evidence=args.evidence,
            note=args.log_note,
            folder=args.folder,
            document=args.document,
            session_file=args.session_file,
            session=args.session,
            time=args.time,
            dry_run=args.dry_run,
        ))


def handle_report_generate(args: argparse.Namespace) -> None:
    commands: List[List[str]] = []

    if args.kind in {"drift", "all"}:
        drift_cmd = [
            sys.executable,
            str(CODEX_GUARD_SCRIPT),
            "drift-check",
            "--report-dir",
            args.drift_report_dir,
        ]
        if args.strict_drift:
            drift_cmd.append("--strict")
        commands.append(drift_cmd)

    if args.kind in {"metrics", "all"}:
        commands.append([
            sys.executable,
            str(METRICS_DASHBOARD_SCRIPT),
            "--report-dir",
            args.report_dir,
        ])

    for cmd in commands:
        printable = " ".join(cmd)
        if args.dry_run:
            print(f"Would run: {printable}")
            continue
        print(f"Running: {printable}")
        result = subprocess.run(cmd, cwd=str(REPO_ROOT))
        if result.returncode != 0:
            raise TaskError(f"Report command failed with exit code {result.returncode}: {printable}")


def _path_display(path: Path) -> str:
    return _relative_to_root(path, REPO_ROOT)


def _is_executable_file(path: Path) -> bool:
    return path.is_file() and os.access(path, os.X_OK)


def _find_pre_commit_binary() -> Optional[Path]:
    local_binary = REPO_ROOT / ".venv" / "bin" / "pre-commit"
    if _is_executable_file(local_binary):
        return local_binary

    found = shutil.which("pre-commit")
    if found:
        return Path(found)
    return None


def _pre_commit_version(binary: Path) -> str:
    result = subprocess.run(
        [str(binary), "--version"],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return "version unavailable"
    return result.stdout.strip() or "version unavailable"


def _verify_pre_commit_config() -> List[str]:
    issues: List[str] = []
    if not PRE_COMMIT_CONFIG.exists():
        return [f"Missing {PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()}"]

    config_text = PRE_COMMIT_CONFIG.read_text(encoding="utf-8")
    for snippet in PRE_COMMIT_REQUIRED_SNIPPETS:
        if snippet not in config_text:
            issues.append(f"{PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()} missing required entry: {snippet}")
    if config_text.count("pass_filenames: false") < len(PRE_COMMIT_REQUIRED_SNIPPETS):
        issues.append(f"{PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()} should keep guard hooks filename-independent")
    if config_text.count("always_run: true") < len(PRE_COMMIT_REQUIRED_SNIPPETS):
        issues.append(f"{PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()} should keep guard hooks always-on")
    return issues


def _pre_commit_hook_status() -> Tuple[bool, str]:
    if not PRE_COMMIT_HOOK.exists():
        return False, f"{_path_display(PRE_COMMIT_HOOK)} is not installed"
    if not PRE_COMMIT_HOOK.is_file():
        return False, f"{_path_display(PRE_COMMIT_HOOK)} exists but is not a file"
    if not os.access(PRE_COMMIT_HOOK, os.X_OK):
        return False, f"{_path_display(PRE_COMMIT_HOOK)} exists but is not executable"
    try:
        hook_text = PRE_COMMIT_HOOK.read_text(encoding="utf-8", errors="ignore")
    except OSError as exc:
        return False, f"{_path_display(PRE_COMMIT_HOOK)} could not be read: {exc}"
    if "pre-commit" not in hook_text and "PRE_COMMIT" not in hook_text:
        return False, f"{_path_display(PRE_COMMIT_HOOK)} does not look like a pre-commit managed hook"
    return True, f"{_path_display(PRE_COMMIT_HOOK)} is installed"


def handle_hooks_verify(args: argparse.Namespace) -> None:
    issues = _verify_pre_commit_config()
    warnings: List[str] = []
    detail_lines: List[str] = []

    if issues:
        detail_lines.append(f"- {_path_display(PRE_COMMIT_CONFIG)}: failed")
    else:
        detail_lines.append(f"- {_path_display(PRE_COMMIT_CONFIG)}: ok")

    binary = _find_pre_commit_binary()
    if binary is None:
        issues.append("pre-commit executable not found; install dev dependencies or ensure .venv/bin/pre-commit exists")
        detail_lines.append("- pre-commit binary: missing")
    else:
        version = _pre_commit_version(binary)
        detail_lines.append(f"- pre-commit binary: ok ({_path_display(binary)}, {version})")

    hook_installed, hook_message = _pre_commit_hook_status()
    if hook_installed:
        detail_lines.append(f"- local pre-commit hook: ok ({hook_message})")
    else:
        message = f"local pre-commit hook: {hook_message}; run `{PRE_COMMIT_INSTALL_COMMAND}`"
        if args.require_installed:
            issues.append(message)
            detail_lines.append(f"- local pre-commit hook: failed ({hook_message})")
        else:
            warnings.append(message)
            detail_lines.append(f"- local pre-commit hook: warning ({hook_message})")

    print("Hook verification:")
    for line in detail_lines:
        print(line)
    if warnings:
        print("Warnings:")
        for warning in warnings:
            print(f"- {warning}")
    if issues:
        print("Issues:")
        for issue in issues:
            print(f"- {issue}")
        raise TaskError("Hook verification failed")
    print("Hook verification passed.")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Codex task helper")
    parser.add_argument("--session", help="Override S field session value", default=None)
    parser.add_argument("--session-file", help="Path to specific session markdown", default=None)
    parser.add_argument("--time", help="Override timestamp")
    parser.add_argument("--dry-run", action="store_true", help="Print output without writing to files")

    subparsers = parser.add_subparsers(dest="command", required=True)

    sessions_parser = subparsers.add_parser("sessions", help="Session log operations")
    sessions_sub = sessions_parser.add_subparsers(dest="subcommand", required=True)
    sessions_update = sessions_sub.add_parser("update", help="Append entry to current session progress log")
    sessions_update.add_argument("--work", required=True, help="W field value")
    sessions_update.add_argument("--handler", required=True, help="H field value")
    sessions_update.add_argument("--evidence", required=True, help="E field value")
    sessions_update.add_argument("--note", required=True, help="Log note")
    sessions_update.set_defaults(func=handle_sessions_update)

    work_parser = subparsers.add_parser("work-tracking", help="Work-tracking document operations")
    work_sub = work_parser.add_subparsers(dest="subcommand", required=True)
    work_scaffold = work_sub.add_parser("scaffold", help="Create a new active work-tracking folder")
    work_scaffold.add_argument("--task", required=True, help="Task ID (numeric)")
    work_scaffold.add_argument("--slug", required=True, help="Slug for the folder name")
    work_scaffold.add_argument("--title", help="Human-readable title for tracker")
    work_scaffold.add_argument("--goal", action="append", help="Goal checklist item (repeatable)")
    work_scaffold.add_argument("--force", action="store_true", help="Allow scaffolding even if another ACTIVE folder exists")
    work_scaffold.set_defaults(func=handle_work_tracking_scaffold)

    work_archive = work_sub.add_parser("archive", help="Archive the current active work-tracking folder")
    work_archive.add_argument("--folder", help="Specific ACTIVE folder relative name")
    work_archive.set_defaults(func=handle_work_tracking_archive)

    work_update = work_sub.add_parser("update", help="Append entry to work-tracking progress log")
    work_update.add_argument("--work", required=True, help="W field value")
    work_update.add_argument("--handler", required=True, help="H field value")
    work_update.add_argument("--evidence", required=True, help="E field value")
    work_update.add_argument("--note", required=True, help="Log note")
    work_update.add_argument("--document", default="TRACKER", help="Work-tracking markdown name (default TRACKER)")
    work_update.add_argument("--folder", help="Specific ACTIVE folder relative name")
    work_update.add_argument("--preset", choices=sorted(WORK_TRACKING_PRESETS.keys()), help="Shortcut for common work-tracking documents (overrides --document). Use --handler auto to apply defaults.")
    work_update.set_defaults(func=handle_work_tracking_update)

    work_audit = work_sub.add_parser("audit", help="Audit active work-tracking folders and sessions")
    work_audit.set_defaults(func=handle_work_tracking_audit)

    plan_parser = subparsers.add_parser("plan", help="Plan utilities")
    plan_sub = plan_parser.add_subparsers(dest="subcommand", required=True)
    plan_sync = plan_sub.add_parser("sync", help="Validate plan/tracker parity and log sync entry")
    plan_sync.add_argument("--plan", help=f"Explicit plan file path (default: {PLANS_CURRENT_REL})")
    plan_sync.add_argument("--tracker", help="Explicit tracker file path (default: active tracker)")
    plan_sync.set_defaults(func=handle_plan_sync)

    report_parser = subparsers.add_parser("report", help="Report generation operations")
    report_sub = report_parser.add_subparsers(dest="subcommand", required=True)
    report_generate = report_sub.add_parser("generate", help="Generate workflow reports")
    report_generate.add_argument(
        "--kind",
        choices=("metrics", "drift", "all"),
        default="metrics",
        help="Report type to generate (default: metrics)",
    )
    report_generate.add_argument(
        "--report-dir",
        default=REPO_STRUCTURE.metrics_report_dir.relative_to(REPO_ROOT).as_posix(),
        help="Output directory for metrics reports",
    )
    report_generate.add_argument(
        "--drift-report-dir",
        default=REPO_STRUCTURE.drift_report_dir.relative_to(REPO_ROOT).as_posix(),
        help="Output directory for drift reports",
    )
    report_generate.add_argument(
        "--strict-drift",
        action="store_true",
        help="Exit nonzero when drift findings are present while generating drift reports",
    )
    report_generate.set_defaults(func=handle_report_generate)

    hooks_parser = subparsers.add_parser("hooks", help="Git hook verification operations")
    hooks_sub = hooks_parser.add_subparsers(dest="subcommand", required=True)
    hooks_verify = hooks_sub.add_parser("verify", help="Verify tracked pre-commit hook configuration and local install state")
    hooks_verify.add_argument(
        "--require-installed",
        action="store_true",
        help="Fail when the local .git/hooks/pre-commit entry is not installed",
    )
    hooks_verify.set_defaults(func=handle_hooks_verify)

    bootstrap_parser = subparsers.add_parser("bootstrap", help="Portable foundation bootstrap operations")
    bootstrap_sub = bootstrap_parser.add_subparsers(dest="subcommand", required=True)
    bootstrap_init = bootstrap_sub.add_parser("init", help="Scaffold starter foundation assets into a target repository")
    bootstrap_init.add_argument("--target-dir", default=".", help="Target repository root (default: current repo)")
    bootstrap_init.add_argument("--force", action="store_true", help="Overwrite existing starter files")
    bootstrap_init.add_argument("--templates-root", help="Repo-local templates root override")
    bootstrap_init.add_argument("--sessions-root", help="Repo-local sessions root override")
    bootstrap_init.add_argument("--plans-root", help="Repo-local plans root override")
    bootstrap_init.add_argument("--plan-state-dir", help="Repo-local plan state directory override")
    bootstrap_init.add_argument("--taskmaster-root", help="Repo-local Taskmaster root override")
    bootstrap_init.add_argument("--work-tracking-root", help="Repo-local work-tracking root override")
    bootstrap_init.add_argument("--reports-root", help="Repo-local reports root override")
    bootstrap_init.set_defaults(func=handle_bootstrap_init)

    wizard_parser = subparsers.add_parser("wizard", help="Guided workflow operations")
    wizard_sub = wizard_parser.add_subparsers(dest="subcommand", required=True)
    wizard_kickoff = wizard_sub.add_parser("kickoff", help="Interactively scaffold a task session, plan, and work-tracking state")
    wizard_kickoff.add_argument("--task", help="Task ID (numeric)")
    wizard_kickoff.add_argument("--slug", help="Slug for session/plan/work-tracking naming")
    wizard_kickoff.add_argument("--title", help="Human-readable task title")
    wizard_kickoff.add_argument("--goal", action="append", help="Goal checklist item (repeatable)")
    wizard_kickoff.add_argument("--task-source", help="Human-readable source line for the session metadata")
    wizard_kickoff.add_argument("--handler-target", help="Primary handler target/path for the generated plan")
    wizard_kickoff.add_argument("--force", action="store_true", help="Allow kickoff even if another ACTIVE folder exists")
    wizard_kickoff.set_defaults(func=handle_wizard_kickoff)

    scanner_parser = subparsers.add_parser("scanner", help="SSOT scanner operations")
    scanner_sub = scanner_parser.add_subparsers(dest="subcommand", required=True)
    scanner_run = scanner_sub.add_parser("run", help="Run a scanner tool and optionally log results")
    scanner_run.add_argument("tool", help="Scanner tool key (scanner, analyze, duplicates, migration, fixes, safe-reorg)")
    scanner_run.add_argument("--work", required=True, help="W field value for logging")
    scanner_run.add_argument("--handler", required=True, help="H field value for logging")
    scanner_run.add_argument("--evidence", required=True, help="E field value for logging")
    scanner_run.add_argument("--log-note", help="Log note to append after successful run")
    scanner_run.add_argument("--folder", help="Work-tracking folder override")
    scanner_run.add_argument("--document", default="TRACKER", help="Work-tracking markdown name for logging")
    scanner_run.set_defaults(func=handle_scanner_run)

    return parser


def main(argv: Optional[List[str]] = None) -> int:
    parser = build_parser()
    args, unknown = parser.parse_known_args(argv)

    if unknown:
        if getattr(args, "command", None) == "scanner" and getattr(args, "subcommand", None) == "run":
            setattr(args, "scanner_args", unknown)
        else:
            parser.error(f"unrecognized arguments: {' '.join(unknown)}")

    try:
        args.func(args)
    except TaskError as exc:
        message = str(exc)
        print(f"error: {message}", file=sys.stderr)
        lowered = message.lower()
        if any(keyword in lowered for keyword in ("guard", "plan sync", "branch policy")):
            print(_meta_guard_message(), file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        return 130
    return 0


if __name__ == "__main__":
    sys.exit(main())
