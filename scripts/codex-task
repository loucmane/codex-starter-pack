def _wrapped_data_document(path_value: str | Path, label: str) -> Dict[str, Any]:
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    payload = _load_json_document(path.as_posix(), label)
    metadata = payload.get("metadata") if isinstance(payload.get("metadata"), dict) else None
    data = payload.get("data") if isinstance(payload.get("data"), dict) else payload
    if not isinstance(data, dict):
        raise TaskError(f"{label} data must be a JSON object")
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "metadata": metadata,
        "data": data,
    }


def _normalise_migration_metrics_baseline(path_value: str | Path) -> Dict[str, Any]:
    baseline = _wrapped_data_document(path_value, "Baseline summary")
    data = baseline["data"]
    metrics = data.get("metrics")
    if not isinstance(metrics, dict):
        raise TaskError("Baseline summary must include data.metrics")
    outputs = data.get("outputs") if isinstance(data.get("outputs"), dict) else {}
    return {
        "path": baseline["path"],
        "metadata": baseline.get("metadata"),
        "generated_at": data.get("generated_at"),
        "metrics": metrics,
        "outputs": outputs,
    }


def _normalise_migration_metrics_security(path_value: str | Path | None) -> Dict[str, Any]:
    if not path_value:
        return {
            "path": None,
            "exists": False,
            "status": "not-provided",
            "findings": None,
            "severity_counts": {},
            "generated_at": None,
        }
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    display = _relative_to_root(path, REPO_ROOT)
    if not path.exists():
        return {
            "path": display,
            "exists": False,
            "status": "missing",
            "findings": None,
            "severity_counts": {},
            "generated_at": None,
        }
    security = _wrapped_data_document(path, "Security validation report")
    data = security["data"]
    metadata = security.get("metadata") if isinstance(security.get("metadata"), dict) else {}
    summary = data.get("summary") if isinstance(data.get("summary"), dict) else {}
    stats = metadata.get("stats") if isinstance(metadata.get("stats"), dict) else {}
    severity_counts = summary.get("severity_counts") if isinstance(summary.get("severity_counts"), dict) else {}
    findings = summary.get("total_findings", stats.get("findings"))
    return {
        "path": security["path"],
        "exists": True,
        "status": "present",
        "findings": int(findings or 0),
        "severity_counts": dict(severity_counts),
        "generated_at": metadata.get("scan_timestamp") or data.get("generated_at"),
    }


def _optional_migration_metrics_roadmap(path_value: str | None, max_items: int) -> Dict[str, Any]:
    if not path_value:
        return {
            "path": None,
            "exists": False,
            "status": "not-provided",
            "summary": None,
        }
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    if not path.exists():
        raise TaskError(f"Migration roadmap not found: {_relative_to_root(path, REPO_ROOT)}")
    roadmap = _normalise_roadmap_payload(path.as_posix())
    return {
        "path": roadmap["path"],
        "exists": True,
        "status": "present",
        "summary": _summarise_rehearsal_roadmap(roadmap, max_items),
    }


def _numeric_metric(metrics: Mapping[str, Any], key: str) -> float | int | None:
    value = metrics.get(key)
    if isinstance(value, bool):
        return int(value)
    if isinstance(value, (int, float)):
        return value
    return None


def _migration_kpi(
    *,
    metric_id: str,
    title: str,
    value: object,
    unit: str,
    target: str,
    status: str,
    severity: str,
    evidence: str,
    message: str,
) -> Dict[str, Any]:
    return {
        "id": metric_id,
        "title": title,
        "value": value,
        "unit": unit,
        "target": target,
        "status": status,
        "severity": severity,
        "evidence": evidence,
        "message": message,
    }


def _zero_target_kpi(
    *,
    metrics: Mapping[str, Any],
    key: str,
    metric_id: str,
    title: str,
    unit: str,
    fail_on_positive: bool,
    evidence: str,
) -> Dict[str, Any]:
    value = _numeric_metric(metrics, key)
    if value is None:
        return _migration_kpi(
            metric_id=metric_id,
            title=title,
            value=None,
            unit=unit,
            target="0",
            status="missing",
            severity="warning",
            evidence=evidence,
            message=f"`{key}` is missing from the baseline summary.",
        )
    if value == 0:
        status = "pass"
        severity = "info"
        message = "Target met."
    else:
        status = "fail" if fail_on_positive else "warn"
        severity = "error" if fail_on_positive else "warning"
        message = f"{value} item(s) remain above the zero target."
    return _migration_kpi(
        metric_id=metric_id,
        title=title,
        value=value,
        unit=unit,
        target="0",
        status=status,
        severity=severity,
        evidence=evidence,
        message=message,
    )


def _migration_metrics_kpis(
    baseline: Mapping[str, Any],
    roadmap: Mapping[str, Any],
    security: Mapping[str, Any],
) -> List[Dict[str, Any]]:
    metrics = baseline.get("metrics") if isinstance(baseline.get("metrics"), dict) else {}
    evidence = str(baseline.get("path"))
    kpis: List[Dict[str, Any]] = []
    migration_percentage = _numeric_metric(metrics, "migration_percentage")
    if migration_percentage is None:
        kpis.append(
            _migration_kpi(
                metric_id="migration-completion",
                title="Migration completion",
                value=None,
                unit="percent",
                target="100",
                status="missing",
                severity="warning",
                evidence=evidence,
                message="`migration_percentage` is missing from the baseline summary.",
            )
        )
    else:
        status = "pass" if migration_percentage >= 100 else "warn"
        kpis.append(
            _migration_kpi(
                metric_id="migration-completion",
                title="Migration completion",
                value=migration_percentage,
                unit="percent",
                target="100",
                status=status,
                severity="info" if status == "pass" else "warning",
                evidence=evidence,
                message="Migration is complete." if status == "pass" else "Migration is not yet complete.",
            )
        )

    kpis.extend(
        [
            _zero_target_kpi(
                metrics=metrics,
                key="pending_migration",
                metric_id="pending-migration",
                title="Pending migration files",
                unit="files",
                fail_on_positive=False,
                evidence=evidence,
            ),
            _zero_target_kpi(
                metrics=metrics,
                key="broken_references",
                metric_id="broken-references",
                title="Broken references",
                unit="references",
                fail_on_positive=True,
                evidence=evidence,
            ),
            _zero_target_kpi(
                metrics=metrics,
                key="circular_dependencies",
                metric_id="circular-dependencies",
                title="Circular dependencies",
                unit="cycles",
                fail_on_positive=True,
                evidence=evidence,
            ),
            _zero_target_kpi(
                metrics=metrics,
                key="duplicate_count",
                metric_id="duplicate-files",
                title="Duplicate files",
                unit="files",
                fail_on_positive=False,
                evidence=evidence,
            ),
            _zero_target_kpi(
                metrics=metrics,
                key="total_fixes",
                metric_id="recommended-fixes",
                title="Recommended fixes",
                unit="fixes",
                fail_on_positive=False,
                evidence=evidence,
            ),
        ]
    )

    security_findings = security.get("findings")
    if security.get("exists") is False:
        kpis.append(
            _migration_kpi(
                metric_id="security-findings",
                title="Security findings",
                value=None,
                unit="findings",
                target="0",
                status="missing",
                severity="warning",
                evidence=str(security.get("path") or "not provided"),
                message="Security validation report is missing or not provided.",
            )
        )
    else:
        severity_counts = security.get("severity_counts") if isinstance(security.get("severity_counts"), dict) else {}
        errors = int(severity_counts.get("error", 0) or 0)
        findings = int(security_findings or 0)
        if findings == 0:
            status = "pass"
            severity = "info"
            message = "Target met."
        elif errors:
            status = "fail"
            severity = "error"
            message = f"{errors} error-level security finding(s) block migration readiness."
        else:
            status = "warn"
            severity = "warning"
            message = f"{findings} non-error security finding(s) require review."
        kpis.append(
            _migration_kpi(
                metric_id="security-findings",
                title="Security findings",
                value=findings,
                unit="findings",
                target="0",
                status=status,
                severity=severity,
                evidence=str(security.get("path")),
                message=message,
            )
        )

    roadmap_summary = roadmap.get("summary") if isinstance(roadmap.get("summary"), dict) else None
    if roadmap_summary is None:
        kpis.append(
            _migration_kpi(
                metric_id="roadmap-critical-items",
                title="Critical roadmap items",
                value=None,
                unit="items",
                target="0",
                status="missing",
                severity="warning",
                evidence=str(roadmap.get("path") or "not provided"),
                message="Migration roadmap was not provided; roadmap backlog metrics are unavailable.",
            )
        )
    else:
        priority_counts = roadmap_summary.get("priority_counts") if isinstance(roadmap_summary.get("priority_counts"), dict) else {}
        critical = int(priority_counts.get("critical", 0) or 0)
        total_items = int(roadmap_summary.get("total_items", 0) or 0)
        kpis.append(
            _migration_kpi(
                metric_id="roadmap-critical-items",
                title="Critical roadmap items",
                value=critical,
                unit="items",
                target="0",
                status="fail" if critical else "pass",
                severity="error" if critical else "info",
                evidence=str(roadmap_summary.get("path")),
                message="Critical roadmap items remain." if critical else "No critical roadmap items remain.",
            )
        )
        kpis.append(
            _migration_kpi(
                metric_id="roadmap-total-items",
                title="Total roadmap items",
                value=total_items,
                unit="items",
                target="reviewed backlog",
                status="warn" if total_items else "pass",
                severity="warning" if total_items else "info",
                evidence=str(roadmap_summary.get("path")),
                message="Roadmap backlog remains." if total_items else "Roadmap has no remaining items.",
            )
        )
    return kpis


def _migration_metrics_status(kpis: Sequence[Mapping[str, Any]]) -> str:
    if any(kpi.get("status") == "fail" for kpi in kpis):
        return "fail"
    if any(kpi.get("status") in {"warn", "missing"} for kpi in kpis):
        return "warn"
    return "pass"


def _migration_metrics_verification_commands() -> List[str]:
    return [
        "python3 scripts/template-ssot-scanner/run_all_scanners.py --profile ci",
        "python3 scripts/template-ssot-scanner/baseline_summary.py --data-dir scripts/template-ssot-scanner/output/data",
        "python3 scripts/template-ssot-scanner/migration_roadmap.py --data-dir scripts/template-ssot-scanner/output/data --json-out <roadmap.json> --markdown-out <roadmap.md>",
        "python3 scripts/codex-task migration metrics --baseline-summary <baseline_summary.json> --roadmap <roadmap.json> --security-report <security_validation.json> --report-file <metrics.json> --runbook-file <metrics.md>",
        "python3 scripts/codex-task report generate --kind migration-health",
        "python3 scripts/codex-task validation final-suite --dry-run",
    ]


def _build_migration_metrics_report(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    baseline = _normalise_migration_metrics_baseline(args.baseline_summary)
    security = _normalise_migration_metrics_security(args.security_report)
    roadmap = _optional_migration_metrics_roadmap(args.roadmap, args.max_roadmap_items)
    kpis = _migration_metrics_kpis(baseline, roadmap, security)
    status = _migration_metrics_status(kpis)
    baseline_metadata = baseline.get("metadata") if isinstance(baseline.get("metadata"), dict) else {}
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "static-file-backed-migration-metrics",
        "executes_external_actions": False,
        "aggregate_status": status,
        "summary": {
            "total_kpis": len(kpis),
            "passed": sum(1 for kpi in kpis if kpi.get("status") == "pass"),
            "warnings": sum(1 for kpi in kpis if kpi.get("status") in {"warn", "missing"}),
            "failures": sum(1 for kpi in kpis if kpi.get("status") == "fail"),
        },
        "inputs": {
            "baseline_summary": {
                "path": baseline["path"],
                "generated_at": baseline.get("generated_at"),
                "scanner_timestamp": baseline_metadata.get("scan_timestamp"),
            },
            "roadmap": {
                "path": roadmap.get("path"),
                "status": roadmap.get("status"),
                "exists": roadmap.get("exists"),
            },
            "security_report": {
                "path": security.get("path"),
                "status": security.get("status"),
                "exists": security.get("exists"),
                "generated_at": security.get("generated_at"),
            },
        },
        "source_outputs": baseline.get("outputs", {}),
        "kpis": kpis,
        "roadmap": roadmap.get("summary"),
        "recommended_refresh_commands": _migration_metrics_verification_commands(),
        "non_goals": list(MIGRATION_METRIC_NON_GOALS),
    }


def _render_migration_metrics_runbook(report: Dict[str, Any]) -> str:
    lines = [
        "# Migration Metrics Collection",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Aggregate status: {report.get('aggregate_status')}",
        f"- Executes external actions: {report.get('executes_external_actions')}",
        "",
        "## Inputs",
        "",
    ]
    inputs = report.get("inputs") if isinstance(report.get("inputs"), dict) else {}
    for key, value in inputs.items():
        if not isinstance(value, dict):
            continue
        lines.append(f"- {key}: `{value.get('path')}`")

    lines.extend(["", "## KPI Summary", ""])
    summary = report.get("summary") if isinstance(report.get("summary"), dict) else {}
    lines.extend(
        [
            f"- Total KPIs: {summary.get('total_kpis')}",
            f"- Passed: {summary.get('passed')}",
            f"- Warnings: {summary.get('warnings')}",
            f"- Failures: {summary.get('failures')}",
            "",
            "## KPIs",
            "",
            "| KPI | Value | Unit | Target | Status | Severity | Evidence |",
            "| --- | --- | --- | --- | --- | --- | --- |",
        ]
    )
    for kpi in report.get("kpis", []):
        if not isinstance(kpi, dict):
            continue
        lines.append(
            f"| {_md_cell(kpi.get('title'))} | {_md_cell(kpi.get('value'))} | "
            f"{_md_cell(kpi.get('unit'))} | {_md_cell(kpi.get('target'))} | "
            f"{_md_cell(kpi.get('status'))} | {_md_cell(kpi.get('severity'))} | "
            f"{_md_cell(kpi.get('evidence'))} |"
        )

    roadmap = report.get("roadmap") if isinstance(report.get("roadmap"), dict) else None
    lines.extend(["", "## Roadmap Backlog", ""])
    if roadmap:
        lines.extend(
            [
                f"- Roadmap: `{roadmap.get('path')}`",
                f"- Total items: {roadmap.get('total_items')}",
                f"- Priority counts: {roadmap.get('priority_counts')}",
                f"- Category counts: {roadmap.get('category_counts')}",
            ]
        )
    else:
        lines.append("- No migration roadmap was provided.")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "No metric agent, time-series database, live dashboard, alert delivery, external service call, scanner regeneration, or remediation mutation was executed by this report.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_migration_metrics(args: argparse.Namespace) -> None:
    report = _build_migration_metrics_report(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_migration_metrics_runbook(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["aggregate_status"] == "fail":
            raise TaskError("Migration metrics aggregate status is fail")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote migration metrics report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote migration metrics runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["aggregate_status"] == "fail":
        raise TaskError("Migration metrics aggregate status is fail")


def _normalise_monitoring_status(value: object) -> str:
    normalised = str(value or "missing").strip().lower()
    aliases = {
        "ok": "pass",
        "passed": "pass",
        "success": "pass",
        "warning": "warn",
        "warnings": "warn",
        "error": "fail",
        "failed": "fail",
        "failure": "fail",
    }
    normalised = aliases.get(normalised, normalised)
    if normalised in {"pass", "warn", "fail", "missing", "not-measured"}:
        return normalised
    return "warn"


def _post_migration_monitoring_severity(status: str) -> str:
    if status == "fail":
        return "error"
    if status in {"warn", "missing", "not-measured"}:
        return "warning"
    return "info"


def _extract_report_status(payload: Mapping[str, Any], fields: Sequence[str]) -> str:
    for field in fields:
        if field in payload:
            return _normalise_monitoring_status(payload.get(field))
    return "missing"


def _summarise_post_migration_items(payload: Mapping[str, Any], max_items: int) -> List[Dict[str, Any]]:
    raw_items = payload.get("kpis")
    if not isinstance(raw_items, list):
        raw_items = payload.get("components")
    if not isinstance(raw_items, list):
        return []
    items: List[Dict[str, Any]] = []
    for raw in raw_items[: max(0, max_items)]:
        if not isinstance(raw, dict):
            continue
        items.append(
            {
                "id": raw.get("id"),
                "title": raw.get("title"),
                "status": _normalise_monitoring_status(raw.get("status")),
                "severity": raw.get("severity") or _post_migration_monitoring_severity(_normalise_monitoring_status(raw.get("status"))),
                "value": raw.get("value"),
                "target": raw.get("target"),
                "evidence": raw.get("evidence"),
                "message": raw.get("message"),
            }
        )
    return items


def _normalise_post_migration_input(
    path_value: str | Path | None,
    label: str,
    status_fields: Sequence[str],
    max_items: int,
) -> Dict[str, Any]:
    if not path_value:
        return {
            "path": None,
            "exists": False,
            "status": "missing",
            "severity": "warning",
            "generated_at": None,
            "summary": None,
            "items": [],
            "message": f"{label} was not provided.",
        }
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    relative = _relative_to_root(path, REPO_ROOT)
    if not path.exists():
        return {
            "path": relative,
            "exists": False,
            "status": "missing",
            "severity": "warning",
            "generated_at": None,
            "summary": None,
            "items": [],
            "message": f"{label} was not found.",
        }
    payload = _load_json_document(path.as_posix(), label)
    status = _extract_report_status(payload, status_fields)
    summary = payload.get("summary") if isinstance(payload.get("summary"), dict) else None
    return {
        "path": relative,
        "exists": True,
        "status": status,
        "severity": _post_migration_monitoring_severity(status),
        "generated_at": payload.get("created_at") or payload.get("generated_at"),
        "summary": summary,
        "items": _summarise_post_migration_items(payload, max_items),
        "message": f"{label} loaded successfully.",
    }


def _post_migration_monitoring_status(inputs: Sequence[Mapping[str, Any]]) -> str:
    statuses = {_normalise_monitoring_status(item.get("status")) for item in inputs}
    if "fail" in statuses:
        return "fail"
    if statuses.intersection({"warn", "missing", "not-measured"}):
        return "warn"
    return "pass"


def _post_migration_monitoring_actions(
    metrics: Mapping[str, Any],
    health: Mapping[str, Any],
) -> List[Dict[str, str]]:
    actions: List[Dict[str, str]] = []
    if metrics.get("status") == "missing":
        actions.append(
            {
                "id": "generate-migration-metrics",
                "severity": "warning",
                "title": "Generate the migration metrics packet.",
                "command": "python3 scripts/codex-task migration metrics --baseline-summary <baseline_summary.json> --roadmap <roadmap.json> --security-report <security_validation.json> --report-file <metrics.json> --runbook-file <metrics.md>",
            }
        )
    elif metrics.get("status") == "fail":
        actions.append(
            {
                "id": "resolve-failing-migration-kpis",
                "severity": "error",
                "title": "Resolve or explicitly waive failing migration KPIs.",
                "command": "Review the migration metrics runbook and update the roadmap before closing monitoring.",
            }
        )
    elif metrics.get("status") in {"warn", "not-measured"}:
        actions.append(
            {
                "id": "review-warning-migration-kpis",
                "severity": "warning",
                "title": "Review warning-level or incomplete migration KPI inputs.",
                "command": "Refresh scanner, roadmap, and security inputs before the next monitoring review.",
            }
        )

    if health.get("status") == "missing":
        actions.append(
            {
                "id": "generate-migration-health",
                "severity": "warning",
                "title": "Generate the aggregate migration-health report.",
                "command": "python3 scripts/codex-task report generate --kind migration-health",
            }
        )
    elif health.get("status") == "fail":
        actions.append(
            {
                "id": "resolve-failing-migration-health",
                "severity": "error",
                "title": "Resolve fail-level migration-health components.",
                "command": "Review reports/migration-health/latest.md and refresh failing source reports.",
            }
        )
    elif health.get("status") in {"warn", "not-measured"}:
        actions.append(
            {
                "id": "review-warning-migration-health",
                "severity": "warning",
                "title": "Review warning or missing migration-health components.",
                "command": "python3 scripts/codex-task report generate --kind telemetry",
            }
        )
    if not actions:
        actions.append(
            {
                "id": "continue-monitoring-cadence",
                "severity": "info",
                "title": "Continue the post-migration monitoring cadence.",
                "command": "Store the monitoring packet with weekly/monthly/quarterly/yearly evidence.",
            }
        )
    return actions


def _build_post_migration_monitoring_report(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    metrics = _normalise_post_migration_input(
        args.metrics_report,
        "Migration metrics report",
        ("aggregate_status", "status"),
        args.max_items,
    )
    health = _normalise_post_migration_input(
        args.migration_health_report,
        "Migration health report",
        ("status", "aggregate_status"),
        args.max_items,
    )
    aggregate_status = _post_migration_monitoring_status((metrics, health))
    actions = _post_migration_monitoring_actions(metrics, health)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "static-file-backed-post-migration-monitoring",
        "executes_external_actions": False,
        "aggregate_status": aggregate_status,
        "summary": {
            "inputs": 2,
            "available_inputs": sum(1 for item in (metrics, health) if item.get("exists")),
            "cadence_checks": len(POST_MIGRATION_MONITORING_CADENCES),
            "required_actions": len(actions),
            "failures": sum(1 for item in (metrics, health) if item.get("status") == "fail"),
            "warnings": sum(1 for item in (metrics, health) if item.get("status") in {"warn", "missing", "not-measured"}),
        },
        "inputs": {
            "migration_metrics": metrics,
            "migration_health": health,
        },
        "required_actions": actions,
        "cadence_plan": list(POST_MIGRATION_MONITORING_CADENCES),
        "automation_guidance": {
            "report_refresh": "Run static report commands manually, in CI, or in a reviewed scheduler owned by the downstream project.",
            "default_review_packet": "Store the generated JSON and Markdown packet as task-local evidence before acting on findings.",
            "strict_gate": "Use --strict only when fail-level post-migration status should fail the caller.",
        },
        "non_goals": list(POST_MIGRATION_MONITORING_NON_GOALS),
    }


def _render_post_migration_monitoring_runbook(report: Dict[str, Any]) -> str:
    lines = [
        "# Post-Migration Monitoring",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Aggregate status: {report.get('aggregate_status')}",
        f"- Executes external actions: {report.get('executes_external_actions')}",
        "",
        "## Inputs",
        "",
        "| Input | Path | Exists | Status | Severity | Generated at |",
        "| --- | --- | --- | --- | --- | --- |",
    ]
    inputs = report.get("inputs") if isinstance(report.get("inputs"), dict) else {}
    for name, value in inputs.items():
        if not isinstance(value, dict):
            continue
        lines.append(
            f"| {_md_cell(name)} | {_md_cell(value.get('path'))} | {_md_cell(value.get('exists'))} | "
            f"{_md_cell(value.get('status'))} | {_md_cell(value.get('severity'))} | {_md_cell(value.get('generated_at'))} |"
        )

    lines.extend(["", "## Required Actions", ""])
    for action in report.get("required_actions", []):
        if not isinstance(action, dict):
            continue
        lines.append(f"- **{action.get('severity')}** - {action.get('title')} `{action.get('command')}`")

    lines.extend(["", "## Source Highlights", ""])
    for name, value in inputs.items():
        if not isinstance(value, dict):
            continue
        items = value.get("items") if isinstance(value.get("items"), list) else []
        if not items:
            continue
        lines.extend([f"### {name.replace('_', ' ').title()}", "", "| Item | Status | Severity | Value | Target | Evidence |", "| --- | --- | --- | --- | --- | --- |"])
        for item in items:
            if not isinstance(item, dict):
                continue
            lines.append(
                f"| {_md_cell(item.get('title') or item.get('id'))} | {_md_cell(item.get('status'))} | "
                f"{_md_cell(item.get('severity'))} | {_md_cell(item.get('value'))} | "
                f"{_md_cell(item.get('target'))} | {_md_cell(item.get('evidence'))} |"
            )
        lines.append("")

    lines.extend(["## Cadence Plan", "", "| Cadence | Check | Purpose | Commands | Evidence |", "| --- | --- | --- | --- | --- |"])
    for item in report.get("cadence_plan", []):
        if not isinstance(item, dict):
            continue
        commands = "<br>".join(f"`{command}`" for command in item.get("commands", []))
        evidence = "<br>".join(str(value) for value in item.get("evidence", []))
        lines.append(
            f"| {_md_cell(item.get('cadence'))} | {_md_cell(item.get('title'))} | "
            f"{_md_cell(item.get('purpose'))} | {commands} | {_md_cell(evidence)} |"
        )

    lines.extend(["", "## Automation Guidance", ""])
    guidance = report.get("automation_guidance") if isinstance(report.get("automation_guidance"), dict) else {}
    for key, value in guidance.items():
        lines.append(f"- {key}: {value}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static review artifact. It coordinates existing reports and review cadences, but it does not install or execute a production monitoring system.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_post_migration_monitoring(args: argparse.Namespace) -> None:
    report = _build_post_migration_monitoring_report(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_post_migration_monitoring_runbook(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["aggregate_status"] == "fail":
            raise TaskError("Post-migration monitoring aggregate status is fail")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote post-migration monitoring report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote post-migration monitoring runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["aggregate_status"] == "fail":
        raise TaskError("Post-migration monitoring aggregate status is fail")


def _resolve_current_plan_path() -> Path:
    if not PLAN_CURRENT.exists() or not PLAN_CURRENT.is_symlink():
        raise TaskError(f"{PLANS_CURRENT_REL} symlink missing; compaction checkpoints require an active plan")
    plan_path = PLAN_CURRENT.resolve()
    if not plan_path.exists():
        raise TaskError(f"{PLANS_CURRENT_REL} target missing: {plan_path}")
    return plan_path


def _compaction_memory_name(task_id: str, slug: str, created_at: datetime) -> str:
    return f"compaction_{created_at.strftime('%Y-%m-%d')}_task{task_id}_{_slugify(slug).replace('-', '_')}"


def _compaction_resume_markdown(manifest: Dict[str, Any]) -> str:
    paths = manifest.get("paths", {})
    git_info = manifest.get("git", {})
    return "\n".join(
        [
            f"# Compaction Checkpoint - Task {manifest.get('task_id')} {manifest.get('slug')}",
            "",
            "## Current State",
            f"- Created at: {manifest.get('created_at')}",
            f"- Branch: {git_info.get('branch')}",
            f"- HEAD: {git_info.get('head')}",
            f"- Summary: {manifest.get('summary')}",
            f"- Next step: {manifest.get('next_step')}",
            "",
            "## Resume Instruction",
            "Continue from this compaction checkpoint.",
            f"Read `{paths.get('session')}`, `{paths.get('plan')}`, `{paths.get('tracker')}`, and Serena memory `{paths.get('memory_name')}`.",
            f"Resume Task {manifest.get('task_id')} at: {manifest.get('next_step')}",
            "",
            "## Evidence",
            f"- Manifest: `{paths.get('manifest')}`",
            f"- Resume message: `{paths.get('resume')}`",
            f"- Serena memory file: `{paths.get('memory_file')}`",
            f"- Active work tracking: `{paths.get('work_tracking')}`",
            "",
            "## Important",
            "- This is a compaction checkpoint, not a session end.",
            "- Do not archive work tracking.",
            "- Do not clear `sessions/current` or `plans/current`.",
            "- Continue with the same session and task state after context resumes.",
            "",
        ]
    )


def _compaction_memory_markdown(manifest: Dict[str, Any]) -> str:
    paths = manifest.get("paths", {})
    return "\n".join(
        [
            f"# Compaction Checkpoint: Task {manifest.get('task_id')} {manifest.get('slug')}",
            "",
            "## Exact State",
            f"- Created at: {manifest.get('created_at')}",
            f"- Branch: {manifest.get('git', {}).get('branch')}",
            f"- HEAD: {manifest.get('git', {}).get('head')}",
            f"- Summary: {manifest.get('summary')}",
            f"- Next step: {manifest.get('next_step')}",
            "",
            "## Files To Read On Resume",
            f"- Session: `{paths.get('session')}`",
            f"- Plan: `{paths.get('plan')}`",
            f"- Tracker: `{paths.get('tracker')}`",
            f"- Manifest: `{paths.get('manifest')}`",
            f"- Resume message: `{paths.get('resume')}`",
            "",
            "## Last Completed",
            *[f"- {item}" for item in manifest.get("last_completed", [])],
            "",
            "## Open Items",
            *[f"- {item}" for item in manifest.get("open_items", [])],
            "",
            "## Resume Instructions",
            "1. Confirm date, branch, and git status.",
            f"2. Read `{paths.get('session')}` and `{paths.get('plan')}`.",
            f"3. Read `{paths.get('tracker')}` and this memory.",
            f"4. Continue Task {manifest.get('task_id')} at: {manifest.get('next_step')}",
            "",
        ]
    )


def _append_compaction_handoff(work_folder: Path, manifest: Dict[str, Any], session_value: str, work: str) -> None:
    handoff_path = work_folder / "HANDOFF.md"
    if not handoff_path.exists():
        handoff_path.write_text(
            f"# Task {manifest.get('task_id')} {manifest.get('slug')} - Handoff Summary\n\n",
            encoding="utf-8",
        )
    lines = _load_file_lines(handoff_path)
    heading = "## Compaction Checkpoints"
    if heading not in (line.strip() for line in lines):
        if lines and lines[-1].strip():
            lines.append("")
        lines.extend([heading, ""])
    swhe = (
        f"[S:{session_value}|W:{work}|H:scripts/codex-task:compaction-checkpoint|"
        f"E:{manifest['paths']['manifest']}]"
    )
    lines = _insert_progress_entry(
        lines,
        heading,
        f"- {manifest.get('created_at')} — {swhe} Resume at: {manifest.get('next_step')}",
    )
    _write_file_lines(handoff_path, lines)


def handle_compaction_checkpoint(args: argparse.Namespace) -> None:
    session_path = _resolve_current_session(args.session_file)
    plan_path = _resolve_current_plan_path()
    work_folder = _resolve_active_work_tracking(args.folder)
    tracker_path = work_folder / "TRACKER.md"
    if not tracker_path.exists():
        raise TaskError(f"Active tracker missing: {_relative_to_root(tracker_path, REPO_ROOT)}")

    created_at = datetime.now().astimezone()
    task_id = str(args.task).strip()
    slug = _slugify(args.slug or f"task{task_id}-compaction")
    checkpoint_id = f"{created_at.strftime('%Y%m%d-%H%M%S')}-task{task_id}-{slug}"
    report_dir = Path(args.report_dir) if args.report_dir else work_folder / "reports" / "compaction-checkpoints"
    if not report_dir.is_absolute():
        report_dir = REPO_ROOT / report_dir
    manifest_path = report_dir / f"{checkpoint_id}.json"
    resume_path = report_dir / f"{checkpoint_id}-resume.md"
    memory_name = args.memory_name or _compaction_memory_name(task_id, slug, created_at)
    memory_file = REPO_ROOT / ".serena" / "memories" / f"{memory_name}.md"
    work = args.work or f"task{task_id}-{slug}"

    manifest: Dict[str, Any] = {
        "version": 1,
        "kind": "compaction-checkpoint",
        "created_at": created_at.isoformat(timespec="seconds"),
        "task_id": task_id,
        "slug": slug,
        "summary": args.summary,
        "next_step": args.next_step,
        "last_completed": tuple(args.last_completed or ()),
        "open_items": tuple(args.open_item or ()),
        "git": {
            "branch": _git_output(["branch", "--show-current"]),
            "head": _git_output(["rev-parse", "HEAD"]),
            "status": _git_status_snapshot(),
        },
        "workflow": _workflow_snapshot(),
        "taskmaster": _taskmaster_snapshot(),
        "serena": _serena_memory_snapshot(),
        "paths": {
            "manifest": _relative_to_root(manifest_path, REPO_ROOT),
            "resume": _relative_to_root(resume_path, REPO_ROOT),
            "memory_name": memory_name,
            "memory_file": _relative_to_root(memory_file, REPO_ROOT),
            "session": _relative_to_root(session_path, REPO_ROOT),
            "plan": _relative_to_root(plan_path, REPO_ROOT),
            "tracker": _relative_to_root(tracker_path, REPO_ROOT),
            "work_tracking": _relative_to_root(work_folder, REPO_ROOT),
        },
    }
    rendered_manifest = json.dumps(manifest, indent=2, sort_keys=True) + "\n"
    rendered_resume = _compaction_resume_markdown(manifest)
    rendered_memory = _compaction_memory_markdown(manifest)

    if args.dry_run:
        print(rendered_resume, end="")
        return

    report_dir.mkdir(parents=True, exist_ok=True)
    memory_file.parent.mkdir(parents=True, exist_ok=True)
    PLAN_STATE_DIR.mkdir(parents=True, exist_ok=True)
    manifest_path.write_text(rendered_manifest, encoding="utf-8")
    resume_path.write_text(rendered_resume, encoding="utf-8")
    memory_file.write_text(rendered_memory, encoding="utf-8")
    with COMPACTION_HISTORY_PATH.open("a", encoding="utf-8") as handle:
        handle.write(
            json.dumps(
                {
                    "created_at": manifest["created_at"],
                    "task_id": task_id,
                    "slug": slug,
                    "manifest": manifest["paths"]["manifest"],
                    "resume": manifest["paths"]["resume"],
                    "memory_name": memory_name,
                },
                sort_keys=True,
            )
            + "\n"
        )

    metadata = _parse_front_matter(session_path)
    session_value = args.session or _derive_session_value(metadata)
    session_entry = (
        f"- **[{created_at.strftime(DEFAULT_TIME_FORMAT_SESSION)}]** — "
        f"[S:{session_value}|W:{work}|H:scripts/codex-task:compaction-checkpoint|E:{manifest['paths']['manifest']}] "
        f"Created compaction checkpoint `{memory_name}`; resume at: {args.next_step}"
    )
    tracker_entry = (
        f"- **{created_at.strftime(DEFAULT_TIME_FORMAT_TRACKER)}** — "
        f"[S:{session_value}|W:{work}|H:scripts/codex-task:compaction-checkpoint|E:{manifest['paths']['manifest']}] "
        f"Created compaction checkpoint `{memory_name}`; resume at: {args.next_step}"
    )
    session_lines = _insert_progress_entry(_load_file_lines(session_path), PROGRESS_HEADING_SESSION, session_entry)
    tracker_lines = _insert_progress_entry(_load_file_lines(tracker_path), PROGRESS_HEADING_TRACKER, tracker_entry)
    _write_file_lines(session_path, session_lines)
    _write_file_lines(tracker_path, tracker_lines)
    _append_compaction_handoff(work_folder, manifest, session_value, work)

    print(f"Wrote compaction checkpoint manifest to {manifest['paths']['manifest']}")
    print(f"Wrote compaction resume message to {manifest['paths']['resume']}")
    print(f"Wrote compaction Serena memory file to {manifest['paths']['memory_file']}")
    print(f"Updated compaction history: {_relative_to_root(COMPACTION_HISTORY_PATH, REPO_ROOT)}")


def _load_json_document(path_value: str, label: str) -> Dict[str, Any]:
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    if not path.exists():
        raise TaskError(f"{label} not found: {_relative_to_root(path, REPO_ROOT)}")
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"{label} is not valid JSON: {_relative_to_root(path, REPO_ROOT)}") from exc
    if not isinstance(payload, dict):
        raise TaskError(f"{label} must be a JSON object: {_relative_to_root(path, REPO_ROOT)}")
    return payload


def _normalise_roadmap_payload(path_value: str) -> Dict[str, Any]:
    raw = _load_json_document(path_value, "Migration roadmap")
    metadata = raw.get("metadata") if isinstance(raw.get("metadata"), dict) else None
    data = raw.get("data") if isinstance(raw.get("data"), dict) else raw
    if not isinstance(data, dict):
        raise TaskError("Migration roadmap data must be a JSON object")
    if "items" not in data or "summary_metrics" not in data:
        raise TaskError("Migration roadmap must include items and summary_metrics")
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "metadata": metadata,
        "data": data,
    }


def _simplify_rehearsal_item(item: Dict[str, Any]) -> Dict[str, Any]:
    source_files = item.get("source_files") if isinstance(item.get("source_files"), list) else []
    dependencies = item.get("dependencies") if isinstance(item.get("dependencies"), list) else []
    return {
        "id": item.get("id"),
        "priority": item.get("priority"),
        "category": item.get("category"),
        "title": item.get("title"),
        "effort": item.get("effort"),
        "risk": item.get("risk"),
        "finding_count": item.get("finding_count"),
        "source_files": source_files[:5],
        "dependencies": dependencies[:5],
    }


def _summarise_rehearsal_roadmap(roadmap: Dict[str, Any], max_items: int) -> Dict[str, Any]:
    data = roadmap["data"]
    items = data.get("items")
    if not isinstance(items, list):
        raise TaskError("Migration roadmap items must be a list")
    taskmaster_export = data.get("taskmaster_export")
    taskmaster_tasks = []
    if isinstance(taskmaster_export, dict) and isinstance(taskmaster_export.get("tasks"), list):
        taskmaster_tasks = taskmaster_export["tasks"]
    return {
        "path": roadmap["path"],
        "metadata": roadmap.get("metadata"),
        "generated_at": data.get("generated_at"),
        "version": data.get("migration_roadmap_version"),
        "summary_metrics": data.get("summary_metrics") if isinstance(data.get("summary_metrics"), dict) else {},
        "priority_counts": data.get("priority_counts") if isinstance(data.get("priority_counts"), dict) else {},
        "category_counts": data.get("category_counts") if isinstance(data.get("category_counts"), dict) else {},
        "phases": data.get("phases") if isinstance(data.get("phases"), list) else [],
        "total_items": len(items),
        "taskmaster_export_tasks": len(taskmaster_tasks),
        "first_items": [
            _simplify_rehearsal_item(item)
            for item in items[: max(0, max_items)]
            if isinstance(item, dict)
        ],
    }


def _summarise_rehearsal_checkpoint(checkpoint: Dict[str, Any], checkpoint_path: str) -> Dict[str, Any]:
    git_info = checkpoint.get("git") if isinstance(checkpoint.get("git"), dict) else {}
    workflow = checkpoint.get("workflow") if isinstance(checkpoint.get("workflow"), dict) else {}
    taskmaster = checkpoint.get("taskmaster") if isinstance(checkpoint.get("taskmaster"), dict) else {}
    status_entries = git_info.get("status") if isinstance(git_info.get("status"), list) else []
    path = Path(checkpoint_path)
    if not path.is_absolute():
        path = REPO_ROOT / path
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "label": checkpoint.get("label"),
        "created_at": checkpoint.get("created_at"),
        "git": {
            "branch": git_info.get("branch"),
            "head": git_info.get("head"),
            "tag": git_info.get("tag"),
            "status_count": len(status_entries),
        },
        "workflow": {
            "current_session": workflow.get("current_session", {}).get("resolved")
            if isinstance(workflow.get("current_session"), dict)
            else None,
            "current_plan": workflow.get("current_plan", {}).get("resolved")
            if isinstance(workflow.get("current_plan"), dict)
            else None,
            "active_work_tracking": workflow.get("active_work_tracking")
            if isinstance(workflow.get("active_work_tracking"), list)
            else [],
        },
        "taskmaster": {
            "sha256": taskmaster.get("sha256"),
            "summary": taskmaster.get("summary") if isinstance(taskmaster.get("summary"), dict) else None,
        },
    }


def _rehearsal_verification_commands() -> List[str]:
    return [
        "git status --short --branch",
        "python3 scripts/codex-task rollback checkpoint --label <label> --report-file <path>",
        "python3 scripts/template-ssot-scanner/migration_roadmap.py --data-dir scripts/template-ssot-scanner/output/data --json-out <path> --markdown-out <path>",
        "python3 scripts/codex-task rehearsal plan --roadmap <roadmap.json> --checkpoint <checkpoint.json> --report-file <plan.json> --runbook-file <runbook.md>",
        "python3 scripts/codex-task taskmaster health --report-file <path>",
        "python3 scripts/codex-task plan sync",
        "python3 scripts/codex-task work-tracking audit",
        "python3 scripts/codex-guard validate --include-untracked",
        "git diff --check",
    ]


def _build_migration_rehearsal_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    roadmap = _normalise_roadmap_payload(args.roadmap)
    checkpoint = _load_json_document(args.checkpoint, "Rollback checkpoint")
    roadmap_summary = _summarise_rehearsal_roadmap(roadmap, args.max_items)
    checkpoint_summary = _summarise_rehearsal_checkpoint(checkpoint, args.checkpoint)
    current_head = _git_output(["rev-parse", "HEAD"])
    current_branch = _git_output(["branch", "--show-current"])
    priority_counts = roadmap_summary.get("priority_counts", {})
    critical_count = int(priority_counts.get("critical", 0) or 0) if isinstance(priority_counts, dict) else 0
    dirty_count = len(_git_status_snapshot())
    abort_criteria = [
        "Stop if guard, plan sync, Taskmaster health, or required pytest suites fail.",
        "Stop if the rollback checkpoint is missing, unreadable, or points at an unexpected branch/head.",
        "Stop if rehearsal requires Docker, external API keys, agent simulators, load testing, or destructive Git commands; those are out of scope for this foundation task.",
    ]
    if critical_count:
        abort_criteria.append(
            f"Treat {critical_count} critical roadmap item(s) as pre-migration blockers unless explicitly waived in work tracking."
        )
    if dirty_count:
        abort_criteria.append(
            f"Review the current dirty working tree ({dirty_count} status entr{'y' if dirty_count == 1 else 'ies'}) before applying roadmap changes."
        )
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "non-destructive-local-rehearsal",
        "executes_mutations": False,
        "inputs": {
            "roadmap": roadmap_summary["path"],
            "checkpoint": checkpoint_summary["path"],
        },
        "current_state": {
            "git": {
                "branch": current_branch,
                "head": current_head,
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "checkpoint": checkpoint_summary,
        "roadmap": roadmap_summary,
        "rehearsal_environment": {
            "isolation_model": "manual-review-or-optional-worktree",
            "automatic_worktree_creation": False,
            "automatic_docker_setup": False,
            "external_api_keys_required": False,
            "agent_simulators_required": False,
            "load_testing_required": False,
            "guidance": [
                "Use the checkpoint commit as the rollback anchor before migration work.",
                "Use the roadmap priority order to select the next migration slice.",
                "If stronger isolation is needed, create a reviewed git worktree manually; this helper does not run that command.",
                "Capture fresh guard, audit, Taskmaster health, and diff-check evidence after each rehearsal slice.",
            ],
        },
        "recommended_verification_commands": _rehearsal_verification_commands(),
        "abort_criteria": abort_criteria,
        "non_goals": [
            "No Docker containers are created.",
            "No test API keys are read or written.",
            "No Claude/Codex agent simulators are launched.",
            "No k6/locust load test harness is invoked.",
            "No Taskmaster tasks are imported from roadmap data.",
            "No rollback, reset, clean, restore, or worktree command is executed.",
        ],
    }


def _md_cell(value: object) -> str:
    return str(value if value is not None else "").replace("|", "\\|")


def _render_migration_rehearsal_runbook(plan: Dict[str, Any]) -> str:
    roadmap = plan.get("roadmap", {})
    checkpoint = plan.get("checkpoint", {})
    current = plan.get("current_state", {})
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    checkpoint_git = checkpoint.get("git", {}) if isinstance(checkpoint.get("git"), dict) else {}
    lines = [
        "# Migration Rehearsal Runbook",
        "",
        f"- Label: {plan.get('label')}",
        f"- Created at: {plan.get('created_at')}",
        f"- Mode: {plan.get('mode')}",
        f"- Executes mutations: {plan.get('executes_mutations')}",
        "",
        "## Inputs",
        "",
        f"- Migration roadmap: {plan.get('inputs', {}).get('roadmap')}",
        f"- Rollback checkpoint: {plan.get('inputs', {}).get('checkpoint')}",
        "",
        "## Current State",
        "",
        f"- Current branch: {git_info.get('branch')}",
        f"- Current HEAD: {git_info.get('head')}",
        f"- Current dirty status entries: {len(git_info.get('status') or [])}",
        f"- Checkpoint branch: {checkpoint_git.get('branch')}",
        f"- Checkpoint HEAD: {checkpoint_git.get('head')}",
        "",
        "## Roadmap Summary",
        "",
        f"- Roadmap generated at: {roadmap.get('generated_at')}",
        f"- Roadmap version: {roadmap.get('version')}",
        f"- Total roadmap items: {roadmap.get('total_items')}",
        f"- Taskmaster draft items: {roadmap.get('taskmaster_export_tasks')}",
        "",
        "### Priority Counts",
        "",
    ]
    priority_counts = roadmap.get("priority_counts") if isinstance(roadmap.get("priority_counts"), dict) else {}
    if priority_counts:
        for priority in ("critical", "high", "medium", "low"):
            lines.append(f"- {priority}: {priority_counts.get(priority, 0)}")
    else:
        lines.append("- No priority counts available.")

    lines.extend(["", "### Phase Plan", ""])
    phases = roadmap.get("phases") if isinstance(roadmap.get("phases"), list) else []
    if phases:
        lines.append("| Phase | Priorities | Start Day | Duration |")
        lines.append("| --- | --- | --- | --- |")
        for phase in phases:
            if not isinstance(phase, dict):
                continue
            priorities = ", ".join(str(priority) for priority in phase.get("priorities", []))
            lines.append(
                f"| {_md_cell(phase.get('title'))} | {_md_cell(priorities)} | "
                f"{_md_cell(phase.get('start_day'))} | {_md_cell(phase.get('duration_days'))} days |"
            )
    else:
        lines.append("- No phase plan available.")

    lines.extend(["", "### First Rehearsal Items", ""])
    items = roadmap.get("first_items") if isinstance(roadmap.get("first_items"), list) else []
    if items:
        lines.append("| Priority | Category | Effort | Risk | Findings | Title |")
        lines.append("| --- | --- | --- | --- | --- | --- |")
        for item in items:
            if not isinstance(item, dict):
                continue
            lines.append(
                f"| {_md_cell(item.get('priority'))} | {_md_cell(item.get('category'))} | "
                f"{_md_cell(item.get('effort'))} | {_md_cell(item.get('risk'))} | "
                f"{_md_cell(item.get('finding_count'))} | {_md_cell(item.get('title'))} |"
            )
    else:
        lines.append("- No roadmap items available.")

    lines.extend(["", "## Rehearsal Steps", ""])
    lines.extend(
        [
            "1. Review the rollback checkpoint and current dirty Git status.",
            "2. Select the smallest roadmap item or coherent group of items to rehearse.",
            "3. If additional isolation is required, create a git worktree manually after reviewing the command; this runbook does not create it.",
            "4. Run the selected scanner or fix command in dry-run mode first.",
            "5. Capture guard, audit, Taskmaster health, plan sync, and diff-check evidence before marking the rehearsal slice complete.",
            "6. If any abort criterion triggers, stop and use the rollback checkpoint recovery plan for reviewed, non-destructive guidance.",
        ]
    )

    lines.extend(["", "## Recommended Verification Commands", ""])
    for command in plan.get("recommended_verification_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Abort Criteria", ""])
    for criterion in plan.get("abort_criteria", []):
        lines.append(f"- {criterion}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in plan.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(["", "No rehearsal commands were executed by this plan.", ""])
    return "\n".join(lines)


def handle_rehearsal_plan(args: argparse.Namespace) -> None:
    plan = _build_migration_rehearsal_plan(args)
    rendered_json = json.dumps(plan, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_migration_rehearsal_runbook(plan)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote migration rehearsal plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote migration rehearsal runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


