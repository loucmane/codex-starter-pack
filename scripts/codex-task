def _render_canary_rollout_runbook(plan: Dict[str, Any]) -> str:
    current = plan.get("current_state", {})
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    promotion = plan.get("promotion_model", {}) if isinstance(plan.get("promotion_model"), dict) else {}
    rollback = plan.get("rollback_policy", {}) if isinstance(plan.get("rollback_policy"), dict) else {}
    lines = [
        "# Foundation Canary Rollout Runbook",
        "",
        f"- Label: {plan.get('label')}",
        f"- Created at: {plan.get('created_at')}",
        f"- Mode: {plan.get('mode')}",
        f"- Executes mutations: {plan.get('executes_mutations')}",
        f"- Current branch: {git_info.get('branch')}",
        f"- Current HEAD: {git_info.get('head')}",
        f"- Current dirty status entries: {len(git_info.get('status') or [])}",
        "",
        "## Promotion Model",
        "",
        f"- Automatic promotion: {promotion.get('automatic_promotion')}",
        f"- Reviewed evidence required: {promotion.get('requires_reviewed_evidence')}",
        f"- Minimum total observation hours: {promotion.get('minimum_total_observation_hours')}",
        "",
        "## Rollback Policy",
        "",
        f"- Automatic rollback: {rollback.get('automatic_rollback')}",
        f"- Checkpoint required: {rollback.get('requires_checkpoint')}",
        "",
        "## Stages",
        "",
    ]
    stages = plan.get("stages") if isinstance(plan.get("stages"), list) else []
    if stages:
        for stage in stages:
            if not isinstance(stage, dict):
                continue
            lines.extend(
                [
                    f"### {stage.get('title')}",
                    "",
                    f"- Stage ID: {stage.get('id')}",
                    f"- Minimum observation: {stage.get('minimum_observation_hours')} hours",
                    f"- Scope: {stage.get('scope')}",
                    "",
                    "Entry criteria:",
                ]
            )
            for item in stage.get("entry_criteria", []):
                lines.append(f"- {item}")
            lines.extend(["", "Health checks:"])
            for item in stage.get("health_checks", []):
                lines.append(f"- `{item}`")
            lines.extend(["", "Promotion criteria:"])
            for item in stage.get("promotion_criteria", []):
                lines.append(f"- {item}")
            lines.extend(["", "Rollback triggers:"])
            for item in stage.get("rollback_triggers", []):
                lines.append(f"- {item}")
            lines.append("")
    else:
        lines.append("- No stages defined.")

    lines.extend(["## Recommended Verification Commands", ""])
    for command in plan.get("recommended_verification_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in plan.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(["", "No deployment, promotion, rollback, traffic split, dashboard update, or notification was executed by this plan.", ""])
    return "\n".join(lines)


def handle_rollout_canary_plan(args: argparse.Namespace) -> None:
    plan = _build_canary_rollout_plan(args)
    rendered_json = json.dumps(plan, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_canary_rollout_runbook(plan)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote canary rollout plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote canary rollout runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


