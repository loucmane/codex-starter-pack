    return _maintenance_domain(
        domain_id="operational-cadence",
        title="Operational cadence",
        cadence="daily/weekly/monthly/quarterly/yearly",
        purpose="Keep reusable daily work, recurring maintenance, escalation, troubleshooting, and validation procedures available.",
        status=status,
        evidence=[readme],
        refresh_commands=(
            "python3 scripts/codex-task operations runbook --label <label> --report-file reports/operational-runbook/<label>.json --runbook-file reports/operational-runbook/<label>.md",
        ),
        message="Operational runbook command is documented." if status == "ready" else "Operational runbook documentation is missing.",
        manual_actions=[] if status == "ready" else ["Restore `reports/operational-runbook/README.md` and regenerate the operational runbook packet."],
    )


