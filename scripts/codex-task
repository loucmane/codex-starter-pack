def _wrapped_data_document(path_value: str | Path, label: str) -> Dict[str, Any]:
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    payload = _load_json_document(path.as_posix(), label)
    metadata = payload.get("metadata") if isinstance(payload.get("metadata"), dict) else None
    data = payload.get("data") if isinstance(payload.get("data"), dict) else payload
    if not isinstance(data, dict):
        raise TaskError(f"{label} data must be a JSON object")
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "metadata": metadata,
        "data": data,
    }


def _normalise_migration_metrics_baseline(path_value: str | Path) -> Dict[str, Any]:
    baseline = _wrapped_data_document(path_value, "Baseline summary")
    data = baseline["data"]
    metrics = data.get("metrics")
    if not isinstance(metrics, dict):
        raise TaskError("Baseline summary must include data.metrics")
    outputs = data.get("outputs") if isinstance(data.get("outputs"), dict) else {}
    return {
        "path": baseline["path"],
        "metadata": baseline.get("metadata"),
        "generated_at": data.get("generated_at"),
        "metrics": metrics,
        "outputs": outputs,
    }


def _normalise_migration_metrics_security(path_value: str | Path | None) -> Dict[str, Any]:
    if not path_value:
        return {
            "path": None,
            "exists": False,
            "status": "not-provided",
            "findings": None,
            "severity_counts": {},
            "generated_at": None,
        }
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    display = _relative_to_root(path, REPO_ROOT)
    if not path.exists():
        return {
            "path": display,
            "exists": False,
            "status": "missing",
            "findings": None,
            "severity_counts": {},
            "generated_at": None,
        }
    security = _wrapped_data_document(path, "Security validation report")
    data = security["data"]
    metadata = security.get("metadata") if isinstance(security.get("metadata"), dict) else {}
    summary = data.get("summary") if isinstance(data.get("summary"), dict) else {}
    stats = metadata.get("stats") if isinstance(metadata.get("stats"), dict) else {}
    severity_counts = summary.get("severity_counts") if isinstance(summary.get("severity_counts"), dict) else {}
    findings = summary.get("total_findings", stats.get("findings"))
    return {
        "path": security["path"],
        "exists": True,
        "status": "present",
        "findings": int(findings or 0),
        "severity_counts": dict(severity_counts),
        "generated_at": metadata.get("scan_timestamp") or data.get("generated_at"),
    }


def _optional_migration_metrics_roadmap(path_value: str | None, max_items: int) -> Dict[str, Any]:
    if not path_value:
        return {
            "path": None,
            "exists": False,
            "status": "not-provided",
            "summary": None,
        }
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    if not path.exists():
        raise TaskError(f"Migration roadmap not found: {_relative_to_root(path, REPO_ROOT)}")
    roadmap = _normalise_roadmap_payload(path.as_posix())
    return {
        "path": roadmap["path"],
        "exists": True,
        "status": "present",
        "summary": _summarise_rehearsal_roadmap(roadmap, max_items),
    }


def _numeric_metric(metrics: Mapping[str, Any], key: str) -> float | int | None:
    value = metrics.get(key)
    if isinstance(value, bool):
        return int(value)
    if isinstance(value, (int, float)):
        return value
    return None


def _migration_kpi(
    *,
    metric_id: str,
    title: str,
    value: object,
    unit: str,
    target: str,
    status: str,
    severity: str,
    evidence: str,
    message: str,
) -> Dict[str, Any]:
    return {
        "id": metric_id,
        "title": title,
        "value": value,
        "unit": unit,
        "target": target,
        "status": status,
        "severity": severity,
        "evidence": evidence,
        "message": message,
    }


def _zero_target_kpi(
    *,
    metrics: Mapping[str, Any],
    key: str,
    metric_id: str,
    title: str,
    unit: str,
    fail_on_positive: bool,
    evidence: str,
) -> Dict[str, Any]:
    value = _numeric_metric(metrics, key)
    if value is None:
        return _migration_kpi(
            metric_id=metric_id,
            title=title,
            value=None,
            unit=unit,
            target="0",
            status="missing",
            severity="warning",
            evidence=evidence,
            message=f"`{key}` is missing from the baseline summary.",
        )
    if value == 0:
        status = "pass"
        severity = "info"
        message = "Target met."
    else:
        status = "fail" if fail_on_positive else "warn"
        severity = "error" if fail_on_positive else "warning"
        message = f"{value} item(s) remain above the zero target."
    return _migration_kpi(
        metric_id=metric_id,
        title=title,
        value=value,
        unit=unit,
        target="0",
        status=status,
        severity=severity,
        evidence=evidence,
        message=message,
    )


def _migration_metrics_kpis(
    baseline: Mapping[str, Any],
    roadmap: Mapping[str, Any],
    security: Mapping[str, Any],
) -> List[Dict[str, Any]]:
    metrics = baseline.get("metrics") if isinstance(baseline.get("metrics"), dict) else {}
    evidence = str(baseline.get("path"))
    kpis: List[Dict[str, Any]] = []
    migration_percentage = _numeric_metric(metrics, "migration_percentage")
    if migration_percentage is None:
        kpis.append(
            _migration_kpi(
                metric_id="migration-completion",
                title="Migration completion",
                value=None,
                unit="percent",
                target="100",
                status="missing",
                severity="warning",
                evidence=evidence,
                message="`migration_percentage` is missing from the baseline summary.",
            )
        )
    else:
        status = "pass" if migration_percentage >= 100 else "warn"
        kpis.append(
            _migration_kpi(
                metric_id="migration-completion",
                title="Migration completion",
                value=migration_percentage,
                unit="percent",
                target="100",
                status=status,
                severity="info" if status == "pass" else "warning",
                evidence=evidence,
                message="Migration is complete." if status == "pass" else "Migration is not yet complete.",
            )
        )

    kpis.extend(
        [
            _zero_target_kpi(
                metrics=metrics,
                key="pending_migration",
                metric_id="pending-migration",
                title="Pending migration files",
                unit="files",
                fail_on_positive=False,
                evidence=evidence,
            ),
            _zero_target_kpi(
                metrics=metrics,
                key="broken_references",
                metric_id="broken-references",
                title="Broken references",
                unit="references",
                fail_on_positive=True,
                evidence=evidence,
            ),
            _zero_target_kpi(
                metrics=metrics,
                key="circular_dependencies",
                metric_id="circular-dependencies",
                title="Circular dependencies",
                unit="cycles",
                fail_on_positive=True,
                evidence=evidence,
            ),
            _zero_target_kpi(
                metrics=metrics,
                key="duplicate_count",
                metric_id="duplicate-files",
                title="Duplicate files",
                unit="files",
                fail_on_positive=False,
                evidence=evidence,
            ),
            _zero_target_kpi(
                metrics=metrics,
                key="total_fixes",
                metric_id="recommended-fixes",
                title="Recommended fixes",
                unit="fixes",
                fail_on_positive=False,
                evidence=evidence,
            ),
        ]
    )

    security_findings = security.get("findings")
    if security.get("exists") is False:
        kpis.append(
            _migration_kpi(
                metric_id="security-findings",
                title="Security findings",
                value=None,
                unit="findings",
                target="0",
                status="missing",
                severity="warning",
                evidence=str(security.get("path") or "not provided"),
                message="Security validation report is missing or not provided.",
            )
        )
    else:
        severity_counts = security.get("severity_counts") if isinstance(security.get("severity_counts"), dict) else {}
        errors = int(severity_counts.get("error", 0) or 0)
        findings = int(security_findings or 0)
        if findings == 0:
            status = "pass"
            severity = "info"
            message = "Target met."
        elif errors:
            status = "fail"
            severity = "error"
            message = f"{errors} error-level security finding(s) block migration readiness."
        else:
            status = "warn"
            severity = "warning"
            message = f"{findings} non-error security finding(s) require review."
        kpis.append(
            _migration_kpi(
                metric_id="security-findings",
                title="Security findings",
                value=findings,
                unit="findings",
                target="0",
                status=status,
                severity=severity,
                evidence=str(security.get("path")),
                message=message,
            )
        )

    roadmap_summary = roadmap.get("summary") if isinstance(roadmap.get("summary"), dict) else None
    if roadmap_summary is None:
        kpis.append(
            _migration_kpi(
                metric_id="roadmap-critical-items",
                title="Critical roadmap items",
                value=None,
                unit="items",
                target="0",
                status="missing",
                severity="warning",
                evidence=str(roadmap.get("path") or "not provided"),
                message="Migration roadmap was not provided; roadmap backlog metrics are unavailable.",
            )
        )
    else:
        priority_counts = roadmap_summary.get("priority_counts") if isinstance(roadmap_summary.get("priority_counts"), dict) else {}
        critical = int(priority_counts.get("critical", 0) or 0)
        total_items = int(roadmap_summary.get("total_items", 0) or 0)
        kpis.append(
            _migration_kpi(
                metric_id="roadmap-critical-items",
                title="Critical roadmap items",
                value=critical,
                unit="items",
                target="0",
                status="fail" if critical else "pass",
                severity="error" if critical else "info",
                evidence=str(roadmap_summary.get("path")),
                message="Critical roadmap items remain." if critical else "No critical roadmap items remain.",
            )
        )
        kpis.append(
            _migration_kpi(
                metric_id="roadmap-total-items",
                title="Total roadmap items",
                value=total_items,
                unit="items",
                target="reviewed backlog",
                status="warn" if total_items else "pass",
                severity="warning" if total_items else "info",
                evidence=str(roadmap_summary.get("path")),
                message="Roadmap backlog remains." if total_items else "Roadmap has no remaining items.",
            )
        )
    return kpis


def _migration_metrics_status(kpis: Sequence[Mapping[str, Any]]) -> str:
    if any(kpi.get("status") == "fail" for kpi in kpis):
        return "fail"
    if any(kpi.get("status") in {"warn", "missing"} for kpi in kpis):
        return "warn"
    return "pass"


def _migration_metrics_verification_commands() -> List[str]:
    return [
        "python3 scripts/template-ssot-scanner/run_all_scanners.py --profile ci",
        "python3 scripts/template-ssot-scanner/baseline_summary.py --data-dir scripts/template-ssot-scanner/output/data",
        "python3 scripts/template-ssot-scanner/migration_roadmap.py --data-dir scripts/template-ssot-scanner/output/data --json-out <roadmap.json> --markdown-out <roadmap.md>",
        "python3 scripts/codex-task migration metrics --baseline-summary <baseline_summary.json> --roadmap <roadmap.json> --security-report <security_validation.json> --report-file <metrics.json> --runbook-file <metrics.md>",
        "python3 scripts/codex-task report generate --kind migration-health",
        "python3 scripts/codex-task validation final-suite --dry-run",
    ]


def _build_migration_metrics_report(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    baseline = _normalise_migration_metrics_baseline(args.baseline_summary)
    security = _normalise_migration_metrics_security(args.security_report)
    roadmap = _optional_migration_metrics_roadmap(args.roadmap, args.max_roadmap_items)
    kpis = _migration_metrics_kpis(baseline, roadmap, security)
    status = _migration_metrics_status(kpis)
    baseline_metadata = baseline.get("metadata") if isinstance(baseline.get("metadata"), dict) else {}
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "static-file-backed-migration-metrics",
        "executes_external_actions": False,
        "aggregate_status": status,
        "summary": {
            "total_kpis": len(kpis),
            "passed": sum(1 for kpi in kpis if kpi.get("status") == "pass"),
            "warnings": sum(1 for kpi in kpis if kpi.get("status") in {"warn", "missing"}),
            "failures": sum(1 for kpi in kpis if kpi.get("status") == "fail"),
        },
        "inputs": {
            "baseline_summary": {
                "path": baseline["path"],
                "generated_at": baseline.get("generated_at"),
                "scanner_timestamp": baseline_metadata.get("scan_timestamp"),
            },
            "roadmap": {
                "path": roadmap.get("path"),
                "status": roadmap.get("status"),
                "exists": roadmap.get("exists"),
            },
            "security_report": {
                "path": security.get("path"),
                "status": security.get("status"),
                "exists": security.get("exists"),
                "generated_at": security.get("generated_at"),
            },
        },
        "source_outputs": baseline.get("outputs", {}),
        "kpis": kpis,
        "roadmap": roadmap.get("summary"),
        "recommended_refresh_commands": _migration_metrics_verification_commands(),
        "non_goals": list(MIGRATION_METRIC_NON_GOALS),
    }


def _render_migration_metrics_runbook(report: Dict[str, Any]) -> str:
    lines = [
        "# Migration Metrics Collection",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Aggregate status: {report.get('aggregate_status')}",
        f"- Executes external actions: {report.get('executes_external_actions')}",
        "",
        "## Inputs",
        "",
    ]
    inputs = report.get("inputs") if isinstance(report.get("inputs"), dict) else {}
    for key, value in inputs.items():
        if not isinstance(value, dict):
            continue
        lines.append(f"- {key}: `{value.get('path')}`")

    lines.extend(["", "## KPI Summary", ""])
    summary = report.get("summary") if isinstance(report.get("summary"), dict) else {}
    lines.extend(
        [
            f"- Total KPIs: {summary.get('total_kpis')}",
            f"- Passed: {summary.get('passed')}",
            f"- Warnings: {summary.get('warnings')}",
            f"- Failures: {summary.get('failures')}",
            "",
            "## KPIs",
            "",
            "| KPI | Value | Unit | Target | Status | Severity | Evidence |",
            "| --- | --- | --- | --- | --- | --- | --- |",
        ]
    )
    for kpi in report.get("kpis", []):
        if not isinstance(kpi, dict):
            continue
        lines.append(
            f"| {_md_cell(kpi.get('title'))} | {_md_cell(kpi.get('value'))} | "
            f"{_md_cell(kpi.get('unit'))} | {_md_cell(kpi.get('target'))} | "
            f"{_md_cell(kpi.get('status'))} | {_md_cell(kpi.get('severity'))} | "
            f"{_md_cell(kpi.get('evidence'))} |"
        )

    roadmap = report.get("roadmap") if isinstance(report.get("roadmap"), dict) else None
    lines.extend(["", "## Roadmap Backlog", ""])
    if roadmap:
        lines.extend(
            [
                f"- Roadmap: `{roadmap.get('path')}`",
                f"- Total items: {roadmap.get('total_items')}",
                f"- Priority counts: {roadmap.get('priority_counts')}",
                f"- Category counts: {roadmap.get('category_counts')}",
            ]
        )
    else:
        lines.append("- No migration roadmap was provided.")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "No metric agent, time-series database, live dashboard, alert delivery, external service call, scanner regeneration, or remediation mutation was executed by this report.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_migration_metrics(args: argparse.Namespace) -> None:
    report = _build_migration_metrics_report(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_migration_metrics_runbook(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["aggregate_status"] == "fail":
            raise TaskError("Migration metrics aggregate status is fail")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote migration metrics report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote migration metrics runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["aggregate_status"] == "fail":
        raise TaskError("Migration metrics aggregate status is fail")


def _normalise_monitoring_status(value: object) -> str:
    normalised = str(value or "missing").strip().lower()
    aliases = {
        "ok": "pass",
        "passed": "pass",
        "success": "pass",
        "warning": "warn",
        "warnings": "warn",
        "error": "fail",
        "failed": "fail",
        "failure": "fail",
    }
    normalised = aliases.get(normalised, normalised)
    if normalised in {"pass", "warn", "fail", "missing", "not-measured"}:
        return normalised
    return "warn"


def _post_migration_monitoring_severity(status: str) -> str:
    if status == "fail":
        return "error"
    if status in {"warn", "missing", "not-measured"}:
        return "warning"
    return "info"


def _extract_report_status(payload: Mapping[str, Any], fields: Sequence[str]) -> str:
    for field in fields:
        if field in payload:
            return _normalise_monitoring_status(payload.get(field))
    return "missing"


def _summarise_post_migration_items(payload: Mapping[str, Any], max_items: int) -> List[Dict[str, Any]]:
    raw_items = payload.get("kpis")
    if not isinstance(raw_items, list):
        raw_items = payload.get("components")
    if not isinstance(raw_items, list):
        return []
    items: List[Dict[str, Any]] = []
    for raw in raw_items[: max(0, max_items)]:
        if not isinstance(raw, dict):
            continue
        items.append(
            {
                "id": raw.get("id"),
                "title": raw.get("title"),
                "status": _normalise_monitoring_status(raw.get("status")),
                "severity": raw.get("severity") or _post_migration_monitoring_severity(_normalise_monitoring_status(raw.get("status"))),
                "value": raw.get("value"),
                "target": raw.get("target"),
                "evidence": raw.get("evidence"),
                "message": raw.get("message"),
            }
        )
    return items


def _normalise_post_migration_input(
    path_value: str | Path | None,
    label: str,
    status_fields: Sequence[str],
    max_items: int,
) -> Dict[str, Any]:
    if not path_value:
        return {
            "path": None,
            "exists": False,
            "status": "missing",
            "severity": "warning",
            "generated_at": None,
            "summary": None,
            "items": [],
            "message": f"{label} was not provided.",
        }
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    relative = _relative_to_root(path, REPO_ROOT)
    if not path.exists():
        return {
            "path": relative,
            "exists": False,
            "status": "missing",
            "severity": "warning",
            "generated_at": None,
            "summary": None,
            "items": [],
            "message": f"{label} was not found.",
        }
    payload = _load_json_document(path.as_posix(), label)
    status = _extract_report_status(payload, status_fields)
    summary = payload.get("summary") if isinstance(payload.get("summary"), dict) else None
    return {
        "path": relative,
        "exists": True,
        "status": status,
        "severity": _post_migration_monitoring_severity(status),
        "generated_at": payload.get("created_at") or payload.get("generated_at"),
        "summary": summary,
        "items": _summarise_post_migration_items(payload, max_items),
        "message": f"{label} loaded successfully.",
    }


def _post_migration_monitoring_status(inputs: Sequence[Mapping[str, Any]]) -> str:
    statuses = {_normalise_monitoring_status(item.get("status")) for item in inputs}
    if "fail" in statuses:
        return "fail"
    if statuses.intersection({"warn", "missing", "not-measured"}):
        return "warn"
    return "pass"


def _post_migration_monitoring_actions(
    metrics: Mapping[str, Any],
    health: Mapping[str, Any],
) -> List[Dict[str, str]]:
    actions: List[Dict[str, str]] = []
    if metrics.get("status") == "missing":
        actions.append(
            {
                "id": "generate-migration-metrics",
                "severity": "warning",
                "title": "Generate the migration metrics packet.",
                "command": "python3 scripts/codex-task migration metrics --baseline-summary <baseline_summary.json> --roadmap <roadmap.json> --security-report <security_validation.json> --report-file <metrics.json> --runbook-file <metrics.md>",
            }
        )
    elif metrics.get("status") == "fail":
        actions.append(
            {
                "id": "resolve-failing-migration-kpis",
                "severity": "error",
                "title": "Resolve or explicitly waive failing migration KPIs.",
                "command": "Review the migration metrics runbook and update the roadmap before closing monitoring.",
            }
        )
    elif metrics.get("status") in {"warn", "not-measured"}:
        actions.append(
            {
                "id": "review-warning-migration-kpis",
                "severity": "warning",
                "title": "Review warning-level or incomplete migration KPI inputs.",
                "command": "Refresh scanner, roadmap, and security inputs before the next monitoring review.",
            }
        )

    if health.get("status") == "missing":
        actions.append(
            {
                "id": "generate-migration-health",
                "severity": "warning",
                "title": "Generate the aggregate migration-health report.",
                "command": "python3 scripts/codex-task report generate --kind migration-health",
            }
        )
    elif health.get("status") == "fail":
        actions.append(
            {
                "id": "resolve-failing-migration-health",
                "severity": "error",
                "title": "Resolve fail-level migration-health components.",
                "command": "Review reports/migration-health/latest.md and refresh failing source reports.",
            }
        )
    elif health.get("status") in {"warn", "not-measured"}:
        actions.append(
            {
                "id": "review-warning-migration-health",
                "severity": "warning",
                "title": "Review warning or missing migration-health components.",
                "command": "python3 scripts/codex-task report generate --kind telemetry",
            }
        )
    if not actions:
        actions.append(
            {
                "id": "continue-monitoring-cadence",
                "severity": "info",
                "title": "Continue the post-migration monitoring cadence.",
                "command": "Store the monitoring packet with weekly/monthly/quarterly/yearly evidence.",
            }
        )
    return actions


def _build_post_migration_monitoring_report(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    metrics = _normalise_post_migration_input(
        args.metrics_report,
        "Migration metrics report",
        ("aggregate_status", "status"),
        args.max_items,
    )
    health = _normalise_post_migration_input(
        args.migration_health_report,
        "Migration health report",
        ("status", "aggregate_status"),
        args.max_items,
    )
    aggregate_status = _post_migration_monitoring_status((metrics, health))
    actions = _post_migration_monitoring_actions(metrics, health)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "static-file-backed-post-migration-monitoring",
        "executes_external_actions": False,
        "aggregate_status": aggregate_status,
        "summary": {
            "inputs": 2,
            "available_inputs": sum(1 for item in (metrics, health) if item.get("exists")),
            "cadence_checks": len(POST_MIGRATION_MONITORING_CADENCES),
            "required_actions": len(actions),
            "failures": sum(1 for item in (metrics, health) if item.get("status") == "fail"),
            "warnings": sum(1 for item in (metrics, health) if item.get("status") in {"warn", "missing", "not-measured"}),
        },
        "inputs": {
            "migration_metrics": metrics,
            "migration_health": health,
        },
        "required_actions": actions,
        "cadence_plan": list(POST_MIGRATION_MONITORING_CADENCES),
        "automation_guidance": {
            "report_refresh": "Run static report commands manually, in CI, or in a reviewed scheduler owned by the downstream project.",
            "default_review_packet": "Store the generated JSON and Markdown packet as task-local evidence before acting on findings.",
            "strict_gate": "Use --strict only when fail-level post-migration status should fail the caller.",
        },
        "non_goals": list(POST_MIGRATION_MONITORING_NON_GOALS),
    }


def _render_post_migration_monitoring_runbook(report: Dict[str, Any]) -> str:
    lines = [
        "# Post-Migration Monitoring",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Aggregate status: {report.get('aggregate_status')}",
        f"- Executes external actions: {report.get('executes_external_actions')}",
        "",
        "## Inputs",
        "",
        "| Input | Path | Exists | Status | Severity | Generated at |",
        "| --- | --- | --- | --- | --- | --- |",
    ]
    inputs = report.get("inputs") if isinstance(report.get("inputs"), dict) else {}
    for name, value in inputs.items():
        if not isinstance(value, dict):
            continue
        lines.append(
            f"| {_md_cell(name)} | {_md_cell(value.get('path'))} | {_md_cell(value.get('exists'))} | "
            f"{_md_cell(value.get('status'))} | {_md_cell(value.get('severity'))} | {_md_cell(value.get('generated_at'))} |"
        )

    lines.extend(["", "## Required Actions", ""])
    for action in report.get("required_actions", []):
        if not isinstance(action, dict):
            continue
        lines.append(f"- **{action.get('severity')}** - {action.get('title')} `{action.get('command')}`")

    lines.extend(["", "## Source Highlights", ""])
    for name, value in inputs.items():
        if not isinstance(value, dict):
            continue
        items = value.get("items") if isinstance(value.get("items"), list) else []
        if not items:
            continue
        lines.extend([f"### {name.replace('_', ' ').title()}", "", "| Item | Status | Severity | Value | Target | Evidence |", "| --- | --- | --- | --- | --- | --- |"])
        for item in items:
            if not isinstance(item, dict):
                continue
            lines.append(
                f"| {_md_cell(item.get('title') or item.get('id'))} | {_md_cell(item.get('status'))} | "
                f"{_md_cell(item.get('severity'))} | {_md_cell(item.get('value'))} | "
                f"{_md_cell(item.get('target'))} | {_md_cell(item.get('evidence'))} |"
            )
        lines.append("")

    lines.extend(["## Cadence Plan", "", "| Cadence | Check | Purpose | Commands | Evidence |", "| --- | --- | --- | --- | --- |"])
    for item in report.get("cadence_plan", []):
        if not isinstance(item, dict):
            continue
        commands = "<br>".join(f"`{command}`" for command in item.get("commands", []))
        evidence = "<br>".join(str(value) for value in item.get("evidence", []))
        lines.append(
            f"| {_md_cell(item.get('cadence'))} | {_md_cell(item.get('title'))} | "
            f"{_md_cell(item.get('purpose'))} | {commands} | {_md_cell(evidence)} |"
        )

    lines.extend(["", "## Automation Guidance", ""])
    guidance = report.get("automation_guidance") if isinstance(report.get("automation_guidance"), dict) else {}
    for key, value in guidance.items():
        lines.append(f"- {key}: {value}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static review artifact. It coordinates existing reports and review cadences, but it does not install or execute a production monitoring system.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_post_migration_monitoring(args: argparse.Namespace) -> None:
    report = _build_post_migration_monitoring_report(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_post_migration_monitoring_runbook(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["aggregate_status"] == "fail":
            raise TaskError("Post-migration monitoring aggregate status is fail")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote post-migration monitoring report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote post-migration monitoring runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["aggregate_status"] == "fail":
        raise TaskError("Post-migration monitoring aggregate status is fail")


MIGRATION_ARCHIVE_KEYWORDS: Tuple[str, ...] = (
    "migration",
    "scanner",
    "roadmap",
    "reference",
    "template",
    "phase",
    "foundation",
    "deployment",
    "cleanup",
    "monitoring",
    "archive",
    "validation",
    "metrics",
    "report",
    "task",
)

MIGRATION_ARCHIVE_NON_GOALS: Tuple[str, ...] = (
    "No files are moved, copied, deleted, zipped, uploaded, or published by this command.",
    "No external archive storage, hosted search index, issue tracker, dashboard, or notification system is contacted.",
    "No retention policy, legal hold, or compliance classification is inferred.",
    "Existing work-tracking archives remain the canonical artifact store.",
)


def _safe_read_text(path: Path, max_chars: int = 6000) -> str:
    try:
        return path.read_text(encoding="utf-8", errors="replace")[:max_chars]
    except OSError:
        return ""


def _migration_archive_relevant(value: str) -> bool:
    lower = value.lower()
    return any(keyword in lower for keyword in MIGRATION_ARCHIVE_KEYWORDS)


def _migration_archive_entry(
    *,
    kind: str,
    path: Path,
    title: str,
    summary: str = "",
    date_value: str | None = None,
    task_id: str | None = None,
    signals: Mapping[str, Any] | None = None,
) -> Dict[str, Any]:
    return {
        "kind": kind,
        "path": _relative_to_root(path, REPO_ROOT),
        "title": title,
        "summary": summary,
        "date": date_value,
        "task_id": task_id,
        "signals": dict(signals or {}),
    }


def _migration_archive_folder_metadata(folder: Path) -> Dict[str, Any]:
    match = re.match(r"(?P<date>\d{8})-(?P<slug>.+)-COMPLETED$", folder.name)
    date_value = None
    title = folder.name
    task_id = None
    if match:
        raw_date = match.group("date")
        date_value = f"{raw_date[:4]}-{raw_date[4:6]}-{raw_date[6:8]}"
        slug = match.group("slug")
        task_match = re.search(r"task(?P<task>\d+)", slug)
        task_id = task_match.group("task") if task_match else None
        title = slug.replace("-", " ").title()
    return {"date": date_value, "title": title, "task_id": task_id}


def _migration_archive_summary_from(folder: Path) -> str:
    for name in ("HANDOFF.md", "IMPLEMENTATION.md", "TRACKER.md"):
        text = _safe_read_text(folder / name, max_chars=1800)
        for line in text.splitlines():
            stripped = line.strip()
            if stripped and not stripped.startswith("#") and not stripped.startswith("---"):
                return stripped[:260]
    return "Completed work-tracking archive folder."


def _collect_migration_archive_work_tracking(max_items: int) -> List[Dict[str, Any]]:
    archive_root = REPO_STRUCTURE.work_tracking_archive_root
    entries: List[Dict[str, Any]] = []
    if not archive_root.exists():
        return entries
    for folder in sorted(path for path in archive_root.glob("*-COMPLETED") if path.is_dir()):
        metadata = _migration_archive_folder_metadata(folder)
        reports_dir = folder / "reports"
        signals = {
            "has_tracker": (folder / "TRACKER.md").exists(),
            "has_findings": (folder / "FINDINGS.md").exists(),
            "has_decisions": (folder / "DECISIONS.md").exists(),
            "has_handoff": (folder / "HANDOFF.md").exists(),
            "report_files": sum(1 for item in reports_dir.rglob("*") if item.is_file()) if reports_dir.exists() else 0,
        }
        searchable = folder.name + "\n" + _safe_read_text(folder / "HANDOFF.md") + "\n" + _safe_read_text(folder / "TRACKER.md")
        if not _migration_archive_relevant(searchable):
            continue
        entries.append(
            _migration_archive_entry(
                kind="work_tracking_archive",
                path=folder,
                title=str(metadata["title"]),
                summary=_migration_archive_summary_from(folder),
                date_value=metadata.get("date"),
                task_id=metadata.get("task_id"),
                signals=signals,
            )
        )
        if len(entries) >= max_items:
            break
    return entries


def _collect_migration_archive_report_families(max_items: int) -> List[Dict[str, Any]]:
    reports_root = REPO_STRUCTURE.reports_root
    entries: List[Dict[str, Any]] = []
    if not reports_root.exists():
        return entries
    if (reports_root / "README.md").exists():
        entries.append(
            _migration_archive_entry(
                kind="report_index",
                path=reports_root / "README.md",
                title="Reports Index",
                summary="Repository-level report index.",
            )
        )
    for folder in sorted(path for path in reports_root.iterdir() if path.is_dir()):
        file_count = sum(1 for item in folder.rglob("*") if item.is_file())
        readme = folder / "README.md"
        text = folder.name + "\n" + _safe_read_text(readme, max_chars=1400)
        if not _migration_archive_relevant(text):
            continue
        entries.append(
            _migration_archive_entry(
                kind="report_family",
                path=folder,
                title=folder.name.replace("-", " ").title(),
                summary=next((line.strip() for line in _safe_read_text(readme).splitlines() if line.strip() and not line.startswith("#")), "Repository report family."),
                signals={"file_count": file_count, "has_readme": readme.exists()},
            )
        )
        if len(entries) >= max_items:
            break
    return entries


def _collect_migration_archive_tools(max_items: int) -> List[Dict[str, Any]]:
    candidates: List[Path] = []
    scanner_root = REPO_ROOT / "scripts" / "template-ssot-scanner"
    if scanner_root.exists():
        candidates.extend(sorted(scanner_root.glob("*.py")))
        candidates.extend(sorted(scanner_root.glob("README.md")))
        candidates.extend(sorted((scanner_root / "output" / "scripts").glob("*")) if (scanner_root / "output" / "scripts").exists() else [])
        candidates.extend(sorted((scanner_root / "output" / "data").glob("*.json")) if (scanner_root / "output" / "data").exists() else [])
    codex_task = REPO_ROOT / "scripts" / "codex-task"
    if codex_task.exists():
        candidates.append(codex_task)

    entries: List[Dict[str, Any]] = []
    for path in candidates:
        if not path.is_file():
            continue
        text = path.name + "\n" + _safe_read_text(path, max_chars=1800)
        if not _migration_archive_relevant(text):
            continue
        entries.append(
            _migration_archive_entry(
                kind="tool_or_output",
                path=path,
                title=path.name,
                summary="Migration archive tooling or generated scanner output.",
                signals={"suffix": path.suffix, "size_bytes": path.stat().st_size},
            )
        )
        if len(entries) >= max_items:
            break
    return entries


def _collect_migration_archive_text_files(root: Path, pattern: str, kind: str, max_items: int) -> List[Dict[str, Any]]:
    entries: List[Dict[str, Any]] = []
    if not root.exists():
        return entries
    for path in sorted(root.glob(pattern)):
        if not path.is_file():
            continue
        text = path.name + "\n" + _safe_read_text(path, max_chars=2400)
        if not _migration_archive_relevant(text):
            continue
        entries.append(
            _migration_archive_entry(
                kind=kind,
                path=path,
                title=path.stem.replace("-", " ").replace("_", " ").title(),
                summary=next((line.strip() for line in text.splitlines() if line.strip() and not line.startswith("#") and not line.startswith("---")), ""),
                signals={"size_bytes": path.stat().st_size},
            )
        )
        if len(entries) >= max_items:
            break
    return entries


def _collect_migration_archive_records(folders: Sequence[Mapping[str, Any]], max_items: int) -> Tuple[List[Dict[str, Any]], List[Dict[str, Any]]]:
    decisions: List[Dict[str, Any]] = []
    lessons: List[Dict[str, Any]] = []
    for entry in folders:
        folder = REPO_ROOT / str(entry.get("path", ""))
        for file_name, target in (("DECISIONS.md", decisions), ("FINDINGS.md", lessons), ("HANDOFF.md", lessons)):
            source = folder / file_name
            text = _safe_read_text(source, max_chars=8000)
            if not text:
                continue
            for line in text.splitlines():
                stripped = line.strip()
                if not stripped.startswith("- "):
                    continue
                if file_name == "HANDOFF.md" and not _migration_archive_relevant(stripped):
                    continue
                target.append(
                    _migration_archive_entry(
                        kind="decision_record" if file_name == "DECISIONS.md" else "lesson_candidate",
                        path=source,
                        title=stripped[2:120],
                        summary=stripped[2:360],
                        date_value=entry.get("date") if isinstance(entry.get("date"), str) else None,
                        task_id=entry.get("task_id") if isinstance(entry.get("task_id"), str) else None,
                    )
                )
                if len(target) >= max_items:
                    break
            if len(target) >= max_items:
                break
    return decisions[:max_items], lessons[:max_items]


def _migration_archive_entry_matches(entry: Mapping[str, Any], query: str) -> bool:
    terms = [term for term in re.split(r"\s+", query.lower().strip()) if term]
    if not terms:
        return True
    blob = json.dumps(entry, sort_keys=True, default=str).lower()
    return all(term in blob for term in terms)


def _build_migration_archive_report(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    max_items = max(1, int(args.max_items))
    completed_work = _collect_migration_archive_work_tracking(max_items)
    report_families = _collect_migration_archive_report_families(max_items)
    tools = _collect_migration_archive_tools(max_items)
    plans = _collect_migration_archive_text_files(PLANS_DIR, "*.md", "plan", max_items)
    task_files = _collect_migration_archive_text_files(REPO_STRUCTURE.taskmaster_root / "tasks", "task_*.txt", "taskmaster_task", max_items)
    memories = _collect_migration_archive_text_files(REPO_ROOT / ".serena" / "memories", "*.md", "serena_memory", max_items)
    decisions, lessons = _collect_migration_archive_records(completed_work, max_items)
    sections = {
        "completed_work": completed_work,
        "report_families": report_families,
        "tools_and_outputs": tools,
        "plans": plans,
        "taskmaster_tasks": task_files,
        "serena_memories": memories,
        "decision_records": decisions,
        "lessons_learned_candidates": lessons,
    }
    all_entries = [item for values in sections.values() for item in values]
    timeline = sorted(
        (
            {
                "date": entry.get("date"),
                "task_id": entry.get("task_id"),
                "title": entry.get("title"),
                "path": entry.get("path"),
            }
            for entry in completed_work
            if entry.get("date")
        ),
        key=lambda item: (str(item.get("date")), str(item.get("path"))),
    )
    query = (args.query or "").strip()
    search_results = [entry for entry in all_entries if _migration_archive_entry_matches(entry, query)] if query else []
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "static-migration-archive-index",
        "executes_external_actions": False,
        "query": query or None,
        "summary": {
            "completed_work": len(completed_work),
            "report_families": len(report_families),
            "tools_and_outputs": len(tools),
            "plans": len(plans),
            "taskmaster_tasks": len(task_files),
            "serena_memories": len(memories),
            "decision_records": len(decisions),
            "lessons_learned_candidates": len(lessons),
            "timeline_items": len(timeline),
            "search_results": len(search_results),
        },
        "sections": sections,
        "timeline": timeline,
        "search_results": search_results[:max_items],
        "recommended_refresh_commands": [
            "python3 scripts/codex-task migration archive --report-file reports/migration-archive/latest.json --runbook-file reports/migration-archive/latest.md",
            "python3 scripts/template-ssot-scanner/run_all_scanners.py",
            "python3 scripts/codex-task work-tracking audit",
            "python3 scripts/codex-task taskmaster health",
        ],
        "non_goals": list(MIGRATION_ARCHIVE_NON_GOALS),
    }


def _render_migration_archive_table(entries: Sequence[Mapping[str, Any]]) -> List[str]:
    lines = ["| Kind | Title | Path | Date | Task |", "| --- | --- | --- | --- | --- |"]
    for entry in entries:
        lines.append(
            f"| {_md_cell(entry.get('kind'))} | {_md_cell(entry.get('title'))} | "
            f"{_md_cell(entry.get('path'))} | {_md_cell(entry.get('date'))} | {_md_cell(entry.get('task_id'))} |"
        )
    return lines


def _render_migration_archive_runbook(report: Dict[str, Any]) -> str:
    lines = [
        "# Migration Archive",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Query: {report.get('query') or 'None'}",
        f"- Executes external actions: {report.get('executes_external_actions')}",
        "",
        "## Summary",
        "",
    ]
    summary = report.get("summary") if isinstance(report.get("summary"), dict) else {}
    for key, value in summary.items():
        lines.append(f"- {key.replace('_', ' ').title()}: {value}")

    sections = report.get("sections") if isinstance(report.get("sections"), dict) else {}
    for section_name in (
        "completed_work",
        "report_families",
        "tools_and_outputs",
        "plans",
        "taskmaster_tasks",
        "serena_memories",
        "decision_records",
        "lessons_learned_candidates",
    ):
        entries = sections.get(section_name)
        if not isinstance(entries, list) or not entries:
            continue
        lines.extend(["", f"## {section_name.replace('_', ' ').title()}", ""])
        lines.extend(_render_migration_archive_table(entries))

    timeline = report.get("timeline") if isinstance(report.get("timeline"), list) else []
    if timeline:
        lines.extend(["", "## Migration Timeline", "", "| Date | Task | Title | Path |", "| --- | --- | --- | --- |"])
        for item in timeline:
            if not isinstance(item, dict):
                continue
            lines.append(
                f"| {_md_cell(item.get('date'))} | {_md_cell(item.get('task_id'))} | "
                f"{_md_cell(item.get('title'))} | {_md_cell(item.get('path'))} |"
            )

    search_results = report.get("search_results") if isinstance(report.get("search_results"), list) else []
    if report.get("query") is not None:
        lines.extend(["", "## Search Results", ""])
        if search_results:
            lines.extend(_render_migration_archive_table(search_results))
        else:
            lines.append("- No matching archive entries.")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static archive index over canonical repository evidence. It improves discoverability without duplicating or moving historical artifacts.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_migration_archive(args: argparse.Namespace) -> None:
    report = _build_migration_archive_report(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_migration_archive_runbook(report)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote migration archive report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote migration archive runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


def _build_operational_runbook(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "operational-runbook"
    procedures = [dict(item) for item in OPERATIONAL_RUNBOOK_PROCEDURES]
    troubleshooting = [dict(item) for item in OPERATIONAL_RUNBOOK_TROUBLESHOOTING]
    escalation = [dict(item) for item in OPERATIONAL_RUNBOOK_ESCALATION]
    validation_checklist = [dict(item) for item in OPERATIONAL_RUNBOOK_VALIDATION_CHECKLIST]

    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "non-destructive-operational-runbook",
        "executes_actions": False,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "procedure_count": len(procedures),
        "procedures": procedures,
        "troubleshooting_matrix": troubleshooting,
        "escalation_tree": escalation,
        "validation_checklist": validation_checklist,
        "related_helpers": {
            "daily_start": "python3 scripts/codex-task wizard kickoff --task <id> --slug <slug>",
            "daily_continuation": "python3 scripts/codex-task sessions continue --task <id> --slug <slug>",
            "guard": "python3 scripts/codex-guard validate --include-untracked",
            "taskmaster_health": "python3 scripts/codex-task taskmaster health",
            "work_tracking_audit": "python3 scripts/codex-task work-tracking audit",
            "recovery_plan": "python3 scripts/codex-task recovery plan --error-class <class> --summary <summary>",
            "emergency_plan": "python3 scripts/codex-task emergency plan --severity <P0-P3> --summary <summary>",
            "change_advisory": "python3 scripts/codex-task change advisory --summary <summary>",
            "post_migration_monitoring": "python3 scripts/codex-task migration monitoring --metrics-report <metrics.json> --migration-health-report reports/migration-health/latest.json",
            "final_validation": "python3 scripts/codex-task validation final-suite --execute --report-dir reports/final-validation-suite",
        },
        "non_goals": list(OPERATIONAL_RUNBOOK_NON_GOALS),
    }


def _render_operational_runbook(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), dict) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), dict) else {}
    taskmaster = current.get("taskmaster", {}) if isinstance(current.get("taskmaster"), dict) else {}
    taskmaster_summary = taskmaster.get("summary", {}) if isinstance(taskmaster.get("summary"), dict) else {}
    lines = [
        "# Operational Runbook",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), dict) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), dict) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        f"- Taskmaster tasks: {taskmaster_summary.get('tasks')}",
        f"- Taskmaster invalid dependency refs: {taskmaster_summary.get('invalid_refs', taskmaster_summary.get('invalid_dependencies'))}",
        "",
        "## Procedure Index",
        "",
        "| Cadence | Procedure | Purpose |",
        "| --- | --- | --- |",
    ]
    for procedure in report.get("procedures", []):
        if not isinstance(procedure, dict):
            continue
        lines.append(
            f"| {_md_cell(procedure.get('cadence'))} | {_md_cell(procedure.get('title'))} | {_md_cell(procedure.get('purpose'))} |"
        )

    lines.extend(["", "## Procedures", ""])
    for procedure in report.get("procedures", []):
        if not isinstance(procedure, dict):
            continue
        lines.extend(
            [
                f"### {procedure.get('title')}",
                "",
                f"- ID: `{procedure.get('id')}`",
                f"- Cadence: {procedure.get('cadence')}",
                f"- Purpose: {procedure.get('purpose')}",
                f"- Owner roles: {', '.join(str(role) for role in procedure.get('owner_roles', []))}",
                "",
                "Commands:",
            ]
        )
        for command in procedure.get("commands", []):
            lines.append(f"- `{command}`")
        lines.extend(["", "Evidence:"])
        for item in procedure.get("evidence", []):
            lines.append(f"- {item}")
        lines.append("")

    lines.extend(
        [
            "## Troubleshooting Matrix",
            "",
            "| Symptom | First Check | Response |",
            "| --- | --- | --- |",
        ]
    )
    for item in report.get("troubleshooting_matrix", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| {_md_cell(item.get('symptom'))} | `{_md_cell(item.get('first_check'))}` | {_md_cell(item.get('response'))} |"
        )

    lines.extend(
        [
            "",
            "## Role-Based Escalation",
            "",
            "| Level | Role | Trigger | Action |",
            "| --- | --- | --- | --- |",
        ]
    )
    for item in report.get("escalation_tree", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| {_md_cell(item.get('level'))} | `{_md_cell(item.get('role'))}` | {_md_cell(item.get('trigger'))} | {_md_cell(item.get('action'))} |"
        )

    lines.extend(
        [
            "",
            "## Validation Checklist",
            "",
            "| Check | Command | Evidence |",
            "| --- | --- | --- |",
        ]
    )
    for item in report.get("validation_checklist", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| `{_md_cell(item.get('id'))}` | `{_md_cell(item.get('command'))}` | {_md_cell(item.get('evidence'))} |"
        )

    lines.extend(["", "## Related Helpers", ""])
    helpers = report.get("related_helpers") if isinstance(report.get("related_helpers"), dict) else {}
    for name, command in sorted(helpers.items()):
        lines.append(f"- {name}: `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "No scheduler, notification, ticket, dashboard update, deployment, rollback, reset, cleanup, or external incident action was executed by this runbook.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_operational_runbook(args: argparse.Namespace) -> None:
    report = _build_operational_runbook(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_operational_runbook(report)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote operational runbook report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote operational runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


POST_MORTEM_NON_GOALS: Tuple[str, ...] = (
    "No external incident, issue, ticket, dashboard, notification, webhook, email, Slack, PagerDuty, or knowledge-base system is created or contacted.",
    "No Taskmaster task, status, dependency, session, plan, work-tracking, Git, or external state is mutated beyond requested post-mortem artifacts.",
    "No timeline is scraped from GitHub, CI, sessions, logs, or external systems.",
    "No root-cause inference, blame assignment, predictive analysis, or automatic prioritization is performed.",
    "No scheduler, daemon, reminder service, or long-running follow-up automation is installed.",
)

POST_MORTEM_RECOMMENDED_HELPERS: Dict[str, str] = {
    "emergency_plan": "python3 scripts/codex-task emergency plan --severity <P0-P3> --summary <summary> --report-file <emergency.json> --runbook-file <emergency.md>",
    "recovery_plan": "python3 scripts/codex-task recovery plan --error-class <class> --summary <summary> --report-file <recovery.json> --runbook-file <recovery.md>",
    "rollback_checkpoint": "python3 scripts/codex-task rollback checkpoint --label <label> --report-file <checkpoint.json>",
    "rollback_plan": "python3 scripts/codex-task rollback plan --snapshot <checkpoint.json> --report-file <rollback-plan.md>",
    "change_advisory": "python3 scripts/codex-task change advisory --summary <summary> --report-file <advisory.json> --runbook-file <advisory.md>",
    "operational_runbook": "python3 scripts/codex-task operations runbook --label <label> --report-file <operations.json> --runbook-file <operations.md>",
    "final_validation": "python3 scripts/codex-task validation final-suite --execute --report-dir reports/final-validation-suite",
    "work_tracking_audit": "python3 scripts/codex-task work-tracking audit",
    "taskmaster_health": "python3 scripts/codex-task taskmaster health",
    "guard": "python3 scripts/codex-guard validate --include-untracked",
}


def _split_post_mortem_fields(raw_value: str, *, label: str, minimum: int, maximum: int) -> List[str]:
    parts = [part.strip() for part in str(raw_value).split("|")]
    if len(parts) < minimum or len(parts) > maximum or any(not part for part in parts[:minimum]):
        if minimum == maximum:
            expected = str(minimum)
        else:
            expected = f"{minimum}-{maximum}"
        raise TaskError(f"{label} entry must contain {expected} pipe-delimited fields: {raw_value}")
    return parts


def _parse_post_mortem_timeline(entries: Sequence[str]) -> List[Dict[str, Any]]:
    timeline: List[Dict[str, Any]] = []
    for index, entry in enumerate(entries, start=1):
        timestamp, phase, description, *rest = _split_post_mortem_fields(
            entry,
            label="Timeline",
            minimum=3,
            maximum=4,
        )
        timeline.append(
            {
                "order": index,
                "timestamp": timestamp,
                "phase": phase,
                "description": description,
                "evidence": rest[0] if rest else None,
            }
        )
    return timeline


def _parse_post_mortem_root_causes(entries: Sequence[str]) -> List[Dict[str, Any]]:
    root_causes: List[Dict[str, Any]] = []
    for index, entry in enumerate(entries, start=1):
        category, description = _split_post_mortem_fields(
            entry,
            label="Root cause",
            minimum=2,
            maximum=2,
        )
        root_causes.append({"id": f"rca-{index}", "category": category, "description": description})
    return root_causes


def _parse_post_mortem_action_items(entries: Sequence[str]) -> List[Dict[str, Any]]:
    action_items: List[Dict[str, Any]] = []
    for index, entry in enumerate(entries, start=1):
        owner, description, status, *rest = _split_post_mortem_fields(
            entry,
            label="Action item",
            minimum=3,
            maximum=4,
        )
        action_items.append(
            {
                "id": f"action-{index}",
                "owner": owner,
                "description": description,
                "status": status,
                "due": rest[0] if rest else None,
            }
        )
    return action_items


def _parse_post_mortem_prevention(entries: Sequence[str]) -> List[Dict[str, Any]]:
    prevention: List[Dict[str, Any]] = []
    for index, entry in enumerate(entries, start=1):
        description, verification_command, *rest = _split_post_mortem_fields(
            entry,
            label="Prevention",
            minimum=2,
            maximum=3,
        )
        prevention.append(
            {
                "id": f"prevention-{index}",
                "description": description,
                "verification_command": verification_command,
                "status": rest[0] if rest else "proposed",
            }
        )
    return prevention


def _post_mortem_parse_timestamp(value: Optional[str]) -> Optional[datetime]:
    if not value:
        return None
    candidate = value.strip()
    if candidate.endswith("Z"):
        candidate = f"{candidate[:-1]}+00:00"
    try:
        return datetime.fromisoformat(candidate)
    except ValueError:
        return None


def _post_mortem_duration_minutes(timeline: Sequence[Dict[str, Any]]) -> Optional[int]:
    detection: Optional[datetime] = None
    recovery: Optional[datetime] = None
    recovery_phases = {"recovery", "recovered", "resolved", "resolution", "restored", "closeout"}
    for item in timeline:
        phase = str(item.get("phase") or "").strip().lower()
        parsed = _post_mortem_parse_timestamp(str(item.get("timestamp") or ""))
        if parsed is None:
            continue
        if detection is None and phase in {"detection", "detected"}:
            detection = parsed
        if recovery is None and phase in recovery_phases:
            recovery = parsed
    if detection is None or recovery is None:
        return None
    seconds = (recovery - detection).total_seconds()
    if seconds < 0:
        return None
    return int(seconds // 60)


def _post_mortem_static_metrics(
    timeline: Sequence[Dict[str, Any]],
    root_causes: Sequence[Dict[str, Any]],
    action_items: Sequence[Dict[str, Any]],
    prevention: Sequence[Dict[str, Any]],
    lessons: Sequence[str],
) -> Dict[str, Any]:
    closed_statuses = {"done", "closed", "complete", "completed", "verified"}
    open_actions = [item for item in action_items if str(item.get("status") or "").strip().lower() not in closed_statuses]
    open_prevention = [item for item in prevention if str(item.get("status") or "").strip().lower() not in closed_statuses]
    return {
        "timeline_entries": len(timeline),
        "root_cause_count": len(root_causes),
        "action_item_count": len(action_items),
        "open_action_item_count": len(open_actions),
        "prevention_measure_count": len(prevention),
        "open_prevention_measure_count": len(open_prevention),
        "lesson_count": len(lessons),
        "detection_to_recovery_minutes": _post_mortem_duration_minutes(timeline),
    }


def _build_incident_post_mortem(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or _slugify(args.summary)
    timeline = _parse_post_mortem_timeline(tuple(args.timeline or ()))
    root_causes = _parse_post_mortem_root_causes(tuple(args.root_cause or ()))
    action_items = _parse_post_mortem_action_items(tuple(args.action_item or ()))
    prevention = _parse_post_mortem_prevention(tuple(args.prevention or ()))
    lessons = [str(item).strip() for item in tuple(args.lesson or ()) if str(item).strip()]
    contributing_factors = [str(item).strip() for item in tuple(args.contributing_factor or ()) if str(item).strip()]
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-incident-post-mortem-packet",
        "executes_actions": False,
        "incident": {
            "id": f"{now.strftime('%Y%m%d-%H%M%S')}-{_slugify(label)}",
            "summary": args.summary,
            "severity": args.severity,
            "impact": args.impact,
            "detection_source": args.detection_source,
        },
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "timeline": timeline,
        "root_causes": root_causes,
        "contributing_factors": contributing_factors,
        "action_items": action_items,
        "prevention_measures": prevention,
        "lessons_learned": lessons,
        "metrics": _post_mortem_static_metrics(timeline, root_causes, action_items, prevention, lessons),
        "recommended_helpers": dict(POST_MORTEM_RECOMMENDED_HELPERS),
        "knowledge_extraction_prompts": [
            "What reusable workflow lesson should be added to FINDINGS.md or DECISIONS.md?",
            "Which prevention measure belongs in tests, guard policy, docs, or Taskmaster follow-up?",
            "Which evidence files should future agents read first if this class of incident recurs?",
            "Does the handoff need a new compaction or Serena memory reference?",
        ],
        "non_goals": list(POST_MORTEM_NON_GOALS),
    }


def _render_incident_post_mortem(report: Dict[str, Any]) -> str:
    incident = report.get("incident", {}) if isinstance(report.get("incident"), dict) else {}
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), dict) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), dict) else {}
    metrics = report.get("metrics", {}) if isinstance(report.get("metrics"), dict) else {}
    lines = [
        "# Incident Post-Mortem Packet",
        "",
        f"- Incident ID: `{incident.get('id')}`",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Severity: {incident.get('severity')}",
        f"- Summary: {incident.get('summary')}",
        f"- Impact: {incident.get('impact')}",
        f"- Detection source: {incident.get('detection_source')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), dict) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), dict) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Timeline",
        "",
        "| Time | Phase | Description | Evidence |",
        "| --- | --- | --- | --- |",
    ]
    for item in report.get("timeline", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| {_md_cell(item.get('timestamp'))} | {_md_cell(item.get('phase'))} | "
            f"{_md_cell(item.get('description'))} | {_md_cell(item.get('evidence') or 'n/a')} |"
        )

    lines.extend(["", "## Root Cause Analysis", ""])
    root_causes = [item for item in report.get("root_causes", []) if isinstance(item, dict)]
    if root_causes:
        for item in root_causes:
            lines.append(f"- `{item.get('category')}`: {item.get('description')}")
    else:
        lines.append("- No root causes supplied.")

    lines.extend(["", "## Contributing Factors", ""])
    contributing = [str(item) for item in report.get("contributing_factors", []) if str(item).strip()]
    if contributing:
        for item in contributing:
            lines.append(f"- {item}")
    else:
        lines.append("- None supplied.")

    lines.extend(
        [
            "",
            "## Action Items",
            "",
            "| ID | Owner | Status | Due | Description |",
            "| --- | --- | --- | --- | --- |",
        ]
    )
    for item in report.get("action_items", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| `{_md_cell(item.get('id'))}` | `{_md_cell(item.get('owner'))}` | "
            f"{_md_cell(item.get('status'))} | {_md_cell(item.get('due') or 'n/a')} | {_md_cell(item.get('description'))} |"
        )

    lines.extend(
        [
            "",
            "## Prevention Measures",
            "",
            "| ID | Status | Measure | Verification Command |",
            "| --- | --- | --- | --- |",
        ]
    )
    for item in report.get("prevention_measures", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| `{_md_cell(item.get('id'))}` | {_md_cell(item.get('status'))} | "
            f"{_md_cell(item.get('description'))} | `{_md_cell(item.get('verification_command'))}` |"
        )

    lines.extend(["", "## Lessons Learned", ""])
    lessons = [str(item) for item in report.get("lessons_learned", []) if str(item).strip()]
    if lessons:
        for item in lessons:
            lines.append(f"- {item}")
    else:
        lines.append("- None supplied.")

    lines.extend(["", "## Static Metrics", ""])
    for key, value in metrics.items():
        lines.append(f"- {key}: {value}")

    lines.extend(["", "## Knowledge Extraction Prompts", ""])
    for prompt in report.get("knowledge_extraction_prompts", []):
        lines.append(f"- {prompt}")

    lines.extend(["", "## Recommended Follow-Up Helpers", ""])
    helpers = report.get("recommended_helpers") if isinstance(report.get("recommended_helpers"), dict) else {}
    for name, command in sorted(helpers.items()):
        lines.append(f"- {name}: `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static post-mortem artifact. It records supplied incident facts and follow-up guidance, but it does not create tickets, send notifications, update dashboards, mutate workflow state, install schedulers, or contact external systems.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_incident_post_mortem(args: argparse.Namespace) -> None:
    report = _build_incident_post_mortem(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_incident_post_mortem(report)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote incident post-mortem report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote incident post-mortem runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


