        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), dict) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Domain Summary",
        "",
        "| Domain | Status | Missing Required | Missing Evidence |",
        "| --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, dict):
            continue
        missing_required = "<br>".join(domain.get("missing_required_paths", []))
        missing_evidence = "<br>".join(domain.get("missing_evidence_paths", []))
        lines.append(
            f"| {_md_cell(domain.get('title'))} | `{_md_cell(domain.get('status'))}` | "
            f"{_md_cell(missing_required or 'None')} | {_md_cell(missing_evidence or 'None')} |"
        )

    lines.extend(["", "## Domain Details", ""])
    for domain in report.get("domains", []):
        if not isinstance(domain, dict):
            continue
        lines.extend(
            [
                f"### {domain.get('title')}",
                "",
                f"- ID: `{domain.get('id')}`",
                f"- Status: `{domain.get('status')}`",
                f"- Source tasks: {', '.join(str(task) for task in domain.get('source_tasks', []))}",
                f"- Purpose: {domain.get('purpose')}",
                f"- Required action: {domain.get('required_action')}",
                "",
                "Refresh commands:",
            ]
        )
        for command in domain.get("refresh_commands", []):
            lines.append(f"- `{command}`")
