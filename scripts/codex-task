        "source_tasks": ("63", "68"),
        "required_paths": (
            "reports/README.md",
            "templates/TOOLS.md",
            "scripts/codex-task",
        ),
        "evidence_paths": (
            "docs/ai/work-tracking/archive/20260513-task63-phase4-documentation-delivery-COMPLETED/reports/phase4-documentation-delivery/phase4-review-2026-05-13.json",
            "docs/ai/work-tracking/archive/20260512-task68-final-validation-suite-COMPLETED/reports/final-validation-suite/",
        ),
        "refresh_commands": (
            "python3 scripts/codex-task documentation phase4-review --label <label> --report-file <phase4.json> --runbook-file <phase4.md>",
            "python3 scripts/codex-task validation final-suite --execute --report-dir reports/final-validation-suite",
        ),
    },
)

KNOWLEDGE_TRANSFER_GUIDANCE: Tuple[str, ...] = (
    "Use `templates/guides/index.md` as the human-facing knowledge hub.",
    "Use `templates/guides/training/foundation-onboarding.md` for onboarding exercises and completion checks.",
    "Use `templates/guides/communication/foundation-communication-templates.md` to capture feedback, milestones, incidents, and follow-up requests as repo-native evidence.",
    "Use `templates/workflows/session/lifecycle.md`, active work-tracking handoff files, and Serena memories for continuity across days and compaction boundaries.",
    "Create follow-up Taskmaster tasks for real knowledge-base platform, video, Q&A, analytics, or succession-plan work instead of claiming those systems inside this static review.",
)


def _knowledge_transfer_path_state(path_value: str) -> Dict[str, Any]:
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    exists = path.exists()
    if path.is_dir():
        kind = "directory"
    elif path.is_file():
        kind = "file"
    else:
        kind = "missing"
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "exists": exists,
        "kind": kind,
    }


def _knowledge_transfer_domain_review(domain: Dict[str, Any]) -> Dict[str, Any]:
    required_paths = [_knowledge_transfer_path_state(path) for path in domain.get("required_paths", ())]
    evidence_paths = [_knowledge_transfer_path_state(path) for path in domain.get("evidence_paths", ())]
    missing_required = [item["path"] for item in required_paths if not item["exists"]]
    missing_evidence = [item["path"] for item in evidence_paths if not item["exists"]]
    if missing_required:
        status = "needs-implementation"
        required_action = "Implement or restore the missing required knowledge-transfer surfaces before claiming readiness."
    elif missing_evidence:
        status = "needs-evidence"
        required_action = "Run the refresh commands and capture the missing evidence before claiming this domain is ready."
    else:
        status = "ready"
        required_action = "Review the linked evidence and keep it referenced from Task 54 closeout."
    return {
        "id": domain["id"],
        "title": domain["title"],
        "purpose": domain["purpose"],
        "status": status,
        "source_tasks": list(domain.get("source_tasks", ())),
        "required_paths": required_paths,
        "evidence_paths": evidence_paths,
        "missing_required_paths": missing_required,
        "missing_evidence_paths": missing_evidence,
        "refresh_commands": list(domain.get("refresh_commands", ())),
        "required_action": required_action,
    }


def _summarise_knowledge_transfer_domains(domains: Sequence[Dict[str, Any]]) -> Dict[str, Any]:
    status_counts = Counter(str(domain.get("status")) for domain in domains)
    missing_required = sum(len(domain.get("missing_required_paths", [])) for domain in domains)
    missing_evidence = sum(len(domain.get("missing_evidence_paths", [])) for domain in domains)
    if missing_required:
        aggregate_status = "needs-implementation"
    elif missing_evidence:
        aggregate_status = "needs-evidence"
    else:
        aggregate_status = "ready"
    return {
        "aggregate_status": aggregate_status,
        "domains": len(domains),
        "ready": status_counts.get("ready", 0),
        "needs_evidence": status_counts.get("needs-evidence", 0),
        "needs_implementation": status_counts.get("needs-implementation", 0),
        "missing_required_paths": missing_required,
        "missing_evidence_paths": missing_evidence,
    }


def _build_knowledge_transfer_review(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "knowledge-transfer-process"
    domains = [_knowledge_transfer_domain_review(dict(domain)) for domain in KNOWLEDGE_TRANSFER_DOMAINS]
    summary = _summarise_knowledge_transfer_domains(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-knowledge-transfer-review",
        "executes_actions": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "domains": domains,
        "out_of_scope_requirements": list(KNOWLEDGE_TRANSFER_OUT_OF_SCOPE),
        "continuity_guidance": list(KNOWLEDGE_TRANSFER_GUIDANCE),
        "non_goals": list(KNOWLEDGE_TRANSFER_NON_GOALS),
    }


def _render_knowledge_transfer_review(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), dict) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), dict) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), dict) else {}
    lines = [
        "# Knowledge Transfer Process Review",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), dict) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), dict) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Domain Summary",
        "",
        "| Domain | Status | Missing Required | Missing Evidence |",
        "| --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, dict):
            continue
        missing_required = "<br>".join(domain.get("missing_required_paths", []))
        missing_evidence = "<br>".join(domain.get("missing_evidence_paths", []))
        lines.append(
            f"| {_md_cell(domain.get('title'))} | `{_md_cell(domain.get('status'))}` | "
            f"{_md_cell(missing_required or 'None')} | {_md_cell(missing_evidence or 'None')} |"
        )

    lines.extend(["", "## Domain Details", ""])
    for domain in report.get("domains", []):
        if not isinstance(domain, dict):
            continue
        lines.extend(
            [
                f"### {domain.get('title')}",
                "",
                f"- ID: `{domain.get('id')}`",
                f"- Status: `{domain.get('status')}`",
                f"- Source tasks: {', '.join(str(task) for task in domain.get('source_tasks', []))}",
                f"- Purpose: {domain.get('purpose')}",
                f"- Required action: {domain.get('required_action')}",
                "",
                "Refresh commands:",
            ]
        )
        for command in domain.get("refresh_commands", []):
            lines.append(f"- `{command}`")
        lines.extend(["", "Evidence paths:"])
        for item in domain.get("evidence_paths", []):
            if isinstance(item, dict):
                lines.append(f"- `{item.get('path')}` ({item.get('kind')})")
        lines.append("")

    lines.extend(
        [
            "## Historical Requirements Reconciled Out Of Scope",
            "",
            "| Historical Requirement | Current Boundary |",
            "| --- | --- |",
        ]
    )
    for item in report.get("out_of_scope_requirements", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| {_md_cell(item.get('historical_requirement'))} | {_md_cell(item.get('current_boundary'))} |"
        )

    lines.extend(["", "## Continuity Guidance", ""])
    for item in report.get("continuity_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static knowledge-transfer review artifact. It composes existing documentation, training, troubleshooting, communication, continuity, handoff, and validation evidence, but it does not create hosted knowledge-base software, video workflows, Q&A services, analytics, notifications, or external succession-planning systems.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_knowledge_transfer_review(args: argparse.Namespace) -> None:
    report = _build_knowledge_transfer_review(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_knowledge_transfer_review(report)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote knowledge transfer review to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote knowledge transfer runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


SUCCESS_METRICS_NON_GOALS: Tuple[str, ...] = (
    "No React/Vue UI, hosted dashboard, WebSocket, database, time-series storage, Prometheus/Grafana integration, analytics backend, or external service is created or contacted.",
    "No predictive model, machine-learning service, alert delivery, notification, scheduler, ticket, or communication system is created or contacted.",
    "No source report, Taskmaster, session, plan, work-tracking, Git, template, scanner, or external state is mutated beyond requested success metrics artifacts.",
)

SUCCESS_METRICS_STATUS_POINTS: Dict[str, int] = {
    "pass": 100,
    "warn": 50,
    "missing": 50,
    "fail": 0,
}


def _success_metrics_path(path_value: Path | str) -> Path:
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    return path


def _success_metrics_latest(pattern: str) -> Optional[Path]:
    candidates = sorted(REPO_STRUCTURE.work_tracking_archive_root.glob(pattern))
    return candidates[-1] if candidates else None


def _success_metrics_load_json(path_value: Path | str) -> Dict[str, Any]:
    path = _success_metrics_path(path_value)
    payload: Optional[Mapping[str, Any]] = None
    message = "Loaded successfully."
    status = "loaded"
    if not path.exists():
        return {
            "path": _relative_to_root(path, REPO_ROOT),
            "exists": False,
            "status": "missing",
            "payload": None,
            "message": "Source report is missing.",
        }
    try:
        loaded = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        return {
            "path": _relative_to_root(path, REPO_ROOT),
            "exists": True,
            "status": "invalid",
            "payload": None,
            "message": f"Source report is not valid JSON: {exc}",
        }
    if not isinstance(loaded, Mapping):
        status = "invalid"
        message = "Source report payload must be a JSON object."
    else:
        payload = loaded
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "exists": True,
        "status": status,
        "payload": payload,
        "message": message,
    }


def _success_metrics_status(value: object) -> str:
    text = str(value or "missing").strip().lower()
    aliases = {
        "ok": "pass",
        "passed": "pass",
        "success": "pass",
        "ready": "pass",
        "warning": "warn",
        "warnings": "warn",
        "needs-evidence": "warn",
        "needs_evidence": "warn",
        "missing": "missing",
        "error": "fail",
        "failed": "fail",
        "failure": "fail",
        "needs-implementation": "fail",
        "needs_implementation": "fail",
    }
    text = aliases.get(text, text)
    if text in SUCCESS_METRICS_STATUS_POINTS:
        return text
    return "warn"


def _success_metrics_severity(status: str) -> str:
    if status == "fail":
        return "error"
    if status in {"warn", "missing"}:
        return "warning"
    return "info"


def _success_metrics_domain(
    *,
    domain_id: str,
    title: str,
    value: object,
    unit: str,
    target: str,
    status: str,
    evidence: str,
    message: str,
    refresh_command: str,
    details: Optional[Mapping[str, Any]] = None,
) -> Dict[str, Any]:
    normalised = _success_metrics_status(status)
    return {
        "id": domain_id,
        "title": title,
        "value": value,
        "unit": unit,
        "target": target,
        "status": normalised,
        "severity": _success_metrics_severity(normalised),
        "evidence": evidence,
        "message": message,
        "refresh_command": refresh_command,
        "details": dict(details or {}),
    }


def _build_success_taskmaster_domain() -> Dict[str, Any]:
    snapshot = _taskmaster_snapshot()
    summary = snapshot.get("summary") if isinstance(snapshot.get("summary"), Mapping) else {}
    status_counts = summary.get("status_counts") if isinstance(summary.get("status_counts"), Mapping) else {}
    total_tasks = int(summary.get("tasks") or 0)
    done_tasks = int(status_counts.get("done", 0) or 0)
    invalid_refs = int(summary.get("invalid_refs") or 0)
    completion_pct = round((done_tasks / total_tasks) * 100, 2) if total_tasks else None
    if not snapshot.get("exists"):
        status = "missing"
        message = "Taskmaster task database is missing."
    elif invalid_refs:
        status = "fail"
        message = f"{invalid_refs} invalid Taskmaster dependency reference(s) block success claims."
    else:
        status = "pass"
        message = "Taskmaster dependency graph is healthy."
    return _success_metrics_domain(
        domain_id="taskmaster-health",
        title="Taskmaster health",
        value=completion_pct,
        unit="percent done",
        target="0 invalid dependency refs",
        status=status,
        evidence=str(snapshot.get("path")),
        message=message,
        refresh_command="python3 scripts/codex-task taskmaster health",
        details={
            "tag": snapshot.get("tag"),
            "summary": summary,
            "invalid_refs": snapshot.get("invalid_refs") or [],
        },
    )


def _build_success_workflow_domain() -> Dict[str, Any]:
    workflow = _workflow_snapshot()
    current_session = workflow.get("current_session") if isinstance(workflow.get("current_session"), Mapping) else {}
    current_plan = workflow.get("current_plan") if isinstance(workflow.get("current_plan"), Mapping) else {}
    active = workflow.get("active_work_tracking") if isinstance(workflow.get("active_work_tracking"), list) else []
    blockers = []
    if not current_session.get("resolved"):
        blockers.append("sessions/current missing")
    if not current_plan.get("resolved"):
        blockers.append("plans/current missing")
    if len(active) != 1:
        blockers.append(f"expected 1 active work-tracking folder, found {len(active)}")
    status = "pass" if not blockers else "warn"
    message = "Workflow pointers are aligned for the active task." if not blockers else "; ".join(blockers)
    return _success_metrics_domain(
        domain_id="workflow-state",
        title="Workflow state",
        value=len(active),
        unit="active folders",
        target="1 active task folder with current session and plan",
        status=status,
        evidence=str(current_session.get("resolved") or current_session.get("path")),
        message=message,
        refresh_command="python3 scripts/codex-task work-tracking audit",
        details=workflow,
    )


def _build_success_template_metrics_domain() -> Dict[str, Any]:
    path = REPO_STRUCTURE.metrics_report_dir / "latest.json"
    source = _success_metrics_load_json(path)
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    if source["status"] == "missing":
        return _success_metrics_domain(
            domain_id="template-metrics",
            title="Template metrics",
            value=None,
            unit="coverage percent",
            target="100% metadata coverage and 0 drift findings",
            status="missing",
            evidence=str(source["path"]),
            message="Template metrics report is missing.",
            refresh_command="python3 scripts/template-metrics-dashboard",
            details=source,
        )
    if source["status"] == "invalid":
        return _success_metrics_domain(
            domain_id="template-metrics",
            title="Template metrics",
            value=None,
            unit="coverage percent",
            target="100% metadata coverage and 0 drift findings",
            status="fail",
            evidence=str(source["path"]),
            message=str(source["message"]),
            refresh_command="python3 scripts/template-metrics-dashboard",
            details=source,
        )
    metadata = payload.get("template_metadata") if isinstance(payload.get("template_metadata"), Mapping) else {}
    drift = payload.get("drift") if isinstance(payload.get("drift"), Mapping) else {}
    coverage = metadata.get("coverage_pct")
    drifted = int(metadata.get("drifted_file_count", 0) or 0)
    finding_count = drift.get("finding_count")
    finding_value = int(finding_count or 0) if finding_count is not None else 0
    status = "pass" if drifted == 0 and finding_value == 0 else "warn"
    message = "Template metadata and drift metrics are clean." if status == "pass" else "Template metric warnings require review."
    return _success_metrics_domain(
        domain_id="template-metrics",
        title="Template metrics",
        value=coverage,
        unit="coverage percent",
        target="100% metadata coverage and 0 drift findings",
        status=status,
        evidence=str(source["path"]),
        message=message,
        refresh_command="python3 scripts/codex-task report generate --kind metrics",
        details={"template_metadata": metadata, "drift": drift},
    )


def _build_success_json_status_domain(
    *,
    domain_id: str,
    title: str,
    path: Path,
    target: str,
    refresh_command: str,
    value_field: str | None = None,
) -> Dict[str, Any]:
    source = _success_metrics_load_json(path)
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    if source["status"] == "missing":
        return _success_metrics_domain(
            domain_id=domain_id,
            title=title,
            value=None,
            unit="status",
            target=target,
            status="missing",
            evidence=str(source["path"]),
            message=f"{title} source report is missing.",
            refresh_command=refresh_command,
            details=source,
        )
    if source["status"] == "invalid":
        return _success_metrics_domain(
            domain_id=domain_id,
            title=title,
            value=None,
            unit="status",
            target=target,
            status="fail",
            evidence=str(source["path"]),
            message=str(source["message"]),
            refresh_command=refresh_command,
            details=source,
        )
    status = _success_metrics_status(payload.get("status") or payload.get("aggregate_status"))
    value = payload.get(value_field) if value_field else (payload.get("status") or payload.get("aggregate_status"))
    message = f"{title} source status is `{value}`."
    return _success_metrics_domain(
        domain_id=domain_id,
        title=title,
        value=value,
        unit="status",
        target=target,
        status=status,
        evidence=str(source["path"]),
        message=message,
        refresh_command=refresh_command,
        details={"source_status": payload.get("status"), "source_aggregate_status": payload.get("aggregate_status"), "generated_at": payload.get("generated_at") or payload.get("created_at")},
    )


def _build_success_latest_artifact_domain(
    *,
    domain_id: str,
    title: str,
    pattern: str,
    target: str,
    refresh_command: str,
    status_field: str = "aggregate_status",
) -> Dict[str, Any]:
    latest = _success_metrics_latest(pattern)
    if latest is None:
        return _success_metrics_domain(
            domain_id=domain_id,
            title=title,
            value=None,
            unit="artifact",
            target=target,
            status="missing",
            evidence=pattern,
            message=f"{title} evidence artifact is missing.",
            refresh_command=refresh_command,
            details={"pattern": pattern},
        )
    source = _success_metrics_load_json(latest)
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    status = "pass"
    value: object = "present"
    if source["status"] == "invalid":
        status = "fail"
        value = "invalid-json"
    elif status_field in payload:
        value = payload.get(status_field)
        status = _success_metrics_status(value)
    return _success_metrics_domain(
        domain_id=domain_id,
        title=title,
        value=value,
        unit="artifact",
        target=target,
        status=status,
        evidence=str(source["path"]),
        message=f"{title} evidence found at `{source['path']}`.",
        refresh_command=refresh_command,
        details={"pattern": pattern, "source": {key: source[key] for key in ("path", "exists", "status", "message")}},
    )


def _build_success_metrics_domains() -> List[Dict[str, Any]]:
    return [
        _build_success_taskmaster_domain(),
        _build_success_workflow_domain(),
        _build_success_template_metrics_domain(),
        _build_success_json_status_domain(
            domain_id="migration-health",
            title="Migration health",
            path=REPO_STRUCTURE.migration_health_report_dir / "latest.json",
            target="migration health status pass",
            refresh_command="python3 scripts/codex-task report generate --kind migration-health",
        ),
        _build_success_json_status_domain(
            domain_id="template-performance",
            title="Template performance",
            path=REPO_STRUCTURE.performance_report_dir / "latest.json",
            target="performance status pass",
            refresh_command="python3 scripts/template-performance-harness --strict",
        ),
        _build_success_latest_artifact_domain(
            domain_id="final-validation",
            title="Final validation",
            pattern="*-task68-final-validation-suite-COMPLETED/reports/final-validation-suite/*final-validation-suite.json",
            target="latest final validation packet exists",
            refresh_command="python3 scripts/codex-task validation final-suite --execute --report-dir reports/final-validation-suite",
        ),
        _build_success_latest_artifact_domain(
            domain_id="knowledge-transfer",
            title="Knowledge transfer",
            pattern="*-task54-knowledge-transfer-process-COMPLETED/reports/knowledge-transfer-process/knowledge-transfer-review-*.json",
            target="knowledge transfer review ready",
            refresh_command="python3 scripts/codex-task knowledge transfer-review --report-file reports/knowledge-transfer-process/latest.json --runbook-file reports/knowledge-transfer-process/latest.md",
        ),
    ]


def _summarise_success_metrics(domains: Sequence[Mapping[str, Any]]) -> Dict[str, Any]:
    total = len(domains)
    passed = sum(1 for domain in domains if domain.get("status") == "pass")
    warnings = sum(1 for domain in domains if domain.get("status") in {"warn", "missing"})
    failures = sum(1 for domain in domains if domain.get("status") == "fail")
    missing = sum(1 for domain in domains if domain.get("status") == "missing")
    points = sum(SUCCESS_METRICS_STATUS_POINTS.get(str(domain.get("status")), 0) for domain in domains)
    score = round(points / total, 2) if total else 0.0
    if failures:
        aggregate_status = "fail"
    elif warnings:
        aggregate_status = "warn"
    else:
        aggregate_status = "pass"
    return {
        "aggregate_status": aggregate_status,
        "success_score_pct": score,
        "total_domains": total,
        "passed": passed,
        "warnings": warnings,
        "failures": failures,
        "missing": missing,
    }


def _success_metrics_refresh_commands(domains: Sequence[Mapping[str, Any]]) -> List[str]:
    commands: List[str] = []
    for domain in domains:
        command = domain.get("refresh_command")
        if isinstance(command, str) and command and command not in commands:
            commands.append(command)
    commands.extend(
        [
            "python3 scripts/codex-task success metrics --report-file reports/success-metrics/latest.json --runbook-file reports/success-metrics/latest.md",
            "python3 scripts/codex-guard validate --include-untracked",
        ]
    )
    return commands


def _build_success_metrics_report(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "success-metrics"
    domains = _build_success_metrics_domains()
    summary = _summarise_success_metrics(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-success-metrics-dashboard",
        "executes_actions": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "domains": domains,
        "recommended_refresh_commands": _success_metrics_refresh_commands(domains),
        "non_goals": list(SUCCESS_METRICS_NON_GOALS),
    }


def _render_success_metrics_report(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    lines = [
        "# Success Metrics Dashboard",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        f"- Success score: {summary.get('success_score_pct')}%",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Summary",
        "",
        f"- Total domains: {summary.get('total_domains')}",
        f"- Passed: {summary.get('passed')}",
        f"- Warnings: {summary.get('warnings')}",
        f"- Failures: {summary.get('failures')}",
        f"- Missing: {summary.get('missing')}",
        "",
        "## Success Domains",
        "",
        "| Domain | Value | Target | Status | Severity | Evidence |",
        "| --- | --- | --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        value = domain.get("value")
        rendered_value = "n/a" if value is None else value
        lines.append(
            f"| {_md_cell(domain.get('title'))} | {_md_cell(rendered_value)} {_md_cell(domain.get('unit'))} | "
            f"{_md_cell(domain.get('target'))} | `{_md_cell(domain.get('status'))}` | "
            f"`{_md_cell(domain.get('severity'))}` | `{_md_cell(domain.get('evidence'))}` |"
        )

    lines.extend(["", "## Domain Notes", ""])
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        lines.extend(
            [
                f"### {domain.get('title')}",
                "",
                f"- ID: `{domain.get('id')}`",
                f"- Message: {domain.get('message')}",
                f"- Refresh command: `{domain.get('refresh_command')}`",
                "",
            ]
        )

    lines.extend(["## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static success metrics artifact. It composes existing evidence and requested output files only; it does not create a live dashboard, database, predictive service, scheduler, alert, notification, or external integration.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_success_metrics(args: argparse.Namespace) -> None:
    report = _build_success_metrics_report(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_success_metrics_report(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] == "fail":
            raise TaskError("Success metrics aggregate status is fail")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote success metrics report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote success metrics runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] == "fail":
        raise TaskError("Success metrics aggregate status is fail")


STAKEHOLDER_REPORTING_NON_GOALS: Tuple[str, ...] = (
    "No hosted executive dashboard, BI workspace, database, warehouse, analytics backend, or external reporting platform is created or contacted.",
    "No scheduler, cron job, daemon, background worker, email, Slack, chat, webhook, ticket, or notification delivery is created or contacted.",
    "No ROI, cost-benefit, risk, or compliance values are fabricated when source evidence is absent.",
    "No Taskmaster, session, plan, work-tracking, Git, report source, template, or external state is mutated beyond requested stakeholder report artifacts.",
)

STAKEHOLDER_REPORTING_COMMUNICATION_GUIDANCE: Tuple[str, ...] = (
    "Lead with the aggregate stakeholder signal and list warning domains before implementation detail.",
    "Use missing-source warnings as refresh prompts, not as synthetic pass/fail claims.",
    "Route distribution through existing communication templates; this command does not send stakeholder notifications.",
    "Attach the JSON and Markdown packet to PR, release, or handoff evidence when sharing status outside the repo.",
)


def _stakeholder_report_status(value: object) -> str:
    return _success_metrics_status(value)


def _stakeholder_report_domain(
    *,
    domain_id: str,
    title: str,
    audience: str,
    status: str,
    evidence: str,
    message: str,
    refresh_command: str,
    details: Optional[Mapping[str, Any]] = None,
) -> Dict[str, Any]:
    normalised = _stakeholder_report_status(status)
    return {
        "id": domain_id,
        "title": title,
        "audience": audience,
        "status": normalised,
        "severity": _success_metrics_severity(normalised),
        "evidence": evidence,
        "message": message,
        "refresh_command": refresh_command,
        "details": dict(details or {}),
    }


def _build_stakeholder_taskmaster_domain() -> Dict[str, Any]:
    snapshot = _taskmaster_snapshot()
    summary = snapshot.get("summary") if isinstance(snapshot.get("summary"), Mapping) else {}
    status_counts = summary.get("status_counts") if isinstance(summary.get("status_counts"), Mapping) else {}
    total_tasks = int(summary.get("tasks") or 0)
    done_tasks = int(status_counts.get("done", 0) or 0)
    pending_tasks = int(status_counts.get("pending", 0) or 0)
    invalid_refs = int(summary.get("invalid_refs") or 0)
    if not snapshot.get("exists"):
        status = "missing"
        message = "Taskmaster database is missing; delivery health cannot be reported."
    elif invalid_refs:
        status = "fail"
        message = f"{invalid_refs} invalid Taskmaster dependency reference(s) require correction."
    else:
        status = "pass"
        message = f"{done_tasks}/{total_tasks} parent tasks done; {pending_tasks} pending; dependency graph healthy."
    return _stakeholder_report_domain(
        domain_id="taskmaster-delivery-health",
        title="Taskmaster delivery health",
        audience="Delivery owners and project sponsors",
        status=status,
        evidence=str(snapshot.get("path")),
        message=message,
        refresh_command="python3 scripts/codex-task taskmaster health",
        details={"summary": summary, "invalid_refs": snapshot.get("invalid_refs") or []},
    )


def _build_stakeholder_workflow_domain() -> Dict[str, Any]:
    workflow = _workflow_snapshot()
    current_session = workflow.get("current_session") if isinstance(workflow.get("current_session"), Mapping) else {}
    current_plan = workflow.get("current_plan") if isinstance(workflow.get("current_plan"), Mapping) else {}
    active = workflow.get("active_work_tracking") if isinstance(workflow.get("active_work_tracking"), list) else []
    blockers = []
    if not current_session.get("resolved"):
        blockers.append("sessions/current missing")
    if not current_plan.get("resolved"):
        blockers.append("plans/current missing")
    if len(active) != 1:
        blockers.append(f"expected 1 active work-tracking folder, found {len(active)}")
    status = "pass" if not blockers else "warn"
    message = "Workflow pointers are aligned for the active task." if not blockers else "; ".join(blockers)
    return _stakeholder_report_domain(
        domain_id="workflow-compliance",
        title="Workflow compliance",
        audience="Maintainers and reviewers",
        status=status,
        evidence=str(current_session.get("resolved") or current_session.get("path")),
        message=message,
        refresh_command="python3 scripts/codex-task work-tracking audit",
        details=workflow,
    )


def _stakeholder_latest_packet_domain(
    *,
    domain_id: str,
    title: str,
    audience: str,
    pattern: str,
    refresh_command: str,
    status_fields: Sequence[str] = ("summary.aggregate_status", "aggregate_status", "status"),
    value_fields: Sequence[str] = (),
) -> Dict[str, Any]:
    latest = _success_metrics_latest(pattern)
    if latest is None:
        return _stakeholder_report_domain(
            domain_id=domain_id,
            title=title,
            audience=audience,
            status="missing",
            evidence=pattern,
            message=f"{title} source packet is missing.",
            refresh_command=refresh_command,
            details={"pattern": pattern},
        )

    source = _success_metrics_load_json(latest)
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    if source["status"] == "invalid":
        return _stakeholder_report_domain(
            domain_id=domain_id,
            title=title,
            audience=audience,
            status="fail",
            evidence=str(source["path"]),
            message=str(source["message"]),
            refresh_command=refresh_command,
            details=source,
        )

    def get_nested(mapping: Mapping[str, Any], dotted: str) -> object:
        current: object = mapping
        for part in dotted.split("."):
            if not isinstance(current, Mapping):
                return None
            current = current.get(part)
        return current

    status_value: object = None
    for field in status_fields:
        status_value = get_nested(payload, field)
        if status_value is not None:
            break
    detail_values = {field: get_nested(payload, field) for field in value_fields}
    status = _stakeholder_report_status(status_value)
    message = f"{title} source status is `{status_value}`."
    return _stakeholder_report_domain(
        domain_id=domain_id,
        title=title,
        audience=audience,
        status=status,
        evidence=str(source["path"]),
        message=message,
        refresh_command=refresh_command,
        details={
            "pattern": pattern,
            "source": {key: source[key] for key in ("path", "exists", "status", "message")},
            "status_value": status_value,
            "values": detail_values,
        },
    )


def _build_stakeholder_communication_domain() -> Dict[str, Any]:
    path = REPO_ROOT / "templates/guides/communication/foundation-communication-templates.md"
    status = "pass" if path.exists() else "missing"
    message = "Communication templates are available for stakeholder distribution." if path.exists() else "Communication template evidence is missing."
    return _stakeholder_report_domain(
        domain_id="stakeholder-communication-guidance",
        title="Stakeholder communication guidance",
        audience="Project sponsors and downstream adopters",
        status=status,
        evidence=_relative_to_root(path, REPO_ROOT),
        message=message,
        refresh_command="Review templates/guides/communication/foundation-communication-templates.md",
        details={"exists": path.exists()},
    )


def _build_stakeholder_report_domains() -> List[Dict[str, Any]]:
    domains = [
        _build_stakeholder_taskmaster_domain(),
        _build_stakeholder_workflow_domain(),
        _stakeholder_latest_packet_domain(
            domain_id="success-metrics",
            title="Success metrics",
            audience="Executive sponsors",
            pattern="*-task67-success-metrics-dashboard-COMPLETED/reports/success-metrics-dashboard/success-metrics-*-final.json",
            refresh_command="python3 scripts/codex-task success metrics --report-file reports/success-metrics/latest.json --runbook-file reports/success-metrics/latest.md",
            status_fields=("summary.aggregate_status",),
            value_fields=("summary.success_score_pct", "summary.missing"),
        ),
        _stakeholder_latest_packet_domain(
            domain_id="knowledge-transfer",
            title="Knowledge transfer",
            audience="Adopters and maintainers",
            pattern="*-task54-knowledge-transfer-process-COMPLETED/reports/knowledge-transfer-process/knowledge-transfer-review-*.json",
            refresh_command="python3 scripts/codex-task knowledge transfer-review --report-file reports/knowledge-transfer-process/latest.json --runbook-file reports/knowledge-transfer-process/latest.md",
            status_fields=("summary.aggregate_status",),
            value_fields=("summary.ready", "summary.needs_evidence", "summary.needs_implementation"),
        ),
        _stakeholder_latest_packet_domain(
            domain_id="deprecation-governance",
            title="Deprecation governance",
            audience="Governance reviewers",
            pattern="*-task66-deprecation-management-COMPLETED/reports/deprecation-management/deprecation-review-*.json",
            refresh_command="python3 scripts/codex-task deprecation review --report-file reports/deprecation-management/latest.json --runbook-file reports/deprecation-management/latest.md",
            status_fields=("summary.aggregate_status",),
            value_fields=("summary.ready", "summary.needs_evidence", "summary.needs_implementation"),
        ),
        _build_stakeholder_communication_domain(),
    ]
    warning_domains = [domain["id"] for domain in domains if domain.get("status") in {"warn", "missing"}]
    failing_domains = [domain["id"] for domain in domains if domain.get("status") == "fail"]
    if failing_domains:
        status = "fail"
        message = f"Blocking stakeholder risks found: {', '.join(failing_domains)}."
    elif warning_domains:
        status = "warn"
        message = f"Stakeholder report has warning domains: {', '.join(warning_domains)}."
    else:
        status = "pass"
        message = "No blocking stakeholder reporting risks found in current evidence."
    domains.append(
        _stakeholder_report_domain(
            domain_id="risk-compliance-summary",
            title="Risk and compliance summary",
            audience="Sponsors, governance, and release reviewers",
            status=status,
            evidence="computed from stakeholder report domains",
            message=message,
            refresh_command="python3 scripts/codex-task stakeholder report --report-file reports/stakeholder-reporting/latest.json --runbook-file reports/stakeholder-reporting/latest.md",
            details={"warning_domains": warning_domains, "failing_domains": failing_domains},
        )
    )
    return domains


def _summarise_stakeholder_report(domains: Sequence[Mapping[str, Any]]) -> Dict[str, Any]:
    total = len(domains)
    passed = sum(1 for domain in domains if domain.get("status") == "pass")
    warnings = sum(1 for domain in domains if domain.get("status") in {"warn", "missing"})
    failures = sum(1 for domain in domains if domain.get("status") == "fail")
    missing = sum(1 for domain in domains if domain.get("status") == "missing")
    if failures:
        aggregate_status = "fail"
        stakeholder_signal = "blocked"
    elif warnings:
        aggregate_status = "warn"
        stakeholder_signal = "needs-refresh"
    else:
        aggregate_status = "pass"
        stakeholder_signal = "ready-to-share"
    return {
        "aggregate_status": aggregate_status,
        "stakeholder_signal": stakeholder_signal,
        "total_domains": total,
        "passed": passed,
        "warnings": warnings,
        "failures": failures,
        "missing": missing,
    }


def _stakeholder_refresh_commands(domains: Sequence[Mapping[str, Any]]) -> List[str]:
    commands: List[str] = []

    def add_command(command: object) -> None:
        if isinstance(command, str) and command and command not in commands:
            commands.append(command)

    for domain in domains:
        add_command(domain.get("refresh_command"))
    add_command("python3 scripts/codex-task stakeholder report --report-file reports/stakeholder-reporting/latest.json --runbook-file reports/stakeholder-reporting/latest.md")
    add_command("python3 scripts/codex-guard validate --include-untracked")
    return commands


def _stakeholder_messages(summary: Mapping[str, Any], domains: Sequence[Mapping[str, Any]]) -> List[Dict[str, str]]:
    warning_titles = [
        str(domain.get("title"))
        for domain in domains
        if domain.get("id") != "risk-compliance-summary" and domain.get("status") in {"warn", "missing", "fail"}
    ]
    if warning_titles:
        risk_text = "Refresh or address these domains before broad stakeholder distribution: " + ", ".join(warning_titles)
    else:
        risk_text = "All stakeholder report domains are ready based on current static evidence."
    return [
        {
            "id": "executive-summary",
            "audience": "Executive sponsors",
            "message": f"Stakeholder report signal is {summary.get('stakeholder_signal')} with aggregate status {summary.get('aggregate_status')}.",
        },
        {
            "id": "risk-summary",
            "audience": "Governance reviewers",
            "message": risk_text,
        },
        {
            "id": "distribution-guidance",
            "audience": "Maintainers",
            "message": "Share the Markdown packet with the linked evidence paths; use existing communication templates for delivery language.",
        },
    ]


def _build_stakeholder_report(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "stakeholder-reporting"
    domains = _build_stakeholder_report_domains()
    summary = _summarise_stakeholder_report(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-stakeholder-reporting-packet",
        "executes_actions": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "domains": domains,
        "stakeholder_messages": _stakeholder_messages(summary, domains),
        "communication_guidance": list(STAKEHOLDER_REPORTING_COMMUNICATION_GUIDANCE),
        "recommended_refresh_commands": _stakeholder_refresh_commands(domains),
        "non_goals": list(STAKEHOLDER_REPORTING_NON_GOALS),
    }


def _render_stakeholder_report(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    lines = [
        "# Stakeholder Reporting Packet",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        f"- Stakeholder signal: {summary.get('stakeholder_signal')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Summary",
        "",
        f"- Total domains: {summary.get('total_domains')}",
        f"- Passed: {summary.get('passed')}",
        f"- Warnings: {summary.get('warnings')}",
        f"- Failures: {summary.get('failures')}",
        f"- Missing: {summary.get('missing')}",
        "",
        "## Stakeholder Domains",
        "",
        "| Domain | Audience | Status | Severity | Evidence |",
        "| --- | --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        lines.append(
            f"| {_md_cell(domain.get('title'))} | {_md_cell(domain.get('audience'))} | "
            f"`{_md_cell(domain.get('status'))}` | `{_md_cell(domain.get('severity'))}` | "
            f"`{_md_cell(domain.get('evidence'))}` |"
        )

    lines.extend(["", "## Domain Notes", ""])
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        lines.extend(
            [
                f"### {domain.get('title')}",
                "",
                f"- ID: `{domain.get('id')}`",
                f"- Audience: {domain.get('audience')}",
                f"- Message: {domain.get('message')}",
                f"- Refresh command: `{domain.get('refresh_command')}`",
                "",
            ]
        )

    lines.extend(["## Stakeholder Messages", ""])
    for message in report.get("stakeholder_messages", []):
        if not isinstance(message, Mapping):
            continue
        lines.extend(
            [
                f"### {message.get('id')}",
                "",
                f"- Audience: {message.get('audience')}",
                f"- Message: {message.get('message')}",
                "",
            ]
        )

    lines.extend(["## Communication Guidance", ""])
    for item in report.get("communication_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static stakeholder reporting artifact. It composes existing evidence and requested output files only; it does not create a live executive dashboard, scheduler, notification system, BI backend, or external reporting integration.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_stakeholder_report(args: argparse.Namespace) -> None:
    report = _build_stakeholder_report(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_stakeholder_report(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] == "fail":
            raise TaskError("Stakeholder report aggregate status is fail")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote stakeholder report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote stakeholder runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] == "fail":
        raise TaskError("Stakeholder report aggregate status is fail")


ENHANCEMENT_PLANNING_NON_GOALS: Tuple[str, ...] = (
    "No automatic compaction trigger, scheduler, daemon, background monitor, or context watcher is installed.",
    "No semantic-search service, vector database, indexer daemon, or replacement for registry/rg discovery is created.",
    "No AI-assisted template generation calls an external model, creates new templates, or mutates template sources.",
    "No optional MCP server is installed, enabled, or configured by this command.",
    "No performance optimization is applied without measured bottleneck evidence.",
    "No Taskmaster tasks, sessions, plans, work tracking, Git state, report sources, templates, or external systems are mutated beyond requested enhancement planning artifacts.",
)

ENHANCEMENT_PLANNING_GUIDANCE: Tuple[str, ...] = (
    "Treat ready candidates as evidence-backed next-task options, not automatic implementation authority.",
    "Treat planned candidates as backlog concepts that require their own Taskmaster task and scope reconciliation before code changes.",
    "Refresh source reports before sharing the plan externally or promoting a candidate to implementation.",
    "Prefer static packet, guard, and helper improvements over live services until a measured repository gap proves the need.",
)

ENHANCEMENT_PRIORITY_ORDER: Dict[str, int] = {"high": 0, "medium": 1, "low": 2}
ENHANCEMENT_READINESS_ORDER: Dict[str, int] = {"ready": 0, "needs-evidence": 1, "planned": 2, "blocked": 3}


def _enhancement_path_state(path_value: str) -> Dict[str, Any]:
    path = REPO_ROOT / path_value
    if path.is_dir():
        kind = "directory"
    elif path.is_file():
        kind = "file"
    else:
        kind = "missing"
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "exists": path.exists(),
        "kind": kind,
    }


def _enhancement_candidate(definition: Mapping[str, Any]) -> Dict[str, Any]:
    evidence_paths = [_enhancement_path_state(str(path)) for path in definition.get("evidence_paths", ())]
    missing = [item["path"] for item in evidence_paths if not item["exists"]]
    planned = bool(definition.get("planned"))
    blocked = bool(definition.get("blocked"))
    if blocked:
        readiness = "blocked"
        required_action = str(definition.get("blocked_action") or "Resolve blocker before this candidate can be planned.")
    elif missing:
        readiness = "needs-evidence"
        required_action = "Refresh or add the missing evidence before promoting this candidate."
    elif planned:
        readiness = "planned"
        required_action = str(definition.get("planned_action") or "Create a dedicated Taskmaster task before implementation.")
    else:
        readiness = "ready"
        required_action = str(definition.get("ready_action") or "Ready for a scoped follow-up task.")
    return {
        "id": definition["id"],
        "title": definition["title"],
        "area": definition["area"],
        "priority": definition["priority"],
        "readiness": readiness,
        "evidence_paths": evidence_paths,
        "missing_evidence_paths": missing,
        "refresh_commands": list(definition.get("refresh_commands", ())),
        "required_action": required_action,
        "non_goal_boundary": definition["non_goal_boundary"],
        "rationale": definition["rationale"],
    }


