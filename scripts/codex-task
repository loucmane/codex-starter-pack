            refresh_command="python3 scripts/codex-task taskmaster health",
            details={"summary": taskmaster_summary, "invalid_refs": taskmaster.get("invalid_refs") or []},
        ),
        _celebration_domain(
            domain_id="success-metrics",
            title="Success metrics packet",
            purpose="Support celebration claims with the latest static success scorecard.",
            evidence_paths=(
                "docs/ai/work-tracking/archive/20260514-task67-success-metrics-dashboard-COMPLETED/reports/success-metrics-dashboard/success-metrics-2026-05-14-final.json",
            ),
            refresh_command="python3 scripts/codex-task success metrics --report-file reports/success-metrics/latest.json --runbook-file reports/success-metrics/latest.md",
        ),
        _celebration_domain(
            domain_id="stakeholder-reporting",
            title="Stakeholder reporting packet",
            purpose="Reuse stakeholder-safe messages, risks, and communication framing.",
            evidence_paths=(
                "docs/ai/work-tracking/archive/20260514-task73-stakeholder-reporting-COMPLETED/reports/stakeholder-reporting/stakeholder-report-2026-05-14-final.json",
                "templates/guides/communication/foundation-communication-templates.md",
            ),
            refresh_command="python3 scripts/codex-task stakeholder report --report-file reports/stakeholder-reporting/latest.json --runbook-file reports/stakeholder-reporting/latest.md",
        ),
        _celebration_domain(
            domain_id="phase5-roadmap",
            title="Phase 5 enhancement roadmap",
            purpose="Connect celebration material to grounded next-step roadmap candidates.",
            evidence_paths=(
                "docs/ai/work-tracking/archive/20260514-task69-phase5-enhancement-planning-COMPLETED/reports/phase5-enhancement-planning/phase5-plan-2026-05-14-final.json",
