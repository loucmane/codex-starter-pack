            {"title": "Retrospective prompts and next commitments", "duration_minutes": 15, "evidence_domain": "work-tracking-archive"},
        ],
        "demo_candidates": [
            {
                "title": "Generate success metrics packet",
                "command": "python3 scripts/codex-task success metrics --report-file reports/success-metrics/latest.json --runbook-file reports/success-metrics/latest.md",
