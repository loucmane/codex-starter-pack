def _build_cleanup_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "cleanup-automation"
    domains = _build_cleanup_domains()
    summary = _summarise_cleanup_domains(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-non-destructive-cleanup-planning-packet",
        "executes_actions": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "domains": domains,
        "cleanup_candidates": _cleanup_candidates(),
        "approval_gates": list(CLEANUP_APPROVAL_GATES),
        "dry_run_checks": list(CLEANUP_DRY_RUN_CHECKS),
        "backup_rollback_guidance": [
            "Capture `python3 scripts/codex-task rollback checkpoint` before risky multi-file cleanup.",
            "Use `python3 scripts/codex-task rollback plan` to render recovery guidance from the checkpoint.",
            "Prefer targeted `git restore -- <path>` only after review; never use `git reset --hard` as a default cleanup path.",
            "Keep scanner backup directories until the related PR is merged and the archive commit is pushed.",
        ],
        "metrics_checklist": list(CLEANUP_METRICS_CHECKLIST),
        "manual_notification_guidance": [
            "Use communication templates to draft cleanup notices when stakeholders need review.",
            "Do not send notifications from this command; record draft or decision in work tracking.",
            "Mention exact candidate IDs, evidence paths, and verification commands in any PR description.",
        ],
        "recommended_refresh_commands": _cleanup_refresh_commands(domains),
        "planning_guidance": list(CLEANUP_AUTOMATION_GUIDANCE),
        "non_goals": list(CLEANUP_AUTOMATION_NON_GOALS),
    }


def _render_cleanup_plan(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    lines = [
        "# Cleanup Automation Planning Packet",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Summary",
        "",
        f"- Total domains: {summary.get('total_domains')}",
        f"- Ready: {summary.get('ready')}",
        f"- Needs evidence: {summary.get('needs_evidence')}",
        f"- Blocked: {summary.get('blocked')}",
        "",
        "## Evidence Domains",
        "",
        "| Domain | Purpose | Status | Missing Evidence |",
        "| --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        missing = "<br>".join(domain.get("missing_evidence_paths", [])) or "None"
        lines.append(
            f"| {_md_cell(domain.get('title'))} | {_md_cell(domain.get('purpose'))} | "
            f"`{_md_cell(domain.get('status'))}` | {_md_cell(missing)} |"
        )

    lines.extend(["", "## Cleanup Candidates", ""])
    lines.extend(["| Candidate | Risk | Evidence Domain | Manual Action | Approval Required |", "| --- | --- | --- | --- | --- |"])
    for candidate in report.get("cleanup_candidates", []):
        if isinstance(candidate, Mapping):
            lines.append(
                f"| {_md_cell(candidate.get('title'))} | `{_md_cell(candidate.get('risk'))}` | "
                f"`{_md_cell(candidate.get('evidence_domain'))}` | {_md_cell(candidate.get('manual_action'))} | {candidate.get('approval_required')} |"
            )

    lines.extend(["", "## Approval Gates", ""])
    for gate in report.get("approval_gates", []):
        if isinstance(gate, Mapping):
            lines.append(f"- `{gate.get('gate')}`: {gate.get('requirement')}")

    lines.extend(["", "## Dry-Run Checks", ""])
    for check in report.get("dry_run_checks", []):
        if isinstance(check, Mapping):
            lines.append(f"- **{check.get('check')}**: `{check.get('command')}` - {check.get('purpose')}")

    lines.extend(["", "## Backup And Rollback Guidance", ""])
    for item in report.get("backup_rollback_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Metrics Checklist", ""])
    for metric in report.get("metrics_checklist", []):
        if isinstance(metric, Mapping):
            lines.append(f"- `{metric.get('metric')}`: {metric.get('review_question')}")

    lines.extend(["", "## Manual Notification Guidance", ""])
    for item in report.get("manual_notification_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Planning Guidance", ""])
    for item in report.get("planning_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static cleanup planning artifact. It composes existing repository evidence and requested output files only; it does not install schedulers, delete files, move files, create backups, run rollback, send notifications, or contact external systems.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_cleanup_plan(args: argparse.Namespace) -> None:
    report = _build_cleanup_plan(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_cleanup_plan(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] != "ready":
            raise TaskError("Cleanup plan aggregate status is not ready")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote cleanup plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote cleanup runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] != "ready":
        raise TaskError("Cleanup plan aggregate status is not ready")


