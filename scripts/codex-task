    return [
        "python3 scripts/codex-task rollout experiment-plan --report-file <plan.json> --runbook-file <runbook.md>",
        "python3 scripts/codex-task taskmaster health",
        "python3 scripts/codex-task work-tracking audit",
        "python3 scripts/codex-guard validate --include-untracked",
        "PYTHONDONTWRITEBYTECODE=1 python3 -m pytest tests/meta_workflow_guard/test_codex_task.py",
        "git diff --check",
    ]


def _experiment_variants(control: str, raw_variants: Optional[Sequence[str]]) -> List[Dict[str, Any]]:
    names = [control.strip() or "control"]
    names.extend(variant.strip() for variant in raw_variants or [] if variant.strip())
    if len(names) == 1:
        names.append("candidate-foundation")

    base = round(100.0 / len(names), 2)
    allocations = [base for _ in names]
    allocations[-1] = round(100.0 - sum(allocations[:-1]), 2)

    variants: List[Dict[str, Any]] = []
    seen: Dict[str, int] = {}
    for index, (name, allocation) in enumerate(zip(names, allocations)):
        variant_id = _slugify(name)
        if variant_id in seen:
            seen[variant_id] += 1
            variant_id = f"{variant_id}-{seen[variant_id]}"
        else:
            seen[variant_id] = 1
        variants.append(
            {
                "id": variant_id,
                "name": name,
                "role": "control" if index == 0 else "candidate",
                "allocation_percent": allocation,
            }
        )
    return variants


def _build_experiment_rollout_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    variants = _experiment_variants(args.control, args.variant)
    error_threshold_pct = float(args.error_threshold_pct)
    if error_threshold_pct < 0:
        raise TaskError("--error-threshold-pct must be non-negative")

    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "non-destructive-foundation-experiment-plan",
        "executes_mutations": False,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "variant_count": len(variants),
        "variants": variants,
        "allocation_model": {
            "automatic_assignment": False,
            "traffic_split": False,
            "reviewed_evidence_only": True,
            "guidance": [
                "Run the same verification commands for the control and each candidate variant.",
                "Store evidence for every variant before comparing outcomes.",
                "Treat missing evidence as a stop condition, not a warning.",
            ],
        },
        "metric_model": {
            "metrics": list(EXPERIMENT_METRICS),
            "comparison_rule": "Promote a candidate only when it is no worse than control on required checks and any tradeoff is documented in FINDINGS/DECISIONS.",
            "error_threshold_pct": error_threshold_pct,
            "stop_conditions": [
                f"Candidate error or failure rate exceeds control by more than {error_threshold_pct:.2f}%.",
                "Any required guard, audit, health, or focused test command fails.",
                "Performance or monitoring reports fail strict policy.",
                "Evidence is missing for any control or candidate variant.",
            ],
        },
        "promotion_model": {
            "automatic_promotion": False,
            "requires_reviewed_evidence": True,
            "requires_decision_log": True,
            "guidance": [
                "Document the selected variant and rationale in DECISIONS.md.",
                "Attach JSON/Markdown experiment evidence to work tracking before merge.",
                "Use the canary rollout planner for staged adoption after selecting a variant.",
            ],
        },
        "rollback_policy": {
            "automatic_rollback": False,
            "guidance": [
                "Stop and render a reviewed rollback/recovery plan if a stop condition fires.",
                "Do not execute destructive rollback commands from this experiment planner.",
            ],
        },
        "recommended_verification_commands": _experiment_verification_commands(),
        "non_goals": [
            "No LaunchDarkly or external feature flag service is configured.",
            "No runtime user segmentation is performed.",
            "No traffic is split or routed.",
            "No automatic rollback command is executed.",
            "No dashboard is generated.",
            "No notification is sent.",
        ],
    }


def _render_experiment_rollout_runbook(plan: Dict[str, Any]) -> str:
    current = plan.get("current_state", {})
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    metric_model = plan.get("metric_model", {}) if isinstance(plan.get("metric_model"), dict) else {}
    promotion = plan.get("promotion_model", {}) if isinstance(plan.get("promotion_model"), dict) else {}
    rollback = plan.get("rollback_policy", {}) if isinstance(plan.get("rollback_policy"), dict) else {}
    lines = [
        "# Foundation Experiment Runbook",
        "",
        f"- Label: {plan.get('label')}",
        f"- Created at: {plan.get('created_at')}",
        f"- Mode: {plan.get('mode')}",
        f"- Executes mutations: {plan.get('executes_mutations')}",
        f"- Current branch: {git_info.get('branch')}",
        f"- Current HEAD: {git_info.get('head')}",
        f"- Current dirty status entries: {len(git_info.get('status') or [])}",
        "",
        "## Variants",
        "",
    ]
    variants = plan.get("variants") if isinstance(plan.get("variants"), list) else []
    if variants:
        for variant in variants:
            if not isinstance(variant, dict):
                continue
            lines.append(
                f"- {variant.get('name')} ({variant.get('role')}): {variant.get('allocation_percent')}%"
            )
    else:
        lines.append("- No variants defined.")

    lines.extend(["", "## Metrics", ""])
    for metric in metric_model.get("metrics", []):
        if not isinstance(metric, dict):
            continue
        lines.append(f"- {metric.get('title')}: `{metric.get('command')}`")
        lines.append(f"  - Success: {metric.get('success_criteria')}")

    lines.extend(["", "## Stop Conditions", ""])
    for condition in metric_model.get("stop_conditions", []):
        lines.append(f"- {condition}")

    lines.extend(
        [
            "",
            "## Promotion Model",
            "",
            f"- Automatic promotion: {promotion.get('automatic_promotion')}",
            f"- Reviewed evidence required: {promotion.get('requires_reviewed_evidence')}",
            f"- Decision log required: {promotion.get('requires_decision_log')}",
            "",
            "## Rollback Policy",
            "",
            f"- Automatic rollback: {rollback.get('automatic_rollback')}",
        ]
    )
    for item in rollback.get("guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Recommended Verification Commands", ""])
    for command in plan.get("recommended_verification_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in plan.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(["", "No feature flag service, traffic split, promotion, rollback, dashboard update, or notification was executed by this plan.", ""])
    return "\n".join(lines)


def handle_rollout_experiment_plan(args: argparse.Namespace) -> None:
    plan = _build_experiment_rollout_plan(args)
    rendered_json = json.dumps(plan, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_experiment_rollout_runbook(plan)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote experiment plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote experiment runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


def _resolve_agent_compatibility_matrix(matrix_file: Optional[str]) -> Path:
    matrix_path = Path(matrix_file) if matrix_file else AGENT_COMPATIBILITY_MATRIX
    if not matrix_path.is_absolute():
        matrix_path = REPO_ROOT / matrix_path
    return matrix_path


def _load_agent_compatibility_matrix(matrix_file: Optional[str] = None) -> Tuple[Path, Dict[str, Any]]:
    matrix_path = _resolve_agent_compatibility_matrix(matrix_file)
    if not matrix_path.exists():
        raise TaskError(f"Agent compatibility matrix not found: {_relative_to_root(matrix_path, REPO_ROOT)}")
    try:
        payload = json.loads(matrix_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"Agent compatibility matrix is invalid JSON: {exc}") from exc
    if not isinstance(payload, dict):
        raise TaskError("Agent compatibility matrix must be a JSON object")
    return matrix_path, payload


def _count_values(values: Iterable[str]) -> Dict[str, int]:
    counts: Dict[str, int] = {}
    for value in values:
        counts[value] = counts.get(value, 0) + 1
    return dict(sorted(counts.items()))


def _validate_agent_compatibility_matrix(matrix: Dict[str, Any], matrix_path: Optional[Path] = None) -> List[str]:
    issues: List[str] = []

    if matrix.get("schema") != AGENT_COMPATIBILITY_SCHEMA:
        issues.append(f"schema must be {AGENT_COMPATIBILITY_SCHEMA}")

    contract = matrix.get("contract")
    if not isinstance(contract, dict):
        issues.append("contract must be an object")
        current_version = None
    else:
        current_version = contract.get("current_version")
        if not isinstance(current_version, str) or not current_version:
            issues.append("contract.current_version must be a non-empty string")

    support_levels = matrix.get("support_levels")
    if not isinstance(support_levels, list) or not all(isinstance(item, str) for item in support_levels):
        issues.append("support_levels must be a list of strings")
        support_level_set = set()
    else:
        support_level_set = set(support_levels)
        missing_mechanical = AGENT_COMPATIBILITY_MECHANICAL_LEVELS - support_level_set
        if missing_mechanical:
            issues.append(f"support_levels missing mechanical levels: {', '.join(sorted(missing_mechanical))}")

    features = matrix.get("features")
    feature_ids: List[str] = []
    if not isinstance(features, list) or not features:
        issues.append("features must be a non-empty list")
    else:
        seen_features: set[str] = set()
        for index, feature in enumerate(features):
            if not isinstance(feature, dict):
                issues.append(f"features[{index}] must be an object")
                continue
            feature_id = feature.get("id")
            if not isinstance(feature_id, str) or not feature_id:
                issues.append(f"features[{index}].id must be a non-empty string")
                continue
            if feature_id in seen_features:
                issues.append(f"duplicate feature id: {feature_id}")
            seen_features.add(feature_id)
            feature_ids.append(feature_id)
            for key in ("title", "description"):
                if not isinstance(feature.get(key), str) or not feature[key]:
                    issues.append(f"feature {feature_id} missing {key}")

    feature_set = set(feature_ids)
    agents = matrix.get("agents")
    if not isinstance(agents, list) or not agents:
        issues.append("agents must be a non-empty list")
        return issues

    seen_agents: set[str] = set()
    for index, agent in enumerate(agents):
        if not isinstance(agent, dict):
            issues.append(f"agents[{index}] must be an object")
            continue

        agent_id = agent.get("id")
        label = agent_id if isinstance(agent_id, str) and agent_id else f"agents[{index}]"
        for key in AGENT_COMPATIBILITY_REQUIRED_AGENT_KEYS:
            if key not in agent:
                issues.append(f"agent {label} missing {key}")

        if not isinstance(agent_id, str) or not agent_id:
            issues.append(f"agents[{index}].id must be a non-empty string")
            continue
        if agent_id in seen_agents:
            issues.append(f"duplicate agent id: {agent_id}")
        seen_agents.add(agent_id)

        status = agent.get("status")
        if status not in AGENT_COMPATIBILITY_AGENT_STATUSES:
            issues.append(f"agent {agent_id} has invalid status: {status}")

        entrypoint = agent.get("entrypoint")
        if not isinstance(entrypoint, str) or not entrypoint:
            issues.append(f"agent {agent_id} entrypoint must be a non-empty string")
        elif matrix_path is not None and not (REPO_ROOT / entrypoint).exists():
            issues.append(f"agent {agent_id} entrypoint does not exist: {entrypoint}")

        contract_versions = agent.get("contract_versions")
        if not isinstance(contract_versions, list) or not all(isinstance(item, str) for item in contract_versions):
            issues.append(f"agent {agent_id} contract_versions must be a list of strings")
        elif status in {"supported", "canary", "planned"} and current_version and current_version not in contract_versions:
            issues.append(f"agent {agent_id} does not declare current contract version {current_version}")

        capabilities = agent.get("capabilities")
        if not isinstance(capabilities, dict):
            issues.append(f"agent {agent_id} capabilities must be an object")
        else:
            capability_ids = set(capabilities)
            missing = feature_set - capability_ids
            extra = capability_ids - feature_set
            if missing:
                issues.append(f"agent {agent_id} missing feature flags: {', '.join(sorted(missing))}")
            if extra:
                issues.append(f"agent {agent_id} has unknown feature flags: {', '.join(sorted(extra))}")
            for feature_id, support_level in capabilities.items():
                if support_levels and support_level not in support_level_set:
                    issues.append(f"agent {agent_id} feature {feature_id} has invalid support level: {support_level}")

        for list_key in ("required_gates", "fallbacks", "transformations", "evidence_paths"):
            value = agent.get(list_key)
            if not isinstance(value, list) or not value:
                issues.append(f"agent {agent_id} {list_key} must be a non-empty list")

        if matrix_path is not None:
            for evidence_path in agent.get("evidence_paths", []):
                if not isinstance(evidence_path, str):
                    issues.append(f"agent {agent_id} evidence path must be a string")
                    continue
                if not (REPO_ROOT / evidence_path).exists():
                    issues.append(f"agent {agent_id} evidence path does not exist: {evidence_path}")

    validation_commands = matrix.get("validation_commands")
    if not isinstance(validation_commands, list) or not validation_commands:
        issues.append("validation_commands must be a non-empty list")

    non_goals = matrix.get("non_goals")
    if not isinstance(non_goals, list) or not non_goals:
        issues.append("non_goals must be a non-empty list")

    return issues


def _agent_compatibility_metrics(matrix: Dict[str, Any], issues: List[str]) -> Dict[str, Any]:
    agents = [agent for agent in matrix.get("agents", []) if isinstance(agent, dict)]
    features = [feature for feature in matrix.get("features", []) if isinstance(feature, dict)]
    feature_ids = [feature.get("id") for feature in features if isinstance(feature.get("id"), str)]
    all_support_levels: List[str] = []
    mechanical_feature_count = 0
    policy_only_feature_count = 0
    planned_feature_count = 0

    for agent in agents:
        capabilities = agent.get("capabilities", {})
        if not isinstance(capabilities, dict):
            continue
        for feature_id in feature_ids:
            support_level = capabilities.get(feature_id)
            if not isinstance(support_level, str):
                continue
            all_support_levels.append(support_level)
            if support_level in AGENT_COMPATIBILITY_MECHANICAL_LEVELS:
                mechanical_feature_count += 1
            if support_level == "policy-only":
                policy_only_feature_count += 1
            if support_level == "planned":
                planned_feature_count += 1

    total_feature_slots = len(agents) * len(feature_ids)
    mechanical_coverage_percent = 0.0
    if total_feature_slots:
        mechanical_coverage_percent = round((mechanical_feature_count / total_feature_slots) * 100, 2)

    return {
        "agent_count": len(agents),
        "feature_count": len(feature_ids),
        "total_feature_slots": total_feature_slots,
        "agent_status_counts": _count_values(
            str(agent.get("status")) for agent in agents if isinstance(agent.get("status"), str)
        ),
        "feature_support_counts": _count_values(all_support_levels),
        "mechanical_feature_count": mechanical_feature_count,
        "mechanical_coverage_percent": mechanical_coverage_percent,
        "policy_only_feature_count": policy_only_feature_count,
        "planned_feature_count": planned_feature_count,
        "agents_with_fallbacks": sum(
            1 for agent in agents if isinstance(agent.get("fallbacks"), list) and bool(agent.get("fallbacks"))
        ),
        "validation_issue_count": len(issues),
    }


def _build_agent_compatibility_report(args: argparse.Namespace) -> Dict[str, Any]:
    matrix_path, matrix = _load_agent_compatibility_matrix(args.matrix_file)
    issues = _validate_agent_compatibility_matrix(matrix, matrix_path)
    features = [feature for feature in matrix.get("features", []) if isinstance(feature, dict)]
    agents = [agent for agent in matrix.get("agents", []) if isinstance(agent, dict)]

    agent_summaries: List[Dict[str, Any]] = []
    for agent in agents:
        capabilities = agent.get("capabilities", {})
        mechanical_count = 0
        policy_only_count = 0
        planned_count = 0
        if isinstance(capabilities, dict):
            mechanical_count = sum(1 for level in capabilities.values() if level in AGENT_COMPATIBILITY_MECHANICAL_LEVELS)
            policy_only_count = sum(1 for level in capabilities.values() if level == "policy-only")
            planned_count = sum(1 for level in capabilities.values() if level == "planned")
        agent_summaries.append(
            {
                "id": agent.get("id"),
                "title": agent.get("title"),
                "status": agent.get("status"),
                "entrypoint": agent.get("entrypoint"),
                "contract_versions": agent.get("contract_versions", []),
                "mechanical_feature_count": mechanical_count,
                "policy_only_feature_count": policy_only_count,
                "planned_feature_count": planned_count,
                "required_gate_count": len(agent.get("required_gates", [])) if isinstance(agent.get("required_gates"), list) else 0,
                "fallback_count": len(agent.get("fallbacks", [])) if isinstance(agent.get("fallbacks"), list) else 0,
                "transformation_count": len(agent.get("transformations", [])) if isinstance(agent.get("transformations"), list) else 0,
            }
        )

    feature_summaries: List[Dict[str, Any]] = []
    for feature in features:
        feature_id = feature.get("id")
        support_by_agent: Dict[str, str] = {}
        for agent in agents:
            agent_id = agent.get("id")
            capabilities = agent.get("capabilities", {})
            if isinstance(agent_id, str) and isinstance(capabilities, dict):
                support_by_agent[agent_id] = str(capabilities.get(feature_id, "missing"))
        feature_summaries.append(
            {
                "id": feature_id,
                "title": feature.get("title"),
                "support_by_agent": support_by_agent,
                "mechanical_agents": sorted(
                    agent_id
                    for agent_id, support_level in support_by_agent.items()
                    if support_level in AGENT_COMPATIBILITY_MECHANICAL_LEVELS
                ),
            }
        )

    now = datetime.now().astimezone()
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "matrix_file": _relative_to_root(matrix_path, REPO_ROOT),
        "matrix_schema": matrix.get("schema"),
        "matrix_version": matrix.get("version"),
        "contract": matrix.get("contract", {}),
        "valid": not issues,
        "issues": issues,
        "metrics": _agent_compatibility_metrics(matrix, issues),
        "agents": agent_summaries,
        "features": feature_summaries,
        "validation_commands": matrix.get("validation_commands", []),
        "non_goals": matrix.get("non_goals", []),
    }


def _render_agent_compatibility_runbook(report: Dict[str, Any]) -> str:
    metrics = report.get("metrics", {}) if isinstance(report.get("metrics"), dict) else {}
    lines = [
        "# Agent Compatibility Report",
        "",
        f"- Created at: {report.get('created_at')}",
        f"- Matrix file: `{report.get('matrix_file')}`",
        f"- Matrix version: {report.get('matrix_version')}",
        f"- Contract version: {report.get('contract', {}).get('current_version') if isinstance(report.get('contract'), dict) else None}",
        f"- Valid: {report.get('valid')}",
        "",
        "## Metrics",
        "",
        f"- Agents: {metrics.get('agent_count')}",
        f"- Features: {metrics.get('feature_count')}",
        f"- Feature slots: {metrics.get('total_feature_slots')}",
        f"- Mechanical feature coverage: {metrics.get('mechanical_coverage_percent')}%",
        f"- Policy-only feature slots: {metrics.get('policy_only_feature_count')}",
        f"- Planned feature slots: {metrics.get('planned_feature_count')}",
        f"- Validation issues: {metrics.get('validation_issue_count')}",
        "",
        "## Agents",
        "",
    ]
    for agent in report.get("agents", []):
        if not isinstance(agent, dict):
            continue
        lines.extend(
            [
                f"### {agent.get('title')}",
                "",
                f"- Agent ID: `{agent.get('id')}`",
                f"- Status: {agent.get('status')}",
                f"- Entry point: `{agent.get('entrypoint')}`",
                f"- Mechanical features: {agent.get('mechanical_feature_count')}",
                f"- Planned features: {agent.get('planned_feature_count')}",
                f"- Policy-only features: {agent.get('policy_only_feature_count')}",
                f"- Required gates: {agent.get('required_gate_count')}",
                f"- Fallbacks: {agent.get('fallback_count')}",
                f"- Transformations: {agent.get('transformation_count')}",
                "",
            ]
        )

    lines.extend(["## Features", ""])
    for feature in report.get("features", []):
        if not isinstance(feature, dict):
            continue
        support = feature.get("support_by_agent", {})
        support_bits = []
        if isinstance(support, dict):
            support_bits = [f"{agent}: {level}" for agent, level in sorted(support.items())]
        lines.append(f"- `{feature.get('id')}` — {feature.get('title')} ({'; '.join(support_bits)})")

    issues = report.get("issues", [])
    lines.extend(["", "## Validation Issues", ""])
    if issues:
        for issue in issues:
            lines.append(f"- {issue}")
    else:
        lines.append("- None")

    lines.extend(["", "## Validation Commands", ""])
    for command in report.get("validation_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.append("")
    return "\n".join(lines)


def handle_agent_compatibility_report(args: argparse.Namespace) -> None:
    report = _build_agent_compatibility_report(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_agent_compatibility_runbook(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and not report["valid"]:
            raise TaskError("Agent compatibility matrix validation failed")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote agent compatibility report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote agent compatibility runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and not report["valid"]:
        raise TaskError("Agent compatibility matrix validation failed")


def _resolve_final_validation_path(path_value: Optional[str], default_path: Path) -> Path:
    path = Path(path_value) if path_value else default_path
    if not path.is_absolute():
        path = REPO_ROOT / path
    return path


def _final_validation_output_paths(args: argparse.Namespace, created_at: datetime) -> Dict[str, str]:
    label_slug = _slugify(args.label)
    stamp = created_at.strftime("%Y%m%d-%H%M%S")
    report_dir = Path(args.report_dir)
    if not report_dir.is_absolute():
        report_dir = REPO_ROOT / report_dir
    evidence_dir = report_dir / f"{stamp}-{label_slug}-evidence"
    report_file = _resolve_final_validation_path(
        args.report_file,
        report_dir / f"{stamp}-{label_slug}.json",
    )
    runbook_file = _resolve_final_validation_path(
        args.runbook_file,
        report_dir / f"{stamp}-{label_slug}.md",
    )
    return {
        "report_dir": _relative_to_root(report_dir, REPO_ROOT),
        "evidence_dir": _relative_to_root(evidence_dir, REPO_ROOT),
        "report_file": _relative_to_root(report_file, REPO_ROOT),
        "runbook_file": _relative_to_root(runbook_file, REPO_ROOT),
    }


def _final_validation_command_display(command: List[str], env: Optional[Dict[str, str]] = None) -> str:
    parts = []
    if env:
        parts.extend(f"{key}={shlex.quote(str(value))}" for key, value in sorted(env.items()))
    for part in command:
        display_part = "python3" if part == sys.executable else part
        parts.append(shlex.quote(display_part))
    return " ".join(parts)


def _final_validation_command_specs(
    evidence_dir: Path,
    pytest_targets: Iterable[str],
    *,
    skip_pytest: bool = False,
) -> List[Dict[str, Any]]:
    python = sys.executable
    drift_report_dir = evidence_dir / "template-drift"
    metrics_report_dir = evidence_dir / "template-metrics"
    monitoring_report_dir = evidence_dir / "template-monitoring"
    phase0_report_dir = evidence_dir / "phase0-scanner-validation"
    performance_report_dir = evidence_dir / "template-performance"
    cost_report_dir = evidence_dir / "cost-tracking"
    reference_log = evidence_dir / "reference-fix-gate.json"
    agent_report = evidence_dir / "agent-compatibility.json"
    agent_runbook = evidence_dir / "agent-compatibility.md"
    checks: List[Dict[str, Any]] = [
        {
            "id": "git-status",
            "title": "Current Git status",
            "category": "workflow-state",
            "requirements": ("checklist-automation",),
            "command": ["git", "status", "--short", "--branch"],
        },
        {
            "id": "taskmaster-health",
            "title": "Taskmaster graph health",
            "category": "workflow-state",
            "requirements": ("checklist-automation",),
            "command": [python, "scripts/codex-task", "taskmaster", "health"],
        },
        {
            "id": "plan-sync",
            "title": "Plan and tracker sync",
            "category": "workflow-state",
            "requirements": ("checklist-automation", "sign-off-workflow"),
            "command": [python, "scripts/codex-task", "plan", "sync"],
        },
        {
            "id": "work-tracking-audit",
            "title": "Work-tracking audit",
            "category": "workflow-state",
            "requirements": ("checklist-automation", "sign-off-workflow"),
            "command": [python, "scripts/codex-task", "work-tracking", "audit"],
        },
        {
            "id": "codex-guard",
            "title": "Codex guard validation",
            "category": "guard",
            "requirements": ("checklist-automation", "security-validation", "sign-off-workflow"),
            "command": [python, "scripts/codex-guard", "validate", "--include-untracked"],
        },
        {
            "id": "template-drift",
            "title": "Template drift check",
            "category": "guard",
            "requirements": ("reference-integrity", "report-generation"),
            "command": [
                python,
                "scripts/codex-guard",
                "drift-check",
                "--strict",
                "--report-dir",
                _relative_to_root(drift_report_dir, REPO_ROOT),
            ],
        },
        {
            "id": "scanner-suite",
            "title": "Scanner validation suite",
            "category": "scanner",
            "requirements": ("reference-integrity", "security-validation"),
            "command": [python, "scripts/template-ssot-scanner/run_all_scanners.py", "--profile", "ci"],
        },
        {
            "id": "reference-fix-gate",
            "title": "Automatic reference-fix gate",
            "category": "scanner",
            "requirements": ("reference-integrity",),
            "command": [
                python,
                "scripts/template-ssot-scanner/apply_reference_fixes.py",
                "--dry-run",
                "--fail-on-changes",
                "--log-file",
                _relative_to_root(reference_log, REPO_ROOT),
            ],
        },
        {
            "id": "static-report-pipeline",
            "title": "Static validation report pipeline",
            "category": "reports",
            "requirements": (
                "performance-validation",
                "cost-validation",
                "security-validation",
                "report-generation",
            ),
            "command": [
                python,
                "scripts/codex-task",
                "report",
                "generate",
                "--kind",
                "all",
                "--drift-report-dir",
                _relative_to_root(drift_report_dir, REPO_ROOT),
                "--report-dir",
                _relative_to_root(metrics_report_dir, REPO_ROOT),
                "--metrics-file",
                _relative_to_root(metrics_report_dir / "latest.json", REPO_ROOT),
                "--monitoring-report-dir",
                _relative_to_root(monitoring_report_dir, REPO_ROOT),
                "--phase0-report-dir",
                _relative_to_root(phase0_report_dir, REPO_ROOT),
                "--performance-report-dir",
                _relative_to_root(performance_report_dir, REPO_ROOT),
                "--cost-report-dir",
                _relative_to_root(cost_report_dir, REPO_ROOT),
                "--strict-drift",
                "--strict-monitoring",
                "--strict-phase0",
                "--strict-performance",
                "--strict-cost",
            ],
        },
        {
            "id": "agent-compatibility",
            "title": "Agent compatibility validation",
            "category": "compatibility",
            "requirements": ("compatibility-validation", "report-generation"),
            "command": [
                python,
                "scripts/codex-task",
                "agent",
                "compatibility-report",
                "--strict",
                "--report-file",
                _relative_to_root(agent_report, REPO_ROOT),
                "--runbook-file",
                _relative_to_root(agent_runbook, REPO_ROOT),
            ],
        },
    ]

    if not skip_pytest:
        targets = list(pytest_targets)
        checks.append(
            {
                "id": "pytest",
                "title": "Python regression tests",
                "category": "tests",
                "requirements": ("regression-tests", "sign-off-workflow"),
                "command": [python, "-m", "pytest", *targets],
                "env": {"PYTHONDONTWRITEBYTECODE": "1"},
            }
        )

    checks.append(
        {
            "id": "diff-check",
            "title": "Patch whitespace check",
            "category": "git",
            "requirements": ("sign-off-workflow",),
            "command": ["git", "diff", "--check"],
        }
    )

    for check in checks:
        check["required"] = True
        check["command_display"] = _final_validation_command_display(check["command"], check.get("env"))
        check["result"] = {"status": "planned", "exit_code": None, "evidence": None}
    return checks


def _build_final_validation_suite(args: argparse.Namespace) -> Dict[str, Any]:
    created_at = datetime.now().astimezone()
    paths = _final_validation_output_paths(args, created_at)
    evidence_dir = REPO_ROOT / paths["evidence_dir"]
    checks = _final_validation_command_specs(
        evidence_dir,
        tuple(args.pytest_target or ()),
        skip_pytest=args.skip_pytest,
    )
    return {
        "version": 1,
        "created_at": created_at.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "final-validation-suite",
        "executes_commands": bool(args.execute),
        "allow_failures": bool(args.allow_failures),
        "paths": paths,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "requirements": list(FINAL_VALIDATION_REQUIREMENTS),
        "checks": checks,
        "sign_off_checklist": list(FINAL_VALIDATION_SIGN_OFF),
        "summary": {
            "status": "planned",
            "total_checks": len(checks),
            "passed": 0,
            "failed": 0,
            "not_run": len(checks),
            "failed_required": 0,
        },
        "valid": None,
        "non_goals": [
            "No standalone security, performance, cost, reference, or compatibility validator is created by this suite.",
            "No external service, repository setting, hosted dashboard, or approval workflow is modified.",
            "Dirty Git status is recorded as evidence; patch hygiene is enforced by git diff --check.",
        ],
    }


def _final_validation_log_text(check: Dict[str, Any], returncode: int, stdout: str, stderr: str) -> str:
    return "\n".join(
        [
            f"Check: {check['id']}",
            f"Title: {check['title']}",
            f"Command: {check['command_display']}",
            f"Exit code: {returncode}",
            "",
            "STDOUT:",
            stdout.rstrip(),
            "",
            "STDERR:",
            stderr.rstrip(),
        ]
    ).rstrip() + "\n"


def _execute_final_validation_suite(plan: Dict[str, Any]) -> None:
    evidence_dir = REPO_ROOT / str(plan["paths"]["evidence_dir"])
    evidence_dir.mkdir(parents=True, exist_ok=True)

    for index, check in enumerate(plan["checks"], start=1):
        evidence_path = evidence_dir / f"{index:02d}-{check['id']}.txt"
        env = os.environ.copy()
        env.update({str(key): str(value) for key, value in check.get("env", {}).items()})
        try:
            result = subprocess.run(
                check["command"],
                cwd=str(REPO_ROOT),
                capture_output=True,
                text=True,
                env=env,
            )
            returncode = result.returncode
            stdout = result.stdout
            stderr = result.stderr
        except OSError as exc:
            returncode = 127
            stdout = ""
            stderr = str(exc)

        evidence_path.write_text(
            _final_validation_log_text(check, returncode, stdout, stderr),
            encoding="utf-8",
        )
        check["result"] = {
            "status": "passed" if returncode == 0 else "failed",
            "exit_code": returncode,
            "evidence": _relative_to_root(evidence_path, REPO_ROOT),
        }

    _summarise_final_validation_suite(plan)


def _summarise_final_validation_suite(plan: Dict[str, Any]) -> None:
    checks = [check for check in plan.get("checks", []) if isinstance(check, dict)]
    passed = sum(1 for check in checks if check.get("result", {}).get("status") == "passed")
    failed = sum(1 for check in checks if check.get("result", {}).get("status") == "failed")
    not_run = sum(1 for check in checks if check.get("result", {}).get("status") == "planned")
    failed_required = sum(
        1
        for check in checks
        if check.get("required", True) and check.get("result", {}).get("status") == "failed"
    )
    status = "planned"
    valid: Optional[bool] = None
    if not_run != len(checks):
        status = "passed" if failed_required == 0 and not_run == 0 else "failed"
        valid = status == "passed"
    plan["summary"] = {
        "status": status,
        "total_checks": len(checks),
        "passed": passed,
        "failed": failed,
        "not_run": not_run,
        "failed_required": failed_required,
    }
    plan["valid"] = valid


def _render_final_validation_runbook(plan: Dict[str, Any]) -> str:
    current = plan.get("current_state", {}) if isinstance(plan.get("current_state"), dict) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), dict) else {}
    summary = plan.get("summary", {}) if isinstance(plan.get("summary"), dict) else {}

    lines = [
        "# Final Validation Suite Runbook",
        "",
        f"- Label: {plan.get('label')}",
        f"- Created at: {plan.get('created_at')}",
        f"- Mode: {plan.get('mode')}",
        f"- Executes commands: {plan.get('executes_commands')}",
        f"- Status: {summary.get('status')}",
        f"- Valid: {plan.get('valid')}",
        "",
        "## Current State",
        "",
        f"- Branch: {git_info.get('branch')}",
        f"- HEAD: {git_info.get('head')}",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: {workflow.get('current_session', {}).get('resolved')}",
        f"- Current plan: {workflow.get('current_plan', {}).get('resolved')}",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Requirement Coverage",
        "",
        "| Requirement | Covered By |",
        "| --- | --- |",
    ]
    for requirement in plan.get("requirements", []):
        if not isinstance(requirement, dict):
            continue
        covered_by = ", ".join(str(item) for item in requirement.get("covered_by", []))
        lines.append(f"| {_md_cell(requirement.get('title'))} | {_md_cell(covered_by)} |")

    lines.extend(
        [
            "",
            "## Validation Checks",
            "",
            "| Check | Category | Status | Evidence | Command |",
            "| --- | --- | --- | --- | --- |",
        ]
    )
    for check in plan.get("checks", []):
        if not isinstance(check, dict):
            continue
        result = check.get("result", {}) if isinstance(check.get("result"), dict) else {}
        lines.append(
            f"| {_md_cell(check.get('title'))} | {_md_cell(check.get('category'))} | "
            f"{_md_cell(result.get('status'))} | {_md_cell(result.get('evidence') or '')} | "
            f"`{_md_cell(check.get('command_display'))}` |"
        )

    lines.extend(["", "## Sign-Off Checklist", ""])
    for item in plan.get("sign_off_checklist", []):
        lines.append(f"- [ ] {item}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in plan.get("non_goals", []):
        lines.append(f"- {non_goal}")

    if not plan.get("executes_commands"):
        lines.extend(["", "No validation commands were executed by this planned suite.", ""])
    else:
        lines.extend(["", "Validation command outputs are captured in the evidence files listed above.", ""])
    return "\n".join(lines)


def handle_validation_final_suite(args: argparse.Namespace) -> None:
    plan = _build_final_validation_suite(args)
    if args.execute:
        _execute_final_validation_suite(plan)
    else:
        _summarise_final_validation_suite(plan)

    rendered_json = json.dumps(plan, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_final_validation_runbook(plan)

    if args.dry_run:
        print(rendered_json, end="")
        return

    report_path = REPO_ROOT / str(plan["paths"]["report_file"])
    runbook_path = REPO_ROOT / str(plan["paths"]["runbook_file"])
    report_path.parent.mkdir(parents=True, exist_ok=True)
    runbook_path.parent.mkdir(parents=True, exist_ok=True)
    report_path.write_text(rendered_json, encoding="utf-8")
    runbook_path.write_text(rendered_runbook, encoding="utf-8")
    print(f"Wrote final validation report to {_relative_to_root(report_path, REPO_ROOT)}")
    print(f"Wrote final validation runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")

    if args.execute and not args.allow_failures and plan["summary"]["failed_required"]:
        raise TaskError("Final validation suite failed")


def _load_emergency_response_policy(policy_file: Optional[str] = None) -> Dict[str, Any]:
    policy_path = Path(policy_file) if policy_file else REPO_STRUCTURE.emergency_response_policy_path
    if not policy_path.is_absolute():
        policy_path = REPO_ROOT / policy_path
    if not policy_path.exists():
        raise TaskError(f"Emergency response policy not found: {_relative_to_root(policy_path, REPO_ROOT)}")
    try:
        policy = json.loads(policy_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"Emergency response policy is invalid JSON: {exc}") from exc
    severities = policy.get("severities")
    if not isinstance(severities, dict) or not severities:
        raise TaskError("Emergency response policy must define severities")
    policy["policy_path"] = _relative_to_root(policy_path, REPO_ROOT)
    return policy


def _emergency_response_verification_commands() -> List[str]:
    return [
        "git status --short --branch",
        "python3 scripts/codex-task work-tracking audit",
        "python3 scripts/codex-task taskmaster health",
        "python3 scripts/codex-guard validate --include-untracked",
        "python3 scripts/codex-task report generate --kind all",
        "git diff --check",
    ]


def _build_emergency_response_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    policy = _load_emergency_response_policy(args.policy_file)
    severity = str(args.severity).upper()
    severities = policy["severities"]
    if severity not in severities:
        valid = ", ".join(sorted(severities))
        raise TaskError(f"Unknown emergency severity {severity}; expected one of: {valid}")

    label = args.label or _slugify(args.summary)
    incident_id = f"{now.strftime('%Y%m%d-%H%M%S')}-{_slugify(label)}"
    halt_recommended_for = {str(item).upper() for item in policy.get("halt_recommended_for", [])}
    halt_mechanism = policy.get("halt_mechanism", {}) if isinstance(policy.get("halt_mechanism"), dict) else {}
    non_goals = list(policy.get("non_goals", [])) if isinstance(policy.get("non_goals"), list) else []
    non_goals.extend(
        [
            "No emergency response command was executed by this planner.",
            "No rollback, reset, clean, restore, branch deletion, notification, dashboard update, or external incident action was executed.",
        ]
    )

    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "mode": "non-destructive-emergency-response-plan",
        "executes_actions": False,
        "policy": {
            "path": policy["policy_path"],
            "version": policy.get("version"),
            "description": policy.get("description"),
        },
        "incident": {
            "id": incident_id,
            "label": label,
            "summary": args.summary,
            "severity": severity,
            "classification": severities[severity],
        },
        "halt": {
            "recommended": severity in halt_recommended_for,
            "automatic_halt": bool(halt_mechanism.get("automatic_halt", False)),
            "guidance": halt_mechanism.get("guidance", []),
        },
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "response_checklist": policy.get("response_checklist", []),
        "escalation_guidance": policy.get("escalation_guidance", {}),
        "post_incident_review": policy.get("post_incident_review", []),
        "recommended_verification_commands": _emergency_response_verification_commands(),
        "non_goals": non_goals,
    }


def _render_emergency_response_runbook(plan: Dict[str, Any]) -> str:
    incident = plan.get("incident", {}) if isinstance(plan.get("incident"), dict) else {}
    classification = incident.get("classification", {}) if isinstance(incident.get("classification"), dict) else {}
    halt = plan.get("halt", {}) if isinstance(plan.get("halt"), dict) else {}
    current = plan.get("current_state", {}) if isinstance(plan.get("current_state"), dict) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), dict) else {}
    escalation = plan.get("escalation_guidance", {}) if isinstance(plan.get("escalation_guidance"), dict) else {}

    lines = [
        "# Emergency Response Runbook",
        "",
        f"- Incident ID: {incident.get('id')}",
        f"- Label: {incident.get('label')}",
        f"- Created at: {plan.get('created_at')}",
        f"- Mode: {plan.get('mode')}",
        f"- Executes actions: {plan.get('executes_actions')}",
        f"- Severity: {incident.get('severity')} - {classification.get('title')}",
        f"- Summary: {incident.get('summary')}",
        "",
        "## Classification",
        "",
        f"- Description: {classification.get('description')}",
        f"- Response SLA: {classification.get('response_sla_minutes')} minutes",
        f"- Review SLA: {classification.get('review_sla_hours')} hours",
        "",
        "Examples:",
    ]
    for example in classification.get("examples", []):
        lines.append(f"- {example}")

    lines.extend(
        [
            "",
            "## Halt Guidance",
            "",
            f"- Halt recommended: {halt.get('recommended')}",
            f"- Automatic halt: {halt.get('automatic_halt')}",
            "",
        ]
    )
    for item in halt.get("guidance", []):
        lines.append(f"- {item}")

    lines.extend(
        [
            "",
            "## Current State Snapshot",
            "",
            f"- Branch: {git_info.get('branch')}",
            f"- HEAD: {git_info.get('head')}",
            f"- Dirty status entries: {len(git_info.get('status') or [])}",
            f"- Current session: {workflow.get('current_session', {}).get('resolved')}",
            f"- Current plan: {workflow.get('current_plan', {}).get('resolved')}",
            f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
            "",
            "## Response Checklist",
            "",
        ]
    )
    for step in plan.get("response_checklist", []):
        if not isinstance(step, dict):
            continue
        lines.extend([f"### {step.get('title')}", "", f"- ID: {step.get('id')}", ""])
        for command in step.get("commands", []):
            if str(command).startswith("Use "):
                lines.append(f"- {command}")
            else:
                lines.append(f"- `{command}`")
        lines.append("")

    lines.extend(["## Escalation Guidance", ""])
    for key, value in escalation.items():
        lines.append(f"- {key}: {value}")

    lines.extend(["", "## Post-Incident Review", ""])
    for prompt in plan.get("post_incident_review", []):
        lines.append(f"- {prompt}")

    lines.extend(["", "## Recommended Verification Commands", ""])
    for command in plan.get("recommended_verification_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in plan.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(["", "No halt, notification, rollback, reset, cleanup, dashboard update, or external incident action was executed by this plan.", ""])
    return "\n".join(lines)


def handle_emergency_plan(args: argparse.Namespace) -> None:
    plan = _build_emergency_response_plan(args)
    rendered_json = json.dumps(plan, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_emergency_response_runbook(plan)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote emergency response plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote emergency response runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


CHANGE_ADVISORY_POST_IMPLEMENTATION_REVIEW: Tuple[str, ...] = (
    "What changed compared with the approved advisory packet?",
    "Which guard, test, audit, health, and validation evidence proves the change behaved as expected?",
    "Were any approval, communication, rollback, canary, emergency, or validation conditions missed?",
    "Did any policy-only or manual step need a follow-up task?",
    "What should be changed in the portable foundation before the next similar change?",
)


def _change_advisory_path_label(paths: Sequence[str]) -> str:
    clean_paths = [path for path in paths if str(path).strip()]
    return ", ".join(clean_paths)


def _manual_change_advisory_governance(review_class: str, paths: Sequence[str], note: Optional[str]) -> Dict[str, Any]:
    policy = load_governance_policy(REPO_ROOT)
    selected = policy.review_class(review_class)
    payload: Dict[str, Any] = {
        "schema": policy.schema,
        "path": _change_advisory_path_label(paths),
        "review_class": selected.name,
        "priority": selected.priority,
        "required_roles": list(selected.required_roles),
        "approval": selected.approval,
        "escalation": selected.escalation,
        "notification_audiences": list(selected.notification_audiences),
        "notification_mode": policy.notification_mode,
        "required_evidence": list(selected.required_evidence),
        "reasons": [
            {
                "signal": "manual_review_class",
                "value": selected.name,
                "review_class": selected.name,
                "message": f"Review class explicitly supplied as {selected.name}",
            }
        ],
    }
    if note is not None:
        payload["note"] = note
    return payload


def _build_change_advisory_governance(args: argparse.Namespace) -> Dict[str, Any]:
    paths = tuple(args.paths or ())
    if args.review_class:
        return _manual_change_advisory_governance(args.review_class, paths, args.note)
    assessment = assess_governance(
        path=_change_advisory_path_label(paths),
        previous_version=args.previous_version,
        current_version=args.current_version,
        lifecycle_from=args.lifecycle_from,
        lifecycle_to=args.lifecycle_to,
        emergency=args.emergency,
        note=args.note,
        repo_root=REPO_ROOT,
    )
    return assessment_to_dict(assessment)


def _change_advisory_risk_level(governance: Mapping[str, Any]) -> str:
    review_class = str(governance.get("review_class") or "")
    priority = int(governance.get("priority") or 0)
    if review_class == "emergency" or priority >= 40:
        return "emergency"
    if priority >= 30:
        return "high"
    if priority >= 20:
        return "medium"
    return "low"


def _change_advisory_evidence_requirements(governance: Mapping[str, Any]) -> List[str]:
    requirements = [str(item) for item in governance.get("required_evidence", [])]
    base = [
        "active session progress entry with S:W:H:E evidence",
        "active tracker progress entry with S:W:H:E evidence",
        "plan sync evidence",
        "work-tracking audit evidence",
        "Taskmaster health evidence",
        "guard evidence",
        "focused or full pytest evidence appropriate to the change",
        "git diff --check evidence",
    ]
    priority = int(governance.get("priority") or 0)
    review_class = str(governance.get("review_class") or "")
    if priority >= 20:
        base.append("communication payload or handoff note for listed notification audiences")
    if priority >= 30:
        base.extend(
            [
                "rollback checkpoint or reviewed rollback note before merge",
                "final validation suite evidence before approval/sign-off",
                "migration or compatibility note when behavior is breaking",
            ]
        )
    if review_class == "emergency" or priority >= 40:
        base.extend(
            [
                "emergency response plan/runbook evidence",
                "explicit emergency approval/bypass record",
                "post-incident follow-up task or review note",
            ]
        )
    return list(dict.fromkeys(requirements + base))


def _change_advisory_controls(governance: Mapping[str, Any]) -> List[str]:
    priority = int(governance.get("priority") or 0)
    review_class = str(governance.get("review_class") or "")
    controls = [
        "Record the advisory packet path in the active tracker and session log.",
        "Record approval/rationale in DECISIONS.md or the active session before merge.",
        "Keep notification mode evidence-only; do not send external notifications from this helper.",
        "Reference final evidence from HANDOFF.md before closing the task.",
    ]
    if priority >= 20:
        controls.append("Record communication guidance for the active work-tracking folder and task handoff.")
    if priority >= 30:
        controls.extend(
            [
                "Capture rollback checkpoint or rollback-note evidence before merge.",
                "Run or explicitly waive final validation suite evidence before merge.",
            ]
        )
    if review_class == "emergency" or priority >= 40:
        controls.extend(
            [
                "Capture an emergency response plan before emergency merge or bypass.",
                "Create a post-incident review/follow-up record after recovery.",
            ]
        )
    return controls


def _change_advisory_verification_commands(governance: Mapping[str, Any]) -> List[str]:
    priority = int(governance.get("priority") or 0)
    review_class = str(governance.get("review_class") or "")
    commands = [
        "python3 scripts/codex-task change advisory --summary <summary> --report-file <advisory.json> --runbook-file <advisory.md>",
        "python3 scripts/codex-task plan sync",
        "python3 scripts/codex-task work-tracking audit",
        "python3 scripts/codex-task taskmaster health",
        "python3 scripts/codex-guard validate --include-untracked",
        "PYTHONDONTWRITEBYTECODE=1 python3 -m pytest",
        "git diff --check",
    ]
    if priority >= 20:
        commands.append("Review Task 49 communication templates and record evidence-only communication guidance.")
    if priority >= 30:
        commands.extend(
            [
                "python3 scripts/codex-task rollback checkpoint --label <change-label> --report-file <checkpoint.json>",
                "python3 scripts/codex-task validation final-suite --execute --report-dir <final-validation-report-dir>",
                "python3 scripts/codex-task rollout canary-plan --label <change-label> --report-file <canary.json> --runbook-file <canary.md>",
            ]
        )
    if review_class == "emergency" or priority >= 40:
        commands.append(
            "python3 scripts/codex-task emergency plan --severity <P0-P3> --summary <summary> --report-file <emergency.json> --runbook-file <emergency.md>"
        )
    return commands


def _build_change_advisory_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    paths = tuple(args.paths or ())
    label = args.label or _slugify(args.summary)
    governance = _build_change_advisory_governance(args)
    evidence_requirements = _change_advisory_evidence_requirements(governance)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "non-destructive-change-advisory-packet",
        "executes_actions": False,
        "change": {
            "summary": args.summary,
            "paths": list(paths),
            "task_id": args.task,
            "note": args.note,
        },
        "governance": governance,
        "risk_assessment": {
            "review_class": governance.get("review_class"),
            "priority": governance.get("priority"),
            "risk_level": _change_advisory_risk_level(governance),
            "reasons": governance.get("reasons", []),
        },
        "advisory_controls": {
            "required_roles": governance.get("required_roles", []),
            "approval": governance.get("approval"),
            "escalation": governance.get("escalation"),
            "notification_mode": governance.get("notification_mode"),
            "notification_audiences": governance.get("notification_audiences", []),
            "required_evidence": evidence_requirements,
            "controls": _change_advisory_controls(governance),
        },
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "communication_guidance": {
            "mode": governance.get("notification_mode"),
            "audiences": governance.get("notification_audiences", []),
            "guidance": [
                "Use repository communication templates and active work-tracking evidence.",
                "Record communication payloads or summaries as evidence; do not send notifications from this helper.",
                "Include Taskmaster ID, branch, advisory packet path, guard/test evidence, and merge/rollback guidance when relevant.",
            ],
        },
        "post_implementation_review": list(CHANGE_ADVISORY_POST_IMPLEMENTATION_REVIEW),
        "recommended_verification_commands": _change_advisory_verification_commands(governance),
        "non_goals": [
            "No CAB meeting is scheduled.",
            "No stakeholder vote is requested or recorded by this helper.",
            "No approval is granted automatically.",
            "No external notification is sent.",
            "No dashboard, ticket, or external tracking system is created.",
            "No deployment, promotion, rollback, reset, cleanup, or branch-protection change is executed.",
            "No duplicate governance policy is created.",
        ],
    }


def _render_change_advisory_runbook(plan: Dict[str, Any]) -> str:
    change = plan.get("change", {}) if isinstance(plan.get("change"), dict) else {}
    governance = plan.get("governance", {}) if isinstance(plan.get("governance"), dict) else {}
    controls = plan.get("advisory_controls", {}) if isinstance(plan.get("advisory_controls"), dict) else {}
    current = plan.get("current_state", {}) if isinstance(plan.get("current_state"), dict) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), dict) else {}
    risk = plan.get("risk_assessment", {}) if isinstance(plan.get("risk_assessment"), dict) else {}
    communication = plan.get("communication_guidance", {}) if isinstance(plan.get("communication_guidance"), dict) else {}

    lines = [
        "# Change Advisory Packet",
        "",
        f"- Label: {plan.get('label')}",
        f"- Created at: {plan.get('created_at')}",
        f"- Mode: {plan.get('mode')}",
        f"- Executes actions: {plan.get('executes_actions')}",
        f"- Summary: {change.get('summary')}",
        f"- Task ID: {change.get('task_id') or 'not specified'}",
        "",
        "## Change Scope",
        "",
    ]
    paths = change.get("paths") if isinstance(change.get("paths"), list) else []
    if paths:
        for path in paths:
            lines.append(f"- `{path}`")
    else:
        lines.append("- No specific paths supplied.")

    lines.extend(
        [
            "",
            "## Governance Assessment",
            "",
            f"- Review class: {governance.get('review_class')}",
            f"- Risk level: {risk.get('risk_level')}",
            f"- Priority: {governance.get('priority')}",
            f"- Required roles: {', '.join(str(item) for item in controls.get('required_roles', []))}",
            f"- Approval guidance: {controls.get('approval')}",
            f"- Escalation guidance: {controls.get('escalation')}",
            f"- Notification mode: {controls.get('notification_mode')}",
            f"- Notification audiences: {', '.join(str(item) for item in controls.get('notification_audiences', []))}",
            "",
            "Reasons:",
        ]
    )
    reasons = governance.get("reasons") if isinstance(governance.get("reasons"), list) else []
    for reason in reasons:
        if not isinstance(reason, dict):
            continue
        lines.append(
            f"- {reason.get('signal')}: {reason.get('value')} -> {reason.get('review_class')}: {reason.get('message')}"
        )

    lines.extend(["", "## Current State Snapshot", ""])
    lines.extend(
        [
            f"- Branch: {git_info.get('branch')}",
            f"- HEAD: {git_info.get('head')}",
            f"- Dirty status entries: {len(git_info.get('status') or [])}",
            f"- Current session: {workflow.get('current_session', {}).get('resolved')}",
            f"- Current plan: {workflow.get('current_plan', {}).get('resolved')}",
            f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        ]
    )

    lines.extend(["", "## Required Evidence", ""])
    for item in controls.get("required_evidence", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Advisory Controls", ""])
    for item in controls.get("controls", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Communication Guidance", ""])
    for item in communication.get("guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Recommended Verification Commands", ""])
    for command in plan.get("recommended_verification_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Post-Implementation Review", ""])
    for prompt in plan.get("post_implementation_review", []):
        lines.append(f"- {prompt}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in plan.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(["", "No CAB meeting, approval, notification, dashboard update, deployment, rollback, reset, cleanup, or external tracking action was executed by this advisory packet.", ""])
    return "\n".join(lines)


def handle_change_advisory(args: argparse.Namespace) -> None:
    plan = _build_change_advisory_plan(args)
    rendered_json = json.dumps(plan, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_change_advisory_runbook(plan)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote change advisory packet to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote change advisory runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


def _template_bundle_verification_commands() -> List[str]:
    return [
        "python3 scripts/codex-task template bundle-plan --template <id> --target-dir <target-repo> --report-file <manifest.json> --runbook-file <runbook.md>",
        "python3 scripts/codex-task bootstrap init --target-dir <target-repo>",
        "python3 scripts/codex-guard drift-check --strict",
        "python3 scripts/codex-task taskmaster health",
        "python3 scripts/codex-guard validate --include-untracked",
        "git diff --check",
    ]


def _template_relative_path(record: TemplateRecord, structure: RepoStructure) -> str:
    try:
        return record.absolute_path.relative_to(structure.templates_root).as_posix()
    except ValueError:
        return record.path


def _template_bundle_target_path(
    record: TemplateRecord,
    source_structure: RepoStructure,
    target_structure: RepoStructure | None,
) -> Path | None:
    if target_structure is None:
        return None
    return target_structure.templates_root / _template_relative_path(record, source_structure)


def _template_bundle_status(source_path: Path, target_path: Path | None) -> Tuple[str, str, str]:
    source_exists = source_path.exists() and source_path.is_file()
    if target_path is None:
        if source_exists:
            return "not-checked", "select-target", "No target repository was supplied."
        return "source-missing", "review-source", "Source template is missing."
    target_exists = target_path.exists() and target_path.is_file()
    if not source_exists:
        return "source-missing", "review-source", "Source template is missing."
    if not target_exists:
        return "missing", "copy-from-source", "Target template is missing."
    if _file_sha256(source_path) == _file_sha256(target_path):
        return "identical", "none", "Source and target template hashes match."
    return "different", "review-update", "Target template differs from source."


def _template_bundle_serialized_record(api: TemplateDiscoveryAPI, record: TemplateRecord) -> Dict[str, object]:
    serialized = api.serialize_record(record)
    return {
        "id": serialized.get("id"),
        "path": serialized.get("path"),
        "title": serialized.get("title"),
        "type": serialized.get("type"),
        "category": serialized.get("category"),
        "status": serialized.get("status"),
        "version": serialized.get("version"),
        "tags": serialized.get("tags") if isinstance(serialized.get("tags"), list) else [],
        "dependencies": serialized.get("dependencies") if isinstance(serialized.get("dependencies"), list) else [],
        "source": serialized.get("source"),
    }


def _collect_template_bundle_records(
    registry: TemplateRegistry,
    api: TemplateDiscoveryAPI,
    queries: Sequence[str],
    *,
    include_dependencies: bool,
) -> Tuple[List[Tuple[TemplateRecord, List[str]]], List[Dict[str, Any]], List[Dict[str, Any]]]:
    records: Dict[str, TemplateRecord] = {}
    requested_by: Dict[str, List[str]] = {}
    missing_templates: List[Dict[str, Any]] = []
    missing_dependencies: List[Dict[str, Any]] = []
    queue: List[Tuple[str, str]] = [(query, "requested") for query in queries]
    seen_edges: set[Tuple[str, str]] = set()

    while queue:
        query, parent = queue.pop(0)
        edge = (query, parent)
        if edge in seen_edges:
            continue
        seen_edges.add(edge)
        result = registry.resolve(query, allow_serena=False, strict=False)
        if result.record is None:
            missing_templates.append(
                {
                    "query": query,
                    "requested_by": parent,
                    "status": result.status,
                    "message": result.message,
                    "suggestions": list(result.suggestions),
                }
            )
            continue

        record = result.record
        records.setdefault(record.id, record)
        requested_by.setdefault(record.id, [])
        if parent not in requested_by[record.id]:
            requested_by[record.id].append(parent)

        if not include_dependencies:
            continue
        dependency_report = api.get_dependencies(record.id) or {}
        for missing in dependency_report.get("missing", []):
            missing_dependencies.append(
                {
                    "query": str(missing),
                    "requested_by": record.id,
                    "message": "Dependency could not be resolved from the local registry.",
                }
            )
        for resolved in dependency_report.get("resolved", []):
            if not isinstance(resolved, dict):
                continue
            dependency_id = str(resolved.get("id") or resolved.get("query") or "").strip()
            if dependency_id:
                queue.append((dependency_id, record.id))

    return [(record, requested_by.get(record.id, [])) for record in records.values()], missing_templates, missing_dependencies


def _template_bundle_asset(
    record: TemplateRecord,
    requested_by: Sequence[str],
    *,
    api: TemplateDiscoveryAPI,
    source_dir: Path,
    source_structure: RepoStructure,
    target_dir: Path | None,
    target_structure: RepoStructure | None,
) -> Dict[str, Any]:
    target_path = _template_bundle_target_path(record, source_structure, target_structure)
    status, action, reason = _template_bundle_status(record.absolute_path, target_path)
    dependencies = api.get_dependencies(record.id) or {}
    return {
        **_template_bundle_serialized_record(api, record),
        "requested_by": list(requested_by),
        "source_path": _relative_to_root(record.absolute_path, source_dir),
        "source_template_path": _template_relative_path(record, source_structure),
        "target_path": _relative_to_root(target_path, target_dir) if target_path and target_dir else None,
        "source_exists": record.absolute_path.exists() and record.absolute_path.is_file(),
        "target_exists": target_path.exists() and target_path.is_file() if target_path else None,
        "source_sha256": _file_sha256(record.absolute_path),
        "target_sha256": _file_sha256(target_path) if target_path else None,
        "bundle_status": status,
        "action": action,
        "reason": reason,
        "dependency_resolution": dependencies,
    }


def _template_bundle_manual_review_queue(assets: Sequence[Dict[str, Any]]) -> List[Dict[str, Any]]:
    queue = []
    for asset in assets:
        if asset.get("bundle_status") == "identical":
            continue
        queue.append(
            {
                "template_id": asset.get("id"),
                "title": asset.get("title"),
                "status": asset.get("bundle_status"),
                "action": asset.get("action"),
                "source_path": asset.get("source_path"),
                "target_path": asset.get("target_path"),
                "reason": asset.get("reason"),
            }
        )
    return queue


def _build_template_bundle_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    source_dir = _resolve_repo_directory(args.source_dir, "Source repository")
    target_dir = _resolve_repo_directory(args.target_dir, "Target repository") if args.target_dir else None
    source_structure = load_repo_structure(source_dir)
    target_structure = load_repo_structure(target_dir) if target_dir else None
    registry = TemplateRegistry(repo_root=source_dir)
    api = TemplateDiscoveryAPI(registry)
    collected, missing_templates, missing_dependencies = _collect_template_bundle_records(
        registry,
        api,
        args.templates,
        include_dependencies=not args.no_dependencies,
    )
    assets = [
        _template_bundle_asset(
            record,
            requested_by,
            api=api,
            source_dir=source_dir,
            source_structure=source_structure,
            target_dir=target_dir,
            target_structure=target_structure,
        )
        for record, requested_by in collected
    ]
    status_counts: Dict[str, int] = {}
    for asset in assets:
        status = str(asset.get("bundle_status"))
        status_counts[status] = status_counts.get(status, 0) + 1
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "non-destructive-template-bundle-plan",
        "executes_mutations": False,
        "source": {
            "path": _relative_to_root(source_dir, REPO_ROOT),
            "templates_root": _relative_to_root(source_structure.templates_root, source_dir),
            "git": _git_snapshot_for_repo(source_dir),
        },
        "target": {
            "path": _relative_to_root(target_dir, REPO_ROOT) if target_dir else None,
            "templates_root": _relative_to_root(target_structure.templates_root, target_dir) if target_structure and target_dir else None,
            "git": _git_snapshot_for_repo(target_dir) if target_dir else None,
        },
        "requested_templates": list(args.templates),
        "include_dependencies": not args.no_dependencies,
        "template_count": len(assets),
        "status_counts": status_counts,
        "templates": assets,
        "missing": {
            "templates": missing_templates,
            "dependencies": missing_dependencies,
        },
        "manual_review_queue": _template_bundle_manual_review_queue(assets),
        "recommended_verification_commands": _template_bundle_verification_commands(),
        "non_goals": [
            "No template files are copied into the target repository.",
            "No ZIP archive is created or extracted.",
            "No marketplace, package registry, or remote service is contacted.",
            "No cryptographic signing or key management is performed.",
            "No bulk import/export mutation is executed.",
            "No target repository branch, commit, push, or pull request is created.",
        ],
    }


def _render_template_bundle_runbook(plan: Dict[str, Any]) -> str:
    source = plan.get("source", {}) if isinstance(plan.get("source"), dict) else {}
    target = plan.get("target", {}) if isinstance(plan.get("target"), dict) else {}
    counts = plan.get("status_counts", {}) if isinstance(plan.get("status_counts"), dict) else {}
    templates = plan.get("templates") if isinstance(plan.get("templates"), list) else []
    missing = plan.get("missing", {}) if isinstance(plan.get("missing"), dict) else {}
    queue = plan.get("manual_review_queue") if isinstance(plan.get("manual_review_queue"), list) else []
    lines = [
        "# Template Bundle Plan",
        "",
        f"- Label: {plan.get('label')}",
        f"- Created at: {plan.get('created_at')}",
        f"- Mode: {plan.get('mode')}",
        f"- Executes mutations: {plan.get('executes_mutations')}",
        f"- Source: {source.get('path')} (`{source.get('templates_root')}`)",
        f"- Target: {target.get('path') or 'not supplied'}",
        f"- Include dependencies: {plan.get('include_dependencies')}",
        "",
        "## Requested Templates",
        "",
    ]
    for query in plan.get("requested_templates", []):
        lines.append(f"- `{query}`")

    lines.extend(["", "## Status Counts", ""])
    for status in ("identical", "different", "missing", "source-missing", "not-checked"):
        lines.append(f"- {status}: {counts.get(status, 0)}")

    lines.extend(["", "## Planned Templates", ""])
    if templates:
        lines.append("| Template | Status | Source | Target | Dependencies |")
        lines.append("| --- | --- | --- | --- | --- |")
        for item in templates:
            if not isinstance(item, dict):
                continue
            deps = item.get("dependencies") if isinstance(item.get("dependencies"), list) else []
            lines.append(
                f"| {_md_cell(item.get('id'))} | {_md_cell(item.get('bundle_status'))} | "
                f"{_md_cell(item.get('source_path'))} | {_md_cell(item.get('target_path') or 'not checked')} | "
                f"{_md_cell(', '.join(str(dep) for dep in deps) or 'none')} |"
            )
    else:
        lines.append("- No templates resolved.")

    lines.extend(["", "## Missing Inputs", ""])
    missing_templates = missing.get("templates") if isinstance(missing.get("templates"), list) else []
    missing_dependencies = missing.get("dependencies") if isinstance(missing.get("dependencies"), list) else []
    if not missing_templates and not missing_dependencies:
        lines.append("- No missing templates or dependencies.")
    for item in missing_templates:
        if isinstance(item, dict):
            lines.append(f"- Template `{item.get('query')}` requested by `{item.get('requested_by')}`: {item.get('message')}")
    for item in missing_dependencies:
        if isinstance(item, dict):
            lines.append(f"- Dependency `{item.get('query')}` requested by `{item.get('requested_by')}`: {item.get('message')}")

    lines.extend(["", "## Manual Review Queue", ""])
    if queue:
        lines.append("| Template | Status | Action | Reason |")
        lines.append("| --- | --- | --- | --- |")
        for item in queue:
            if not isinstance(item, dict):
                continue
            lines.append(
                f"| {_md_cell(item.get('template_id'))} | {_md_cell(item.get('status'))} | "
                f"{_md_cell(item.get('action'))} | {_md_cell(item.get('reason'))} |"
            )
    else:
        lines.append("- No manual review items. All compared templates are identical.")

    lines.extend(["", "## Recommended Verification Commands", ""])
    for command in plan.get("recommended_verification_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in plan.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(["", "No template copy, archive, extraction, marketplace, signing, Git, or target-repository mutation was executed by this plan.", ""])
    return "\n".join(lines)


def handle_template_bundle_plan(args: argparse.Namespace) -> None:
    plan = _build_template_bundle_plan(args)
    rendered_json = json.dumps(plan, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_template_bundle_runbook(plan)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote template bundle plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote template bundle runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


