    rehearsal_parser = subparsers.add_parser("rehearsal", help="Migration rehearsal planning operations")
    rehearsal_sub = rehearsal_parser.add_subparsers(dest="subcommand", required=True)
    rehearsal_plan = rehearsal_sub.add_parser("plan", help="Compose roadmap and checkpoint inputs into a rehearsal plan")
    rehearsal_plan.add_argument("--roadmap", required=True, help="Migration roadmap JSON produced by migration_roadmap.py")
    rehearsal_plan.add_argument("--checkpoint", required=True, help="Rollback checkpoint JSON produced by rollback checkpoint")
    rehearsal_plan.add_argument("--label", default="migration-rehearsal", help="Human-readable rehearsal label")
    rehearsal_plan.add_argument("--report-file", help="Optional path to write the rehearsal plan JSON")
    rehearsal_plan.add_argument("--runbook-file", help="Optional path to write the rehearsal runbook markdown")
    rehearsal_plan.add_argument("--max-items", type=int, default=10, help="Number of roadmap items to include in the runbook")
    rehearsal_plan.set_defaults(func=handle_rehearsal_plan)

    rollout_parser = subparsers.add_parser("rollout", help="Foundation rollout planning operations")
    rollout_sub = rollout_parser.add_subparsers(dest="subcommand", required=True)
    rollout_canary = rollout_sub.add_parser("canary-plan", help="Render a non-destructive foundation canary rollout plan")
    rollout_canary.add_argument("--label", default="foundation-canary-rollout", help="Human-readable rollout label")
    rollout_canary.add_argument("--report-file", help="Optional path to write the canary rollout plan JSON")
    rollout_canary.add_argument("--runbook-file", help="Optional path to write the canary rollout runbook markdown")
    rollout_canary.add_argument("--dry-run", action="store_true", help="Print the canary rollout plan JSON without writing files")
    rollout_canary.set_defaults(func=handle_rollout_canary_plan)
    rollout_experiment = rollout_sub.add_parser("experiment-plan", help="Render a non-destructive foundation experiment plan")
    rollout_experiment.add_argument("--label", default="foundation-experiment", help="Human-readable experiment label")
    rollout_experiment.add_argument("--control", default="current-foundation", help="Control variant name")
    rollout_experiment.add_argument("--variant", action="append", help="Candidate variant name; may be provided multiple times")
    rollout_experiment.add_argument("--error-threshold-pct", type=float, default=5.0, help="Failure-rate delta that stops the experiment")
    rollout_experiment.add_argument("--report-file", help="Optional path to write the experiment plan JSON")
    rollout_experiment.add_argument("--runbook-file", help="Optional path to write the experiment runbook markdown")
    rollout_experiment.add_argument("--dry-run", action="store_true", help="Print the experiment plan JSON without writing files")
    rollout_experiment.set_defaults(func=handle_rollout_experiment_plan)

    change_parser = subparsers.add_parser("change", help="Change advisory planning operations")
    change_sub = change_parser.add_subparsers(dest="subcommand", required=True)
    change_advisory = change_sub.add_parser("advisory", help="Render a non-destructive change advisory packet")
    change_advisory.add_argument("--summary", required=True, help="One-line summary of the proposed change")
    change_advisory.add_argument("--label", help="Human-readable advisory label; defaults to a slug from --summary")
    change_advisory.add_argument("--task", help="Taskmaster task ID associated with the change")
    change_advisory.add_argument("--path", dest="paths", action="append", help="Changed or proposed path; repeatable")
    change_advisory.add_argument("--previous-version", help="Previous semantic version for governance assessment")
    change_advisory.add_argument("--current-version", help="Current semantic version for governance assessment")
    change_advisory.add_argument("--lifecycle-from", help="Previous lifecycle state for governance assessment")
    change_advisory.add_argument("--lifecycle-to", help="Target lifecycle state for governance assessment")
    change_advisory.add_argument("--review-class", help="Explicit governance review class override")
    change_advisory.add_argument("--emergency", action="store_true", help="Force emergency governance assessment")
    change_advisory.add_argument("--note", help="Optional advisory note")
    change_advisory.add_argument("--report-file", help="Optional path to write the advisory JSON packet")
    change_advisory.add_argument("--runbook-file", help="Optional path to write the advisory Markdown runbook")
    change_advisory.add_argument("--dry-run", action="store_true", help="Print the advisory JSON without writing files")
    change_advisory.set_defaults(func=handle_change_advisory)

    agent_parser = subparsers.add_parser("agent", help="Agent compatibility and adapter operations")
    agent_sub = agent_parser.add_subparsers(dest="subcommand", required=True)
    agent_compatibility = agent_sub.add_parser(
        "compatibility-report",
        help="Validate and summarize the portable agent compatibility matrix",
    )
    agent_compatibility.add_argument(
        "--matrix-file",
        default=AGENT_COMPATIBILITY_MATRIX.relative_to(REPO_ROOT).as_posix(),
        help="Agent compatibility matrix JSON file",
    )
    agent_compatibility.add_argument("--report-file", help="Optional path to write the compatibility report JSON")
    agent_compatibility.add_argument("--runbook-file", help="Optional path to write the compatibility report markdown")
    agent_compatibility.add_argument("--strict", action="store_true", help="Fail when matrix validation issues are present")
    agent_compatibility.add_argument("--dry-run", action="store_true", help="Print the compatibility report JSON without writing files")
    agent_compatibility.set_defaults(func=handle_agent_compatibility_report)

    validation_parser = subparsers.add_parser("validation", help="Final validation suite operations")
    validation_sub = validation_parser.add_subparsers(dest="subcommand", required=True)
    validation_final_suite = validation_sub.add_parser(
        "final-suite",
        help="Plan or execute the portable final validation suite and sign-off runbook",
    )
    validation_final_suite.add_argument("--label", default="final-validation-suite", help="Human-readable validation label")
    validation_final_suite.add_argument(
        "--report-dir",
        default=(REPO_STRUCTURE.reports_root / "final-validation-suite").relative_to(REPO_ROOT).as_posix(),
        help="Directory for final validation report, runbook, and evidence logs",
    )
    validation_final_suite.add_argument("--report-file", help="Optional path to write the final validation JSON report")
    validation_final_suite.add_argument("--runbook-file", help="Optional path to write the final validation Markdown runbook")
    validation_final_suite.add_argument(
        "--execute",
        action="store_true",
        help="Run validation commands and capture per-check evidence logs",
    )
    validation_final_suite.add_argument(
        "--allow-failures",
        action="store_true",
        help="Write failed evidence without exiting nonzero when required checks fail",
    )
    validation_final_suite.add_argument(
        "--pytest-target",
        action="append",
        help="Pytest target to pass to the regression-test check; repeatable. Defaults to the full suite.",
    )
    validation_final_suite.add_argument(
        "--skip-pytest",
        action="store_true",
        help="Omit the pytest check from the final suite, for scoped rehearsal only",
    )
    validation_final_suite.add_argument("--dry-run", action="store_true", help="Print the final validation JSON without writing files")
    validation_final_suite.set_defaults(func=handle_validation_final_suite)

    emergency_parser = subparsers.add_parser("emergency", help="Emergency response planning operations")
    emergency_sub = emergency_parser.add_subparsers(dest="subcommand", required=True)
    emergency_plan = emergency_sub.add_parser("plan", help="Render a non-destructive emergency response plan")
    emergency_plan.add_argument("--severity", required=True, help="Incident severity from the emergency response policy, e.g. P0-P3")
    emergency_plan.add_argument("--summary", required=True, help="One-line incident summary")
    emergency_plan.add_argument("--label", help="Human-readable incident label; defaults to a slug from --summary")
    emergency_plan.add_argument("--policy-file", help="Override emergency response policy JSON path")
    emergency_plan.add_argument("--report-file", help="Optional path to write the emergency plan JSON")
    emergency_plan.add_argument("--runbook-file", help="Optional path to write the emergency response runbook markdown")
    emergency_plan.add_argument("--dry-run", action="store_true", help="Print the emergency response plan JSON without writing files")
    emergency_plan.set_defaults(func=handle_emergency_plan)

    sync_parser = subparsers.add_parser("sync", help="Cross-repository foundation sync planning operations")
    sync_sub = sync_parser.add_subparsers(dest="subcommand", required=True)
    sync_plan = sync_sub.add_parser("plan", help="Compare portable foundation assets between source and target repositories")
    sync_plan.add_argument("--source-dir", default=".", help="Source repository root (default: current repo)")
    sync_plan.add_argument("--target-dir", required=True, help="Target repository root to compare against")
    sync_plan.add_argument("--label", default="cross-repository-sync", help="Human-readable sync plan label")
    sync_plan.add_argument("--report-file", help="Optional path to write the sync plan JSON")
    sync_plan.add_argument("--runbook-file", help="Optional path to write the sync runbook markdown")
    sync_plan.set_defaults(func=handle_sync_plan)

    bootstrap_parser = subparsers.add_parser("bootstrap", help="Portable foundation bootstrap operations")
    bootstrap_sub = bootstrap_parser.add_subparsers(dest="subcommand", required=True)
    bootstrap_init = bootstrap_sub.add_parser("init", help="Scaffold starter foundation assets into a target repository")
    bootstrap_init.add_argument("--target-dir", default=".", help="Target repository root (default: current repo)")
    bootstrap_init.add_argument("--force", action="store_true", help="Overwrite existing starter files")
    bootstrap_init.add_argument("--templates-root", help="Repo-local templates root override")
    bootstrap_init.add_argument("--sessions-root", help="Repo-local sessions root override")
    bootstrap_init.add_argument("--plans-root", help="Repo-local plans root override")
    bootstrap_init.add_argument("--plan-state-dir", help="Repo-local plan state directory override")
    bootstrap_init.add_argument("--taskmaster-root", help="Repo-local Taskmaster root override")
    bootstrap_init.add_argument("--work-tracking-root", help="Repo-local work-tracking root override")
    bootstrap_init.add_argument("--reports-root", help="Repo-local reports root override")
    bootstrap_init.set_defaults(func=handle_bootstrap_init)

    wizard_parser = subparsers.add_parser("wizard", help="Guided workflow operations")
    wizard_sub = wizard_parser.add_subparsers(dest="subcommand", required=True)
    wizard_kickoff = wizard_sub.add_parser("kickoff", help="Interactively scaffold a task session, plan, and work-tracking state")
    wizard_kickoff.add_argument("--task", help="Task ID (numeric)")
    wizard_kickoff.add_argument("--slug", help="Slug for session/plan/work-tracking naming")
    wizard_kickoff.add_argument("--title", help="Human-readable task title")
    wizard_kickoff.add_argument("--goal", action="append", help="Goal checklist item (repeatable)")
    wizard_kickoff.add_argument("--task-source", help="Human-readable source line for the session metadata")
    wizard_kickoff.add_argument("--handler-target", help="Primary handler target/path for the generated plan")
    wizard_kickoff.add_argument("--force", action="store_true", help="Allow kickoff even if another ACTIVE folder exists")
    wizard_kickoff.set_defaults(func=handle_wizard_kickoff)

    scanner_parser = subparsers.add_parser("scanner", help="SSOT scanner operations")
    scanner_sub = scanner_parser.add_subparsers(dest="subcommand", required=True)
    scanner_run = scanner_sub.add_parser("run", help="Run a scanner tool and optionally log results")
    scanner_run.add_argument("tool", help="Scanner tool key (scanner, analyze, duplicates, migration, fixes, safe-reorg)")
    scanner_run.add_argument("--work", required=True, help="W field value for logging")
    scanner_run.add_argument("--handler", required=True, help="H field value for logging")
    scanner_run.add_argument("--evidence", required=True, help="E field value for logging")
    scanner_run.add_argument("--log-note", help="Log note to append after successful run")
    scanner_run.add_argument("--folder", help="Work-tracking folder override")
    scanner_run.add_argument("--document", default="TRACKER", help="Work-tracking markdown name for logging")
    scanner_run.set_defaults(func=handle_scanner_run)

    return parser


def main(argv: Optional[List[str]] = None) -> int:
    parser = build_parser()
    args, unknown = parser.parse_known_args(argv)

    if unknown:
        if getattr(args, "command", None) == "scanner" and getattr(args, "subcommand", None) == "run":
            setattr(args, "scanner_args", unknown)
        else:
            parser.error(f"unrecognized arguments: {' '.join(unknown)}")

    try:
        args.func(args)
    except TaskError as exc:
        message = str(exc)
        print(f"error: {message}", file=sys.stderr)
        lowered = message.lower()
        if any(keyword in lowered for keyword in ("guard", "plan sync", "branch policy")):
            print(_meta_guard_message(), file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        return 130
    return 0


if __name__ == "__main__":
    sys.exit(main())
