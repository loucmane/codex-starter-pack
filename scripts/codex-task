def _build_maintenance_security_domain() -> Dict[str, Any]:
    latest = _success_metrics_latest("*-task50-security-audit-process-COMPLETED/reports/security-audit-process/security-audit-*.json")
    path: Path | str = latest or "reports/security-audit-process/latest.json"
    source = _success_metrics_load_json(path)
    evidence = [_maintenance_path_state(source["path"])]
    if source["status"] == "missing":
        return _maintenance_domain(
            domain_id="security-maintenance",
            title="Security maintenance",
            cadence="monthly",
            purpose="Keep security validation and manual patch-review evidence current.",
            status="missing",
            evidence=evidence,
            refresh_commands=(
                "python3 scripts/codex-task security audit --summary <summary> --report-file reports/security-audit-process/latest.json --runbook-file reports/security-audit-process/latest.md",
            ),
            message="Security audit evidence is missing.",
            manual_actions=["Regenerate the security audit packet before claiming security maintenance is reviewed."],
        )
    if source["status"] == "invalid":
        return _maintenance_domain(
            domain_id="security-maintenance",
            title="Security maintenance",
            cadence="monthly",
            purpose="Keep security validation and manual patch-review evidence current.",
            status="blocked",
            evidence=evidence,
            refresh_commands=(
                "python3 scripts/codex-task security audit --summary <summary> --report-file reports/security-audit-process/latest.json --runbook-file reports/security-audit-process/latest.md",
            ),
            message=str(source["message"]),
            manual_actions=["Regenerate a valid security audit JSON packet."],
        )
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    controls = payload.get("controls") if isinstance(payload.get("controls"), list) else []
    available = sum(1 for control in controls if isinstance(control, Mapping) and control.get("status") == "available")
    non_available = [
        str(control.get("id"))
        for control in controls
        if isinstance(control, Mapping) and control.get("status") != "available"
    ]
    status = "ready" if controls and not non_available else "review"
    actions = [f"Review security control evidence for: {', '.join(non_available)}."] if non_available else []
    actions.append("Perform dependency vulnerability review manually; this packet does not contact CVE databases or package registries.")
    return _maintenance_domain(
        domain_id="security-maintenance",
        title="Security maintenance",
        cadence="monthly",
        purpose="Keep security validation and manual patch-review evidence current.",
        status=status,
        evidence=evidence,
        refresh_commands=(
            "python3 scripts/codex-task security audit --summary <summary> --report-file reports/security-audit-process/latest.json --runbook-file reports/security-audit-process/latest.md",
        ),
        message=f"Security audit reports {available}/{len(controls)} available control(s).",
        details={"available_controls": available, "total_controls": len(controls), "non_available_controls": non_available},
        manual_actions=actions,
    )


def _build_maintenance_dependency_domain() -> Dict[str, Any]:
    candidates = ("pyproject.toml", "requirements.txt", "package.json", "package-lock.json", "pnpm-lock.yaml")
    states = [_maintenance_path_state(candidate) for candidate in candidates]
    present = [state for state in states if state["exists"]]
    status = "ready" if present else "missing"
    actions = [
        "Review dependency updates manually before changing manifests.",
        "Run the relevant test and guard suite after any future dependency change.",
        "Do not claim vulnerability coverage unless a future task adds explicit CVE/SBOM evidence.",
    ]
    return _maintenance_domain(
        domain_id="dependency-maintenance",
        title="Dependency maintenance",
        cadence="monthly",
        purpose="Keep dependency inventory and update review guidance visible without applying updates.",
        status=status,
        evidence=states,
        refresh_commands=(
            "python3 scripts/codex-task security audit --summary <summary> --report-file reports/security-audit-process/latest.json --runbook-file reports/security-audit-process/latest.md",
            "python3 -m pytest tests/meta_workflow_guard/test_codex_task.py",
        ),
        message=f"Found {len(present)} dependency manifest(s)." if present else "No dependency manifest evidence found.",
        details={"present_manifests": [state["path"] for state in present]},
        manual_actions=actions,
    )


def _build_maintenance_domains() -> List[Dict[str, Any]]:
    return [
        _build_maintenance_workflow_domain(),
        _build_maintenance_operational_domain(),
        _build_maintenance_post_migration_domain(),
        _build_maintenance_performance_domain(),
        _build_maintenance_template_quality_domain(),
        _build_maintenance_cleanup_domain(),
        _build_maintenance_security_domain(),
        _build_maintenance_dependency_domain(),
    ]


def _summarise_maintenance_domains(domains: Sequence[Mapping[str, Any]]) -> Dict[str, Any]:
    counts = Counter(str(domain.get("status")) for domain in domains)
    total = len(domains)
    score = round(sum(float(domain.get("score", 0) or 0) for domain in domains) / total, 2) if total else 0.0
    if counts.get("blocked"):
        aggregate_status = "blocked"
    elif counts.get("missing") or counts.get("review"):
        aggregate_status = "needs-review"
    else:
        aggregate_status = "ready"
    return {
        "aggregate_status": aggregate_status,
        "maintenance_score_pct": score,
        "total_domains": total,
        "ready": counts.get("ready", 0),
        "review": counts.get("review", 0),
        "missing": counts.get("missing", 0),
        "blocked": counts.get("blocked", 0),
    }


def _maintenance_action_queue(domains: Sequence[Mapping[str, Any]]) -> List[Dict[str, Any]]:
    queue: List[Dict[str, Any]] = []
    for domain in domains:
        if domain.get("status") == "ready" and not domain.get("manual_actions"):
            continue
        for action in domain.get("manual_actions", []) or []:
            queue.append(
                {
                    "domain": domain.get("id"),
                    "status": domain.get("status"),
                    "cadence": domain.get("cadence"),
                    "action": action,
                }
            )
    return queue


def _maintenance_gates(domains: Sequence[Mapping[str, Any]]) -> List[Dict[str, Any]]:
    domain_by_id = {str(domain.get("id")): domain for domain in domains}
    gate_ids = (
        ("workflow-health", "Workflow pointers, guard, and Taskmaster health stay coherent."),
        ("performance-baseline", "Performance telemetry remains current."),
        ("template-quality", "Template quality scorecard is available for review."),
        ("security-maintenance", "Security audit and patch-review evidence is current."),
        ("dependency-maintenance", "Dependency inventory and manual update process are visible."),
    )
    return [
        {
            "gate": gate_id,
            "status": str(domain_by_id.get(gate_id, {}).get("status", "missing")),
            "target": target,
        }
        for gate_id, target in gate_ids
    ]


def _build_maintenance_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    domains = _build_maintenance_domains()
    summary = _summarise_maintenance_domains(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label or "long-term-maintenance",
        "mode": "static-non-destructive-long-term-maintenance-plan",
        "executes_mutations": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "domains": domains,
        "maintenance_gates": _maintenance_gates(domains),
        "manual_action_queue": _maintenance_action_queue(domains),
        "recommended_refresh_commands": list(MAINTENANCE_REFRESH_COMMANDS),
        "non_goals": list(MAINTENANCE_NON_GOALS),
    }


def _render_maintenance_plan(report: Dict[str, Any]) -> str:
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    lines = [
        "# Long-term Maintenance Plan",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes mutations: {report.get('executes_mutations')}",
        f"- Aggregate status: `{summary.get('aggregate_status')}`",
        f"- Maintenance score: {summary.get('maintenance_score_pct')}%",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Maintenance Domains",
        "",
        "| Domain | Cadence | Status | Score | Evidence |",
        "| --- | --- | --- | ---: | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        evidence_paths = [
            str(item.get("path"))
            for item in domain.get("evidence", [])
            if isinstance(item, Mapping)
        ]
        lines.append(
            f"| {_md_cell(domain.get('title'))} | {_md_cell(domain.get('cadence'))} | "
            f"`{_md_cell(domain.get('status'))}` | {domain.get('score')} | {_md_cell(', '.join(evidence_paths) or 'None')} |"
        )

    lines.extend(["", "## Domain Details", ""])
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        lines.extend(
            [
                f"### {domain.get('title')}",
                "",
                f"- ID: `{domain.get('id')}`",
                f"- Cadence: {domain.get('cadence')}",
                f"- Status: `{domain.get('status')}`",
                f"- Purpose: {domain.get('purpose')}",
                f"- Message: {domain.get('message')}",
                "",
                "Refresh commands:",
            ]
        )
        for command in domain.get("refresh_commands", []):
            lines.append(f"- `{command}`")
        actions = domain.get("manual_actions", [])
        if actions:
            lines.extend(["", "Manual actions:"])
            for action in actions:
                lines.append(f"- {action}")
        lines.append("")

    lines.extend(["## Maintenance Gates", ""])
    for gate in report.get("maintenance_gates", []):
        if isinstance(gate, Mapping):
            lines.append(f"- `{gate.get('gate')}`: `{gate.get('status')}` - {gate.get('target')}")

    lines.extend(["", "## Manual Action Queue", ""])
    queue = report.get("manual_action_queue", [])
    if queue:
        for item in queue:
            if isinstance(item, Mapping):
                lines.append(f"- `{item.get('domain')}` ({item.get('status')}, {item.get('cadence')}): {item.get('action')}")
    else:
        lines.append("- No manual review actions for the current maintenance inputs.")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This maintenance plan is static and evidence-based. It composes existing repository reports and requested output files only; it does not install schedulers, send alerts, apply patches, update dependencies, create tickets, mutate templates, or contact external services.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_maintenance_plan(args: argparse.Namespace) -> None:
    report = _build_maintenance_plan(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_maintenance_plan(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] != "ready":
            raise TaskError("Long-term maintenance aggregate status is not ready")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote long-term maintenance plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote long-term maintenance runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] != "ready":
        raise TaskError("Long-term maintenance aggregate status is not ready")


DEPLOYMENT_READINESS_NON_GOALS: Tuple[str, ...] = (
    "No production application deployment, release publication, package publish, or hosted service update is executed.",
    "No traffic routing, feature flag rollout, automatic promotion, rollback execution, or service canary is performed.",
    "No live monitoring service, dashboard, alert delivery, notification, scheduler, daemon, ticketing, or external observability integration is created or contacted.",
    "No automatic guard auto-fix, cleanup mutation, maintenance automation activation, dependency update, or patch application is run.",
    "No email, chat, publication, stakeholder notification, calendar event, celebration scheduling, or external communication is sent.",
    "No Taskmaster, session, plan, work-tracking, Git, report source, template, or external state is mutated beyond requested production readiness packet artifacts.",
)

DEPLOYMENT_READINESS_STATUS_ORDER: Dict[str, int] = {
    "ready": 0,
    "not-applicable": 1,
    "review": 2,
    "needs-evidence": 3,
    "blocked": 4,
}


def _deployment_status(value: object, *, exists: bool = True) -> str:
    if not exists:
        return "needs-evidence"
    text = str(value or "missing").strip().lower().replace("_", "-")
    aliases = {
        "ok": "ready",
        "pass": "ready",
        "passed": "ready",
        "success": "ready",
        "complete": "ready",
        "completed": "ready",
        "available": "ready",
        "needs-review": "review",
        "needs-refresh": "review",
        "warn": "review",
        "warning": "review",
        "warnings": "review",
        "missing": "needs-evidence",
        "needs-evidence": "needs-evidence",
        "needs-implementation": "blocked",
        "fail": "blocked",
        "failed": "blocked",
        "failure": "blocked",
        "error": "blocked",
        "invalid": "blocked",
        "n/a": "not-applicable",
        "na": "not-applicable",
        "not-applicable": "not-applicable",
    }
    return aliases.get(text, text if text in DEPLOYMENT_READINESS_STATUS_ORDER else "review")


def _deployment_get_nested(mapping: Mapping[str, Any], dotted: str) -> object:
    current: object = mapping
    for part in dotted.split("."):
        if not isinstance(current, Mapping):
            return None
        current = current.get(part)
    return current


def _deployment_domain(
    *,
    domain_id: str,
    title: str,
    purpose: str,
    status: str,
    evidence: Sequence[Mapping[str, Any]],
    refresh_commands: Sequence[str],
    message: str,
    manual_actions: Sequence[str] = (),
    details: Optional[Mapping[str, Any]] = None,
) -> Dict[str, Any]:
    missing = [str(item.get("path")) for item in evidence if not item.get("exists")]
    return {
        "id": domain_id,
        "title": title,
        "purpose": purpose,
        "status": status,
        "evidence": [dict(item) for item in evidence],
        "missing_evidence_paths": missing,
        "refresh_commands": list(refresh_commands),
        "message": message,
        "manual_actions": list(manual_actions),
        "details": dict(details or {}),
    }


def _deployment_evidence_domain(
    *,
    domain_id: str,
    title: str,
    purpose: str,
    evidence_paths: Sequence[str],
    refresh_commands: Sequence[str],
    ready_message: str,
    missing_message: str,
    manual_actions: Sequence[str] = (),
) -> Dict[str, Any]:
    evidence = [_enhancement_path_state(path) for path in evidence_paths]
    missing = [item["path"] for item in evidence if not item["exists"]]
    status = "needs-evidence" if missing else "ready"
    message = ready_message if status == "ready" else f"{missing_message}: {', '.join(missing)}."
    return _deployment_domain(
        domain_id=domain_id,
        title=title,
        purpose=purpose,
        status=status,
        evidence=evidence,
        refresh_commands=refresh_commands,
        message=message,
        manual_actions=manual_actions,
        details={"source_type": "path-evidence"},
    )


def _deployment_latest_packet_path(pattern: str | Sequence[str]) -> Optional[Path]:
    patterns = [pattern] if isinstance(pattern, str) else list(pattern)
    candidates: List[Path] = []
    for item in patterns:
        candidates.extend(REPO_STRUCTURE.work_tracking_active_root.glob(item))
        candidates.extend(REPO_STRUCTURE.work_tracking_archive_root.glob(item))
    unique = set(candidates)
    return max(unique, key=lambda item: (item.stat().st_mtime_ns, str(item))) if unique else None


def _deployment_latest_packet_domain(
    *,
    domain_id: str,
    title: str,
    purpose: str,
    pattern: str | Sequence[str],
    refresh_commands: Sequence[str],
    status_fields: Sequence[str],
    value_fields: Sequence[str] = (),
    ready_message: str,
    missing_message: str,
    manual_actions: Sequence[str] = (),
) -> Dict[str, Any]:
    patterns = [pattern] if isinstance(pattern, str) else list(pattern)
    pattern_detail: str | List[str] = patterns[0] if len(patterns) == 1 else patterns
    latest = _deployment_latest_packet_path(patterns)
    if latest is None:
        evidence = [_enhancement_path_state(item) for item in patterns]
        return _deployment_domain(
            domain_id=domain_id,
            title=title,
            purpose=purpose,
            status="needs-evidence",
            evidence=evidence,
            refresh_commands=refresh_commands,
            message=missing_message,
            manual_actions=manual_actions,
            details={"pattern": pattern_detail, "source_type": "latest-packet"},
        )

    source = _success_metrics_load_json(latest)
    evidence = [
        {
            "path": str(source.get("path")),
            "exists": bool(source.get("exists")),
            "kind": "file" if source.get("exists") else "missing",
            "load_status": source.get("status"),
        }
    ]
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    if source.get("status") == "invalid":
        return _deployment_domain(
            domain_id=domain_id,
            title=title,
            purpose=purpose,
            status="blocked",
            evidence=evidence,
            refresh_commands=refresh_commands,
            message=str(source.get("message")),
            manual_actions=("Regenerate a valid source packet before production readiness review.",),
            details={"pattern": pattern, "source": source},
        )

    status_value: object = None
    for field in status_fields:
        status_value = _deployment_get_nested(payload, field)
        if status_value is not None:
            break
    status = _deployment_status(status_value)
    values = {field: _deployment_get_nested(payload, field) for field in value_fields}
    message = ready_message if status == "ready" else f"{title} source status is `{status_value}`."
    actions = list(manual_actions)
    if status in {"review", "needs-evidence"}:
        actions.append("Review or refresh this source packet before treating Task 80 as release/BAU ready.")
    if status == "blocked":
        actions.append("Resolve the source packet blocker before Task 80 sign-off.")
    return _deployment_domain(
        domain_id=domain_id,
        title=title,
        purpose=purpose,
        status=status,
        evidence=evidence,
        refresh_commands=refresh_commands,
        message=message,
        manual_actions=actions,
        details={
            "pattern": pattern_detail,
            "source": {key: source[key] for key in ("path", "exists", "status", "message")},
            "status_value": status_value,
            "values": values,
        },
    )


def _build_deployment_workflow_domain() -> Dict[str, Any]:
    workflow = _workflow_snapshot()
    taskmaster = _taskmaster_snapshot()
    summary = taskmaster.get("summary") if isinstance(taskmaster.get("summary"), Mapping) else {}
    invalid_refs = int(summary.get("invalid_refs") or 0)
    current_session = workflow.get("current_session") if isinstance(workflow.get("current_session"), Mapping) else {}
    current_plan = workflow.get("current_plan") if isinstance(workflow.get("current_plan"), Mapping) else {}
    active = workflow.get("active_work_tracking") if isinstance(workflow.get("active_work_tracking"), list) else []
    blockers: List[str] = []
    if invalid_refs:
        blockers.append(f"{invalid_refs} invalid Taskmaster dependency reference(s)")
    if not current_session.get("resolved"):
        blockers.append("sessions/current missing")
    if not current_plan.get("resolved"):
        blockers.append("plans/current missing")
    if len(active) != 1:
        blockers.append(f"expected 1 active work-tracking folder, found {len(active)}")
    status = "ready" if not blockers else "blocked"
    evidence = [
        _enhancement_path_state(TASKMASTER_TASKS_JSON_REL),
        _enhancement_path_state(str(current_session.get("resolved") or SESSIONS_CURRENT_REL)),
        _enhancement_path_state(str(current_plan.get("resolved") or PLANS_CURRENT_REL)),
    ]
    evidence.extend(_enhancement_path_state(str(path)) for path in active)
    return _deployment_domain(
        domain_id="workflow-and-taskmaster-health",
        title="Workflow and Taskmaster health",
        purpose="Confirm the production-readiness review itself is task-aligned and dependency-clean.",
        status=status,
        evidence=evidence,
        refresh_commands=(
            "python3 scripts/codex-task taskmaster health",
            "python3 scripts/codex-task work-tracking audit",
            "python3 scripts/codex-guard validate --include-untracked",
        ),
        message="Workflow pointers and Taskmaster dependencies are ready." if not blockers else "; ".join(blockers),
        manual_actions=("Fix workflow or Taskmaster blockers before closing Task 80.",) if blockers else (),
        details={"workflow": workflow, "taskmaster_summary": summary},
    )


