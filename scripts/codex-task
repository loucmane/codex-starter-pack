                "docs/ai/work-tracking/archive/20260514-task69-phase5-enhancement-planning-COMPLETED/",
            ),
            refresh_command="python3 scripts/codex-task work-tracking audit",
        ),
    ]


def _summarise_celebration_domains(domains: Sequence[Mapping[str, Any]]) -> Dict[str, Any]:
    total = len(domains)
    ready = sum(1 for domain in domains if domain.get("status") == "ready")
    needs_evidence = sum(1 for domain in domains if domain.get("status") == "needs-evidence")
    blocked = sum(1 for domain in domains if domain.get("status") == "blocked")
    if blocked:
        aggregate_status = "blocked"
    elif needs_evidence:
        aggregate_status = "needs-evidence"
    else:
        aggregate_status = "ready"
    return {
        "aggregate_status": aggregate_status,
        "total_domains": total,
        "ready": ready,
        "needs_evidence": needs_evidence,
        "blocked": blocked,
    }


def _celebration_refresh_commands(domains: Sequence[Mapping[str, Any]]) -> List[str]:
    commands: List[str] = []
    for domain in domains:
        command = domain.get("refresh_command")
        if isinstance(command, str) and command and command not in commands:
            commands.append(command)
    commands.extend(
        command
        for command in (
            "python3 scripts/codex-task celebration plan --report-file reports/celebration-planning/latest.json --runbook-file reports/celebration-planning/latest.md",
            "python3 scripts/codex-guard validate --include-untracked",
        )
        if command not in commands
    )
    return commands


def _celebration_achievement_highlights(domains: Sequence[Mapping[str, Any]]) -> List[Dict[str, str]]:
    taskmaster = _taskmaster_snapshot()
    summary = taskmaster.get("summary") if isinstance(taskmaster.get("summary"), Mapping) else {}
    status_counts = summary.get("status_counts") if isinstance(summary.get("status_counts"), Mapping) else {}
    done_tasks = status_counts.get("done", "unknown")
    pending_tasks = status_counts.get("pending", "unknown")
    invalid_refs = summary.get("invalid_refs", 0)
    return [
        {
            "id": "delivery-progress",
            "title": "Foundation delivery progress",
            "message": f"Taskmaster reports {done_tasks} completed parent tasks, {pending_tasks} pending tasks, and {invalid_refs} invalid dependency refs.",
            "evidence_domain": "taskmaster-delivery-health",
        },
        {
            "id": "success-scorecard",
            "title": "Success metrics are reportable",
            "message": "The static success metrics packet provides a reusable scorecard for the foundation state.",
            "evidence_domain": "success-metrics",
        },
        {
            "id": "stakeholder-ready",
            "title": "Stakeholder narrative is available",
            "message": "The stakeholder packet gives review-ready delivery, workflow, risk, and communication framing.",
            "evidence_domain": "stakeholder-reporting",
        },
        {
            "id": "roadmap-grounded",
            "title": "Next roadmap is grounded",
            "message": "The Phase 5 enhancement packet separates ready next actions from planned future work.",
            "evidence_domain": "phase5-roadmap",
        },
    ]


