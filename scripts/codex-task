def handle_aegis_kickoff(args: argparse.Namespace) -> None:
    try:
        if args.local:
            if not args.title:
                raise AegisError("aegis kickoff --local requires --title")
            payload = aegis_start_local_work(
                args.target_dir,
                title=args.title,
                slug=args.slug,
                goals=list(args.goal or []),
                create_branch=not args.no_create_branch,
                source_root=REPO_ROOT,
            )
        else:
            missing = [name for name in ("task", "slug", "title") if not getattr(args, name)]
            if missing:
                raise AegisError(f"aegis kickoff requires: {', '.join('--' + name for name in missing)}")
            payload = aegis_kickoff(
                args.target_dir,
                task_id=args.task,
                slug=args.slug,
                title=args.title,
                goals=list(args.goal or []),
                create_branch=not args.no_create_branch,
                source_root=REPO_ROOT,
            )
    except AegisError as exc:
        raise TaskError(str(exc)) from exc
    _print_json(payload)


def handle_aegis_start(args: argparse.Namespace) -> None:
    try:
        payload = aegis_start_local_work(
            args.target_dir,
            title=args.title,
            slug=args.slug,
            goals=list(args.goal or []),
            create_branch=not args.no_create_branch,
            source_root=REPO_ROOT,
        )
    except AegisError as exc:
        raise TaskError(str(exc)) from exc
    _print_json(payload)


def handle_aegis_observe(args: argparse.Namespace) -> None:
    try:
        if args.observe_subcommand == "start":
            payload = aegis_start_observation(
                args.target_dir,
                title=args.title,
                slug=args.slug or "",
                goals=list(args.goal or []),
                source_root=REPO_ROOT,
            )
        elif args.observe_subcommand == "stop":
            payload = aegis_stop_observation(
                args.target_dir,
                summary=args.summary or "",
                allow_dirty=args.allow_dirty,
                collect_artifacts=args.collect_artifacts,
                source_root=REPO_ROOT,
            )
        else:
            raise AegisError("unknown observe subcommand")
    except AegisError as exc:
        raise TaskError(str(exc)) from exc
    _print_json(payload)
    if payload.get("status") == "blocked":
        raise TaskError("Aegis observation stop refused unexpected working-tree deltas")


