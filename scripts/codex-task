        for item in domain.get("evidence_paths", []):
            if isinstance(item, dict):
                lines.append(f"- `{item.get('path')}` ({item.get('kind')})")
        lines.append("")

    lines.extend(
        [
            "## Historical Requirements Reconciled Out Of Scope",
            "",
            "| Historical Requirement | Current Boundary |",
            "| --- | --- |",
        ]
    )
    for item in report.get("out_of_scope_requirements", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| {_md_cell(item.get('historical_requirement'))} | {_md_cell(item.get('current_boundary'))} |"
        )

    lines.extend(["", "## Feedback Capture Guidance", ""])
    for item in report.get("feedback_capture_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Gate Review Checklist", ""])
    for item in report.get("gate_review_checklist", []):
        if not isinstance(item, dict):
            continue
        lines.append(f"- [ ] {item.get('item')} Evidence: {item.get('evidence')}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static Phase 4 documentation delivery review artifact. It composes existing documentation, training, communication, operations, Phase 3, and validation evidence, but it does not publish docs, deploy training, schedule meetings, send communications, collect surveys, update dashboards, or contact external systems.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_phase4_documentation_review(args: argparse.Namespace) -> None:
    report = _build_phase4_documentation_review(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_phase4_documentation_review(report)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote Phase 4 documentation review to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote Phase 4 documentation runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


