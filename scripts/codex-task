def _summarise_continuous_improvement_domains(domains: Sequence[Mapping[str, Any]]) -> Dict[str, Any]:
    total = len(domains)
    ready = sum(1 for domain in domains if domain.get("status") == "ready")
    needs_evidence = sum(1 for domain in domains if domain.get("status") == "needs-evidence")
    blocked = sum(1 for domain in domains if domain.get("status") == "blocked")
    if blocked:
        aggregate_status = "blocked"
        improvement_signal = "blocked"
    elif needs_evidence:
        aggregate_status = "needs-evidence"
        improvement_signal = "needs-refresh"
    else:
        aggregate_status = "ready"
        improvement_signal = "ready-for-review"
    return {
        "aggregate_status": aggregate_status,
        "improvement_signal": improvement_signal,
        "total_domains": total,
        "ready": ready,
        "needs_evidence": needs_evidence,
        "blocked": blocked,
    }


def _continuous_improvement_refresh_commands(domains: Sequence[Mapping[str, Any]]) -> List[str]:
    commands: List[str] = []
    for domain in domains:
        for command in domain.get("refresh_commands", []):
            if isinstance(command, str) and command and command not in commands:
                commands.append(command)
    commands.extend(
        command
        for command in (
            "python3 scripts/codex-task enhancement continuous-improvement --report-file reports/continuous-improvement/latest.json --runbook-file reports/continuous-improvement/latest.md",
            "python3 scripts/codex-task taskmaster health",
            "python3 scripts/codex-guard validate --include-untracked",
        )
        if command not in commands
    )
    return commands


def _continuous_improvement_review_queue(domains: Sequence[Mapping[str, Any]]) -> List[Dict[str, Any]]:
    queue: List[Dict[str, Any]] = []
    for domain in domains:
        if not isinstance(domain, Mapping):
            continue
        if domain.get("status") == "ready":
            queue.append(
                {
                    "domain_id": domain.get("id"),
                    "title": domain.get("title"),
                    "stage": domain.get("stage"),
                    "action": domain.get("required_action"),
                    "handoff_destination": domain.get("handoff_destination"),
                }
            )
        else:
            queue.append(
                {
                    "domain_id": domain.get("id"),
                    "title": domain.get("title"),
                    "stage": domain.get("stage"),
                    "action": domain.get("required_action"),
                    "missing_evidence_paths": list(domain.get("missing_evidence_paths", [])),
                }
            )
    return queue


def _build_continuous_improvement_review(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "continuous-improvement"
    domains = [_continuous_improvement_domain(definition) for definition in _continuous_improvement_domain_definitions()]
    summary = _summarise_continuous_improvement_domains(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-continuous-improvement-review-packet",
        "executes_actions": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "loop_stages": [
            {"stage": "capture", "purpose": "Collect observations and suggestions as repository evidence."},
            {"stage": "prioritize", "purpose": "Select candidates using metrics, roadmap evidence, and explicit scope boundaries."},
            {"stage": "validate", "purpose": "Use experiment planning, CAB review, and final validation evidence before adoption."},
            {"stage": "learn", "purpose": "Convert incidents, stakeholder risks, and knowledge gaps into reviewed follow-ups."},
            {"stage": "publish", "purpose": "Expose the operating cadence, refresh commands, handoff, and archive evidence."},
        ],
        "domains": domains,
        "review_queue": _continuous_improvement_review_queue(domains),
        "recommended_refresh_commands": _continuous_improvement_refresh_commands(domains),
        "planning_guidance": list(CONTINUOUS_IMPROVEMENT_GUIDANCE),
        "non_goals": list(CONTINUOUS_IMPROVEMENT_NON_GOALS),
    }


def _render_continuous_improvement_review(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    lines = [
        "# Continuous Improvement Review Packet",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        f"- Improvement signal: {summary.get('improvement_signal')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Summary",
        "",
        f"- Total domains: {summary.get('total_domains')}",
        f"- Ready: {summary.get('ready')}",
        f"- Needs evidence: {summary.get('needs_evidence')}",
        f"- Blocked: {summary.get('blocked')}",
        "",
        "## Improvement Loop Stages",
        "",
    ]
    for stage in report.get("loop_stages", []):
        if isinstance(stage, Mapping):
            lines.append(f"- `{stage.get('stage')}`: {stage.get('purpose')}")

    lines.extend(
        [
            "",
            "## Continuous Improvement Domains",
            "",
            "| Domain | Stage | Cadence | Status | Missing Evidence |",
            "| --- | --- | --- | --- | --- |",
        ]
    )
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        missing = "<br>".join(domain.get("missing_evidence_paths", [])) or "None"
        lines.append(
            f"| {_md_cell(domain.get('title'))} | `{_md_cell(domain.get('stage'))}` | "
            f"{_md_cell(domain.get('cadence'))} | `{_md_cell(domain.get('status'))}` | {_md_cell(missing)} |"
        )

    lines.extend(["", "## Domain Details", ""])
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        lines.extend(
            [
                f"### {domain.get('title')}",
                "",
                f"- ID: `{domain.get('id')}`",
                f"- Stage: `{domain.get('stage')}`",
                f"- Cadence: {domain.get('cadence')}",
                f"- Purpose: {domain.get('purpose')}",
                f"- Improvement use: {domain.get('improvement_use')}",
                f"- Required action: {domain.get('required_action')}",
                f"- Handoff destination: {domain.get('handoff_destination')}",
                "",
                "Evidence paths:",
            ]
        )
        for item in domain.get("evidence_paths", []):
            if isinstance(item, Mapping):
                lines.append(f"- `{item.get('path')}` ({item.get('kind')})")
        lines.extend(["", "Refresh commands:"])
        for command in domain.get("refresh_commands", []):
            lines.append(f"- `{command}`")
        lines.append("")

    lines.extend(["## Review Queue", ""])
    for item in report.get("review_queue", []):
        if isinstance(item, Mapping):
            lines.append(f"- `{item.get('domain_id')}` ({item.get('stage')}): {item.get('action')}")

    lines.extend(["", "## Planning Guidance", ""])
    for item in report.get("planning_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static continuous-improvement review artifact. It composes existing repository evidence and requested output files only; it does not create live suggestion systems, experimentation backends, dashboards, schedulers, tickets, notifications, approvals, or external integrations.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_continuous_improvement_review(args: argparse.Namespace) -> None:
    report = _build_continuous_improvement_review(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_continuous_improvement_review(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] != "ready":
            raise TaskError("Continuous improvement review aggregate status is not ready")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote continuous improvement review to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote continuous improvement runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] != "ready":
        raise TaskError("Continuous improvement review aggregate status is not ready")


CELEBRATION_PLANNING_NON_GOALS: Tuple[str, ...] = (
    "No calendar event, meeting invitation, reminder, scheduling workflow, or event logistics automation is created.",
    "No email, chat, social post, blog post, website, external publication, notification, or webhook is sent or published.",
    "No award decision, compensation action, HR record, or personal attribution is made by this command.",
    "No slide deck, hosted demo, video, media asset, live dashboard, or external presentation system is generated.",
    "No survey, response collection, sentiment analysis, analytics tracking, or contact database is created.",
    "No Taskmaster tasks, sessions, plans, work tracking, Git state, report sources, templates, or external systems are mutated beyond requested celebration planning artifacts.",
)

CELEBRATION_PLANNING_GUIDANCE: Tuple[str, ...] = (
    "Treat this packet as draft review material; a human owner must approve any announcement, event, or publication.",
    "Refresh success, stakeholder, and roadmap evidence before sharing celebration materials externally.",
    "Keep recognition prompts team-safe and evidence-based; do not infer individual awards or sensitive people decisions.",
    "Use static evidence paths in the packet so reviewers can verify every celebration claim.",
)


def _celebration_domain(
    *,
    domain_id: str,
    title: str,
    purpose: str,
    evidence_paths: Sequence[str],
    refresh_command: str,
    details: Optional[Mapping[str, Any]] = None,
) -> Dict[str, Any]:
    evidence = [_enhancement_path_state(path) for path in evidence_paths]
    missing = [item["path"] for item in evidence if not item["exists"]]
    status = "needs-evidence" if missing else "ready"
    message = (
        f"{title} evidence is ready for celebration planning."
        if status == "ready"
        else f"{title} is missing evidence: {', '.join(missing)}."
    )
    return {
        "id": domain_id,
        "title": title,
        "purpose": purpose,
        "status": status,
        "evidence_paths": evidence,
        "missing_evidence_paths": missing,
        "message": message,
        "refresh_command": refresh_command,
        "details": dict(details or {}),
    }


