def _aegis_mcp_registration_request_from_args(
    args: argparse.Namespace,
    *,
    client: mcp_registration.ClientName | None = None,
) -> mcp_registration.RegistrationRequest:
    return mcp_registration.RegistrationRequest(
        client=client or args.client,
        scope=getattr(args, "scope", None),
        source_mode=args.source_mode,
        package_spec=args.package_spec,
        package_version=args.package_version,
        github_url=args.github_url,
        github_ref=args.github_ref,
        artifact=args.artifact,
        target_dir=args.target_dir,
        transport=args.transport,
        uv_cache_dir=args.uv_cache_dir,
        uv_tool_dir=args.uv_tool_dir,
    )


def handle_aegis_mcp_generate_registration(args: argparse.Namespace) -> None:
    try:
        payload = mcp_registration.registration_payload(_aegis_mcp_registration_request_from_args(args))
    except ValueError as exc:
        raise TaskError(str(exc)) from exc
    _print_json(payload)


def handle_aegis_mcp_execute_registration(args: argparse.Namespace) -> None:
    try:
        payload = mcp_registration.execute_registration(
            _aegis_mcp_registration_request_from_args(args),
            cwd=args.cwd or args.target_dir,
        )
    except ValueError as exc:
        raise TaskError(str(exc)) from exc
    _print_json(payload)
    if payload.get("status") in {"missing_client", "failed"}:
        raise TaskError("Aegis native MCP registration failed")


def handle_aegis_mcp_verify_registration(args: argparse.Namespace) -> None:
    try:
        payload = mcp_registration.verify_registration(
            _aegis_mcp_registration_request_from_args(args),
            cwd=args.cwd or args.target_dir,
        )
    except ValueError as exc:
        raise TaskError(str(exc)) from exc
    _print_json(payload)
    if payload.get("status") in {"missing_client", "failed"}:
        raise TaskError("Aegis native MCP registration verification failed")


def handle_aegis_mcp_register(args: argparse.Namespace) -> None:
    try:
        payload = mcp_registration.execute_registration(
            _aegis_mcp_registration_request_from_args(args),
            cwd=args.cwd or args.target_dir,
        )
    except ValueError as exc:
        raise TaskError(str(exc)) from exc
    _print_json(payload)
    if payload.get("status") in {"missing_client", "failed"}:
        raise TaskError("Aegis native MCP registration failed")


def _normalize_aegis_mcp_smoke_clients(values: Sequence[str] | None) -> Tuple[mcp_registration.ClientName, ...]:
    requested = list(values or ["all"])
    if "all" in requested:
        return mcp_registration.SMOKE_CLIENTS
    return tuple(dict.fromkeys(requested))  # type: ignore[return-value]


def handle_aegis_mcp_smoke_registration(args: argparse.Namespace) -> None:
    clients = _normalize_aegis_mcp_smoke_clients(args.client)
    try:
        payload = mcp_registration.smoke_registration(
            _aegis_mcp_registration_request_from_args(args, client=clients[0]),
            clients=clients,
            smoke_root=args.smoke_root,
            keep_temp=args.keep_temp,
        )
    except ValueError as exc:
        raise TaskError(str(exc)) from exc
    mcp_registration.write_smoke_reports(
        payload,
        report_file=args.report_file,
        markdown_report_file=args.markdown_report_file,
    )
    _print_json(payload)
    if payload.get("status") == "failed":
        raise TaskError("Aegis native MCP registration smoke failed")


def _add_aegis_mcp_registration_arguments(parser: argparse.ArgumentParser, *, execute: bool = False) -> None:
    parser.add_argument("--client", choices=("claude", "codex"), required=True, help="Native MCP client to configure")
    parser.add_argument(
        "--scope",
        choices=("local", "user", "project"),
        help="Claude MCP scope. Defaults to user for Claude and is ignored for Codex.",
    )
    parser.add_argument(
        "--source-mode",
        choices=("package", "pinned", "github", "private-github", "wheel", "source"),
        default="package",
        help="How uvx should resolve the Aegis package that provides aegis-mcp-server",
    )
    parser.add_argument("--package-spec", help="Explicit uvx --from package/artifact spec")
    parser.add_argument("--package-version", help="Version for --source-mode pinned")
    parser.add_argument(
        "--github-url",
        default=mcp_registration.DEFAULT_GITHUB_URL,
        help="GitHub repository URL for --source-mode github/private-github",
    )
    parser.add_argument("--github-ref", help="Optional ref for --source-mode github/private-github")
    parser.add_argument("--artifact", help="Wheel path or source checkout path for wheel/source modes")
    parser.add_argument("--target-dir", default=".", help="Default target directory passed to aegis-mcp-server")
    parser.add_argument(
        "--uv-cache-dir",
        default=mcp_registration.DEFAULT_UV_CACHE_DIR,
        help="UV_CACHE_DIR value registered with the native client; use '' to omit",
    )
    parser.add_argument(
        "--uv-tool-dir",
        default=mcp_registration.DEFAULT_UV_TOOL_DIR,
        help="UV_TOOL_DIR value registered with the native client; use '' to omit",
    )
    parser.add_argument("--transport", choices=("stdio",), default="stdio", help="MCP transport to register")
    if execute:
        parser.add_argument("--cwd", help="Working directory for the native client command. Defaults to --target-dir")


def _validate_branch_for_task(branch: str, task_id: str) -> None:
    expected = f"feat/task-{task_id}"
    if not branch.startswith(expected):
        raise TaskError(
            f"Current branch '{branch}' does not satisfy feature-required policy for task {task_id}; expected prefix '{expected}'"
        )


def _build_session_lines(
    session_id: str,
    now: datetime,
    task_id: str,
    title: str,
    branch: str,
    source: str,
    task_file_relative: str,
    work_context: str,
    tracker_relative: str,
) -> List[str]:
    date_iso = now.strftime("%Y-%m-%d")
    time_label = now.strftime("%H:%M %Z")
    timestamp_full = now.strftime("%Y-%m-%d %H:%M:%S %Z %z")
    session_value = now.strftime("%Y%m%d")
    pretty_title = f"Task {task_id} - {title}"
    return [
        "---",
        f"session_id: {session_id}",
        f"date: {date_iso}",
        f"time: {time_label}",
        f"title: {pretty_title}",
        "---",
        "",
        f"## Session: {date_iso} {time_label}",
        "**AI Assistant**: Codex GPT-5.4",
        "**Developer**: loucmane",
        f"**Task**: Start Task {task_id} via the guided kickoff flow and establish compliant session, plan, and work-tracking state for {title}.",
        f"**Task Source**: {source}",
        "",
        "### Session Validation",
        f"- [x] Date confirmed (`date '+%Y-%m-%d %H:%M:%S %Z %z'` -> `{timestamp_full}`)",
        f"- [x] Git branch checked (`{branch}`)",
        f"- [x] Taskmaster task reviewed (`{task_file_relative}`)",
        "",
        "### Session Goals",
        f"- [x] Start a fresh Task {task_id} session on the Task {task_id} branch.",
        f"- [x] Scaffold Task {task_id} work tracking.",
        f"- [x] Repoint `{SESSIONS_CURRENT_REL}` and `{PLANS_CURRENT_REL}` to Task {task_id}.",
        f"- [x] Mark Taskmaster Task {task_id} in progress and update its generated task file.",
        f"- [ ] Review the design baseline and implementation boundary for {title}.",
        "- [ ] Capture implementation and verification evidence.",
        "",
        "### Starting Context",
        f"Task {task_id} was kicked off via `python3 scripts/codex-task wizard kickoff`, which created the session, plan, work-tracking scaffolding, and targeted generated task-file update in a guard-compliant state before implementation began.",
        "",
        "### 📝 Progress Log",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:shell:date|E:cmd`date \"+%Y-%m-%d %H:%M:%S %Z %z\"`] Confirmed current timestamp as `{timestamp_full}`",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:scripts/codex-task|E:{tracker_relative}] Scaffolded the Task {task_id} ACTIVE work-tracking folder through the guided kickoff flow",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:task-master:set-status|E:{TASKMASTER_TASKS_JSON_REL}] Marked Taskmaster Task {task_id} in progress and updated only its generated task file",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:{SESSIONS_CURRENT_REL}|E:{SESSIONS_CURRENT_REL}] Repointed `{SESSIONS_CURRENT_REL}`, `{PLANS_CURRENT_REL}`, and `{SESSION_STATE_REL}` to the new Task {task_id} kickoff",
    ]


def _build_tracker_entries(
    now: datetime,
    task_id: str,
    work_context: str,
    tracker_relative: str,
) -> List[str]:
    session_value = now.strftime("%Y%m%d")
    timestamp = now.strftime("%Y-%m-%d %H:%M")
    return [
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:shell:date|E:cmd`date \"+%Y-%m-%d %H:%M %Z\"`] Confirmed current timestamp as `{now.strftime('%Y-%m-%d %H:%M %Z')}`",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:scripts/codex-task|E:{tracker_relative}] Scaffolded the Task {task_id} ACTIVE work-tracking folder through the guided kickoff flow",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:task-master:set-status|E:{TASKMASTER_TASKS_JSON_REL}] Marked Taskmaster Task {task_id} in progress and updated only its generated task file",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:{SESSIONS_CURRENT_REL}|E:{SESSIONS_CURRENT_REL}] Repointed `{SESSIONS_CURRENT_REL}`, `{PLANS_CURRENT_REL}`, and `{SESSION_STATE_REL}` to the new Task {task_id} kickoff",
    ]


def _build_continuation_session_lines(
    session_id: str,
    now: datetime,
    task_id: str,
    title: str,
    branch: str,
    source: str,
    task_file_relative: str,
    work_context: str,
    tracker_relative: str,
    plan_relative: str,
    completed_source: bool = False,
) -> List[str]:
    date_iso = now.strftime("%Y-%m-%d")
    time_label = now.strftime("%H:%M %Z")
    timestamp_full = now.strftime("%Y-%m-%d %H:%M:%S %Z %z")
    session_value = now.strftime("%Y%m%d")
    pretty_title = f"Task {task_id} - {title} Continuation"
    work_state = "completed source archive" if completed_source else "active task work tracking"
    activity = "publication and terminal verification" if completed_source else "implementation and verification"
    return [
        "---",
        f"session_id: {session_id}",
        f"date: {date_iso}",
        f"time: {time_label}",
        f"title: {pretty_title}",
        "---",
        "",
        f"## Session: {date_iso} {time_label}",
        "**AI Assistant**: Codex GPT-5.4",
        "**Developer**: loucmane",
        f"**Task**: Continue Task {task_id} using the existing task-scoped plan and {work_state} for {title}.",
        f"**Task Source**: {source}",
        "",
        "### Session Validation",
        f"- [x] Date confirmed (`date '+%Y-%m-%d %H:%M:%S %Z %z'` -> `{timestamp_full}`)",
        f"- [x] Git branch checked (`{branch}`)",
        f"- [x] Taskmaster task reviewed (`{task_file_relative}`)",
        f"- [x] Reused {work_state} (`{tracker_relative}`)",
        f"- [x] Reused task plan (`{plan_relative}`)",
        "",
        "### Session Goals",
        f"- [x] Start a fresh daily session for existing Task {task_id} work.",
        f"- [x] Reuse the existing Task {task_id} {work_state} instead of recreating workflow state.",
        f"- [x] Repoint `{SESSIONS_CURRENT_REL}` and `{PLANS_CURRENT_REL}` to the continuation state.",
        f"- [ ] Continue {activity} work with S:W:H:E evidence.",
        "",
        "### Starting Context",
        f"Task {task_id} continuation was created via `python3 scripts/codex-task sessions continue`, which created a fresh session while preserving the existing task-scoped plan and {work_state}.",
        "",
        "### 📝 Progress Log",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:shell:date|E:cmd`date \"+%Y-%m-%d %H:%M:%S %Z %z\"`] Confirmed current timestamp as `{timestamp_full}`",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:scripts/codex-task:sessions-continue|E:{tracker_relative}] Reused the existing Task {task_id} {work_state} for a new daily session",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:{PLANS_CURRENT_REL}|E:{plan_relative}] Reused the Task {task_id} plan for continuation",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:{SESSIONS_CURRENT_REL}|E:{SESSIONS_CURRENT_REL}] Repointed `{SESSIONS_CURRENT_REL}`, `{PLANS_CURRENT_REL}`, and `{SESSION_STATE_REL}` to the Task {task_id} continuation session",
    ]


def _build_continuation_tracker_entries(
    now: datetime,
    task_id: str,
    work_context: str,
    tracker_relative: str,
    session_relative: str,
    plan_relative: str,
    completed_source: bool = False,
) -> List[str]:
    session_value = now.strftime("%Y%m%d")
    timestamp = now.strftime("%Y-%m-%d %H:%M")
    work_state = "completed source archive" if completed_source else "ACTIVE work-tracking folder"
    return [
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:shell:date|E:cmd`date \"+%Y-%m-%d %H:%M %Z\"`] Confirmed current timestamp as `{now.strftime('%Y-%m-%d %H:%M %Z')}`",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:scripts/codex-task:sessions-continue|E:{session_relative}] Created a fresh daily Task {task_id} continuation session while reusing the existing {work_state}",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:{PLANS_CURRENT_REL}|E:{plan_relative}] Reused the existing Task {task_id} plan for continuation",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:{SESSION_STATE_REL}|E:{SESSION_STATE_REL}] Repointed session state to the Task {task_id} continuation session",
    ]


def _build_plan_lines(
    session_id: str,
    task_id: str,
    title: str,
    work_context: str,
    handler_target: str,
    tracker_relative: str,
    task_file_relative: str,
    branch: str,
) -> List[str]:
    return [
        "---",
        f"session_id: {session_id}",
        f"work_context: {work_context}",
        f"handler_target: {handler_target}",
        f"task_ids: [{task_id}]",
        "branch_policy: feature-required",
        "evidence_summary:",
        f"  - {tracker_relative.rsplit('/', 1)[0]}/",
        f"  - {handler_target}",
        f"  - {task_file_relative}",
        f"  - {Path('scripts/codex-task').as_posix()}",
        "plan_version: v1",
        "emergency_bypass: false",
        "---",
        "",
        f"# Plan - Task {task_id} {title}",
        "",
        "## Header",
        f"- **Session ID (S)**: {session_id}",
        f"- **Work Context (W)**: {work_context}",
        f"- **Handler Target (H)**: {handler_target}",
        f"- **Task IDs**: {task_id}",
        "- **Branch Policy**: feature-required",
        f"- **Evidence Summary (E)**: {tracker_relative.rsplit('/', 1)[0]}/, {handler_target}, {task_file_relative}, scripts/codex-task",
        "- **Plan Version**: v1",
        "- **Emergency Bypass**: false",
        "",
        "## Plan Table",
        "| Step ID             | Description | Evidence | Status |",
        "|---------------------|-------------|----------|--------|",
        f"| plan-step-scope | Design the wizard flow, prompt contract, and workflow boundary for {title} | {tracker_relative.rsplit('/', 1)[0]}/designs/wizard-flow.md | pending |",
        f"| plan-step-implement | Implement the wizard CLI, helper integration, and documentation for {title} | scripts/codex-task; {tracker_relative.rsplit('/', 1)[0]}/IMPLEMENTATION.md | pending |",
        f"| plan-step-verify | Store evidence, refresh handoff docs, and confirm Taskmaster status | {tracker_relative.rsplit('/', 1)[0]}/HANDOFF.md; {tracker_relative} | pending |",
        "| plan-step-emergency | _Optional_ - only if bypass required | Waiver + post-mortem plan | n/a |",
        "",
        "## Scope",
        f"- `{tracker_relative.rsplit('/', 1)[0]}/`",
        f"- `{handler_target}`",
        f"- `{task_file_relative}`",
        "- `scripts/codex-task`",
        "- `tests/`",
        f"- Taskmaster Task `{task_id}`",
        "",
        "## Branch Policy",
        f"- Working branch: `{branch}`",
        "",
        "## Amendments & Versioning",
        f"- {datetime.now().date().isoformat()} - Task {task_id} kickoff created via the guided wizard flow.",
        "",
        "## Continuation & Handoff",
        "- Next owner: loucmane (default)",
        "- Context reload steps:",
        f"  1. Read `{SESSIONS_CURRENT_REL}` and this plan.",
        f"  2. Review Taskmaster Task {task_id} and its subtasks.",
        "  3. Review the wizard design artifact before changing helper behavior.",
        "  4. Run `python3 scripts/codex-task plan sync` after tracker updates.",
        "- Outstanding risks/todos: keep the wizard grounded in the existing helper commands rather than creating a parallel workflow engine.",
        "",
        "## Conflict & Scope Declaration",
        "- Related plans: Tasks 94-95 enforcement groundwork, Task 97 dashboard follow-on.",
        "- Guard cross-check: wizard flows must preserve plan/tracker/session compliance as the default path.",
        "",
        "## Evidence Checklist",
        "- Wizard design note under `designs/`",
        "- Tracker/session entries for kickoff and implementation progress",
        "- Stored test and guard evidence once the wizard implementation lands",
        "",
        "## Emergency Bypass Protocol",
        "- No bypass authorized.",
    ]


def handle_wizard_kickoff(args: argparse.Namespace) -> None:
    now = datetime.now().astimezone()
    task_id = args.task or _prompt_with_default("Task ID")
    task_meta = _load_task_metadata(task_id)
    title = args.title or _prompt_with_default("Task title", task_meta["title"])
    slug = _slugify(args.slug or _prompt_with_default("Task slug", _slugify(title)))
    goals = args.goal or _default_goals_for_title(title)
    source = args.task_source or f"Guided kickoff for Task {task_id}"
    task_file_relative = task_meta["path"]
    handler_target = args.handler_target or task_file_relative
    work_context = f"task{task_id}-{slug}"
    branch = subprocess.run(
        ["git", "branch", "--show-current"],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
        check=False,
    ).stdout.strip() or f"feat/task-{task_id}-{slug}"
    _validate_branch_for_task(branch, task_id)

    scaffold_args = argparse.Namespace(
        task=task_id,
        slug=slug,
        title=title,
        goal=goals,
        force=args.force,
        dry_run=args.dry_run,
    )
    handle_work_tracking_scaffold(scaffold_args)

    session_id = _next_session_id(now)
    session_dir = SESSIONS_DIR / now.strftime("%Y") / now.strftime("%m")
    session_path = session_dir / f"{session_id}-task{task_id}-{slug}.md"
    plan_path = PLAN_CURRENT.parent / f"{now.strftime('%Y-%m-%d')}-task{task_id}-{slug}.md"
    tracker_relative = (WORK_TRACKING_BASE / f"{now.strftime('%Y%m%d')}-task{task_id}-{slug}-ACTIVE" / "TRACKER.md").relative_to(REPO_ROOT).as_posix()

    session_lines = _build_session_lines(
        session_id=session_id,
        now=now,
        task_id=task_id,
        title=title,
        branch=branch,
        source=source,
        task_file_relative=task_file_relative,
        work_context=work_context,
        tracker_relative=tracker_relative,
    )
    plan_lines = _build_plan_lines(
        session_id=session_id,
        task_id=task_id,
        title=title,
        work_context=work_context,
        handler_target=handler_target,
        tracker_relative=tracker_relative,
        task_file_relative=task_file_relative,
        branch=branch,
    )

    if args.dry_run:
        print(f"Would create session {session_path.relative_to(REPO_ROOT)}")
        print(f"Would create plan {plan_path.relative_to(REPO_ROOT)}")
        return

    session_dir.mkdir(parents=True, exist_ok=True)
    _write_file_lines(session_path, session_lines)
    _write_file_lines(plan_path, plan_lines)
    _symlink_to(SESSIONS_DIR / "current", session_path)
    _symlink_to(PLAN_CURRENT, plan_path)
    _write_session_state(session_path.name, now)
    tracker_path = REPO_ROOT / tracker_relative
    tracker_lines = _load_file_lines(tracker_path)
    for entry in _build_tracker_entries(now, task_id, work_context, tracker_relative):
        tracker_lines = _insert_progress_entry(tracker_lines, PROGRESS_HEADING_TRACKER, entry)
    _write_file_lines(tracker_path, tracker_lines)
    handle_plan_sync(argparse.Namespace(plan=plan_path.relative_to(REPO_ROOT).as_posix(), tracker=tracker_relative, dry_run=False))
    _run_checked_command(["task-master", "set-status", f"--id={task_id}", "--status=in-progress"])
    handle_taskmaster_generate_one(argparse.Namespace(task_id=task_id, dry_run=False))
    print(f"Created session: {session_path.relative_to(REPO_ROOT)}")
    print(f"Created plan: {plan_path.relative_to(REPO_ROOT)}")
    print(f"Repointed {SESSIONS_CURRENT_REL}, {PLANS_CURRENT_REL}, and {SESSION_STATE_REL}")


def _work_tracking_folder_matches_task(folder: Path, task_id: str) -> bool:
    return f"-task{int(task_id)}-" in folder.name


def _source_checkout_branch() -> str:
    branch = subprocess.run(
        ["git", "branch", "--show-current"],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
        check=False,
    ).stdout.strip()
    if branch and branch != "HEAD":
        return branch
    for variable in ("GITHUB_HEAD_REF", "GITHUB_REF_NAME"):
        value = os.environ.get(variable, "").strip()
        if value and value != "HEAD":
            return value
    return ""


def _derive_current_completed_source_work():
    source_module = _load_source_workflow_state_module()
    if source_module is None or not source_module.is_uninstalled_aegis_source_checkout(REPO_ROOT):
        return None
    branch = _source_checkout_branch()
    try:
        return source_module.derive_completed_source_work(REPO_ROOT, branch)
    except Exception as exc:
        raise TaskError(f"Completed source work-tracking derivation failed: {exc}") from exc


def _resolve_task_work_tracking(task_id: str, explicit: Optional[str] = None) -> Path:
    if explicit:
        folder = _resolve_active_work_tracking(explicit)
        if not _work_tracking_folder_matches_task(folder, task_id):
            raise TaskError(
                f"Work-tracking folder {folder.name} does not match Task {task_id}; refusing to continue the wrong task."
            )
        return folder

    if not WORK_TRACKING_BASE.exists():
        raise TaskError(f"No ACTIVE work-tracking directory found at {WORK_TRACKING_ACTIVE_REL}/.")

    candidates = [
        path
        for path in WORK_TRACKING_BASE.iterdir()
        if path.is_dir() and path.name.endswith("-ACTIVE") and _work_tracking_folder_matches_task(path, task_id)
    ]
    if not candidates:
        completed_work = _derive_current_completed_source_work()
        if completed_work is not None:
            if str(completed_work.task_id) != str(int(task_id)):
                raise TaskError(
                    f"Completed source archive resolves Task {completed_work.task_id}, expected Task {task_id}."
                )
            return Path(completed_work.archive_folder)
        raise TaskError(
            f"No ACTIVE work-tracking folder found for Task {task_id}; use `wizard kickoff` for new tasks or restore the task folder before continuing."
        )
    if len(candidates) > 1:
        names = ", ".join(sorted(path.name for path in candidates))
        raise TaskError(f"Multiple ACTIVE work-tracking folders found for Task {task_id} ({names}); specify one via --folder.")
    return candidates[0]


def _resolve_continuation_plan(task_id: str, explicit: Optional[str] = None) -> Path:
    if explicit:
        plan = (REPO_ROOT / explicit).resolve()
        if not plan.exists():
            raise TaskError(f"Specified plan file not found: {plan}")
        return plan

    if PLAN_CURRENT.exists() or PLAN_CURRENT.is_symlink():
        try:
            plan = PLAN_CURRENT.resolve()
        except FileNotFoundError as exc:
            raise TaskError(f"{PLANS_CURRENT_REL} points to a missing plan file.") from exc
        if not plan.exists():
            raise TaskError(f"{PLANS_CURRENT_REL} points to a missing plan file: {plan}")
        return plan

    patterns = [f"*task{int(task_id)}-*.md", f"*task-{int(task_id)}-*.md"]
    candidates: List[Path] = []
    for pattern in patterns:
        candidates.extend(path for path in PLANS_DIR.glob(pattern) if path.is_file())
    candidates = sorted(dict.fromkeys(candidates))
    if not candidates:
        raise TaskError(
            f"No plan found for Task {task_id}; pass --plan or run `wizard kickoff` if this is a new task."
        )
    if len(candidates) > 1:
        names = ", ".join(path.relative_to(REPO_ROOT).as_posix() for path in candidates)
        raise TaskError(f"Multiple plans found for Task {task_id} ({names}); specify one via --plan.")
    return candidates[0]


def handle_sessions_continue(args: argparse.Namespace) -> None:
    now = datetime.now().astimezone()
    task_id = args.task
    task_meta = _load_task_metadata(task_id)
    title = args.title or task_meta["title"]
    slug = _slugify(args.slug or title)
    source = args.task_source or f"Continuation session for Task {task_id}"
    work_context = args.work or f"task{task_id}-{slug}"
    task_file_relative = task_meta["path"]
    branch = _source_checkout_branch() or f"feat/task-{task_id}-{slug}"
    _validate_branch_for_task(branch, task_id)

    work_folder = _resolve_task_work_tracking(task_id, args.folder)
    completed_source = work_folder.name.endswith("-COMPLETED")
    tracker_path = work_folder / "TRACKER.md"
    if not tracker_path.exists():
        raise TaskError(f"Tracker file missing at {tracker_path}")
    plan_path = _resolve_continuation_plan(task_id, args.plan)

    session_id = _next_session_id(now)
    session_dir = SESSIONS_DIR / now.strftime("%Y") / now.strftime("%m")
    session_path = session_dir / f"{session_id}-task{task_id}-{slug}.md"
    tracker_relative = tracker_path.relative_to(REPO_ROOT).as_posix()
    plan_relative = plan_path.relative_to(REPO_ROOT).as_posix()
    session_relative = session_path.relative_to(REPO_ROOT).as_posix()

    session_lines = _build_continuation_session_lines(
        session_id=session_id,
        now=now,
        task_id=task_id,
        title=title,
        branch=branch,
        source=source,
        task_file_relative=task_file_relative,
        work_context=work_context,
        tracker_relative=tracker_relative,
        plan_relative=plan_relative,
        completed_source=completed_source,
    )

    if args.dry_run:
        print(f"Would create continuation session {session_relative}")
        print(f"Would reuse plan {plan_relative}")
        print(f"Would reuse work-tracking folder {work_folder.relative_to(REPO_ROOT).as_posix()}")
        return

    session_dir.mkdir(parents=True, exist_ok=True)
    _write_file_lines(session_path, session_lines)
    _symlink_to(SESSIONS_DIR / "current", session_path)
    _symlink_to(PLAN_CURRENT, plan_path)
    _write_session_state(session_path.name, now)

    tracker_lines = _load_file_lines(tracker_path)
    for entry in _build_continuation_tracker_entries(
        now=now,
        task_id=task_id,
        work_context=work_context,
            tracker_relative=tracker_relative,
            session_relative=session_relative,
            plan_relative=plan_relative,
            completed_source=completed_source,
    ):
        tracker_lines = _insert_progress_entry(tracker_lines, PROGRESS_HEADING_TRACKER, entry)
    _write_file_lines(tracker_path, tracker_lines)

    handle_plan_sync(
        argparse.Namespace(
            plan=plan_path.relative_to(REPO_ROOT).as_posix(),
            tracker=tracker_relative,
            dry_run=False,
        )
    )
    print(f"Created continuation session: {session_relative}")
    state_label = "completed source archive" if completed_source else "work-tracking folder"
    print(f"Reused {state_label}: {work_folder.relative_to(REPO_ROOT).as_posix()}")
    print(f"Reused plan: {plan_relative}")
    print(f"Repointed {SESSIONS_CURRENT_REL}, {PLANS_CURRENT_REL}, and {SESSION_STATE_REL}")


def _resolve_plan_path(override: Optional[str] = None) -> Path:
    if override:
        candidate = (REPO_ROOT / override).resolve()
        if not candidate.exists():
            raise TaskError(f"Plan file not found: {candidate}")
        return candidate

    if not PLAN_CURRENT.exists():
        raise TaskError("Active plan symlink missing; create plan with templates/workflows/processes/plan-template.md")

    resolved = PLAN_CURRENT.resolve()
    if not resolved.exists():
        raise TaskError(f"Active plan target missing: {resolved}")
    return resolved


def _is_between_sessions_state() -> bool:
    """Return true when the repository is intentionally between sessions."""

    if PLAN_CURRENT.exists() or PLAN_CURRENT.is_symlink():
        return False

    current_session_link = SESSIONS_DIR / "current"
    if current_session_link.exists() or current_session_link.is_symlink():
        return False

    if not SESSION_STATE_PATH.exists():
        return False

    try:
        state = json.loads(SESSION_STATE_PATH.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return False

    return state.get("current") in {None, ""}


def _resolve_tracker_path(override: Optional[str] = None) -> Path:
    if override:
        candidate = (REPO_ROOT / override).resolve()
        if not candidate.exists():
            raise TaskError(f"Tracker file not found: {candidate}")
        return candidate
    return _get_tracker_path()


def _parse_plan_table(text: str) -> Dict[str, Dict[str, str]]:
    steps: Dict[str, Dict[str, str]] = {}
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line.startswith("|"):
            continue
        cells = [cell.strip() for cell in line.strip("|").split("|")]
        if not cells or not cells[0].startswith("plan-step-"):
            continue
        if len(cells) < 4:
            raise TaskError(f"Malformed plan table row: {raw_line}")
        step_id = cells[0]
        description = cells[1] if len(cells) > 1 else ""
        evidence = cells[-2] if len(cells) >= 3 else ""
        status = cells[-1].lower()
        steps[step_id] = {
            "description": description,
            "evidence": evidence,
            "status": status,
        }
    return steps


def _ensure_plan_steps_present(steps: Dict[str, Dict[str, str]]) -> None:
    missing = [step for step in PLAN_REQUIRED_STEPS if step not in steps]
    if missing:
        raise TaskError(f"Plan is missing required rows: {', '.join(missing)}")


def _load_tracker_text(tracker_path: Path) -> str:
    return tracker_path.read_text(encoding="utf-8")


def _tracker_has_checkbox(tracker_text: str, step_id: str, checked: bool) -> bool:
    token = "- [x]" if checked else "- [ ]"
    return f"{token} {step_id}" in tracker_text


def _validate_tracker_alignment(steps: Dict[str, Dict[str, str]], tracker_text: str) -> None:
    issues: List[str] = []
    for step_id, data in steps.items():
        status = data.get("status", "").strip().lower()
        has_checked = _tracker_has_checkbox(tracker_text, step_id, True)
        has_unchecked = _tracker_has_checkbox(tracker_text, step_id, False)
        if not has_checked and not has_unchecked:
            issues.append(f"Tracker missing checkbox for {step_id}")
            continue

        if status in PLAN_STATUS_COMPLETE and not has_checked:
            issues.append(f"Tracker checkbox for {step_id} should be checked (status {status})")
        elif status in PLAN_STATUS_INCOMPLETE and not has_unchecked:
            issues.append(f"Tracker checkbox for {step_id} should remain unchecked (status {status})")
        elif status in PLAN_STATUS_PASSIVE and not has_unchecked:
            issues.append(f"Tracker checkbox for {step_id} should remain unchecked (status {status})")
    if issues:
        raise TaskError("; ".join(issues))


def _compute_sha256(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _load_plan_sync_entries() -> List[Dict[str, str]]:
    if not PLAN_SYNC_LOG.exists():
        return []
    try:
        data = json.loads(PLAN_SYNC_LOG.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"Plan sync log is not valid JSON: {exc}")
    if not isinstance(data, list):
        raise TaskError("Plan sync log root must be a list")
    return data


def _write_plan_sync_entries(entries: List[Dict[str, str]]) -> None:
    PLAN_STATE_DIR.mkdir(parents=True, exist_ok=True)
    PLAN_SYNC_LOG.write_text(json.dumps(entries, indent=2) + "\n", encoding="utf-8")


def handle_plan_sync(args: argparse.Namespace) -> None:
    if not args.plan and not args.tracker and _is_between_sessions_state():
        print("No active plan; repository is between sessions. Plan sync skipped.")
        return

    plan_path = _resolve_plan_path(args.plan)
    tracker_path = _resolve_tracker_path(args.tracker)

    plan_text = plan_path.read_text(encoding="utf-8")
    steps = _parse_plan_table(plan_text)
    _ensure_plan_steps_present(steps)

    tracker_text = _load_tracker_text(tracker_path)
    _validate_tracker_alignment(steps, tracker_text)

    plan_hash = _compute_sha256(plan_path)
    tracker_hash = _compute_sha256(tracker_path)

    rel_plan = plan_path.relative_to(REPO_ROOT).as_posix()
    entries = _load_plan_sync_entries()
    entry = {
        "plan": rel_plan,
        "plan_hash": plan_hash,
        "tracker_hash": tracker_hash,
        "synced_at": datetime.now().astimezone().isoformat(),
    }

    if args.dry_run:
        print(json.dumps(entry, indent=2))
        return

    entries.append(entry)
    _write_plan_sync_entries(entries)
    print(f"Plan sync recorded for {rel_plan}")
def _parse_front_matter(path: Path) -> Dict[str, str]:
    text = path.read_text(encoding="utf-8")
    if not text.startswith("---"):
        return {}
    parts = text.split("---", 2)
    if len(parts) < 3:
        return {}
    front_matter = parts[1]
    data: Dict[str, str] = {}
    for raw_line in front_matter.strip().splitlines():
        if not raw_line.strip() or raw_line.strip().startswith("#"):
            continue
        if ":" not in raw_line:
            continue
        key, value = raw_line.split(":", 1)
        data[key.strip()] = value.strip()
    return data


def _resolve_current_session(explicit: Optional[str] = None) -> Path:
    if explicit:
        candidate = (REPO_ROOT / explicit).resolve()
        if not candidate.exists():
            raise TaskError(f"Specified session file not found: {candidate}")
        return candidate

    current_link = SESSIONS_DIR / "current"
    if current_link.exists() or current_link.is_symlink():
        try:
            resolved = current_link.resolve()
        except FileNotFoundError as exc:
            raise TaskError(f"{SESSIONS_CURRENT_REL} points to a missing session file.") from exc
        if not resolved.exists():
            raise TaskError(f"{SESSIONS_CURRENT_REL} points to a missing session file: {resolved}")
        return resolved

    if SESSION_STATE_PATH.exists():
        raise TaskError(
            f"{SESSIONS_CURRENT_REL} is missing; refusing to infer the latest historical session. "
            "Start a session with `wizard kickoff` or `sessions continue`, or pass --session-file explicitly."
        )

    # Fallback: find most recent session markdown in sessions directory.
    candidates = sorted(SESSIONS_DIR.glob("**/*.md"))
    if not candidates:
        raise TaskError(f"No session files located under {SESSIONS_DIR.relative_to(REPO_ROOT).as_posix()}/.")
    return candidates[-1]


def _resolve_active_work_tracking(explicit: Optional[str] = None) -> Path:
    if explicit:
        target = (WORK_TRACKING_BASE / explicit).resolve()
        if not target.exists():
            raise TaskError(f"Work-tracking folder not found: {target}")
        return target

    candidates = [p for p in WORK_TRACKING_BASE.iterdir() if p.is_dir() and p.name.endswith("-ACTIVE")]
    if not candidates:
        raise TaskError(f"No ACTIVE work-tracking folder found under {WORK_TRACKING_ACTIVE_REL}/.")
    if len(candidates) > 1:
        names = ", ".join(p.name for p in candidates)
        raise TaskError(f"Multiple ACTIVE work-tracking folders found ({names}); specify one via --folder.")
    return candidates[0]


def _get_tracker_path(explicit: Optional[str] = None) -> Path:
    if explicit:
        tracker = _resolve_active_work_tracking(explicit) / "TRACKER.md"
    else:
        try:
            tracker = _resolve_active_work_tracking() / "TRACKER.md"
        except TaskError as active_error:
            completed_work = _derive_current_completed_source_work()
            if completed_work is None:
                raise active_error
            tracker = Path(completed_work.tracker_path)
    if not tracker.exists():
        raise TaskError(f"Tracker file missing at {tracker}")
    return tracker


def _derive_session_value(meta: Dict[str, str]) -> str:
    if "session_id" in meta:
        session_id = meta["session_id"].strip()
        if session_id:
            parts = session_id.split("-")
            if len(parts) >= 3:
                return "".join(parts[:3])
            return session_id.replace("-", "")
    if "date" in meta:
        return meta["date"].replace("-", "")
    raise TaskError("Unable to derive session value from metadata; ensure front matter includes session_id or date.")


def _ensure_no_active_conflict(ignore_existing: bool) -> None:
    if ignore_existing:
        return
    active = [p for p in WORK_TRACKING_BASE.iterdir() if p.is_dir() and p.name.endswith("-ACTIVE")]
    if active:
        names = ", ".join(sorted(p.name for p in active))
        raise TaskError(
            f"Active work-tracking folder(s) already exist ({names}). Archive them first or pass --force to scaffold."
        )


def handle_work_tracking_scaffold(args: argparse.Namespace) -> None:
    now = datetime.now().astimezone()
    date_prefix = now.strftime("%Y%m%d")
    iso_today = now.date().isoformat()
    slug = _slugify(args.slug)
    task_token = f"task{args.task}"
    folder_name = f"{date_prefix}-{task_token}-{slug}-ACTIVE"
    folder_path = WORK_TRACKING_BASE / folder_name

    WORK_TRACKING_BASE.mkdir(parents=True, exist_ok=True)

    if folder_path.exists():
        raise TaskError(f"Work-tracking folder already exists: {folder_path}")

    _ensure_no_active_conflict(args.force)

    if args.dry_run:
        print(f"Would create {folder_path.relative_to(REPO_ROOT)}")
        return

    folder_path.mkdir(parents=True)
    (folder_path / "designs").mkdir()
    reports_base = folder_path / "reports" / slug
    reports_base.mkdir(parents=True)

    title = args.title or args.slug.replace('-', ' ').title()
    goals = args.goal or ["Document alignment prerequisites", "Implement alignment workflow and guard", "Capture evidence"]

    tracker_lines = [
        f"# Task {args.task} {title} Tracker",
        "",
        f"**Started**: {iso_today}",
        "**Status**: ACTIVE",
        f"**Last Updated**: {iso_today}",
        "",
        "## Goals",
    ] + [f"- [ ] {goal}" for goal in goals] + [
        "",
        "## Progress Log",
        "",
        "## Plan Compliance Checklist",
        "- [ ] plan-step-scope — Define alignment prerequisites and scope",
        "- [ ] plan-step-implement — Update workflow/guard/docs and capture tests",
        "- [ ] plan-step-verify — Evidence stored, documentation updated",
        "- [ ] plan-step-emergency (if applicable)",
        "",
        "## Dependencies & Notes",
        f"- Session log: {SESSIONS_CURRENT_REL}",
    ]
    _write_file_lines(folder_path / "TRACKER.md", tracker_lines)

    timestamp = now.strftime("%Y-%m-%d %H:%M %Z")
    changelog_lines = [
        f"# Task {args.task} {title} – Changelog",
        "",
        f"- {timestamp} — Initialized active work-tracking folder.",
    ]
    _write_file_lines(folder_path / "CHANGELOG.md", changelog_lines)

    for doc_name, template in WORK_TRACKING_DEFAULT_DOCS.items():
        content = template.format(today=iso_today, task=args.task, title=title)
        (folder_path / doc_name).write_text(content, encoding='utf-8')

    print(f"Created active work-tracking folder: {folder_path.relative_to(REPO_ROOT)}")


def _load_source_workflow_state_module():
    helper_path = REPO_ROOT / "scripts" / "_source_workflow_state.py"
    if not helper_path.is_file():
        return None
    module_name = "_aegis_source_workflow_state_archive"
    spec = importlib.util.spec_from_file_location(module_name, helper_path)
    if spec is None or spec.loader is None:
        raise TaskError(f"Could not load source workflow helper: {helper_path}")
    module = importlib.util.module_from_spec(spec)
    sys.modules[module_name] = module
    spec.loader.exec_module(module)
    return module


def _is_uninstalled_source_checkout_for_archive() -> bool:
    module = _load_source_workflow_state_module()
    return bool(module and module.is_uninstalled_aegis_source_checkout(REPO_ROOT))


def _resolve_current_repo_document(relative_path: str) -> Optional[Path]:
    link = REPO_ROOT / relative_path
    if not link.exists():
        return None
    try:
        resolved = link.resolve(strict=True)
        resolved.relative_to(REPO_ROOT.resolve())
    except (FileNotFoundError, ValueError) as exc:
        raise TaskError(f"{relative_path} must resolve to a file inside the repository") from exc
    if not resolved.is_file():
        raise TaskError(f"{relative_path} must resolve to a regular file")
    return resolved


def _rewrite_archived_work_tracking_references(folder: Path, target_path: Path) -> Optional[Path]:
    old_reference = folder.relative_to(REPO_ROOT).as_posix()
    new_reference = target_path.relative_to(REPO_ROOT).as_posix()
    current_plan = _resolve_current_repo_document(PLANS_CURRENT_REL)
    current_session = _resolve_current_repo_document(SESSIONS_CURRENT_REL)
    plan_referenced_active_folder = False

    candidates = [
        path
        for path in target_path.rglob("*.md")
        if path.is_file() and not path.is_symlink()
    ]
    for current_document in (current_plan, current_session):
        if current_document is not None and current_document not in candidates:
            candidates.append(current_document)

    for path in candidates:
        text = path.read_text(encoding="utf-8")
        if path == current_plan and old_reference in text:
            plan_referenced_active_folder = True
        if old_reference not in text:
            continue
        path.write_text(text.replace(old_reference, new_reference), encoding="utf-8")

    return current_plan if plan_referenced_active_folder else None


def handle_work_tracking_archive(args: argparse.Namespace) -> None:
    folder = _resolve_active_work_tracking(args.folder)
    now = datetime.now().astimezone()
    iso_today = now.date().isoformat()
    timestamp = now.strftime("%Y-%m-%d %H:%M %Z")

    if args.dry_run:
        print(f"Would archive {folder.relative_to(REPO_ROOT)}")
        return

    tracker_path = folder / "TRACKER.md"
    if tracker_path.exists():
        lines = _load_file_lines(tracker_path)
        if not _replace_line_with_prefix(lines, "**Status**:", "**Status**: COMPLETED"):
            lines.insert(3, "**Status**: COMPLETED")
        if not _replace_line_with_prefix(lines, "**Last Updated**:", f"**Last Updated**: {iso_today}"):
            lines.insert(4, f"**Last Updated**: {iso_today}")
        _write_file_lines(tracker_path, lines)

    changelog_path = folder / "CHANGELOG.md"
    if changelog_path.exists():
        lines = _load_file_lines(changelog_path)
        lines.append(f"- {timestamp} — Archived active work-tracking folder.")
        _write_file_lines(changelog_path, lines)

    handoff_path = folder / "HANDOFF.md"
    if handoff_path.exists():
        lines = _load_file_lines(handoff_path)
        lines.append(f"- Archived on {timestamp} — Folder moved to archive and tracker marked COMPLETED.")
        _write_file_lines(handoff_path, lines)

    archive_base = WORK_TRACKING_BASE.parent / "archive"
    archive_base.mkdir(parents=True, exist_ok=True)
    target_name = folder.name.replace("-ACTIVE", "-COMPLETED")
    target_path = archive_base / target_name
    if target_path.exists():
        raise TaskError(f"Archive destination already exists: {target_path}")

    shutil.move(str(folder), str(target_path))
    rewritten_plan = None
    if _is_uninstalled_source_checkout_for_archive():
        rewritten_plan = _rewrite_archived_work_tracking_references(folder, target_path)
    if rewritten_plan is not None:
        handle_plan_sync(
            argparse.Namespace(
                plan=rewritten_plan.relative_to(REPO_ROOT).as_posix(),
                tracker=(target_path / "TRACKER.md").relative_to(REPO_ROOT).as_posix(),
                dry_run=False,
            )
        )
    print(f"Archived work-tracking folder to {target_path.relative_to(REPO_ROOT)}")



def handle_work_tracking_audit(args: argparse.Namespace) -> None:
    today = datetime.now().date().isoformat()
    today_prefix = today.replace('-', '')
    issues: List[str] = []
    warnings: List[str] = []

    if not WORK_TRACKING_BASE.exists():
        issues.append("Active work-tracking directory missing")
    else:
        active_folders = [p for p in WORK_TRACKING_BASE.iterdir() if p.is_dir() and p.name.endswith('-ACTIVE')]
        if not active_folders:
            warnings.append("No ACTIVE work-tracking folders present")
        else:
            if len(active_folders) > 1:
                names = ", ".join(p.name for p in active_folders)
                issues.append(f"Multiple ACTIVE folders detected: {names}")
            for folder in active_folders:
                prefix = folder.name.split('-', 1)[0]
                if prefix != today_prefix:
                    warnings.append(
                        f"Active folder {folder.name} has prefix {prefix}; today's prefix is {today_prefix} (ensure multi-day reuse is intentional)"
                    )
                tracker_path = folder / 'TRACKER.md'
                if tracker_path.exists():
                    try:
                        tracker_text = tracker_path.read_text(encoding='utf-8')
                    except FileNotFoundError:
                        tracker_text = ''
                    if today not in tracker_text or 'serena/memory' not in tracker_text.lower():
                        warnings.append(
                            f"Tracker for {folder.name} missing Serena memory entry for {today}; capture memory and log via presets."
                        )

    current_symlink = SESSIONS_DIR / 'current'
    if not current_symlink.exists() or not current_symlink.is_symlink():
        current_state = object()
        try:
            current_state = json.loads(SESSION_STATE_PATH.read_text(encoding='utf-8')).get('current')
        except (FileNotFoundError, json.JSONDecodeError):
            pass
        if current_state in {None, ''}:
            warnings.append(f"{SESSIONS_CURRENT_REL} symlink missing because repository is between sessions")
        else:
            issues.append(f"{SESSIONS_CURRENT_REL} symlink missing")
    else:
        target = current_symlink.resolve()
        if target.exists():
            try:
                relative = target.relative_to(SESSIONS_DIR)
            except ValueError:
                warnings.append(f"{SESSIONS_CURRENT_REL} points outside {SESSIONS_DIR.relative_to(REPO_ROOT).as_posix()}/: {target}")
            else:
                session_date = relative.name[:10]
                if session_date != today:
                    warnings.append(
                        f"{SESSIONS_CURRENT_REL} points to {relative} (date {session_date}); consider starting a new session for {today}"
                    )
        else:
            issues.append(f"{SESSIONS_CURRENT_REL} target missing: {target}")

    if issues:
        print("Audit issues detected:")
        for issue in issues:
            print(f"- {issue}")
    if warnings:
        print("Audit warnings:")
        for warning in warnings:
            print(f"- {warning}")
    if not issues and not warnings:
        print("Audit passed: no issues found.")
    if issues:
        sys.exit(1)


def _insert_progress_entry(lines: List[str], heading: str, entry_line: str) -> List[str]:
    try:
        heading_index = next(idx for idx, line in enumerate(lines) if line.strip() == heading)
    except StopIteration as exc:
        raise TaskError(f"Heading '{heading}' not found in target document.") from exc

    last_entry_index: Optional[int] = None
    for idx in range(heading_index + 1, len(lines)):
        line = lines[idx]
        if line.startswith("##") or line.startswith("###"):
            break
        if line.startswith("- "):
            last_entry_index = idx

    insert_at = heading_index + 1 if last_entry_index is None else last_entry_index + 1
    lines.insert(insert_at, entry_line)
    return lines


def handle_sessions_update(args: argparse.Namespace) -> None:
    session_path = _resolve_current_session(args.session_file)
    metadata = _parse_front_matter(session_path)
    session_value = args.session or _derive_session_value(metadata)

    timestamp = args.time or datetime.now().strftime(DEFAULT_TIME_FORMAT_SESSION)
    work = args.work
    handler = args.handler
    evidence = args.evidence
    note = args.note

    swhe = f"[S:{session_value}|W:{work}|H:{handler}|E:{evidence}]"
    entry = f"- **[{timestamp}]** — {swhe} {note}"

    if args.dry_run:
        print(entry)
        return

    lines = _load_file_lines(session_path)
    updated = _insert_progress_entry(lines, PROGRESS_HEADING_SESSION, entry)
    _write_file_lines(session_path, updated)
    print(f"Updated session log: {session_path}")


def _ensure_progress_heading(lines: List[str]) -> List[str]:
    heading = "## Progress Log"
    if heading in (line.strip() for line in lines):
        return lines
    if lines and not lines[-1].endswith("\n"):
        lines[-1] = lines[-1] + "\n"
    lines.extend(["\n", f"{heading}\n", "\n"])
    return lines


def handle_work_tracking_update(args: argparse.Namespace) -> None:
    work_folder = _resolve_active_work_tracking(args.folder)

    preset = getattr(args, "preset", None)
    handler_value = args.handler

    if preset:
        doc_name, default_handler = WORK_TRACKING_PRESETS[preset]
        target_name = doc_name
        if handler_value.lower() == "auto":
            handler_value = default_handler
    else:
        target_name = args.document if args.document.endswith(".md") else f"{args.document}.md"

    target_path = work_folder / target_name
    if not target_path.exists():
        template = WORK_TRACKING_DEFAULT_DOCS.get(target_name)
        today = datetime.now().date().isoformat()
        title_token = args.work.replace('-', ' ').title()
        task_match = re.search(r"(\d+)", args.work)
        task_value = task_match.group(1) if task_match else args.work
        if template:
            content = template.format(today=today, task=task_value, title=title_token)
        else:
            content = f"# {title_token}\n\n## Progress Log\n"
        target_path.write_text(content, encoding='utf-8')

    session_path = _resolve_current_session(args.session_file)
    metadata = _parse_front_matter(session_path)
    session_value = args.session or _derive_session_value(metadata)

    timestamp = args.time or datetime.now().strftime(DEFAULT_TIME_FORMAT_TRACKER)
    swhe = f"[S:{session_value}|W:{args.work}|H:{handler_value}|E:{args.evidence}]"
    entry = f"- **{timestamp}** — {swhe} {args.note}"

    if args.dry_run:
        print(entry)
        return

    lines = _load_file_lines(target_path)
    lines = _ensure_progress_heading(lines)
    updated = _insert_progress_entry(lines, PROGRESS_HEADING_TRACKER, entry)
    _write_file_lines(target_path, updated)
    print(f"Updated work-tracking log: {target_path}")


def _resolve_scanner(tool: str) -> Path:
    mapping = {
        "scanner": SCANNER_PATH / "scanner.py",
        "analyze": SCANNER_PATH / "analyze_references.py",
        "duplicates": SCANNER_PATH / "find_duplicates.py",
        "migration": SCANNER_PATH / "migration_detector.py",
        "fixes": SCANNER_PATH / "generate_fixes.py",
        "safe-reorg": SCANNER_PATH / "safe_reorganize.py",
    }
    if tool not in mapping:
        valid = ", ".join(sorted(mapping.keys()))
        raise TaskError(f"Unknown scanner tool '{tool}'. Valid options: {valid}")
    target = mapping[tool]
    if not target.exists():
        raise TaskError(f"Scanner script not found at {target}")
    return target


def _meta_guard_message() -> str:
    return (
        "Meta Workflow Guard failed. Ensure your plan includes the meta workflow assets, "
        "branch matches policy (e.g., feat/task<id>-description), and run plan sync. "
        "See templates/engine/enforcement/meta-workflow-guard-remediation.md for remediation steps."
    )


def handle_scanner_run(args: argparse.Namespace) -> None:
    script_path = _resolve_scanner(args.tool)
    extra_args = getattr(args, "scanner_args", [])
    cmd = [sys.executable, str(script_path)] + extra_args
    print("Running:", " ".join(cmd))
    result = subprocess.run(cmd, cwd=str(REPO_ROOT))
    if result.returncode != 0:
        raise TaskError(f"Scanner command failed with exit code {result.returncode}")

    if args.log_note:
        log_kwargs = {
            "work": args.work,
            "handler": args.handler,
            "evidence": args.evidence,
            "note": args.log_note,
            "session_file": args.session_file,
            "session": args.session,
            "time": args.time,
            "dry_run": args.dry_run,
        }
        handle_sessions_update(argparse.Namespace(**log_kwargs))
        handle_work_tracking_update(argparse.Namespace(
            work=args.work,
            handler=args.handler,
            evidence=args.evidence,
            note=args.log_note,
            folder=args.folder,
            document=args.document,
            session_file=args.session_file,
            session=args.session,
            time=args.time,
            dry_run=args.dry_run,
        ))


def handle_report_generate(args: argparse.Namespace) -> None:
    commands: List[List[str]] = []
    full_pipeline = args.kind in {"all", "telemetry"}

    if args.kind == "drift" or full_pipeline:
        drift_cmd = [
            sys.executable,
            str(CODEX_GUARD_SCRIPT),
            "drift-check",
            "--report-dir",
            args.drift_report_dir,
        ]
        if args.strict_drift:
            drift_cmd.append("--strict")
        commands.append(drift_cmd)

    if args.kind == "metrics" or full_pipeline:
        commands.append([
            sys.executable,
            str(METRICS_DASHBOARD_SCRIPT),
            "--report-dir",
            args.report_dir,
        ])

    if args.kind == "monitoring" or full_pipeline:
        monitoring_report_dir = args.monitoring_report_dir
        monitoring_cmd = [
            sys.executable,
            str(MONITORING_SCRIPT),
            "--metrics",
            args.metrics_file,
            "--report-dir",
            monitoring_report_dir,
        ]
        if args.strict_monitoring:
            monitoring_cmd.append("--strict")
        commands.append(monitoring_cmd)

    if args.kind == "phase0" or full_pipeline:
        monitoring_file = args.phase0_monitoring_file
        if full_pipeline:
            monitoring_file = (Path(args.monitoring_report_dir) / "latest.json").as_posix()
        phase0_cmd = [
            sys.executable,
            str(PHASE0_VALIDATION_SCRIPT),
            "--scanner-data-dir",
            args.scanner_data_dir,
            "--monitoring-file",
            monitoring_file,
            "--report-dir",
            args.phase0_report_dir,
        ]
        if args.strict_phase0:
            phase0_cmd.append("--strict")
        commands.append(phase0_cmd)

    if args.kind == "performance" or full_pipeline:
        performance_cmd = [
            sys.executable,
            str(PERFORMANCE_HARNESS_SCRIPT),
            "--report-dir",
            args.performance_report_dir,
        ]
        if args.performance_baseline_file:
            performance_cmd.extend(["--baseline-file", args.performance_baseline_file])
        if args.strict_performance:
            performance_cmd.append("--strict")
        commands.append(performance_cmd)

    if args.kind == "cost" or full_pipeline:
        cost_cmd = [
            sys.executable,
            str(COST_REPORT_SCRIPT),
            "--report-dir",
            args.cost_report_dir,
        ]
        if args.cost_usage_file:
            cost_cmd.extend(["--usage-file", args.cost_usage_file])
        if args.strict_cost:
            cost_cmd.append("--strict")
        commands.append(cost_cmd)

    if args.kind == "migration-health" or full_pipeline:
        metrics_file = args.metrics_file
        if full_pipeline:
            metrics_file = (Path(args.report_dir) / "latest.json").as_posix()
        migration_health_cmd = [
            sys.executable,
            str(MIGRATION_HEALTH_SCRIPT),
            "--metrics-file",
            metrics_file,
            "--monitoring-file",
            (Path(args.monitoring_report_dir) / "latest.json").as_posix(),
            "--phase0-file",
            (Path(args.phase0_report_dir) / "latest.json").as_posix(),
            "--performance-file",
            (Path(args.performance_report_dir) / "latest.json").as_posix(),
            "--cost-file",
            (Path(args.cost_report_dir) / "latest.json").as_posix(),
            "--report-dir",
            args.migration_health_report_dir,
        ]
        if args.strict_migration_health:
            migration_health_cmd.append("--strict")
        commands.append(migration_health_cmd)

    for cmd in commands:
        printable = " ".join(cmd)
        if args.dry_run:
            print(f"Would run: {printable}")
            continue
        print(f"Running: {printable}")
        result = subprocess.run(cmd, cwd=str(REPO_ROOT))
        if result.returncode != 0:
            raise TaskError(f"Report command failed with exit code {result.returncode}: {printable}")


def _path_display(path: Path) -> str:
    return _relative_to_root(path, REPO_ROOT)


def _is_executable_file(path: Path) -> bool:
    return path.is_file() and os.access(path, os.X_OK)


def _find_pre_commit_binary() -> Optional[Path]:
    local_binary = REPO_ROOT / ".venv" / "bin" / "pre-commit"
    if _is_executable_file(local_binary):
        return local_binary

    found = shutil.which("pre-commit")
    if found:
        return Path(found)
    return None


def _pre_commit_version(binary: Path) -> str:
    result = subprocess.run(
        [str(binary), "--version"],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return "version unavailable"
    return result.stdout.strip() or "version unavailable"


def _verify_pre_commit_config() -> List[str]:
    issues: List[str] = []
    if not PRE_COMMIT_CONFIG.exists():
        return [f"Missing {PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()}"]

    config_text = PRE_COMMIT_CONFIG.read_text(encoding="utf-8")
    for snippet in PRE_COMMIT_REQUIRED_SNIPPETS:
        if snippet not in config_text:
            issues.append(f"{PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()} missing required entry: {snippet}")
    if config_text.count("pass_filenames: false") < len(PRE_COMMIT_REQUIRED_SNIPPETS):
        issues.append(f"{PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()} should keep guard hooks filename-independent")
    if config_text.count("always_run: true") < len(PRE_COMMIT_REQUIRED_SNIPPETS):
        issues.append(f"{PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()} should keep guard hooks always-on")
    return issues


def _pre_commit_hook_status() -> Tuple[bool, str]:
    if not PRE_COMMIT_HOOK.exists():
        return False, f"{_path_display(PRE_COMMIT_HOOK)} is not installed"
    if not PRE_COMMIT_HOOK.is_file():
        return False, f"{_path_display(PRE_COMMIT_HOOK)} exists but is not a file"
    if not os.access(PRE_COMMIT_HOOK, os.X_OK):
        return False, f"{_path_display(PRE_COMMIT_HOOK)} exists but is not executable"
    try:
        hook_text = PRE_COMMIT_HOOK.read_text(encoding="utf-8", errors="ignore")
    except OSError as exc:
        return False, f"{_path_display(PRE_COMMIT_HOOK)} could not be read: {exc}"
    if "pre-commit" not in hook_text and "PRE_COMMIT" not in hook_text:
        return False, f"{_path_display(PRE_COMMIT_HOOK)} does not look like a pre-commit managed hook"
    return True, f"{_path_display(PRE_COMMIT_HOOK)} is installed"


def handle_hooks_verify(args: argparse.Namespace) -> None:
    issues = _verify_pre_commit_config()
    warnings: List[str] = []
    detail_lines: List[str] = []

    if issues:
        detail_lines.append(f"- {_path_display(PRE_COMMIT_CONFIG)}: failed")
    else:
        detail_lines.append(f"- {_path_display(PRE_COMMIT_CONFIG)}: ok")

    binary = _find_pre_commit_binary()
    if binary is None:
        issues.append("pre-commit executable not found; install dev dependencies or ensure .venv/bin/pre-commit exists")
        detail_lines.append("- pre-commit binary: missing")
    else:
        version = _pre_commit_version(binary)
        detail_lines.append(f"- pre-commit binary: ok ({_path_display(binary)}, {version})")

    hook_installed, hook_message = _pre_commit_hook_status()
    if hook_installed:
        detail_lines.append(f"- local pre-commit hook: ok ({hook_message})")
    else:
        message = f"local pre-commit hook: {hook_message}; run `{PRE_COMMIT_INSTALL_COMMAND}`"
        if args.require_installed:
            issues.append(message)
            detail_lines.append(f"- local pre-commit hook: failed ({hook_message})")
        else:
            warnings.append(message)
            detail_lines.append(f"- local pre-commit hook: warning ({hook_message})")

    print("Hook verification:")
    for line in detail_lines:
        print(line)
    if warnings:
        print("Warnings:")
        for warning in warnings:
            print(f"- {warning}")
    if issues:
        print("Issues:")
        for issue in issues:
            print(f"- {issue}")
        raise TaskError("Hook verification failed")
    print("Hook verification passed.")


def handle_taskmaster_generate_one(args: argparse.Namespace) -> None:
    task_id = str(args.task_id)
    try:
        int(task_id)
    except ValueError as exc:
        raise TaskError(f"Invalid task ID: {task_id}") from exc

    _assert_no_unrelated_task_file_changes(task_id, "before targeted generation")

    with tempfile.TemporaryDirectory(prefix="codex-taskmaster-generate-") as temp_name:
        temp_dir = Path(temp_name)
        result = subprocess.run(
            ["task-master", "generate", "--output", str(temp_dir)],
            cwd=str(REPO_ROOT),
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            message = result.stderr.strip() or result.stdout.strip() or "task-master generate failed"
            raise TaskError(message)

        source_path = _locate_generated_task_file(temp_dir, task_id)
        destination_path = _destination_task_file(task_id, source_path)
        rendered = _render_generated_task_content(source_path, destination_path)

        if args.dry_run:
            print(f"Would update {destination_path.relative_to(REPO_ROOT)} from temporary {source_path.name}")
            return

        destination_path.parent.mkdir(parents=True, exist_ok=True)
        destination_path.write_text(rendered, encoding="utf-8")

    _assert_no_unrelated_task_file_changes(task_id, "after targeted generation")
    print(f"Updated {destination_path.relative_to(REPO_ROOT)} from targeted Taskmaster generation")


def _normalise_dependency_id(value: object) -> str:
    return str(value).strip()


def _load_taskmaster_tasks_data() -> dict:
    if not TASKMASTER_TASKS_JSON.exists():
        raise TaskError(f"Taskmaster tasks file not found: {TASKMASTER_TASKS_JSON.relative_to(REPO_ROOT)}")
    try:
        return json.loads(TASKMASTER_TASKS_JSON.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"Invalid Taskmaster JSON: {TASKMASTER_TASKS_JSON.relative_to(REPO_ROOT)}") from exc


def _resolve_taskmaster_tag(data: dict, requested_tag: str | None = None) -> str:
    if requested_tag:
        if requested_tag not in data:
            raise TaskError(f"Taskmaster tag not found: {requested_tag}")
        return requested_tag
    if "master" in data:
        return "master"
    tags = [key for key, value in data.items() if isinstance(value, dict) and "tasks" in value]
    if len(tags) == 1:
        return tags[0]
    raise TaskError("Unable to determine Taskmaster tag; pass --tag explicitly")


def _taskmaster_dependency_health(tag_data: dict) -> tuple[dict, list[str]]:
    tasks = tag_data.get("tasks")
    if not isinstance(tasks, list):
        raise TaskError("Taskmaster tag data does not contain a tasks list")

    task_ids = {_normalise_dependency_id(task.get("id")) for task in tasks}
    status_counts: Dict[str, int] = {}
    total_subtasks = 0
    dependency_refs = 0
    invalid_refs: list[str] = []

    for task in tasks:
        task_id = _normalise_dependency_id(task.get("id"))
        status = str(task.get("status") or "unknown")
        status_counts[status] = status_counts.get(status, 0) + 1

        for dependency in task.get("dependencies") or []:
            dependency_id = _normalise_dependency_id(dependency)
            if not dependency_id:
                continue
            dependency_refs += 1
            if dependency_id not in task_ids:
                invalid_refs.append(f"Task {task_id} depends on missing task {dependency_id}")

        subtasks = task.get("subtasks") or []
        total_subtasks += len(subtasks)
        subtask_local_ids = {_normalise_dependency_id(subtask.get("id")) for subtask in subtasks}
        subtask_full_ids = {f"{task_id}.{subtask_id}" for subtask_id in subtask_local_ids if subtask_id}
        valid_subtask_refs = subtask_local_ids | subtask_full_ids | task_ids
        for subtask in subtasks:
            subtask_id = _normalise_dependency_id(subtask.get("id"))
            for dependency in subtask.get("dependencies") or []:
                dependency_id = _normalise_dependency_id(dependency)
                if not dependency_id:
                    continue
                dependency_refs += 1
                if dependency_id not in valid_subtask_refs:
                    invalid_refs.append(f"Subtask {task_id}.{subtask_id} depends on missing reference {dependency_id}")

    summary = {
        "tasks": len(tasks),
        "subtasks": total_subtasks,
        "status_counts": status_counts,
        "dependency_refs": dependency_refs,
        "invalid_refs": len(invalid_refs),
    }
    return summary, invalid_refs


def _render_taskmaster_health_report(tag: str, summary: dict, invalid_refs: list[str]) -> str:
    status_counts = summary["status_counts"]
    status_text = ", ".join(f"{name}={count}" for name, count in sorted(status_counts.items()))
    lines = [
        "Taskmaster health: " + ("OK" if not invalid_refs else "FAILED"),
        f"Tag: {tag}",
        f"Tasks: {summary['tasks']}",
        f"Subtasks: {summary['subtasks']}",
        f"Statuses: {status_text}",
        f"Dependency refs: {summary['dependency_refs']}",
        f"Invalid dependency refs: {summary['invalid_refs']}",
        "",
        "Note: `task-master list --status=<status>` can print filtered-view dependency warnings because dependencies outside the filtered subset are hidden. Use this helper or `task-master validate-dependencies` for authoritative full-graph health.",
    ]
    if invalid_refs:
        lines.extend(["", "Invalid references:"])
        lines.extend(f"- {issue}" for issue in invalid_refs)
    return "\n".join(lines) + "\n"


def handle_taskmaster_health(args: argparse.Namespace) -> None:
    data = _load_taskmaster_tasks_data()
    tag = _resolve_taskmaster_tag(data, args.tag)
    summary, invalid_refs = _taskmaster_dependency_health(data[tag])
    report = _render_taskmaster_health_report(tag, summary, invalid_refs)

    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(report, encoding="utf-8")
        print(f"Wrote Taskmaster health report to {report_path.relative_to(REPO_ROOT)}")
    print(report, end="")

    if invalid_refs:
        raise TaskError("Taskmaster dependency health failed")


def _git_output(args: List[str]) -> str:
    result = subprocess.run(
        ["git", *args],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or f"git {' '.join(args)} failed"
        raise TaskError(message)
    return result.stdout.rstrip("\n")


def _git_status_snapshot() -> List[Dict[str, str]]:
    output = _git_output(["status", "--short"])
    entries: List[Dict[str, str]] = []
    for raw in output.splitlines():
        if not raw:
            continue
        path_text = raw[3:].strip()
        if " -> " in path_text:
            path_text = path_text.rsplit(" -> ", 1)[1]
        entries.append({"status": raw[:2], "path": path_text.strip('"')})
    return entries


def _file_sha256(path: Path) -> Optional[str]:
    if not path.exists() or not path.is_file():
        return None
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _symlink_snapshot(path: Path) -> Dict[str, Any]:
    payload: Dict[str, Any] = {
        "path": _relative_to_root(path, REPO_ROOT),
        "exists": path.exists() or path.is_symlink(),
        "is_symlink": path.is_symlink(),
        "target": None,
        "resolved": None,
        "sha256": None,
    }
    if path.is_symlink():
        payload["target"] = os.readlink(path)
    if path.exists():
        resolved = path.resolve()
        payload["resolved"] = _relative_to_root(resolved, REPO_ROOT)
        payload["sha256"] = _file_sha256(resolved)
    return payload


def _taskmaster_snapshot() -> Dict[str, Any]:
    payload: Dict[str, Any] = {
        "path": _relative_to_root(TASKMASTER_TASKS_JSON, REPO_ROOT),
        "exists": TASKMASTER_TASKS_JSON.exists(),
        "sha256": _file_sha256(TASKMASTER_TASKS_JSON),
        "tag": None,
        "summary": None,
        "invalid_refs": [],
    }
    if not TASKMASTER_TASKS_JSON.exists():
        return payload
    data = _load_taskmaster_tasks_data()
    tag = _resolve_taskmaster_tag(data, None)
    summary, invalid_refs = _taskmaster_dependency_health(data[tag])
    payload["tag"] = tag
    payload["summary"] = summary
    payload["invalid_refs"] = invalid_refs
    return payload


def _serena_memory_snapshot() -> Dict[str, Any]:
    memory_dir = REPO_ROOT / ".serena" / "memories"
    memories = (
        sorted(memory_dir.glob("*.md"), key=lambda path: (path.stat().st_mtime, path.name))
        if memory_dir.exists()
        else []
    )
    return {
        "path": _relative_to_root(memory_dir, REPO_ROOT),
        "exists": memory_dir.exists(),
        "count": len(memories),
        "latest": [_relative_to_root(path, REPO_ROOT) for path in memories[-10:]],
    }


SERENA_REQUIRED_ARGS = ("serena", "start-mcp-server", "--project-from-cwd")


def _load_toml_document(path: Path) -> Dict[str, Any]:
    try:
        with path.open("rb") as handle:
            return tomllib.load(handle)
    except FileNotFoundError:
        return {}
    except tomllib.TOMLDecodeError as exc:
        raise TaskError(f"Could not parse {path.relative_to(REPO_ROOT).as_posix()}: {exc}") from exc


def _load_json_file_document(path: Path) -> Dict[str, Any]:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return {}
    except json.JSONDecodeError as exc:
        raise TaskError(f"Could not parse {path.relative_to(REPO_ROOT).as_posix()}: {exc}") from exc


def _serena_server_issues(server: Any, *, label: str) -> Tuple[List[str], List[str]]:
    issues: List[str] = []
    warnings: List[str] = []
    if not isinstance(server, dict):
        return [f"{label}: missing Serena MCP server entry"], warnings

    server_type = server.get("type")
    if server_type != "stdio":
        issues.append(f"{label}: expected type=stdio, found {server_type!r}")

    command = server.get("command")
    if command != "uvx":
        issues.append(f"{label}: expected command=uvx, found {command!r}")

    args = server.get("args")
    if not isinstance(args, list):
        issues.append(f"{label}: args must be a list containing Serena startup tokens")
        return issues, warnings

    missing = [token for token in SERENA_REQUIRED_ARGS if token not in args]
    if missing:
        issues.append(f"{label}: missing required Serena args: {', '.join(missing)}")

    if "--from" not in args:
        warnings.append(f"{label}: args do not pin Serena source with --from")
    else:
        from_index = args.index("--from")
        source = args[from_index + 1] if from_index + 1 < len(args) else ""
        if "github.com/oraios/serena" not in str(source):
            warnings.append(f"{label}: --from source does not point at oraios/serena")
        if "@" not in str(source):
            warnings.append(f"{label}: Serena source is not pinned to a commit or version")

    return issues, warnings


def _serena_status_report() -> Tuple[str, List[str]]:
    issues: List[str] = []
    warnings: List[str] = []
    lines: List[str] = []

    codex_config_path = REPO_ROOT / ".codex" / "config.toml"
    project_mcp_path = REPO_ROOT / ".mcp.json"
    memory_dir = REPO_ROOT / ".serena" / "memories"

    codex_config = _load_toml_document(codex_config_path)
    codex_server = codex_config.get("mcp_servers", {}).get("serena") if isinstance(codex_config, dict) else None
    codex_issues, codex_warnings = _serena_server_issues(codex_server, label=".codex/config.toml")
    issues.extend(codex_issues)
    warnings.extend(codex_warnings)

    project_mcp = _load_json_file_document(project_mcp_path)
    project_server = project_mcp.get("mcpServers", {}).get("serena") if isinstance(project_mcp, dict) else None
    project_issues, project_warnings = _serena_server_issues(project_server, label=".mcp.json")
    issues.extend(project_issues)
    warnings.extend(project_warnings)

    memories = (
        sorted(memory_dir.glob("*.md"), key=lambda path: (path.stat().st_mtime, path.name))
        if memory_dir.exists()
        else []
    )
    if not memory_dir.exists():
        warnings.append(".serena/memories: directory missing; create Serena memory during the first tracked session")

    status = "OK" if not issues else "ISSUES"
    lines.append(f"Serena integration status: {status}")
    lines.append("")
    lines.append(f"- Codex MCP config: {_relative_to_root(codex_config_path, REPO_ROOT)}")
    lines.append(f"- Project MCP config: {_relative_to_root(project_mcp_path, REPO_ROOT)}")
    lines.append(f"- Serena memory directory: {_relative_to_root(memory_dir, REPO_ROOT)}")
    lines.append(f"- Serena memory count: {len(memories)}")
    if memories:
        lines.append("- Latest Serena memories:")
        for path in memories[-5:]:
            lines.append(f"  - {_relative_to_root(path, REPO_ROOT)}")
    lines.append("")
    lines.append("Runtime verification:")
    lines.append("- In an active agent session, confirm Serena tools with `mcp__serena__.get_current_config`.")
    lines.append("- Template registry misses should surface `source=serena` / `fallback_action=serena_search` rather than silently failing.")

    if warnings:
        lines.append("")
        lines.append("Warnings:")
        lines.extend(f"- {warning}" for warning in warnings)
    if issues:
        lines.append("")
        lines.append("Issues:")
        lines.extend(f"- {issue}" for issue in issues)

    return "\n".join(lines) + "\n", issues


def handle_serena_status(args: argparse.Namespace) -> None:
    report, issues = _serena_status_report()
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(report, encoding="utf-8")
        print(f"Wrote Serena status report to {_relative_to_root(report_path, REPO_ROOT)}")
    else:
        print(report, end="")

    if args.strict and issues:
        raise TaskError("Serena integration status failed in strict mode")


def _workflow_snapshot() -> Dict[str, Any]:
    active_folders = []
    if WORK_TRACKING_BASE.exists():
        active_folders = [
            _relative_to_root(path, REPO_ROOT)
            for path in sorted(WORK_TRACKING_BASE.iterdir())
            if path.is_dir() and path.name.endswith("-ACTIVE")
        ]
    return {
        "current_session": _symlink_snapshot(SESSIONS_DIR / "current"),
        "current_plan": _symlink_snapshot(PLAN_CURRENT),
        "session_state": {
            "path": _relative_to_root(SESSION_STATE_PATH, REPO_ROOT),
            "exists": SESSION_STATE_PATH.exists(),
            "sha256": _file_sha256(SESSION_STATE_PATH),
        },
        "active_work_tracking": active_folders,
    }


def _create_rollback_tag(prefix: str, label: str, created_at: datetime) -> str:
    tag_prefix = prefix.strip().strip("/") or "codex-rollback"
    stamp = created_at.strftime("%Y%m%d-%H%M%S")
    tag_name = f"{tag_prefix}/{stamp}-{_slugify(label)}"
    result = subprocess.run(
        ["git", "tag", "-a", tag_name, "-m", f"Codex rollback checkpoint: {label}"],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or f"Unable to create rollback tag {tag_name}"
        raise TaskError(message)
    return tag_name


def _build_rollback_checkpoint(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "checkpoint"
    snapshot: Dict[str, Any] = {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "git": {
            "branch": _git_output(["branch", "--show-current"]),
            "head": _git_output(["rev-parse", "HEAD"]),
            "status": _git_status_snapshot(),
            "tag": None,
        },
        "workflow": _workflow_snapshot(),
        "taskmaster": _taskmaster_snapshot(),
        "serena": _serena_memory_snapshot(),
    }
    if args.create_tag:
        snapshot["git"]["tag"] = _create_rollback_tag(args.tag_prefix, label, now)
    return snapshot


def _default_rollback_checkpoint_path(snapshot: Dict[str, Any]) -> Path:
    created = datetime.fromisoformat(str(snapshot["created_at"]))
    label = _slugify(str(snapshot.get("label") or "checkpoint"))
    return REPO_ROOT / "reports" / "rollback" / "checkpoints" / f"{created.strftime('%Y%m%d-%H%M%S')}-{label}.json"


def handle_rollback_checkpoint(args: argparse.Namespace) -> None:
    snapshot = _build_rollback_checkpoint(args)
    output_path = Path(args.report_file) if args.report_file else _default_rollback_checkpoint_path(snapshot)
    if not output_path.is_absolute():
        output_path = REPO_ROOT / output_path
    rendered = json.dumps(snapshot, indent=2, sort_keys=True) + "\n"
    if args.dry_run:
        print(rendered, end="")
        return
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(rendered, encoding="utf-8")
    print(f"Wrote rollback checkpoint to {_relative_to_root(output_path, REPO_ROOT)}")
    tag = snapshot["git"].get("tag")
    if tag:
        print(f"Created rollback tag: {tag}")


def _render_rollback_plan(snapshot: Dict[str, Any]) -> str:
    git_info = snapshot.get("git", {})
    workflow = snapshot.get("workflow", {})
    taskmaster = snapshot.get("taskmaster", {})
    lines = [
        "# Rollback Recovery Plan",
        "",
        f"- Snapshot label: {snapshot.get('label')}",
        f"- Created at: {snapshot.get('created_at')}",
        f"- Branch at checkpoint: {git_info.get('branch')}",
        f"- Commit at checkpoint: {git_info.get('head')}",
        f"- Rollback tag: {git_info.get('tag') or 'not created'}",
        "",
        "## Non-Destructive First Steps",
        "1. Run `git status --short --branch` and inspect the current diff.",
        f"2. Compare current changes with the checkpoint commit: `git diff {git_info.get('head')} --stat`.",
        "3. Review the active session, plan, and work-tracking folder before restoring files.",
        "",
        "## Safe Restore Guidance",
        f"- Return to the checkpoint branch if needed: `git switch {git_info.get('branch')}`.",
        f"- Restore selected tracked paths only after review: `git restore --source {git_info.get('head')} --staged --worktree -- <path>`.",
        "- Preview untracked cleanup with `git clean -nd`; do not remove untracked files without explicit approval.",
        "- Avoid `git reset --hard`; this helper intentionally does not execute destructive rollback commands.",
        "",
        "## Workflow Pointers At Checkpoint",
        f"- Current session: {workflow.get('current_session', {}).get('resolved')}",
        f"- Current plan: {workflow.get('current_plan', {}).get('resolved')}",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        f"- Taskmaster tasks.json SHA256: {taskmaster.get('sha256')}",
        "",
        "No rollback commands were executed by this plan.",
    ]
    return "\n".join(lines) + "\n"


def handle_rollback_plan(args: argparse.Namespace) -> None:
    snapshot_path = Path(args.snapshot)
    if not snapshot_path.is_absolute():
        snapshot_path = REPO_ROOT / snapshot_path
    snapshot = json.loads(snapshot_path.read_text(encoding="utf-8"))
    rendered = _render_rollback_plan(snapshot)
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        if not args.dry_run:
            report_path.parent.mkdir(parents=True, exist_ok=True)
            report_path.write_text(rendered, encoding="utf-8")
            print(f"Wrote rollback plan to {_relative_to_root(report_path, REPO_ROOT)}")
            return
    print(rendered, end="")


