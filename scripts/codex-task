        "--plan-status",
        default="in-progress",
        choices=sorted(AEGIS_PLAN_STATUS_CHOICES),
        help="Status to write for --plan-step.",
    )
    aegis_log_parser.set_defaults(func=handle_aegis_log)

    aegis_list_profiles = aegis_sub.add_parser("list-profiles", help="List built-in Aegis profiles")
    aegis_list_profiles.set_defaults(func=handle_aegis_list_profiles)

    aegis_explain_profile = aegis_sub.add_parser("explain-profile", help="Print the built-in Aegis profile contract")
    aegis_explain_profile.add_argument("--profile", default="generic", help="Aegis profile (V1 supports generic)")
    aegis_explain_profile.set_defaults(func=handle_aegis_explain_profile)

    aegis_mcp_parser = aegis_sub.add_parser(
        "mcp",
        help="Generate, execute, and verify native MCP client registration commands",
    )
    aegis_mcp_sub = aegis_mcp_parser.add_subparsers(dest="aegis_mcp_subcommand", required=True)

    aegis_mcp_register = aegis_mcp_sub.add_parser("register", help="Register Aegis with a native MCP client")
    aegis_mcp_register.add_argument("client", choices=("claude", "codex"), help="Native MCP client to configure")
    aegis_mcp_register.add_argument(
        "--scope",
        choices=("local", "user", "project"),
        default="user",
        help="Claude MCP scope. Defaults to user for Claude and is ignored for Codex.",
    )
    aegis_mcp_register.add_argument(
        "--source-mode",
        choices=("package", "pinned", "github", "private-github", "wheel", "source"),
        default="package",
        help="How uvx should resolve the Aegis package that provides aegis-mcp-server",
    )
    aegis_mcp_register.add_argument("--package-spec", help="Explicit uvx --from package/artifact spec")
    aegis_mcp_register.add_argument("--package-version", help="Version for --source-mode pinned")
    aegis_mcp_register.add_argument(
        "--github-url",
        default=mcp_registration.DEFAULT_GITHUB_URL,
        help="GitHub repository URL for --source-mode github/private-github",
    )
    aegis_mcp_register.add_argument("--github-ref", help="Optional ref for --source-mode github/private-github")
    aegis_mcp_register.add_argument("--artifact", help="Wheel path or source checkout path for wheel/source modes")
    aegis_mcp_register.add_argument("--target-dir", default=".", help="Default target directory passed to aegis-mcp-server")
    aegis_mcp_register.add_argument(
        "--uv-cache-dir",
        default=mcp_registration.DEFAULT_UV_CACHE_DIR,
        help="UV_CACHE_DIR value registered with the native client; use '' to omit.",
    )
    aegis_mcp_register.add_argument(
        "--uv-tool-dir",
        default=mcp_registration.DEFAULT_UV_TOOL_DIR,
        help="UV_TOOL_DIR value registered with the native client; use '' to omit.",
    )
    aegis_mcp_register.add_argument("--transport", choices=("stdio",), default="stdio", help="MCP server transport to register")
    aegis_mcp_register.add_argument("--cwd", help="Working directory for native client command. Defaults to --target-dir")
    aegis_mcp_register.set_defaults(func=handle_aegis_mcp_register)

    aegis_mcp_generate = aegis_mcp_sub.add_parser(
        "generate-registration",
        help="Generate the native MCP client command for registering Aegis",
    )
    _add_aegis_mcp_registration_arguments(aegis_mcp_generate)
    aegis_mcp_generate.set_defaults(func=handle_aegis_mcp_generate_registration)

    aegis_mcp_execute = aegis_mcp_sub.add_parser(
        "execute-registration",
        help="Run the native MCP client command for registering Aegis",
    )
    _add_aegis_mcp_registration_arguments(aegis_mcp_execute, execute=True)
    aegis_mcp_execute.set_defaults(func=handle_aegis_mcp_execute_registration)

    aegis_mcp_verify = aegis_mcp_sub.add_parser(
        "verify-registration",
        help="Verify the native MCP client's Aegis registration",
    )
    _add_aegis_mcp_registration_arguments(aegis_mcp_verify, execute=True)
    aegis_mcp_verify.set_defaults(func=handle_aegis_mcp_verify_registration)

    aegis_mcp_smoke = aegis_mcp_sub.add_parser(
        "smoke-registration",
        help="Run native MCP register and verify in isolated temporary client homes",
    )
    aegis_mcp_smoke.add_argument(
        "--client",
        action="append",
        choices=("all", "claude", "codex"),
        help="Native MCP client to smoke test. Repeatable. Defaults to all.",
    )
    aegis_mcp_smoke.add_argument(
        "--scope",
        choices=("local", "user", "project"),
        default="user",
        help="Claude MCP scope. Defaults to user and is ignored for Codex.",
    )
    aegis_mcp_smoke.add_argument(
        "--source-mode",
        choices=("package", "pinned", "github", "private-github", "wheel", "source"),
        default="package",
        help="How uvx should resolve the Aegis package that provides aegis-mcp-server",
    )
    aegis_mcp_smoke.add_argument("--package-spec", help="Explicit uvx --from package/artifact spec")
    aegis_mcp_smoke.add_argument("--package-version", help="Version for --source-mode pinned")
    aegis_mcp_smoke.add_argument(
        "--github-url",
        default=mcp_registration.DEFAULT_GITHUB_URL,
        help="GitHub repository URL for --source-mode github/private-github",
    )
    aegis_mcp_smoke.add_argument("--github-ref", help="Optional ref for --source-mode github/private-github")
    aegis_mcp_smoke.add_argument("--artifact", help="Wheel path or source checkout path for wheel/source modes")
    aegis_mcp_smoke.add_argument("--target-dir", default=".", help="Default target directory passed to aegis-mcp-server")
    aegis_mcp_smoke.add_argument(
        "--uv-cache-dir",
        default=mcp_registration.DEFAULT_UV_CACHE_DIR,
        help="UV_CACHE_DIR value registered with the native client; use '' to omit.",
    )
    aegis_mcp_smoke.add_argument(
        "--uv-tool-dir",
        default=mcp_registration.DEFAULT_UV_TOOL_DIR,
        help="UV_TOOL_DIR value registered with the native client; use '' to omit.",
    )
    aegis_mcp_smoke.add_argument("--transport", choices=("stdio",), default="stdio", help="MCP server transport to register")
    aegis_mcp_smoke.add_argument("--smoke-root", help="Directory for isolated client homes. Defaults to a temporary directory.")
    aegis_mcp_smoke.add_argument("--keep-temp", action="store_true", help="Keep generated temporary homes after the smoke run.")
    aegis_mcp_smoke.add_argument("--report-file", help="Optional JSON report path.")
    aegis_mcp_smoke.add_argument("--markdown-report-file", help="Optional Markdown report path.")
    aegis_mcp_smoke.set_defaults(func=handle_aegis_mcp_smoke_registration)

    wizard_parser = subparsers.add_parser("wizard", help="Guided workflow operations")
    wizard_sub = wizard_parser.add_subparsers(dest="subcommand", required=True)
    wizard_kickoff = wizard_sub.add_parser("kickoff", help="Interactively scaffold a task session, plan, and work-tracking state")
    wizard_kickoff.add_argument("--task", help="Task ID (numeric)")
    wizard_kickoff.add_argument("--slug", help="Slug for session/plan/work-tracking naming")
    wizard_kickoff.add_argument("--title", help="Human-readable task title")
    wizard_kickoff.add_argument("--goal", action="append", help="Goal checklist item (repeatable)")
    wizard_kickoff.add_argument("--task-source", help="Human-readable source line for the session metadata")
    wizard_kickoff.add_argument("--handler-target", help="Primary handler target/path for the generated plan")
    wizard_kickoff.add_argument("--force", action="store_true", help="Allow kickoff even if another ACTIVE folder exists")
    wizard_kickoff.set_defaults(func=handle_wizard_kickoff)

    scanner_parser = subparsers.add_parser("scanner", help="SSOT scanner operations")
    scanner_sub = scanner_parser.add_subparsers(dest="subcommand", required=True)
    scanner_run = scanner_sub.add_parser("run", help="Run a scanner tool and optionally log results")
    scanner_run.add_argument("tool", help="Scanner tool key (scanner, analyze, duplicates, migration, fixes, safe-reorg)")
    scanner_run.add_argument("--work", required=True, help="W field value for logging")
    scanner_run.add_argument("--handler", required=True, help="H field value for logging")
    scanner_run.add_argument("--evidence", required=True, help="E field value for logging")
    scanner_run.add_argument("--log-note", help="Log note to append after successful run")
    scanner_run.add_argument("--folder", help="Work-tracking folder override")
    scanner_run.add_argument("--document", default="TRACKER", help="Work-tracking markdown name for logging")
    scanner_run.set_defaults(func=handle_scanner_run)

    return parser


def main(argv: Optional[List[str]] = None) -> int:
    parser = build_parser()
    args, unknown = parser.parse_known_args(argv)

    if unknown:
        if getattr(args, "command", None) == "scanner" and getattr(args, "subcommand", None) == "run":
            setattr(args, "scanner_args", unknown)
        else:
            parser.error(f"unrecognized arguments: {' '.join(unknown)}")

    try:
        args.func(args)
    except TaskError as exc:
        message = str(exc)
        print(f"error: {message}", file=sys.stderr)
        lowered = message.lower()
        if any(keyword in lowered for keyword in ("guard", "plan sync", "branch policy")):
            print(_meta_guard_message(), file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        return 130
    return 0


if __name__ == "__main__":
    sys.exit(main())
