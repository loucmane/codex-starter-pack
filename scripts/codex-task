def _slugify(value: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", value.strip().lower()).strip('-')
    return slug or "work"

class TaskError(Exception):
    """Custom exception for predictable task failures."""


def _load_file_lines(path: Path) -> List[str]:
    text = path.read_text(encoding="utf-8")
    # `splitlines()` keeps consistent handling regardless of trailing newline.
    return text.splitlines()


def _write_file_lines(path: Path, lines: Iterable[str]) -> None:
    content = "\n".join(lines) + "\n"
    path.write_text(content, encoding="utf-8")


def _relative_to_root(path: Path, root: Path) -> str:
    try:
        return path.relative_to(root).as_posix()
    except ValueError:
        return path.as_posix()


def _symlink_to(link_path: Path, target_path: Path) -> None:
    link_path.parent.mkdir(parents=True, exist_ok=True)
    if link_path.exists() or link_path.is_symlink():
        link_path.unlink()
    relative_target = Path(
        *target_path.relative_to(link_path.parent).parts
    ) if target_path.is_relative_to(link_path.parent) else Path(
        *Path(
            *(['..'] * len(link_path.parent.relative_to(REPO_ROOT).parts)),
            *target_path.relative_to(REPO_ROOT).parts,
        ).parts
    )
    link_path.symlink_to(relative_target)


def _replace_line_with_prefix(lines: List[str], prefix: str, new_line: str) -> bool:
    for idx, line in enumerate(lines):
        if line.startswith(prefix):
            lines[idx] = new_line
            return True
    return False


def _next_session_id(now: datetime) -> str:
    date_prefix = now.strftime("%Y-%m-%d")
    session_dir = SESSIONS_DIR / now.strftime("%Y") / now.strftime("%m")
    session_dir.mkdir(parents=True, exist_ok=True)
    pattern = re.compile(rf"^{re.escape(date_prefix)}-(\d{{3}})-")
    max_suffix = 0
    for candidate in session_dir.glob(f"{date_prefix}-*.md"):
        match = pattern.match(candidate.name)
        if match:
            max_suffix = max(max_suffix, int(match.group(1)))
    return f"{date_prefix}-{max_suffix + 1:03d}"


def _task_file_path(task_id: str) -> Path:
    token = int(task_id)
    tasks_dir = _taskmaster_tasks_dir()
    for candidate in _task_file_candidates(tasks_dir, task_id):
        if candidate.exists():
            return candidate
    return tasks_dir / f"task_{token:03d}.txt"


def _taskmaster_tasks_dir() -> Path:
    tasks_dir = TASKMASTER_TASKS_DIR
    if not tasks_dir.is_relative_to(REPO_ROOT):
        tasks_dir = load_repo_structure(REPO_ROOT).taskmaster_tasks_dir
    return tasks_dir


def _task_file_name_stems(task_id: str) -> List[str]:
    token = int(task_id)
    stems = [f"task_{token:03d}", f"task_{token}"]
    return list(dict.fromkeys(stems))


def _task_file_candidates(base_dir: Path, task_id: str, suffixes: Tuple[str, ...] = (".txt", ".md")) -> List[Path]:
    return [base_dir / f"{stem}{suffix}" for stem in _task_file_name_stems(task_id) for suffix in suffixes]


def _task_id_from_task_file(path: Path) -> Optional[int]:
    match = re.match(r"^task_(\d+)\.(?:txt|md)$", path.name)
    if not match:
        return None
    return int(match.group(1))


def _load_task_metadata(task_id: str) -> Dict[str, str]:
    task_file = _task_file_path(task_id)
    data = {
        "title": f"Task {task_id}",
        "description": "",
        "path": task_file.relative_to(REPO_ROOT).as_posix(),
    }
    if not task_file.exists():
        return data
    for raw in task_file.read_text(encoding="utf-8").splitlines():
        if raw.startswith("# Title:"):
            data["title"] = raw.split(":", 1)[1].strip()
        elif raw.startswith("# Description:"):
            data["description"] = raw.split(":", 1)[1].strip()
        elif raw.startswith("**Title:**"):
            data["title"] = raw.split("**Title:**", 1)[1].strip()
        elif raw.startswith("**Description:**"):
            data["description"] = raw.split("**Description:**", 1)[1].strip()
    return data


def _prompt_with_default(label: str, default: Optional[str] = None) -> str:
    while True:
        prompt = f"{label}"
        if default:
            prompt += f" [{default}]"
        prompt += ": "
        value = input(prompt).strip()
        if value:
            return value
        if default is not None:
            return default


def _default_goals_for_title(title: str) -> List[str]:
    return [
        f"Define the scope and workflow boundary for {title}",
        f"Implement {title} using the existing helper surface",
        "Verify guard integration, documentation, and regression coverage",
    ]


def _write_session_state(current_session_name: str, now: datetime) -> None:
    payload = {
        "current": current_session_name,
        "paused": [],
        "updated_at": now.isoformat(timespec="seconds"),
    }
    SESSION_STATE_PATH.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def _run_checked_command(cmd: List[str]) -> None:
    result = subprocess.run(cmd, cwd=str(REPO_ROOT), capture_output=True, text=True)
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or f"Command failed: {' '.join(cmd)}"
        raise TaskError(message)


def _task_status_entries() -> Dict[Path, str]:
    tasks_rel = _taskmaster_tasks_dir().relative_to(REPO_ROOT).as_posix()
    result = subprocess.run(
        ["git", "status", "--porcelain", "--", tasks_rel],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or "Unable to inspect Taskmaster task-file status"
        raise TaskError(message)

    entries: Dict[Path, str] = {}
    for raw_line in result.stdout.splitlines():
        if not raw_line:
            continue
        status = raw_line[:2]
        path_text = raw_line[3:].strip()
        if " -> " in path_text:
            path_text = path_text.rsplit(" -> ", 1)[1]
        path_text = path_text.strip('"')
        path = REPO_ROOT / path_text
        if _task_id_from_task_file(path) is not None:
            entries[path.resolve()] = status
    return entries


def _assert_no_unrelated_task_file_changes(task_id: str, phase: str) -> None:
    target_id = int(task_id)
    unrelated = []
    for path, status in _task_status_entries().items():
        if _task_id_from_task_file(path) != target_id:
            unrelated.append(f"{status} {_relative_to_root(path, REPO_ROOT)}")
    if unrelated:
        rendered = ", ".join(sorted(unrelated))
        raise TaskError(f"Unrelated Taskmaster task files are dirty {phase}: {rendered}")


def _locate_generated_task_file(output_dir: Path, task_id: str) -> Path:
    for candidate in _task_file_candidates(output_dir, task_id):
        if candidate.exists():
            return candidate
    expected = ", ".join(candidate.name for candidate in _task_file_candidates(output_dir, task_id))
    raise TaskError(f"Generated task file for task {task_id} not found in temporary output ({expected})")


def _destination_task_file(task_id: str, source_path: Path) -> Path:
    tasks_dir = _taskmaster_tasks_dir()
    for candidate in _task_file_candidates(tasks_dir, task_id):
        if candidate.exists():
            return candidate
    return tasks_dir / f"{_task_file_name_stems(task_id)[0]}{source_path.suffix}"


def _clean_dependency_value(value: str) -> str:
    return re.sub(r"\s*[✓✔]\s*$", "", value).strip()


def _convert_taskmaster_markdown_to_text(markdown_text: str) -> str:
    output: List[str] = []
    in_subtasks = False
    source_lines = markdown_text.splitlines()

    def next_non_empty(index: int) -> str:
        for candidate in source_lines[index + 1:]:
            if candidate.strip():
                return candidate.strip()
        return ""

    for index, raw in enumerate(source_lines):
        line = raw.rstrip()
        if not line:
            previous = output[-1] if output else ""
            upcoming = next_non_empty(index)
            if previous.startswith(("# ", "### ")) and upcoming.startswith(("**", "# Task ID:")):
                continue
            if previous.endswith(":") and previous.startswith(("# ", "### ")):
                continue
            if output and output[-1] != "":
                output.append("")
            continue

        metadata = re.match(r"^\*\*(Title|Status|Dependencies|Priority|Description):\*\*\s*(.*)$", line)
        section = re.match(r"^\*\*(Details|Test Strategy):\*\*\s*$", line)

        if line.startswith("# Task ID:"):
            output.append(line)
        elif metadata:
            label = metadata.group(1)
            value = metadata.group(2).strip().rstrip()
            if label == "Dependencies":
                value = _clean_dependency_value(value)
            prefix = "###" if in_subtasks else "#"
            output.append(f"{prefix} {label}: {value}")
        elif section:
            prefix = "###" if in_subtasks else "#"
            output.append(f"{prefix} {section.group(1)}:")
        elif line == "## Subtasks":
            in_subtasks = True
            output.append("# Subtasks:")
        elif in_subtasks and line.startswith("### "):
            subtask_match = re.match(r"^###\s+\d+\.(\d+)\.\s+(.*)$", line)
            if subtask_match:
                output.append(f"## {subtask_match.group(1)}. {subtask_match.group(2)}")
            else:
                output.append(f"## {line[4:]}")
        else:
            output.append(line)

    while output and output[-1] == "":
        output.pop()
    return "\n".join(output) + "\n"


def _render_generated_task_content(source_path: Path, destination_path: Path) -> str:
    content = source_path.read_text(encoding="utf-8")
    if source_path.suffix == ".md" and destination_path.suffix == ".txt":
        return _convert_taskmaster_markdown_to_text(content)
    return content if content.endswith("\n") else f"{content}\n"


def _target_path(target_root: Path, raw_value: str) -> Path:
    path = Path(raw_value)
    if not path.is_absolute():
        path = target_root / path
    return path.resolve()


def _repo_structure_from_values(target_root: Path, values: Dict[str, str]) -> RepoStructure:
    return RepoStructure(
        repo_root=target_root.resolve(),
        templates_root=_target_path(target_root, values["templates_root"]),
        sessions_root=_target_path(target_root, values["sessions_root"]),
        plans_root=_target_path(target_root, values["plans_root"]),
        plan_state_dir=_target_path(target_root, values["plan_state_dir"]),
        taskmaster_root=_target_path(target_root, values["taskmaster_root"]),
        work_tracking_root=_target_path(target_root, values["work_tracking_root"]),
        reports_root=_target_path(target_root, values["reports_root"]),
    )


def _bootstrap_values_from_args(args: argparse.Namespace) -> Dict[str, str]:
    values = dict(DEFAULT_REPO_STRUCTURE)
    for key in BOOTSTRAP_STRUCTURE_KEYS:
        override = getattr(args, key, None)
        if override:
            values[key] = override
    return values


def _render_bootstrap_config(values: Dict[str, str]) -> str:
    lines = [
        "# Portable foundation bootstrap config",
        "# Review and adjust repo-local roots before broad adoption.",
        "",
        "[repo_structure]",
    ]
    for key in BOOTSTRAP_STRUCTURE_KEYS:
        lines.append(f'{key} = "{values[key]}"')
    return "\n".join(lines) + "\n"


def _render_bootstrap_setup_doc(target_root: Path, structure: RepoStructure) -> str:
    lines = [
        "# Foundation Bootstrap Setup",
        "",
        "This repository has been scaffolded with the portable Codex foundation starter assets.",
        "",
        "## Created Starter Assets",
        "",
        f"- `.codex/config.toml` — repo-local workflow roots for `{target_root.name or target_root.as_posix()}`",
        f"- `{_relative_to_root(structure.template_metadata_policy_path, target_root)}` — starter metadata policy",
        f"- `{_relative_to_root(structure.sessions_root, target_root)}/` — session root",
        f"- `{_relative_to_root(structure.plans_root, target_root)}/` — plan root",
        f"- `{_relative_to_root(structure.taskmaster_root, target_root)}/` — Taskmaster root scaffold",
        f"- `{_relative_to_root(structure.work_tracking_root, target_root)}/` — work-tracking root scaffold",
        f"- `{_relative_to_root(structure.reports_root, target_root)}/` — reports root scaffold",
        "",
        "## Next Steps",
        "",
        "1. Review `.codex/config.toml` and adjust `[repo_structure]` to match this repository if needed.",
        "2. Review the metadata policy at the configured template path before enabling broad enforcement.",
        "3. Initialize or reconcile Taskmaster content for this repository if it is part of the workflow.",
        "4. Start the first task on a `feat/task-<id>-...` branch with `python3 scripts/codex-task wizard kickoff --task <id>`.",
        "",
        "## Migration Safety",
        "",
        "- Existing config and policy files are preserved unless bootstrap is re-run with `--force`.",
        "- Existing workflow directories are treated as valid inputs and are not removed.",
        "- Re-run bootstrap after changing repo roots if you need the starter layout refreshed.",
    ]
    return "\n".join(lines) + "\n"


def _record_bootstrap_result(results: List[Tuple[str, str, str]], kind: str, path: Path, status: str, root: Path) -> None:
    results.append((kind, _relative_to_root(path, root), status))


def _ensure_directory(path: Path, root: Path, results: List[Tuple[str, str, str]], dry_run: bool) -> None:
    if path.exists():
        if not path.is_dir():
            raise TaskError(f"Expected directory but found file: {path}")
        _record_bootstrap_result(results, "dir", path, "existing", root)
        return
    if dry_run:
        _record_bootstrap_result(results, "dir", path, "would-create", root)
        return
    path.mkdir(parents=True, exist_ok=True)
    _record_bootstrap_result(results, "dir", path, "created", root)


def _write_bootstrap_file(
    path: Path,
    content: str,
    *,
    force: bool,
    root: Path,
    results: List[Tuple[str, str, str]],
    dry_run: bool,
) -> None:
    existed = path.exists()
    if existed and not force:
        _record_bootstrap_result(results, "file", path, "existing", root)
        return
    if dry_run:
        _record_bootstrap_result(results, "file", path, "would-update" if existed else "would-create", root)
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    _record_bootstrap_result(results, "file", path, "updated" if existed else "created", root)


def handle_bootstrap_init(args: argparse.Namespace) -> None:
    target_root = Path(args.target_dir).expanduser()
    if not target_root.is_absolute():
        target_root = (REPO_ROOT / target_root).resolve()
    else:
        target_root = target_root.resolve()

    if not args.dry_run:
        target_root.mkdir(parents=True, exist_ok=True)

    target_config = target_root / ".codex" / "config.toml"
    bootstrap_values = _bootstrap_values_from_args(args)
    should_write_config = args.force or not target_config.exists()
    structure = _repo_structure_from_values(target_root, bootstrap_values) if should_write_config else load_repo_structure(target_root)

    results: List[Tuple[str, str, str]] = []

    _write_bootstrap_file(
        target_config,
        _render_bootstrap_config(bootstrap_values),
        force=args.force,
        root=target_root,
        results=results,
        dry_run=args.dry_run,
    )

    directories = [
        structure.templates_root,
        structure.template_metadata_policy_path.parent,
        structure.sessions_root,
        structure.plans_root,
        structure.plan_state_dir,
        structure.taskmaster_root,
        structure.taskmaster_tasks_dir,
        structure.taskmaster_root / "docs",
        structure.taskmaster_root / "reports",
        structure.work_tracking_root,
        structure.work_tracking_active_root,
        structure.work_tracking_archive_root,
        structure.reports_root,
        structure.drift_report_dir,
        structure.metrics_report_dir,
        structure.continuation_guard_dir,
        (target_root / BOOTSTRAP_SETUP_REL).parent,
    ]
    for directory in directories:
        _ensure_directory(directory, target_root, results, args.dry_run)

    policy_source = REPO_STRUCTURE.template_metadata_policy_path
    policy_content = policy_source.read_text(encoding="utf-8")
    _write_bootstrap_file(
        structure.template_metadata_policy_path,
        policy_content,
        force=args.force,
        root=target_root,
        results=results,
        dry_run=args.dry_run,
    )

    _write_bootstrap_file(
        target_root / BOOTSTRAP_SETUP_REL,
        _render_bootstrap_setup_doc(target_root, structure),
        force=args.force,
        root=target_root,
        results=results,
        dry_run=args.dry_run,
    )

    status_order = ("created", "updated", "existing", "would-create", "would-update")
    print(f"Bootstrap target: {target_root}")
    for status in status_order:
        matching = [(kind, rel) for kind, rel, item_status in results if item_status == status]
        if not matching:
            continue
        print(f"{status}:")
        for kind, rel in matching:
            print(f"  - {kind}: {rel}")


def _validate_branch_for_task(branch: str, task_id: str) -> None:
    expected = f"feat/task-{task_id}"
    if not branch.startswith(expected):
        raise TaskError(
            f"Current branch '{branch}' does not satisfy feature-required policy for task {task_id}; expected prefix '{expected}'"
        )


def _build_session_lines(
    session_id: str,
    now: datetime,
    task_id: str,
    title: str,
    branch: str,
    source: str,
    task_file_relative: str,
    work_context: str,
    tracker_relative: str,
) -> List[str]:
    date_iso = now.strftime("%Y-%m-%d")
    time_label = now.strftime("%H:%M %Z")
    timestamp_full = now.strftime("%Y-%m-%d %H:%M:%S %Z %z")
    session_value = now.strftime("%Y%m%d")
    pretty_title = f"Task {task_id} - {title}"
    return [
        "---",
        f"session_id: {session_id}",
        f"date: {date_iso}",
        f"time: {time_label}",
        f"title: {pretty_title}",
        "---",
        "",
        f"## Session: {date_iso} {time_label}",
        "**AI Assistant**: Codex GPT-5.4",
        "**Developer**: loucmane",
        f"**Task**: Start Task {task_id} via the guided kickoff flow and establish compliant session, plan, and work-tracking state for {title}.",
        f"**Task Source**: {source}",
        "",
        "### Session Validation",
        f"- [x] Date confirmed (`date '+%Y-%m-%d %H:%M:%S %Z %z'` -> `{timestamp_full}`)",
        f"- [x] Git branch checked (`{branch}`)",
        f"- [x] Taskmaster task reviewed (`{task_file_relative}`)",
        "",
        "### Session Goals",
        f"- [x] Start a fresh Task {task_id} session on the Task {task_id} branch.",
        f"- [x] Scaffold Task {task_id} work tracking.",
        f"- [x] Repoint `{SESSIONS_CURRENT_REL}` and `{PLANS_CURRENT_REL}` to Task {task_id}.",
        f"- [x] Mark Taskmaster Task {task_id} in progress and update its generated task file.",
        f"- [ ] Review the design baseline and implementation boundary for {title}.",
        "- [ ] Capture implementation and verification evidence.",
        "",
        "### Starting Context",
        f"Task {task_id} was kicked off via `python3 scripts/codex-task wizard kickoff`, which created the session, plan, work-tracking scaffolding, and targeted generated task-file update in a guard-compliant state before implementation began.",
        "",
        "### 📝 Progress Log",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:shell:date|E:cmd`date \"+%Y-%m-%d %H:%M:%S %Z %z\"`] Confirmed current timestamp as `{timestamp_full}`",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:scripts/codex-task|E:{tracker_relative}] Scaffolded the Task {task_id} ACTIVE work-tracking folder through the guided kickoff flow",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:task-master:set-status|E:{TASKMASTER_TASKS_JSON_REL}] Marked Taskmaster Task {task_id} in progress and updated only its generated task file",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:{SESSIONS_CURRENT_REL}|E:{SESSIONS_CURRENT_REL}] Repointed `{SESSIONS_CURRENT_REL}`, `{PLANS_CURRENT_REL}`, and `{SESSION_STATE_REL}` to the new Task {task_id} kickoff",
    ]


def _build_tracker_entries(
    now: datetime,
    task_id: str,
    work_context: str,
    tracker_relative: str,
) -> List[str]:
    session_value = now.strftime("%Y%m%d")
    timestamp = now.strftime("%Y-%m-%d %H:%M")
    return [
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:shell:date|E:cmd`date \"+%Y-%m-%d %H:%M %Z\"`] Confirmed current timestamp as `{now.strftime('%Y-%m-%d %H:%M %Z')}`",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:scripts/codex-task|E:{tracker_relative}] Scaffolded the Task {task_id} ACTIVE work-tracking folder through the guided kickoff flow",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:task-master:set-status|E:{TASKMASTER_TASKS_JSON_REL}] Marked Taskmaster Task {task_id} in progress and updated only its generated task file",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:{SESSIONS_CURRENT_REL}|E:{SESSIONS_CURRENT_REL}] Repointed `{SESSIONS_CURRENT_REL}`, `{PLANS_CURRENT_REL}`, and `{SESSION_STATE_REL}` to the new Task {task_id} kickoff",
    ]


def _build_plan_lines(
    session_id: str,
    task_id: str,
    title: str,
    work_context: str,
    handler_target: str,
    tracker_relative: str,
    task_file_relative: str,
    branch: str,
) -> List[str]:
    return [
        "---",
        f"session_id: {session_id}",
        f"work_context: {work_context}",
        f"handler_target: {handler_target}",
        f"task_ids: [{task_id}]",
        "branch_policy: feature-required",
        "evidence_summary:",
        f"  - {tracker_relative.rsplit('/', 1)[0]}/",
        f"  - {handler_target}",
        f"  - {task_file_relative}",
        f"  - {Path('scripts/codex-task').as_posix()}",
        "plan_version: v1",
        "emergency_bypass: false",
        "---",
        "",
        f"# Plan - Task {task_id} {title}",
        "",
        "## Header",
        f"- **Session ID (S)**: {session_id}",
        f"- **Work Context (W)**: {work_context}",
        f"- **Handler Target (H)**: {handler_target}",
        f"- **Task IDs**: {task_id}",
        "- **Branch Policy**: feature-required",
        f"- **Evidence Summary (E)**: {tracker_relative.rsplit('/', 1)[0]}/, {handler_target}, {task_file_relative}, scripts/codex-task",
        "- **Plan Version**: v1",
        "- **Emergency Bypass**: false",
        "",
        "## Plan Table",
        "| Step ID             | Description | Evidence | Status |",
        "|---------------------|-------------|----------|--------|",
        f"| plan-step-scope | Design the wizard flow, prompt contract, and workflow boundary for {title} | {tracker_relative.rsplit('/', 1)[0]}/designs/wizard-flow.md | pending |",
        f"| plan-step-implement | Implement the wizard CLI, helper integration, and documentation for {title} | scripts/codex-task; {tracker_relative.rsplit('/', 1)[0]}/IMPLEMENTATION.md | pending |",
        f"| plan-step-verify | Store evidence, refresh handoff docs, and confirm Taskmaster status | {tracker_relative.rsplit('/', 1)[0]}/HANDOFF.md; {tracker_relative} | pending |",
        "| plan-step-emergency | _Optional_ - only if bypass required | Waiver + post-mortem plan | n/a |",
        "",
        "## Scope",
        f"- `{tracker_relative.rsplit('/', 1)[0]}/`",
        f"- `{handler_target}`",
        f"- `{task_file_relative}`",
        "- `scripts/codex-task`",
        "- `tests/`",
        f"- Taskmaster Task `{task_id}`",
        "",
        "## Branch Policy",
        f"- Working branch: `{branch}`",
        "",
        "## Amendments & Versioning",
        f"- {datetime.now().date().isoformat()} - Task {task_id} kickoff created via the guided wizard flow.",
        "",
        "## Continuation & Handoff",
        "- Next owner: loucmane (default)",
        "- Context reload steps:",
        f"  1. Read `{SESSIONS_CURRENT_REL}` and this plan.",
        f"  2. Review Taskmaster Task {task_id} and its subtasks.",
        "  3. Review the wizard design artifact before changing helper behavior.",
        "  4. Run `python3 scripts/codex-task plan sync` after tracker updates.",
        "- Outstanding risks/todos: keep the wizard grounded in the existing helper commands rather than creating a parallel workflow engine.",
        "",
        "## Conflict & Scope Declaration",
        "- Related plans: Tasks 94-95 enforcement groundwork, Task 97 dashboard follow-on.",
        "- Guard cross-check: wizard flows must preserve plan/tracker/session compliance as the default path.",
        "",
        "## Evidence Checklist",
        "- Wizard design note under `designs/`",
        "- Tracker/session entries for kickoff and implementation progress",
        "- Stored test and guard evidence once the wizard implementation lands",
        "",
        "## Emergency Bypass Protocol",
        "- No bypass authorized.",
    ]


def handle_wizard_kickoff(args: argparse.Namespace) -> None:
    now = datetime.now().astimezone()
    task_id = args.task or _prompt_with_default("Task ID")
    task_meta = _load_task_metadata(task_id)
    title = args.title or _prompt_with_default("Task title", task_meta["title"])
    slug = _slugify(args.slug or _prompt_with_default("Task slug", _slugify(title)))
    goals = args.goal or _default_goals_for_title(title)
    source = args.task_source or f"Guided kickoff for Task {task_id}"
    task_file_relative = task_meta["path"]
    handler_target = args.handler_target or task_file_relative
    work_context = f"task{task_id}-{slug}"
    branch = subprocess.run(
        ["git", "branch", "--show-current"],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
        check=False,
    ).stdout.strip() or f"feat/task-{task_id}-{slug}"
    _validate_branch_for_task(branch, task_id)

    scaffold_args = argparse.Namespace(
        task=task_id,
        slug=slug,
        title=title,
        goal=goals,
        force=args.force,
        dry_run=args.dry_run,
    )
    handle_work_tracking_scaffold(scaffold_args)

    session_id = _next_session_id(now)
    session_dir = SESSIONS_DIR / now.strftime("%Y") / now.strftime("%m")
    session_path = session_dir / f"{session_id}-task{task_id}-{slug}.md"
    plan_path = PLAN_CURRENT.parent / f"{now.strftime('%Y-%m-%d')}-task{task_id}-{slug}.md"
    tracker_relative = (WORK_TRACKING_BASE / f"{now.strftime('%Y%m%d')}-task{task_id}-{slug}-ACTIVE" / "TRACKER.md").relative_to(REPO_ROOT).as_posix()

    session_lines = _build_session_lines(
        session_id=session_id,
        now=now,
        task_id=task_id,
        title=title,
        branch=branch,
        source=source,
        task_file_relative=task_file_relative,
        work_context=work_context,
        tracker_relative=tracker_relative,
    )
    plan_lines = _build_plan_lines(
        session_id=session_id,
        task_id=task_id,
        title=title,
        work_context=work_context,
        handler_target=handler_target,
        tracker_relative=tracker_relative,
        task_file_relative=task_file_relative,
        branch=branch,
    )

    if args.dry_run:
        print(f"Would create session {session_path.relative_to(REPO_ROOT)}")
        print(f"Would create plan {plan_path.relative_to(REPO_ROOT)}")
        return

    session_dir.mkdir(parents=True, exist_ok=True)
    _write_file_lines(session_path, session_lines)
    _write_file_lines(plan_path, plan_lines)
    _symlink_to(SESSIONS_DIR / "current", session_path)
    _symlink_to(PLAN_CURRENT, plan_path)
    _write_session_state(session_path.name, now)
    tracker_path = REPO_ROOT / tracker_relative
    tracker_lines = _load_file_lines(tracker_path)
    for entry in _build_tracker_entries(now, task_id, work_context, tracker_relative):
        tracker_lines = _insert_progress_entry(tracker_lines, PROGRESS_HEADING_TRACKER, entry)
    _write_file_lines(tracker_path, tracker_lines)
    handle_plan_sync(argparse.Namespace(plan=plan_path.relative_to(REPO_ROOT).as_posix(), tracker=tracker_relative, dry_run=False))
    _run_checked_command(["task-master", "set-status", f"--id={task_id}", "--status=in-progress"])
    handle_taskmaster_generate_one(argparse.Namespace(task_id=task_id, dry_run=False))
    print(f"Created session: {session_path.relative_to(REPO_ROOT)}")
    print(f"Created plan: {plan_path.relative_to(REPO_ROOT)}")
    print(f"Repointed {SESSIONS_CURRENT_REL}, {PLANS_CURRENT_REL}, and {SESSION_STATE_REL}")


def _resolve_plan_path(override: Optional[str] = None) -> Path:
    if override:
        candidate = (REPO_ROOT / override).resolve()
        if not candidate.exists():
            raise TaskError(f"Plan file not found: {candidate}")
        return candidate

    if not PLAN_CURRENT.exists():
        raise TaskError("Active plan symlink missing; create plan with templates/workflows/processes/plan-template.md")

    resolved = PLAN_CURRENT.resolve()
    if not resolved.exists():
        raise TaskError(f"Active plan target missing: {resolved}")
    return resolved


def _is_between_sessions_state() -> bool:
    """Return true when the repository is intentionally between sessions."""

    if PLAN_CURRENT.exists() or PLAN_CURRENT.is_symlink():
        return False

    current_session_link = SESSIONS_DIR / "current"
    if current_session_link.exists() or current_session_link.is_symlink():
        return False

    if not SESSION_STATE_PATH.exists():
        return False

    try:
        state = json.loads(SESSION_STATE_PATH.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return False

    return state.get("current") in {None, ""}


def _resolve_tracker_path(override: Optional[str] = None) -> Path:
    if override:
        candidate = (REPO_ROOT / override).resolve()
        if not candidate.exists():
            raise TaskError(f"Tracker file not found: {candidate}")
        return candidate
    return _get_tracker_path()


def _parse_plan_table(text: str) -> Dict[str, Dict[str, str]]:
    steps: Dict[str, Dict[str, str]] = {}
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line.startswith("|"):
            continue
        cells = [cell.strip() for cell in line.strip("|").split("|")]
        if not cells or not cells[0].startswith("plan-step-"):
            continue
        if len(cells) < 4:
            raise TaskError(f"Malformed plan table row: {raw_line}")
        step_id = cells[0]
        description = cells[1] if len(cells) > 1 else ""
        evidence = cells[-2] if len(cells) >= 3 else ""
        status = cells[-1].lower()
        steps[step_id] = {
            "description": description,
            "evidence": evidence,
            "status": status,
        }
    return steps


def _ensure_plan_steps_present(steps: Dict[str, Dict[str, str]]) -> None:
    missing = [step for step in PLAN_REQUIRED_STEPS if step not in steps]
    if missing:
        raise TaskError(f"Plan is missing required rows: {', '.join(missing)}")


def _load_tracker_text(tracker_path: Path) -> str:
    return tracker_path.read_text(encoding="utf-8")


def _tracker_has_checkbox(tracker_text: str, step_id: str, checked: bool) -> bool:
    token = "- [x]" if checked else "- [ ]"
    return f"{token} {step_id}" in tracker_text


def _validate_tracker_alignment(steps: Dict[str, Dict[str, str]], tracker_text: str) -> None:
    issues: List[str] = []
    for step_id, data in steps.items():
        status = data.get("status", "").strip().lower()
        has_checked = _tracker_has_checkbox(tracker_text, step_id, True)
        has_unchecked = _tracker_has_checkbox(tracker_text, step_id, False)
        if not has_checked and not has_unchecked:
            issues.append(f"Tracker missing checkbox for {step_id}")
            continue

        if status in PLAN_STATUS_COMPLETE and not has_checked:
            issues.append(f"Tracker checkbox for {step_id} should be checked (status {status})")
        elif status in PLAN_STATUS_INCOMPLETE and not has_unchecked:
            issues.append(f"Tracker checkbox for {step_id} should remain unchecked (status {status})")
        elif status in PLAN_STATUS_PASSIVE and not has_unchecked:
            issues.append(f"Tracker checkbox for {step_id} should remain unchecked (status {status})")
    if issues:
        raise TaskError("; ".join(issues))


def _compute_sha256(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _load_plan_sync_entries() -> List[Dict[str, str]]:
    if not PLAN_SYNC_LOG.exists():
        return []
    try:
        data = json.loads(PLAN_SYNC_LOG.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"Plan sync log is not valid JSON: {exc}")
    if not isinstance(data, list):
        raise TaskError("Plan sync log root must be a list")
    return data


def _write_plan_sync_entries(entries: List[Dict[str, str]]) -> None:
    PLAN_STATE_DIR.mkdir(parents=True, exist_ok=True)
    PLAN_SYNC_LOG.write_text(json.dumps(entries, indent=2) + "\n", encoding="utf-8")


def handle_plan_sync(args: argparse.Namespace) -> None:
    if not args.plan and not args.tracker and _is_between_sessions_state():
        print("No active plan; repository is between sessions. Plan sync skipped.")
        return

    plan_path = _resolve_plan_path(args.plan)
    tracker_path = _resolve_tracker_path(args.tracker)

    plan_text = plan_path.read_text(encoding="utf-8")
    steps = _parse_plan_table(plan_text)
    _ensure_plan_steps_present(steps)

    tracker_text = _load_tracker_text(tracker_path)
    _validate_tracker_alignment(steps, tracker_text)

    plan_hash = _compute_sha256(plan_path)
    tracker_hash = _compute_sha256(tracker_path)

    rel_plan = plan_path.relative_to(REPO_ROOT).as_posix()
    entries = _load_plan_sync_entries()
    entry = {
        "plan": rel_plan,
        "plan_hash": plan_hash,
        "tracker_hash": tracker_hash,
        "synced_at": datetime.now().astimezone().isoformat(),
    }

    if args.dry_run:
        print(json.dumps(entry, indent=2))
        return

    entries.append(entry)
    _write_plan_sync_entries(entries)
    print(f"Plan sync recorded for {rel_plan}")
def _parse_front_matter(path: Path) -> Dict[str, str]:
    text = path.read_text(encoding="utf-8")
    if not text.startswith("---"):
        return {}
    parts = text.split("---", 2)
    if len(parts) < 3:
        return {}
    front_matter = parts[1]
    data: Dict[str, str] = {}
    for raw_line in front_matter.strip().splitlines():
        if not raw_line.strip() or raw_line.strip().startswith("#"):
            continue
        if ":" not in raw_line:
            continue
        key, value = raw_line.split(":", 1)
        data[key.strip()] = value.strip()
    return data


def _resolve_current_session(explicit: Optional[str] = None) -> Path:
    if explicit:
        candidate = (REPO_ROOT / explicit).resolve()
        if not candidate.exists():
            raise TaskError(f"Specified session file not found: {candidate}")
        return candidate

    current_link = SESSIONS_DIR / "current"
    if current_link.exists():
        return current_link.resolve()

    # Fallback: find most recent session markdown in sessions directory.
    candidates = sorted(SESSIONS_DIR.glob("**/*.md"))
    if not candidates:
        raise TaskError(f"No session files located under {SESSIONS_DIR.relative_to(REPO_ROOT).as_posix()}/.")
    return candidates[-1]


def _resolve_active_work_tracking(explicit: Optional[str] = None) -> Path:
    if explicit:
        target = (WORK_TRACKING_BASE / explicit).resolve()
        if not target.exists():
            raise TaskError(f"Work-tracking folder not found: {target}")
        return target

    candidates = [p for p in WORK_TRACKING_BASE.iterdir() if p.is_dir() and p.name.endswith("-ACTIVE")]
    if not candidates:
        raise TaskError(f"No ACTIVE work-tracking folder found under {WORK_TRACKING_ACTIVE_REL}/.")
    if len(candidates) > 1:
        names = ", ".join(p.name for p in candidates)
        raise TaskError(f"Multiple ACTIVE work-tracking folders found ({names}); specify one via --folder.")
    return candidates[0]


def _get_tracker_path(explicit: Optional[str] = None) -> Path:
    folder = _resolve_active_work_tracking(explicit)
    tracker = folder / "TRACKER.md"
    if not tracker.exists():
        raise TaskError(f"Tracker file missing at {tracker}")
    return tracker


def _derive_session_value(meta: Dict[str, str]) -> str:
    if "session_id" in meta:
        session_id = meta["session_id"].strip()
        if session_id:
            parts = session_id.split("-")
            if len(parts) >= 3:
                return "".join(parts[:3])
            return session_id.replace("-", "")
    if "date" in meta:
        return meta["date"].replace("-", "")
    raise TaskError("Unable to derive session value from metadata; ensure front matter includes session_id or date.")


def _ensure_no_active_conflict(ignore_existing: bool) -> None:
    if ignore_existing:
        return
    active = [p for p in WORK_TRACKING_BASE.iterdir() if p.is_dir() and p.name.endswith("-ACTIVE")]
    if active:
        names = ", ".join(sorted(p.name for p in active))
        raise TaskError(
            f"Active work-tracking folder(s) already exist ({names}). Archive them first or pass --force to scaffold."
        )


def handle_work_tracking_scaffold(args: argparse.Namespace) -> None:
    now = datetime.now().astimezone()
    date_prefix = now.strftime("%Y%m%d")
    iso_today = now.date().isoformat()
    slug = _slugify(args.slug)
    task_token = f"task{args.task}"
    folder_name = f"{date_prefix}-{task_token}-{slug}-ACTIVE"
    folder_path = WORK_TRACKING_BASE / folder_name

    WORK_TRACKING_BASE.mkdir(parents=True, exist_ok=True)

    if folder_path.exists():
        raise TaskError(f"Work-tracking folder already exists: {folder_path}")

    _ensure_no_active_conflict(args.force)

    if args.dry_run:
        print(f"Would create {folder_path.relative_to(REPO_ROOT)}")
        return

    folder_path.mkdir(parents=True)
    (folder_path / "designs").mkdir()
    reports_base = folder_path / "reports" / slug
    reports_base.mkdir(parents=True)

    title = args.title or args.slug.replace('-', ' ').title()
    goals = args.goal or ["Document alignment prerequisites", "Implement alignment workflow and guard", "Capture evidence"]

    tracker_lines = [
        f"# Task {args.task} {title} Tracker",
        "",
        f"**Started**: {iso_today}",
        "**Status**: ACTIVE",
        f"**Last Updated**: {iso_today}",
        "",
        "## Goals",
    ] + [f"- [ ] {goal}" for goal in goals] + [
        "",
        "## Progress Log",
        "",
        "## Plan Compliance Checklist",
        "- [ ] plan-step-scope — Define alignment prerequisites and scope",
        "- [ ] plan-step-implement — Update workflow/guard/docs and capture tests",
        "- [ ] plan-step-verify — Evidence stored, documentation updated",
        "- [ ] plan-step-emergency (if applicable)",
        "",
        "## Dependencies & Notes",
        f"- Session log: {SESSIONS_CURRENT_REL}",
    ]
    _write_file_lines(folder_path / "TRACKER.md", tracker_lines)

    timestamp = now.strftime("%Y-%m-%d %H:%M %Z")
    changelog_lines = [
        f"# Task {args.task} {title} – Changelog",
        "",
        f"- {timestamp} — Initialized active work-tracking folder.",
    ]
    _write_file_lines(folder_path / "CHANGELOG.md", changelog_lines)

    for doc_name, template in WORK_TRACKING_DEFAULT_DOCS.items():
        content = template.format(today=iso_today, task=args.task, title=title)
        (folder_path / doc_name).write_text(content, encoding='utf-8')

    print(f"Created active work-tracking folder: {folder_path.relative_to(REPO_ROOT)}")


def handle_work_tracking_archive(args: argparse.Namespace) -> None:
    folder = _resolve_active_work_tracking(args.folder)
    now = datetime.now().astimezone()
    iso_today = now.date().isoformat()
    timestamp = now.strftime("%Y-%m-%d %H:%M %Z")

    if args.dry_run:
        print(f"Would archive {folder.relative_to(REPO_ROOT)}")
        return

    tracker_path = folder / "TRACKER.md"
    if tracker_path.exists():
        lines = _load_file_lines(tracker_path)
        if not _replace_line_with_prefix(lines, "**Status**:", "**Status**: COMPLETED"):
            lines.insert(3, "**Status**: COMPLETED")
        if not _replace_line_with_prefix(lines, "**Last Updated**:", f"**Last Updated**: {iso_today}"):
            lines.insert(4, f"**Last Updated**: {iso_today}")
        _write_file_lines(tracker_path, lines)

    changelog_path = folder / "CHANGELOG.md"
    if changelog_path.exists():
        lines = _load_file_lines(changelog_path)
        lines.append(f"- {timestamp} — Archived active work-tracking folder.")
        _write_file_lines(changelog_path, lines)

    handoff_path = folder / "HANDOFF.md"
    if handoff_path.exists():
        lines = _load_file_lines(handoff_path)
        lines.append(f"- Archived on {timestamp} — Folder moved to archive and tracker marked COMPLETED.")
        _write_file_lines(handoff_path, lines)

    archive_base = WORK_TRACKING_BASE.parent / "archive"
    archive_base.mkdir(parents=True, exist_ok=True)
    target_name = folder.name.replace("-ACTIVE", "-COMPLETED")
    target_path = archive_base / target_name
    if target_path.exists():
        raise TaskError(f"Archive destination already exists: {target_path}")

    shutil.move(str(folder), str(target_path))
    print(f"Archived work-tracking folder to {target_path.relative_to(REPO_ROOT)}")



def handle_work_tracking_audit(args: argparse.Namespace) -> None:
    today = datetime.now().date().isoformat()
    today_prefix = today.replace('-', '')
    issues: List[str] = []
    warnings: List[str] = []

    if not WORK_TRACKING_BASE.exists():
        issues.append("Active work-tracking directory missing")
    else:
        active_folders = [p for p in WORK_TRACKING_BASE.iterdir() if p.is_dir() and p.name.endswith('-ACTIVE')]
        if not active_folders:
            warnings.append("No ACTIVE work-tracking folders present")
        else:
            if len(active_folders) > 1:
                names = ", ".join(p.name for p in active_folders)
                issues.append(f"Multiple ACTIVE folders detected: {names}")
            for folder in active_folders:
                prefix = folder.name.split('-', 1)[0]
                if prefix != today_prefix:
                    warnings.append(
                        f"Active folder {folder.name} has prefix {prefix}; today's prefix is {today_prefix} (ensure multi-day reuse is intentional)"
                    )
                tracker_path = folder / 'TRACKER.md'
                if tracker_path.exists():
                    try:
                        tracker_text = tracker_path.read_text(encoding='utf-8')
                    except FileNotFoundError:
                        tracker_text = ''
                    if today not in tracker_text or 'serena/memory' not in tracker_text.lower():
                        warnings.append(
                            f"Tracker for {folder.name} missing Serena memory entry for {today}; capture memory and log via presets."
                        )

    current_symlink = SESSIONS_DIR / 'current'
    if not current_symlink.exists() or not current_symlink.is_symlink():
        current_state = object()
        try:
            current_state = json.loads(SESSION_STATE_PATH.read_text(encoding='utf-8')).get('current')
        except (FileNotFoundError, json.JSONDecodeError):
            pass
        if current_state in {None, ''}:
            warnings.append(f"{SESSIONS_CURRENT_REL} symlink missing because repository is between sessions")
        else:
            issues.append(f"{SESSIONS_CURRENT_REL} symlink missing")
    else:
        target = current_symlink.resolve()
        if target.exists():
            try:
                relative = target.relative_to(SESSIONS_DIR)
            except ValueError:
                warnings.append(f"{SESSIONS_CURRENT_REL} points outside {SESSIONS_DIR.relative_to(REPO_ROOT).as_posix()}/: {target}")
            else:
                session_date = relative.name[:10]
                if session_date != today:
                    warnings.append(
                        f"{SESSIONS_CURRENT_REL} points to {relative} (date {session_date}); consider starting a new session for {today}"
                    )
        else:
            issues.append(f"{SESSIONS_CURRENT_REL} target missing: {target}")

    if issues:
        print("Audit issues detected:")
        for issue in issues:
            print(f"- {issue}")
    if warnings:
        print("Audit warnings:")
        for warning in warnings:
            print(f"- {warning}")
    if not issues and not warnings:
        print("Audit passed: no issues found.")
    if issues:
        sys.exit(1)


def _insert_progress_entry(lines: List[str], heading: str, entry_line: str) -> List[str]:
    try:
        heading_index = next(idx for idx, line in enumerate(lines) if line.strip() == heading)
    except StopIteration as exc:
        raise TaskError(f"Heading '{heading}' not found in target document.") from exc

    last_entry_index: Optional[int] = None
    for idx in range(heading_index + 1, len(lines)):
        line = lines[idx]
        if line.startswith("##") or line.startswith("###"):
            break
        if line.startswith("- "):
            last_entry_index = idx

    insert_at = heading_index + 1 if last_entry_index is None else last_entry_index + 1
    lines.insert(insert_at, entry_line)
    return lines


def handle_sessions_update(args: argparse.Namespace) -> None:
    session_path = _resolve_current_session(args.session_file)
    metadata = _parse_front_matter(session_path)
    session_value = args.session or _derive_session_value(metadata)

    timestamp = args.time or datetime.now().strftime(DEFAULT_TIME_FORMAT_SESSION)
    work = args.work
    handler = args.handler
    evidence = args.evidence
    note = args.note

    swhe = f"[S:{session_value}|W:{work}|H:{handler}|E:{evidence}]"
    entry = f"- **[{timestamp}]** — {swhe} {note}"

    if args.dry_run:
        print(entry)
        return

    lines = _load_file_lines(session_path)
    updated = _insert_progress_entry(lines, PROGRESS_HEADING_SESSION, entry)
    _write_file_lines(session_path, updated)
    print(f"Updated session log: {session_path}")


def _ensure_progress_heading(lines: List[str]) -> List[str]:
    heading = "## Progress Log"
    if heading in (line.strip() for line in lines):
        return lines
    if lines and not lines[-1].endswith("\n"):
        lines[-1] = lines[-1] + "\n"
    lines.extend(["\n", f"{heading}\n", "\n"])
    return lines


def handle_work_tracking_update(args: argparse.Namespace) -> None:
    work_folder = _resolve_active_work_tracking(args.folder)

    preset = getattr(args, "preset", None)
    handler_value = args.handler

    if preset:
        doc_name, default_handler = WORK_TRACKING_PRESETS[preset]
        target_name = doc_name
        if handler_value.lower() == "auto":
            handler_value = default_handler
    else:
        target_name = args.document if args.document.endswith(".md") else f"{args.document}.md"

    target_path = work_folder / target_name
    if not target_path.exists():
        template = WORK_TRACKING_DEFAULT_DOCS.get(target_name)
        today = datetime.now().date().isoformat()
        title_token = args.work.replace('-', ' ').title()
        task_match = re.search(r"(\d+)", args.work)
        task_value = task_match.group(1) if task_match else args.work
        if template:
            content = template.format(today=today, task=task_value, title=title_token)
        else:
            content = f"# {title_token}\n\n## Progress Log\n"
        target_path.write_text(content, encoding='utf-8')

    session_path = _resolve_current_session(args.session_file)
    metadata = _parse_front_matter(session_path)
    session_value = args.session or _derive_session_value(metadata)

    timestamp = args.time or datetime.now().strftime(DEFAULT_TIME_FORMAT_TRACKER)
    swhe = f"[S:{session_value}|W:{args.work}|H:{handler_value}|E:{args.evidence}]"
    entry = f"- **{timestamp}** — {swhe} {args.note}"

    if args.dry_run:
        print(entry)
        return

    lines = _load_file_lines(target_path)
    lines = _ensure_progress_heading(lines)
    updated = _insert_progress_entry(lines, PROGRESS_HEADING_TRACKER, entry)
    _write_file_lines(target_path, updated)
    print(f"Updated work-tracking log: {target_path}")


def _resolve_scanner(tool: str) -> Path:
    mapping = {
        "scanner": SCANNER_PATH / "scanner.py",
        "analyze": SCANNER_PATH / "analyze_references.py",
        "duplicates": SCANNER_PATH / "find_duplicates.py",
        "migration": SCANNER_PATH / "migration_detector.py",
        "fixes": SCANNER_PATH / "generate_fixes.py",
        "safe-reorg": SCANNER_PATH / "safe_reorganize.py",
    }
    if tool not in mapping:
        valid = ", ".join(sorted(mapping.keys()))
        raise TaskError(f"Unknown scanner tool '{tool}'. Valid options: {valid}")
    target = mapping[tool]
    if not target.exists():
        raise TaskError(f"Scanner script not found at {target}")
    return target


def _meta_guard_message() -> str:
    return (
        "Meta Workflow Guard failed. Ensure your plan includes the meta workflow assets, "
        "branch matches policy (e.g., feat/task<id>-description), and run plan sync. "
        "See templates/engine/enforcement/meta-workflow-guard-remediation.md for remediation steps."
    )


def handle_scanner_run(args: argparse.Namespace) -> None:
    script_path = _resolve_scanner(args.tool)
    extra_args = getattr(args, "scanner_args", [])
    cmd = [sys.executable, str(script_path)] + extra_args
    print("Running:", " ".join(cmd))
    result = subprocess.run(cmd, cwd=str(REPO_ROOT))
    if result.returncode != 0:
        raise TaskError(f"Scanner command failed with exit code {result.returncode}")

    if args.log_note:
        log_kwargs = {
            "work": args.work,
            "handler": args.handler,
            "evidence": args.evidence,
            "note": args.log_note,
            "session_file": args.session_file,
            "session": args.session,
            "time": args.time,
            "dry_run": args.dry_run,
        }
        handle_sessions_update(argparse.Namespace(**log_kwargs))
        handle_work_tracking_update(argparse.Namespace(
            work=args.work,
            handler=args.handler,
            evidence=args.evidence,
            note=args.log_note,
            folder=args.folder,
            document=args.document,
            session_file=args.session_file,
            session=args.session,
            time=args.time,
            dry_run=args.dry_run,
        ))


def handle_report_generate(args: argparse.Namespace) -> None:
    commands: List[List[str]] = []

    if args.kind in {"drift", "all"}:
        drift_cmd = [
            sys.executable,
            str(CODEX_GUARD_SCRIPT),
            "drift-check",
            "--report-dir",
            args.drift_report_dir,
        ]
        if args.strict_drift:
            drift_cmd.append("--strict")
        commands.append(drift_cmd)

    if args.kind in {"metrics", "all"}:
        commands.append([
            sys.executable,
            str(METRICS_DASHBOARD_SCRIPT),
            "--report-dir",
            args.report_dir,
        ])

    for cmd in commands:
        printable = " ".join(cmd)
        if args.dry_run:
            print(f"Would run: {printable}")
            continue
        print(f"Running: {printable}")
        result = subprocess.run(cmd, cwd=str(REPO_ROOT))
        if result.returncode != 0:
            raise TaskError(f"Report command failed with exit code {result.returncode}: {printable}")


def _path_display(path: Path) -> str:
    return _relative_to_root(path, REPO_ROOT)


def _is_executable_file(path: Path) -> bool:
    return path.is_file() and os.access(path, os.X_OK)


def _find_pre_commit_binary() -> Optional[Path]:
    local_binary = REPO_ROOT / ".venv" / "bin" / "pre-commit"
    if _is_executable_file(local_binary):
        return local_binary

    found = shutil.which("pre-commit")
    if found:
        return Path(found)
    return None


def _pre_commit_version(binary: Path) -> str:
    result = subprocess.run(
        [str(binary), "--version"],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return "version unavailable"
    return result.stdout.strip() or "version unavailable"


def _verify_pre_commit_config() -> List[str]:
    issues: List[str] = []
    if not PRE_COMMIT_CONFIG.exists():
        return [f"Missing {PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()}"]

    config_text = PRE_COMMIT_CONFIG.read_text(encoding="utf-8")
    for snippet in PRE_COMMIT_REQUIRED_SNIPPETS:
        if snippet not in config_text:
            issues.append(f"{PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()} missing required entry: {snippet}")
    if config_text.count("pass_filenames: false") < len(PRE_COMMIT_REQUIRED_SNIPPETS):
        issues.append(f"{PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()} should keep guard hooks filename-independent")
    if config_text.count("always_run: true") < len(PRE_COMMIT_REQUIRED_SNIPPETS):
        issues.append(f"{PRE_COMMIT_CONFIG.relative_to(REPO_ROOT).as_posix()} should keep guard hooks always-on")
    return issues


def _pre_commit_hook_status() -> Tuple[bool, str]:
    if not PRE_COMMIT_HOOK.exists():
        return False, f"{_path_display(PRE_COMMIT_HOOK)} is not installed"
    if not PRE_COMMIT_HOOK.is_file():
        return False, f"{_path_display(PRE_COMMIT_HOOK)} exists but is not a file"
    if not os.access(PRE_COMMIT_HOOK, os.X_OK):
        return False, f"{_path_display(PRE_COMMIT_HOOK)} exists but is not executable"
    try:
        hook_text = PRE_COMMIT_HOOK.read_text(encoding="utf-8", errors="ignore")
    except OSError as exc:
        return False, f"{_path_display(PRE_COMMIT_HOOK)} could not be read: {exc}"
    if "pre-commit" not in hook_text and "PRE_COMMIT" not in hook_text:
        return False, f"{_path_display(PRE_COMMIT_HOOK)} does not look like a pre-commit managed hook"
    return True, f"{_path_display(PRE_COMMIT_HOOK)} is installed"


def handle_hooks_verify(args: argparse.Namespace) -> None:
    issues = _verify_pre_commit_config()
    warnings: List[str] = []
    detail_lines: List[str] = []

    if issues:
        detail_lines.append(f"- {_path_display(PRE_COMMIT_CONFIG)}: failed")
    else:
        detail_lines.append(f"- {_path_display(PRE_COMMIT_CONFIG)}: ok")

    binary = _find_pre_commit_binary()
    if binary is None:
        issues.append("pre-commit executable not found; install dev dependencies or ensure .venv/bin/pre-commit exists")
        detail_lines.append("- pre-commit binary: missing")
    else:
        version = _pre_commit_version(binary)
        detail_lines.append(f"- pre-commit binary: ok ({_path_display(binary)}, {version})")

    hook_installed, hook_message = _pre_commit_hook_status()
    if hook_installed:
        detail_lines.append(f"- local pre-commit hook: ok ({hook_message})")
    else:
        message = f"local pre-commit hook: {hook_message}; run `{PRE_COMMIT_INSTALL_COMMAND}`"
        if args.require_installed:
            issues.append(message)
            detail_lines.append(f"- local pre-commit hook: failed ({hook_message})")
        else:
            warnings.append(message)
            detail_lines.append(f"- local pre-commit hook: warning ({hook_message})")

    print("Hook verification:")
    for line in detail_lines:
        print(line)
    if warnings:
        print("Warnings:")
        for warning in warnings:
            print(f"- {warning}")
    if issues:
        print("Issues:")
        for issue in issues:
            print(f"- {issue}")
        raise TaskError("Hook verification failed")
    print("Hook verification passed.")


def handle_taskmaster_generate_one(args: argparse.Namespace) -> None:
    task_id = str(args.task_id)
    try:
        int(task_id)
    except ValueError as exc:
        raise TaskError(f"Invalid task ID: {task_id}") from exc

    _assert_no_unrelated_task_file_changes(task_id, "before targeted generation")

    with tempfile.TemporaryDirectory(prefix="codex-taskmaster-generate-") as temp_name:
        temp_dir = Path(temp_name)
        result = subprocess.run(
            ["task-master", "generate", "--output", str(temp_dir)],
            cwd=str(REPO_ROOT),
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            message = result.stderr.strip() or result.stdout.strip() or "task-master generate failed"
            raise TaskError(message)

        source_path = _locate_generated_task_file(temp_dir, task_id)
        destination_path = _destination_task_file(task_id, source_path)
        rendered = _render_generated_task_content(source_path, destination_path)

        if args.dry_run:
            print(f"Would update {destination_path.relative_to(REPO_ROOT)} from temporary {source_path.name}")
            return

        destination_path.parent.mkdir(parents=True, exist_ok=True)
        destination_path.write_text(rendered, encoding="utf-8")

    _assert_no_unrelated_task_file_changes(task_id, "after targeted generation")
    print(f"Updated {destination_path.relative_to(REPO_ROOT)} from targeted Taskmaster generation")


def _normalise_dependency_id(value: object) -> str:
    return str(value).strip()


def _load_taskmaster_tasks_data() -> dict:
    if not TASKMASTER_TASKS_JSON.exists():
        raise TaskError(f"Taskmaster tasks file not found: {TASKMASTER_TASKS_JSON.relative_to(REPO_ROOT)}")
    try:
        return json.loads(TASKMASTER_TASKS_JSON.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"Invalid Taskmaster JSON: {TASKMASTER_TASKS_JSON.relative_to(REPO_ROOT)}") from exc


def _resolve_taskmaster_tag(data: dict, requested_tag: str | None = None) -> str:
    if requested_tag:
        if requested_tag not in data:
            raise TaskError(f"Taskmaster tag not found: {requested_tag}")
        return requested_tag
    if "master" in data:
        return "master"
    tags = [key for key, value in data.items() if isinstance(value, dict) and "tasks" in value]
    if len(tags) == 1:
        return tags[0]
    raise TaskError("Unable to determine Taskmaster tag; pass --tag explicitly")


def _taskmaster_dependency_health(tag_data: dict) -> tuple[dict, list[str]]:
    tasks = tag_data.get("tasks")
    if not isinstance(tasks, list):
        raise TaskError("Taskmaster tag data does not contain a tasks list")

    task_ids = {_normalise_dependency_id(task.get("id")) for task in tasks}
    status_counts: Dict[str, int] = {}
    total_subtasks = 0
    dependency_refs = 0
    invalid_refs: list[str] = []

    for task in tasks:
        task_id = _normalise_dependency_id(task.get("id"))
        status = str(task.get("status") or "unknown")
        status_counts[status] = status_counts.get(status, 0) + 1

        for dependency in task.get("dependencies") or []:
            dependency_id = _normalise_dependency_id(dependency)
            if not dependency_id:
                continue
            dependency_refs += 1
            if dependency_id not in task_ids:
                invalid_refs.append(f"Task {task_id} depends on missing task {dependency_id}")

        subtasks = task.get("subtasks") or []
        total_subtasks += len(subtasks)
        subtask_local_ids = {_normalise_dependency_id(subtask.get("id")) for subtask in subtasks}
        subtask_full_ids = {f"{task_id}.{subtask_id}" for subtask_id in subtask_local_ids if subtask_id}
        valid_subtask_refs = subtask_local_ids | subtask_full_ids | task_ids
        for subtask in subtasks:
            subtask_id = _normalise_dependency_id(subtask.get("id"))
            for dependency in subtask.get("dependencies") or []:
                dependency_id = _normalise_dependency_id(dependency)
                if not dependency_id:
                    continue
                dependency_refs += 1
                if dependency_id not in valid_subtask_refs:
                    invalid_refs.append(f"Subtask {task_id}.{subtask_id} depends on missing reference {dependency_id}")

    summary = {
        "tasks": len(tasks),
        "subtasks": total_subtasks,
        "status_counts": status_counts,
        "dependency_refs": dependency_refs,
        "invalid_refs": len(invalid_refs),
    }
    return summary, invalid_refs


def _render_taskmaster_health_report(tag: str, summary: dict, invalid_refs: list[str]) -> str:
    status_counts = summary["status_counts"]
    status_text = ", ".join(f"{name}={count}" for name, count in sorted(status_counts.items()))
    lines = [
        "Taskmaster health: " + ("OK" if not invalid_refs else "FAILED"),
        f"Tag: {tag}",
        f"Tasks: {summary['tasks']}",
        f"Subtasks: {summary['subtasks']}",
        f"Statuses: {status_text}",
        f"Dependency refs: {summary['dependency_refs']}",
        f"Invalid dependency refs: {summary['invalid_refs']}",
        "",
        "Note: `task-master list --status=<status>` can print filtered-view dependency warnings because dependencies outside the filtered subset are hidden. Use this helper or `task-master validate-dependencies` for authoritative full-graph health.",
    ]
    if invalid_refs:
        lines.extend(["", "Invalid references:"])
        lines.extend(f"- {issue}" for issue in invalid_refs)
    return "\n".join(lines) + "\n"


def handle_taskmaster_health(args: argparse.Namespace) -> None:
    data = _load_taskmaster_tasks_data()
    tag = _resolve_taskmaster_tag(data, args.tag)
    summary, invalid_refs = _taskmaster_dependency_health(data[tag])
    report = _render_taskmaster_health_report(tag, summary, invalid_refs)

    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(report, encoding="utf-8")
        print(f"Wrote Taskmaster health report to {report_path.relative_to(REPO_ROOT)}")
    print(report, end="")

    if invalid_refs:
        raise TaskError("Taskmaster dependency health failed")


def _git_output(args: List[str]) -> str:
    result = subprocess.run(
        ["git", *args],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or f"git {' '.join(args)} failed"
        raise TaskError(message)
    return result.stdout.rstrip("\n")


def _git_status_snapshot() -> List[Dict[str, str]]:
    output = _git_output(["status", "--short"])
    entries: List[Dict[str, str]] = []
    for raw in output.splitlines():
        if not raw:
            continue
        path_text = raw[3:].strip()
        if " -> " in path_text:
            path_text = path_text.rsplit(" -> ", 1)[1]
        entries.append({"status": raw[:2], "path": path_text.strip('"')})
    return entries


def _file_sha256(path: Path) -> Optional[str]:
    if not path.exists() or not path.is_file():
        return None
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _symlink_snapshot(path: Path) -> Dict[str, Any]:
    payload: Dict[str, Any] = {
        "path": _relative_to_root(path, REPO_ROOT),
        "exists": path.exists() or path.is_symlink(),
        "is_symlink": path.is_symlink(),
        "target": None,
        "resolved": None,
        "sha256": None,
    }
    if path.is_symlink():
        payload["target"] = os.readlink(path)
    if path.exists():
        resolved = path.resolve()
        payload["resolved"] = _relative_to_root(resolved, REPO_ROOT)
        payload["sha256"] = _file_sha256(resolved)
    return payload


def _taskmaster_snapshot() -> Dict[str, Any]:
    payload: Dict[str, Any] = {
        "path": _relative_to_root(TASKMASTER_TASKS_JSON, REPO_ROOT),
        "exists": TASKMASTER_TASKS_JSON.exists(),
        "sha256": _file_sha256(TASKMASTER_TASKS_JSON),
        "tag": None,
        "summary": None,
        "invalid_refs": [],
    }
    if not TASKMASTER_TASKS_JSON.exists():
        return payload
    data = _load_taskmaster_tasks_data()
    tag = _resolve_taskmaster_tag(data, None)
    summary, invalid_refs = _taskmaster_dependency_health(data[tag])
    payload["tag"] = tag
    payload["summary"] = summary
    payload["invalid_refs"] = invalid_refs
    return payload


def _serena_memory_snapshot() -> Dict[str, Any]:
    memory_dir = REPO_ROOT / ".serena" / "memories"
    memories = sorted(memory_dir.glob("*.md")) if memory_dir.exists() else []
    return {
        "path": _relative_to_root(memory_dir, REPO_ROOT),
        "exists": memory_dir.exists(),
        "count": len(memories),
        "latest": [_relative_to_root(path, REPO_ROOT) for path in memories[-10:]],
    }


def _workflow_snapshot() -> Dict[str, Any]:
    active_folders = []
    if WORK_TRACKING_BASE.exists():
        active_folders = [
            _relative_to_root(path, REPO_ROOT)
            for path in sorted(WORK_TRACKING_BASE.iterdir())
            if path.is_dir() and path.name.endswith("-ACTIVE")
        ]
    return {
        "current_session": _symlink_snapshot(SESSIONS_DIR / "current"),
        "current_plan": _symlink_snapshot(PLAN_CURRENT),
        "session_state": {
            "path": _relative_to_root(SESSION_STATE_PATH, REPO_ROOT),
            "exists": SESSION_STATE_PATH.exists(),
            "sha256": _file_sha256(SESSION_STATE_PATH),
        },
        "active_work_tracking": active_folders,
    }


def _create_rollback_tag(prefix: str, label: str, created_at: datetime) -> str:
    tag_prefix = prefix.strip().strip("/") or "codex-rollback"
    stamp = created_at.strftime("%Y%m%d-%H%M%S")
    tag_name = f"{tag_prefix}/{stamp}-{_slugify(label)}"
    result = subprocess.run(
        ["git", "tag", "-a", tag_name, "-m", f"Codex rollback checkpoint: {label}"],
        cwd=str(REPO_ROOT),
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or f"Unable to create rollback tag {tag_name}"
        raise TaskError(message)
    return tag_name


def _build_rollback_checkpoint(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "checkpoint"
    snapshot: Dict[str, Any] = {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "git": {
            "branch": _git_output(["branch", "--show-current"]),
            "head": _git_output(["rev-parse", "HEAD"]),
            "status": _git_status_snapshot(),
            "tag": None,
        },
        "workflow": _workflow_snapshot(),
        "taskmaster": _taskmaster_snapshot(),
        "serena": _serena_memory_snapshot(),
    }
    if args.create_tag:
        snapshot["git"]["tag"] = _create_rollback_tag(args.tag_prefix, label, now)
    return snapshot


def _default_rollback_checkpoint_path(snapshot: Dict[str, Any]) -> Path:
    created = datetime.fromisoformat(str(snapshot["created_at"]))
    label = _slugify(str(snapshot.get("label") or "checkpoint"))
    return REPO_ROOT / "reports" / "rollback" / "checkpoints" / f"{created.strftime('%Y%m%d-%H%M%S')}-{label}.json"


def handle_rollback_checkpoint(args: argparse.Namespace) -> None:
    snapshot = _build_rollback_checkpoint(args)
    output_path = Path(args.report_file) if args.report_file else _default_rollback_checkpoint_path(snapshot)
    if not output_path.is_absolute():
        output_path = REPO_ROOT / output_path
    rendered = json.dumps(snapshot, indent=2, sort_keys=True) + "\n"
    if args.dry_run:
        print(rendered, end="")
        return
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(rendered, encoding="utf-8")
    print(f"Wrote rollback checkpoint to {_relative_to_root(output_path, REPO_ROOT)}")
    tag = snapshot["git"].get("tag")
    if tag:
        print(f"Created rollback tag: {tag}")


def _render_rollback_plan(snapshot: Dict[str, Any]) -> str:
    git_info = snapshot.get("git", {})
    workflow = snapshot.get("workflow", {})
    taskmaster = snapshot.get("taskmaster", {})
    lines = [
        "# Rollback Recovery Plan",
        "",
        f"- Snapshot label: {snapshot.get('label')}",
        f"- Created at: {snapshot.get('created_at')}",
        f"- Branch at checkpoint: {git_info.get('branch')}",
        f"- Commit at checkpoint: {git_info.get('head')}",
        f"- Rollback tag: {git_info.get('tag') or 'not created'}",
        "",
        "## Non-Destructive First Steps",
        "1. Run `git status --short --branch` and inspect the current diff.",
        f"2. Compare current changes with the checkpoint commit: `git diff {git_info.get('head')} --stat`.",
        "3. Review the active session, plan, and work-tracking folder before restoring files.",
        "",
        "## Safe Restore Guidance",
        f"- Return to the checkpoint branch if needed: `git switch {git_info.get('branch')}`.",
        f"- Restore selected tracked paths only after review: `git restore --source {git_info.get('head')} --staged --worktree -- <path>`.",
        "- Preview untracked cleanup with `git clean -nd`; do not remove untracked files without explicit approval.",
        "- Avoid `git reset --hard`; this helper intentionally does not execute destructive rollback commands.",
        "",
        "## Workflow Pointers At Checkpoint",
        f"- Current session: {workflow.get('current_session', {}).get('resolved')}",
        f"- Current plan: {workflow.get('current_plan', {}).get('resolved')}",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        f"- Taskmaster tasks.json SHA256: {taskmaster.get('sha256')}",
        "",
        "No rollback commands were executed by this plan.",
    ]
    return "\n".join(lines) + "\n"


def handle_rollback_plan(args: argparse.Namespace) -> None:
    snapshot_path = Path(args.snapshot)
    if not snapshot_path.is_absolute():
        snapshot_path = REPO_ROOT / snapshot_path
    snapshot = json.loads(snapshot_path.read_text(encoding="utf-8"))
    rendered = _render_rollback_plan(snapshot)
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        if not args.dry_run:
            report_path.parent.mkdir(parents=True, exist_ok=True)
            report_path.write_text(rendered, encoding="utf-8")
            print(f"Wrote rollback plan to {_relative_to_root(report_path, REPO_ROOT)}")
            return
    print(rendered, end="")


def _load_json_document(path_value: str, label: str) -> Dict[str, Any]:
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    if not path.exists():
        raise TaskError(f"{label} not found: {_relative_to_root(path, REPO_ROOT)}")
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"{label} is not valid JSON: {_relative_to_root(path, REPO_ROOT)}") from exc
    if not isinstance(payload, dict):
        raise TaskError(f"{label} must be a JSON object: {_relative_to_root(path, REPO_ROOT)}")
    return payload


def _normalise_roadmap_payload(path_value: str) -> Dict[str, Any]:
    raw = _load_json_document(path_value, "Migration roadmap")
    metadata = raw.get("metadata") if isinstance(raw.get("metadata"), dict) else None
    data = raw.get("data") if isinstance(raw.get("data"), dict) else raw
    if not isinstance(data, dict):
        raise TaskError("Migration roadmap data must be a JSON object")
    if "items" not in data or "summary_metrics" not in data:
        raise TaskError("Migration roadmap must include items and summary_metrics")
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "metadata": metadata,
        "data": data,
    }


def _simplify_rehearsal_item(item: Dict[str, Any]) -> Dict[str, Any]:
    source_files = item.get("source_files") if isinstance(item.get("source_files"), list) else []
    dependencies = item.get("dependencies") if isinstance(item.get("dependencies"), list) else []
    return {
        "id": item.get("id"),
        "priority": item.get("priority"),
        "category": item.get("category"),
        "title": item.get("title"),
        "effort": item.get("effort"),
        "risk": item.get("risk"),
        "finding_count": item.get("finding_count"),
        "source_files": source_files[:5],
        "dependencies": dependencies[:5],
    }


def _summarise_rehearsal_roadmap(roadmap: Dict[str, Any], max_items: int) -> Dict[str, Any]:
    data = roadmap["data"]
    items = data.get("items")
    if not isinstance(items, list):
        raise TaskError("Migration roadmap items must be a list")
    taskmaster_export = data.get("taskmaster_export")
    taskmaster_tasks = []
    if isinstance(taskmaster_export, dict) and isinstance(taskmaster_export.get("tasks"), list):
        taskmaster_tasks = taskmaster_export["tasks"]
    return {
        "path": roadmap["path"],
        "metadata": roadmap.get("metadata"),
        "generated_at": data.get("generated_at"),
        "version": data.get("migration_roadmap_version"),
        "summary_metrics": data.get("summary_metrics") if isinstance(data.get("summary_metrics"), dict) else {},
        "priority_counts": data.get("priority_counts") if isinstance(data.get("priority_counts"), dict) else {},
        "category_counts": data.get("category_counts") if isinstance(data.get("category_counts"), dict) else {},
        "phases": data.get("phases") if isinstance(data.get("phases"), list) else [],
        "total_items": len(items),
        "taskmaster_export_tasks": len(taskmaster_tasks),
        "first_items": [
            _simplify_rehearsal_item(item)
            for item in items[: max(0, max_items)]
            if isinstance(item, dict)
        ],
    }


def _summarise_rehearsal_checkpoint(checkpoint: Dict[str, Any], checkpoint_path: str) -> Dict[str, Any]:
    git_info = checkpoint.get("git") if isinstance(checkpoint.get("git"), dict) else {}
    workflow = checkpoint.get("workflow") if isinstance(checkpoint.get("workflow"), dict) else {}
    taskmaster = checkpoint.get("taskmaster") if isinstance(checkpoint.get("taskmaster"), dict) else {}
    status_entries = git_info.get("status") if isinstance(git_info.get("status"), list) else []
    path = Path(checkpoint_path)
    if not path.is_absolute():
        path = REPO_ROOT / path
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "label": checkpoint.get("label"),
        "created_at": checkpoint.get("created_at"),
        "git": {
            "branch": git_info.get("branch"),
            "head": git_info.get("head"),
            "tag": git_info.get("tag"),
            "status_count": len(status_entries),
        },
        "workflow": {
            "current_session": workflow.get("current_session", {}).get("resolved")
            if isinstance(workflow.get("current_session"), dict)
            else None,
            "current_plan": workflow.get("current_plan", {}).get("resolved")
            if isinstance(workflow.get("current_plan"), dict)
            else None,
            "active_work_tracking": workflow.get("active_work_tracking")
            if isinstance(workflow.get("active_work_tracking"), list)
            else [],
        },
        "taskmaster": {
            "sha256": taskmaster.get("sha256"),
            "summary": taskmaster.get("summary") if isinstance(taskmaster.get("summary"), dict) else None,
        },
    }


def _rehearsal_verification_commands() -> List[str]:
    return [
        "git status --short --branch",
        "python3 scripts/codex-task rollback checkpoint --label <label> --report-file <path>",
        "python3 scripts/template-ssot-scanner/migration_roadmap.py --data-dir scripts/template-ssot-scanner/output/data --json-out <path> --markdown-out <path>",
        "python3 scripts/codex-task rehearsal plan --roadmap <roadmap.json> --checkpoint <checkpoint.json> --report-file <plan.json> --runbook-file <runbook.md>",
        "python3 scripts/codex-task taskmaster health --report-file <path>",
        "python3 scripts/codex-task plan sync",
        "python3 scripts/codex-task work-tracking audit",
        "python3 scripts/codex-guard validate --include-untracked",
        "git diff --check",
    ]


def _build_migration_rehearsal_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    roadmap = _normalise_roadmap_payload(args.roadmap)
    checkpoint = _load_json_document(args.checkpoint, "Rollback checkpoint")
    roadmap_summary = _summarise_rehearsal_roadmap(roadmap, args.max_items)
    checkpoint_summary = _summarise_rehearsal_checkpoint(checkpoint, args.checkpoint)
    current_head = _git_output(["rev-parse", "HEAD"])
    current_branch = _git_output(["branch", "--show-current"])
    priority_counts = roadmap_summary.get("priority_counts", {})
    critical_count = int(priority_counts.get("critical", 0) or 0) if isinstance(priority_counts, dict) else 0
    dirty_count = len(_git_status_snapshot())
    abort_criteria = [
        "Stop if guard, plan sync, Taskmaster health, or required pytest suites fail.",
        "Stop if the rollback checkpoint is missing, unreadable, or points at an unexpected branch/head.",
        "Stop if rehearsal requires Docker, external API keys, agent simulators, load testing, or destructive Git commands; those are out of scope for this foundation task.",
    ]
    if critical_count:
        abort_criteria.append(
            f"Treat {critical_count} critical roadmap item(s) as pre-migration blockers unless explicitly waived in work tracking."
        )
    if dirty_count:
        abort_criteria.append(
            f"Review the current dirty working tree ({dirty_count} status entr{'y' if dirty_count == 1 else 'ies'}) before applying roadmap changes."
        )
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "non-destructive-local-rehearsal",
        "executes_mutations": False,
        "inputs": {
            "roadmap": roadmap_summary["path"],
            "checkpoint": checkpoint_summary["path"],
        },
        "current_state": {
            "git": {
                "branch": current_branch,
                "head": current_head,
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "checkpoint": checkpoint_summary,
        "roadmap": roadmap_summary,
        "rehearsal_environment": {
            "isolation_model": "manual-review-or-optional-worktree",
            "automatic_worktree_creation": False,
            "automatic_docker_setup": False,
            "external_api_keys_required": False,
            "agent_simulators_required": False,
            "load_testing_required": False,
            "guidance": [
                "Use the checkpoint commit as the rollback anchor before migration work.",
                "Use the roadmap priority order to select the next migration slice.",
                "If stronger isolation is needed, create a reviewed git worktree manually; this helper does not run that command.",
                "Capture fresh guard, audit, Taskmaster health, and diff-check evidence after each rehearsal slice.",
            ],
        },
        "recommended_verification_commands": _rehearsal_verification_commands(),
        "abort_criteria": abort_criteria,
        "non_goals": [
            "No Docker containers are created.",
            "No test API keys are read or written.",
            "No Claude/Codex agent simulators are launched.",
            "No k6/locust load test harness is invoked.",
            "No Taskmaster tasks are imported from roadmap data.",
            "No rollback, reset, clean, restore, or worktree command is executed.",
        ],
    }


def _md_cell(value: object) -> str:
    return str(value if value is not None else "").replace("|", "\\|")


def _render_migration_rehearsal_runbook(plan: Dict[str, Any]) -> str:
    roadmap = plan.get("roadmap", {})
    checkpoint = plan.get("checkpoint", {})
    current = plan.get("current_state", {})
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    checkpoint_git = checkpoint.get("git", {}) if isinstance(checkpoint.get("git"), dict) else {}
    lines = [
        "# Migration Rehearsal Runbook",
        "",
        f"- Label: {plan.get('label')}",
        f"- Created at: {plan.get('created_at')}",
        f"- Mode: {plan.get('mode')}",
        f"- Executes mutations: {plan.get('executes_mutations')}",
        "",
        "## Inputs",
        "",
        f"- Migration roadmap: {plan.get('inputs', {}).get('roadmap')}",
        f"- Rollback checkpoint: {plan.get('inputs', {}).get('checkpoint')}",
        "",
        "## Current State",
        "",
        f"- Current branch: {git_info.get('branch')}",
        f"- Current HEAD: {git_info.get('head')}",
        f"- Current dirty status entries: {len(git_info.get('status') or [])}",
        f"- Checkpoint branch: {checkpoint_git.get('branch')}",
        f"- Checkpoint HEAD: {checkpoint_git.get('head')}",
        "",
        "## Roadmap Summary",
        "",
        f"- Roadmap generated at: {roadmap.get('generated_at')}",
        f"- Roadmap version: {roadmap.get('version')}",
        f"- Total roadmap items: {roadmap.get('total_items')}",
        f"- Taskmaster draft items: {roadmap.get('taskmaster_export_tasks')}",
        "",
        "### Priority Counts",
        "",
    ]
    priority_counts = roadmap.get("priority_counts") if isinstance(roadmap.get("priority_counts"), dict) else {}
    if priority_counts:
        for priority in ("critical", "high", "medium", "low"):
            lines.append(f"- {priority}: {priority_counts.get(priority, 0)}")
    else:
        lines.append("- No priority counts available.")

    lines.extend(["", "### Phase Plan", ""])
    phases = roadmap.get("phases") if isinstance(roadmap.get("phases"), list) else []
    if phases:
        lines.append("| Phase | Priorities | Start Day | Duration |")
        lines.append("| --- | --- | --- | --- |")
        for phase in phases:
            if not isinstance(phase, dict):
                continue
            priorities = ", ".join(str(priority) for priority in phase.get("priorities", []))
            lines.append(
                f"| {_md_cell(phase.get('title'))} | {_md_cell(priorities)} | "
                f"{_md_cell(phase.get('start_day'))} | {_md_cell(phase.get('duration_days'))} days |"
            )
    else:
        lines.append("- No phase plan available.")

    lines.extend(["", "### First Rehearsal Items", ""])
    items = roadmap.get("first_items") if isinstance(roadmap.get("first_items"), list) else []
    if items:
        lines.append("| Priority | Category | Effort | Risk | Findings | Title |")
        lines.append("| --- | --- | --- | --- | --- | --- |")
        for item in items:
            if not isinstance(item, dict):
                continue
            lines.append(
                f"| {_md_cell(item.get('priority'))} | {_md_cell(item.get('category'))} | "
                f"{_md_cell(item.get('effort'))} | {_md_cell(item.get('risk'))} | "
                f"{_md_cell(item.get('finding_count'))} | {_md_cell(item.get('title'))} |"
            )
    else:
        lines.append("- No roadmap items available.")

    lines.extend(["", "## Rehearsal Steps", ""])
    lines.extend(
        [
            "1. Review the rollback checkpoint and current dirty Git status.",
            "2. Select the smallest roadmap item or coherent group of items to rehearse.",
            "3. If additional isolation is required, create a git worktree manually after reviewing the command; this runbook does not create it.",
            "4. Run the selected scanner or fix command in dry-run mode first.",
            "5. Capture guard, audit, Taskmaster health, plan sync, and diff-check evidence before marking the rehearsal slice complete.",
            "6. If any abort criterion triggers, stop and use the rollback checkpoint recovery plan for reviewed, non-destructive guidance.",
        ]
    )

    lines.extend(["", "## Recommended Verification Commands", ""])
    for command in plan.get("recommended_verification_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Abort Criteria", ""])
    for criterion in plan.get("abort_criteria", []):
        lines.append(f"- {criterion}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in plan.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(["", "No rehearsal commands were executed by this plan.", ""])
    return "\n".join(lines)


def handle_rehearsal_plan(args: argparse.Namespace) -> None:
    plan = _build_migration_rehearsal_plan(args)
    rendered_json = json.dumps(plan, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_migration_rehearsal_runbook(plan)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote migration rehearsal plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote migration rehearsal runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Codex task helper")
    parser.add_argument("--session", help="Override S field session value", default=None)
    parser.add_argument("--session-file", help="Path to specific session markdown", default=None)
    parser.add_argument("--time", help="Override timestamp")
    parser.add_argument("--dry-run", action="store_true", help="Print output without writing to files")

    subparsers = parser.add_subparsers(dest="command", required=True)

    sessions_parser = subparsers.add_parser("sessions", help="Session log operations")
    sessions_sub = sessions_parser.add_subparsers(dest="subcommand", required=True)
    sessions_update = sessions_sub.add_parser("update", help="Append entry to current session progress log")
    sessions_update.add_argument("--work", required=True, help="W field value")
    sessions_update.add_argument("--handler", required=True, help="H field value")
    sessions_update.add_argument("--evidence", required=True, help="E field value")
    sessions_update.add_argument("--note", required=True, help="Log note")
    sessions_update.set_defaults(func=handle_sessions_update)

    work_parser = subparsers.add_parser("work-tracking", help="Work-tracking document operations")
    work_sub = work_parser.add_subparsers(dest="subcommand", required=True)
    work_scaffold = work_sub.add_parser("scaffold", help="Create a new active work-tracking folder")
    work_scaffold.add_argument("--task", required=True, help="Task ID (numeric)")
    work_scaffold.add_argument("--slug", required=True, help="Slug for the folder name")
    work_scaffold.add_argument("--title", help="Human-readable title for tracker")
    work_scaffold.add_argument("--goal", action="append", help="Goal checklist item (repeatable)")
    work_scaffold.add_argument("--force", action="store_true", help="Allow scaffolding even if another ACTIVE folder exists")
    work_scaffold.set_defaults(func=handle_work_tracking_scaffold)

    work_archive = work_sub.add_parser("archive", help="Archive the current active work-tracking folder")
    work_archive.add_argument("--folder", help="Specific ACTIVE folder relative name")
    work_archive.set_defaults(func=handle_work_tracking_archive)

    work_update = work_sub.add_parser("update", help="Append entry to work-tracking progress log")
    work_update.add_argument("--work", required=True, help="W field value")
    work_update.add_argument("--handler", required=True, help="H field value")
    work_update.add_argument("--evidence", required=True, help="E field value")
    work_update.add_argument("--note", required=True, help="Log note")
    work_update.add_argument("--document", default="TRACKER", help="Work-tracking markdown name (default TRACKER)")
    work_update.add_argument("--folder", help="Specific ACTIVE folder relative name")
    work_update.add_argument("--preset", choices=sorted(WORK_TRACKING_PRESETS.keys()), help="Shortcut for common work-tracking documents (overrides --document). Use --handler auto to apply defaults.")
    work_update.set_defaults(func=handle_work_tracking_update)

    work_audit = work_sub.add_parser("audit", help="Audit active work-tracking folders and sessions")
    work_audit.set_defaults(func=handle_work_tracking_audit)

    plan_parser = subparsers.add_parser("plan", help="Plan utilities")
    plan_sub = plan_parser.add_subparsers(dest="subcommand", required=True)
    plan_sync = plan_sub.add_parser("sync", help="Validate plan/tracker parity and log sync entry")
    plan_sync.add_argument("--plan", help=f"Explicit plan file path (default: {PLANS_CURRENT_REL})")
    plan_sync.add_argument("--tracker", help="Explicit tracker file path (default: active tracker)")
    plan_sync.set_defaults(func=handle_plan_sync)

    report_parser = subparsers.add_parser("report", help="Report generation operations")
    report_sub = report_parser.add_subparsers(dest="subcommand", required=True)
    report_generate = report_sub.add_parser("generate", help="Generate workflow reports")
    report_generate.add_argument(
        "--kind",
        choices=("metrics", "drift", "all"),
        default="metrics",
        help="Report type to generate (default: metrics)",
    )
    report_generate.add_argument(
        "--report-dir",
        default=REPO_STRUCTURE.metrics_report_dir.relative_to(REPO_ROOT).as_posix(),
        help="Output directory for metrics reports",
    )
    report_generate.add_argument(
        "--drift-report-dir",
        default=REPO_STRUCTURE.drift_report_dir.relative_to(REPO_ROOT).as_posix(),
        help="Output directory for drift reports",
    )
    report_generate.add_argument(
        "--strict-drift",
        action="store_true",
        help="Exit nonzero when drift findings are present while generating drift reports",
    )
    report_generate.set_defaults(func=handle_report_generate)

    hooks_parser = subparsers.add_parser("hooks", help="Git hook verification operations")
    hooks_sub = hooks_parser.add_subparsers(dest="subcommand", required=True)
    hooks_verify = hooks_sub.add_parser("verify", help="Verify tracked pre-commit hook configuration and local install state")
    hooks_verify.add_argument(
        "--require-installed",
        action="store_true",
        help="Fail when the local .git/hooks/pre-commit entry is not installed",
    )
    hooks_verify.set_defaults(func=handle_hooks_verify)

    taskmaster_parser = subparsers.add_parser("taskmaster", help="Taskmaster helper operations")
    taskmaster_sub = taskmaster_parser.add_subparsers(dest="subcommand", required=True)
    taskmaster_generate_one = taskmaster_sub.add_parser(
        "generate-one",
        help="Generate Taskmaster output into a temporary directory and update only one task file",
    )
    taskmaster_generate_one.add_argument("--id", dest="task_id", required=True, help="Task ID to update")
    taskmaster_generate_one.set_defaults(func=handle_taskmaster_generate_one)
    taskmaster_health = taskmaster_sub.add_parser(
        "health",
        help="Report authoritative Taskmaster graph health from tasks.json",
    )
    taskmaster_health.add_argument("--tag", help="Taskmaster tag to inspect (default: master when present)")
    taskmaster_health.add_argument("--report-file", help="Optional path to write the health report")
    taskmaster_health.set_defaults(func=handle_taskmaster_health)

    rollback_parser = subparsers.add_parser("rollback", help="Rollback checkpoint and recovery planning operations")
    rollback_sub = rollback_parser.add_subparsers(dest="subcommand", required=True)
    rollback_checkpoint = rollback_sub.add_parser("checkpoint", help="Capture a rollback checkpoint manifest")
    rollback_checkpoint.add_argument("--label", default="checkpoint", help="Human-readable checkpoint label")
    rollback_checkpoint.add_argument("--report-file", help="Path to write the checkpoint JSON")
    rollback_checkpoint.add_argument("--create-tag", action="store_true", help="Create an annotated git tag at HEAD")
    rollback_checkpoint.add_argument("--tag-prefix", default="codex-rollback", help="Prefix for created rollback tags")
    rollback_checkpoint.set_defaults(func=handle_rollback_checkpoint)
    rollback_plan = rollback_sub.add_parser("plan", help="Render a non-destructive recovery plan from a checkpoint")
    rollback_plan.add_argument("--snapshot", required=True, help="Checkpoint JSON produced by rollback checkpoint")
    rollback_plan.add_argument("--report-file", help="Optional path to write the rendered recovery plan")
    rollback_plan.set_defaults(func=handle_rollback_plan)

    rehearsal_parser = subparsers.add_parser("rehearsal", help="Migration rehearsal planning operations")
    rehearsal_sub = rehearsal_parser.add_subparsers(dest="subcommand", required=True)
    rehearsal_plan = rehearsal_sub.add_parser("plan", help="Compose roadmap and checkpoint inputs into a rehearsal plan")
    rehearsal_plan.add_argument("--roadmap", required=True, help="Migration roadmap JSON produced by migration_roadmap.py")
    rehearsal_plan.add_argument("--checkpoint", required=True, help="Rollback checkpoint JSON produced by rollback checkpoint")
    rehearsal_plan.add_argument("--label", default="migration-rehearsal", help="Human-readable rehearsal label")
    rehearsal_plan.add_argument("--report-file", help="Optional path to write the rehearsal plan JSON")
    rehearsal_plan.add_argument("--runbook-file", help="Optional path to write the rehearsal runbook markdown")
    rehearsal_plan.add_argument("--max-items", type=int, default=10, help="Number of roadmap items to include in the runbook")
    rehearsal_plan.set_defaults(func=handle_rehearsal_plan)

    bootstrap_parser = subparsers.add_parser("bootstrap", help="Portable foundation bootstrap operations")
    bootstrap_sub = bootstrap_parser.add_subparsers(dest="subcommand", required=True)
    bootstrap_init = bootstrap_sub.add_parser("init", help="Scaffold starter foundation assets into a target repository")
    bootstrap_init.add_argument("--target-dir", default=".", help="Target repository root (default: current repo)")
    bootstrap_init.add_argument("--force", action="store_true", help="Overwrite existing starter files")
    bootstrap_init.add_argument("--templates-root", help="Repo-local templates root override")
    bootstrap_init.add_argument("--sessions-root", help="Repo-local sessions root override")
    bootstrap_init.add_argument("--plans-root", help="Repo-local plans root override")
    bootstrap_init.add_argument("--plan-state-dir", help="Repo-local plan state directory override")
    bootstrap_init.add_argument("--taskmaster-root", help="Repo-local Taskmaster root override")
    bootstrap_init.add_argument("--work-tracking-root", help="Repo-local work-tracking root override")
    bootstrap_init.add_argument("--reports-root", help="Repo-local reports root override")
    bootstrap_init.set_defaults(func=handle_bootstrap_init)

    wizard_parser = subparsers.add_parser("wizard", help="Guided workflow operations")
    wizard_sub = wizard_parser.add_subparsers(dest="subcommand", required=True)
    wizard_kickoff = wizard_sub.add_parser("kickoff", help="Interactively scaffold a task session, plan, and work-tracking state")
    wizard_kickoff.add_argument("--task", help="Task ID (numeric)")
    wizard_kickoff.add_argument("--slug", help="Slug for session/plan/work-tracking naming")
    wizard_kickoff.add_argument("--title", help="Human-readable task title")
    wizard_kickoff.add_argument("--goal", action="append", help="Goal checklist item (repeatable)")
    wizard_kickoff.add_argument("--task-source", help="Human-readable source line for the session metadata")
    wizard_kickoff.add_argument("--handler-target", help="Primary handler target/path for the generated plan")
    wizard_kickoff.add_argument("--force", action="store_true", help="Allow kickoff even if another ACTIVE folder exists")
    wizard_kickoff.set_defaults(func=handle_wizard_kickoff)

    scanner_parser = subparsers.add_parser("scanner", help="SSOT scanner operations")
    scanner_sub = scanner_parser.add_subparsers(dest="subcommand", required=True)
    scanner_run = scanner_sub.add_parser("run", help="Run a scanner tool and optionally log results")
    scanner_run.add_argument("tool", help="Scanner tool key (scanner, analyze, duplicates, migration, fixes, safe-reorg)")
    scanner_run.add_argument("--work", required=True, help="W field value for logging")
    scanner_run.add_argument("--handler", required=True, help="H field value for logging")
    scanner_run.add_argument("--evidence", required=True, help="E field value for logging")
    scanner_run.add_argument("--log-note", help="Log note to append after successful run")
    scanner_run.add_argument("--folder", help="Work-tracking folder override")
    scanner_run.add_argument("--document", default="TRACKER", help="Work-tracking markdown name for logging")
    scanner_run.set_defaults(func=handle_scanner_run)

    return parser


def main(argv: Optional[List[str]] = None) -> int:
    parser = build_parser()
    args, unknown = parser.parse_known_args(argv)

    if unknown:
        if getattr(args, "command", None) == "scanner" and getattr(args, "subcommand", None) == "run":
            setattr(args, "scanner_args", unknown)
        else:
            parser.error(f"unrecognized arguments: {' '.join(unknown)}")

    try:
        args.func(args)
    except TaskError as exc:
        message = str(exc)
        print(f"error: {message}", file=sys.stderr)
        lowered = message.lower()
        if any(keyword in lowered for keyword in ("guard", "plan sync", "branch policy")):
            print(_meta_guard_message(), file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        return 130
    return 0


if __name__ == "__main__":
    sys.exit(main())
