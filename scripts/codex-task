            "Recognize implementation work through evidence-backed task outcomes rather than personal claims inferred by automation.",
            "Recognize review discipline that caught scope drift and kept broad PRD wording grounded in current-state gaps.",
        ],
        "retrospective_prompts": [
            "Which workflow gates most improved reliability?",
            "Which task patterns should become reusable foundation defaults?",
            "Where did historical PRD wording diverge most from current project needs?",
            "Which remaining planned candidates need new Taskmaster tasks before implementation?",
        ],
        "roadmap_talking_points": [
            "Use Task 69's ready candidates as the next review queue, not automatic implementation authority.",
            "Keep planned AI-generation and optional MCP work behind dedicated scope reconciliation tasks.",
            "Continue static packet and guard-first improvements before adding live services.",
        ],
        "manual_next_steps": [
            "Review this packet with the project owner before sharing.",
            "Refresh referenced reports immediately before any celebration/readout.",
            "Choose which announcement, agenda, demo, and retrospective sections to use manually.",
            "Record any follow-up implementation ideas as separate Taskmaster tasks.",
        ],
        "recommended_refresh_commands": _celebration_refresh_commands(domains),
        "planning_guidance": list(CELEBRATION_PLANNING_GUIDANCE),
        "non_goals": list(CELEBRATION_PLANNING_NON_GOALS),
    }


def _render_celebration_plan(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    lines = [
        "# Celebration Planning Packet",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Summary",
        "",
        f"- Total domains: {summary.get('total_domains')}",
        f"- Ready: {summary.get('ready')}",
        f"- Needs evidence: {summary.get('needs_evidence')}",
        f"- Blocked: {summary.get('blocked')}",
        "",
        "## Evidence Domains",
        "",
        "| Domain | Purpose | Status | Missing Evidence |",
        "| --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        missing = "<br>".join(domain.get("missing_evidence_paths", [])) or "None"
        lines.append(
            f"| {_md_cell(domain.get('title'))} | {_md_cell(domain.get('purpose'))} | "
            f"`{_md_cell(domain.get('status'))}` | {_md_cell(missing)} |"
        )

    lines.extend(["", "## Achievement Highlights", ""])
    for highlight in report.get("achievement_highlights", []):
        if isinstance(highlight, Mapping):
            lines.append(f"- **{highlight.get('title')}**: {highlight.get('message')} (`{highlight.get('evidence_domain')}`)")

    announcement = report.get("announcement_draft", {}) if isinstance(report.get("announcement_draft"), Mapping) else {}
    lines.extend(
        [
            "",
            "## Announcement Draft",
            "",
            f"### {announcement.get('headline')}",
            "",
            str(announcement.get("opening")),
            "",
            "Proof points:",
        ]
    )
    for point in announcement.get("proof_points", []):
        lines.append(f"- {point}")
    lines.extend(["", f"Review note: {announcement.get('review_note')}", ""])

    lines.extend(["## Event / Readout Agenda", ""])
    for item in report.get("event_agenda", []):
        if isinstance(item, Mapping):
            lines.append(f"- {item.get('title')} ({item.get('duration_minutes')} min, `{item.get('evidence_domain')}`)")

    lines.extend(["", "## Demo Candidates", ""])
    for demo in report.get("demo_candidates", []):
        if isinstance(demo, Mapping):
            lines.append(f"- **{demo.get('title')}** (`{demo.get('evidence_domain')}`): `{demo.get('command')}`")

    lines.extend(["", "## Recognition Prompts", ""])
    for prompt in report.get("recognition_prompts", []):
        lines.append(f"- {prompt}")

    lines.extend(["", "## Retrospective Prompts", ""])
    for prompt in report.get("retrospective_prompts", []):
        lines.append(f"- {prompt}")

    lines.extend(["", "## Roadmap Talking Points", ""])
    for point in report.get("roadmap_talking_points", []):
        lines.append(f"- {point}")

    lines.extend(["", "## Manual Next Steps", ""])
    for step in report.get("manual_next_steps", []):
        lines.append(f"- {step}")

    lines.extend(["", "## Planning Guidance", ""])
    for item in report.get("planning_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static celebration planning artifact. It composes existing evidence and requested output files only; it does not schedule events, send announcements, publish posts, create awards, generate decks, collect feedback, or contact external systems.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_celebration_plan(args: argparse.Namespace) -> None:
    report = _build_celebration_plan(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_celebration_plan(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] != "ready":
            raise TaskError("Celebration plan aggregate status is not ready")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote celebration plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote celebration runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] != "ready":
        raise TaskError("Celebration plan aggregate status is not ready")


