BOOTSTRAP_STRUCTURE_KEYS = tuple(DEFAULT_REPO_STRUCTURE.keys())


def _slugify(value: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", value.strip().lower()).strip('-')
    return slug or "work"

class TaskError(Exception):
    """Custom exception for predictable task failures."""


def _load_file_lines(path: Path) -> List[str]:
    text = path.read_text(encoding="utf-8")
    # `splitlines()` keeps consistent handling regardless of trailing newline.
    return text.splitlines()


def _write_file_lines(path: Path, lines: Iterable[str]) -> None:
    content = "\n".join(lines) + "\n"
    path.write_text(content, encoding="utf-8")


def _relative_to_root(path: Path, root: Path) -> str:
    try:
        return path.relative_to(root).as_posix()
    except ValueError:
        return path.as_posix()


def _symlink_to(link_path: Path, target_path: Path) -> None:
    link_path.parent.mkdir(parents=True, exist_ok=True)
    if link_path.exists() or link_path.is_symlink():
        link_path.unlink()
    relative_target = Path(
        *target_path.relative_to(link_path.parent).parts
    ) if target_path.is_relative_to(link_path.parent) else Path(
        *Path(
            *(['..'] * len(link_path.parent.relative_to(REPO_ROOT).parts)),
            *target_path.relative_to(REPO_ROOT).parts,
        ).parts
    )
    link_path.symlink_to(relative_target)


def _replace_line_with_prefix(lines: List[str], prefix: str, new_line: str) -> bool:
    for idx, line in enumerate(lines):
        if line.startswith(prefix):
            lines[idx] = new_line
            return True
    return False


def _next_session_id(now: datetime) -> str:
    date_prefix = now.strftime("%Y-%m-%d")
    session_dir = SESSIONS_DIR / now.strftime("%Y") / now.strftime("%m")
    session_dir.mkdir(parents=True, exist_ok=True)
    pattern = re.compile(rf"^{re.escape(date_prefix)}-(\d{{3}})-")
    max_suffix = 0
    for candidate in session_dir.glob(f"{date_prefix}-*.md"):
        match = pattern.match(candidate.name)
        if match:
            max_suffix = max(max_suffix, int(match.group(1)))
    return f"{date_prefix}-{max_suffix + 1:03d}"


def _task_file_path(task_id: str) -> Path:
    token = int(task_id)
    tasks_dir = TASKMASTER_TASKS_DIR
    if not tasks_dir.is_relative_to(REPO_ROOT):
        tasks_dir = load_repo_structure(REPO_ROOT).taskmaster_tasks_dir
    return tasks_dir / f"task_{token:03d}.txt"


def _load_task_metadata(task_id: str) -> Dict[str, str]:
    task_file = _task_file_path(task_id)
    data = {
        "title": f"Task {task_id}",
        "description": "",
        "path": task_file.relative_to(REPO_ROOT).as_posix(),
    }
    if not task_file.exists():
        return data
    for raw in task_file.read_text(encoding="utf-8").splitlines():
        if raw.startswith("# Title:"):
            data["title"] = raw.split(":", 1)[1].strip()
        elif raw.startswith("# Description:"):
            data["description"] = raw.split(":", 1)[1].strip()
    return data


def _prompt_with_default(label: str, default: Optional[str] = None) -> str:
    while True:
        prompt = f"{label}"
        if default:
            prompt += f" [{default}]"
        prompt += ": "
        value = input(prompt).strip()
        if value:
            return value
        if default is not None:
            return default


def _default_goals_for_title(title: str) -> List[str]:
    return [
        f"Define the scope and workflow boundary for {title}",
        f"Implement {title} using the existing helper surface",
        "Verify guard integration, documentation, and regression coverage",
    ]


def _write_session_state(current_session_name: str, now: datetime) -> None:
    payload = {
        "current": current_session_name,
        "paused": [],
        "updated_at": now.isoformat(timespec="seconds"),
    }
    SESSION_STATE_PATH.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def _run_checked_command(cmd: List[str]) -> None:
    result = subprocess.run(cmd, cwd=str(REPO_ROOT), capture_output=True, text=True)
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip() or f"Command failed: {' '.join(cmd)}"
        raise TaskError(message)


def _target_path(target_root: Path, raw_value: str) -> Path:
    path = Path(raw_value)
    if not path.is_absolute():
        path = target_root / path
    return path.resolve()


def _repo_structure_from_values(target_root: Path, values: Dict[str, str]) -> RepoStructure:
    return RepoStructure(
        repo_root=target_root.resolve(),
        templates_root=_target_path(target_root, values["templates_root"]),
        sessions_root=_target_path(target_root, values["sessions_root"]),
        plans_root=_target_path(target_root, values["plans_root"]),
        plan_state_dir=_target_path(target_root, values["plan_state_dir"]),
        taskmaster_root=_target_path(target_root, values["taskmaster_root"]),
        work_tracking_root=_target_path(target_root, values["work_tracking_root"]),
        reports_root=_target_path(target_root, values["reports_root"]),
    )


def _bootstrap_values_from_args(args: argparse.Namespace) -> Dict[str, str]:
    values = dict(DEFAULT_REPO_STRUCTURE)
    for key in BOOTSTRAP_STRUCTURE_KEYS:
        override = getattr(args, key, None)
        if override:
            values[key] = override
    return values


def _render_bootstrap_config(values: Dict[str, str]) -> str:
    lines = [
        "# Portable foundation bootstrap config",
        "# Review and adjust repo-local roots before broad adoption.",
        "",
        "[repo_structure]",
    ]
    for key in BOOTSTRAP_STRUCTURE_KEYS:
        lines.append(f'{key} = "{values[key]}"')
    return "\n".join(lines) + "\n"


def _render_bootstrap_setup_doc(target_root: Path, structure: RepoStructure) -> str:
    lines = [
        "# Foundation Bootstrap Setup",
        "",
        "This repository has been scaffolded with the portable Codex foundation starter assets.",
        "",
        "## Created Starter Assets",
        "",
        f"- `.codex/config.toml` — repo-local workflow roots for `{target_root.name or target_root.as_posix()}`",
        f"- `{_relative_to_root(structure.template_metadata_policy_path, target_root)}` — starter metadata policy",
        f"- `{_relative_to_root(structure.sessions_root, target_root)}/` — session root",
        f"- `{_relative_to_root(structure.plans_root, target_root)}/` — plan root",
        f"- `{_relative_to_root(structure.taskmaster_root, target_root)}/` — Taskmaster root scaffold",
        f"- `{_relative_to_root(structure.work_tracking_root, target_root)}/` — work-tracking root scaffold",
        f"- `{_relative_to_root(structure.reports_root, target_root)}/` — reports root scaffold",
        "",
        "## Next Steps",
        "",
        "1. Review `.codex/config.toml` and adjust `[repo_structure]` to match this repository if needed.",
        "2. Review the metadata policy at the configured template path before enabling broad enforcement.",
        "3. Initialize or reconcile Taskmaster content for this repository if it is part of the workflow.",
        "4. Start the first task on a `feat/task-<id>-...` branch with `python3 scripts/codex-task wizard kickoff --task <id>`.",
        "",
        "## Migration Safety",
        "",
        "- Existing config and policy files are preserved unless bootstrap is re-run with `--force`.",
        "- Existing workflow directories are treated as valid inputs and are not removed.",
        "- Re-run bootstrap after changing repo roots if you need the starter layout refreshed.",
    ]
    return "\n".join(lines) + "\n"


def _record_bootstrap_result(results: List[Tuple[str, str, str]], kind: str, path: Path, status: str, root: Path) -> None:
    results.append((kind, _relative_to_root(path, root), status))


def _ensure_directory(path: Path, root: Path, results: List[Tuple[str, str, str]], dry_run: bool) -> None:
    if path.exists():
        if not path.is_dir():
            raise TaskError(f"Expected directory but found file: {path}")
        _record_bootstrap_result(results, "dir", path, "existing", root)
        return
    if dry_run:
        _record_bootstrap_result(results, "dir", path, "would-create", root)
        return
    path.mkdir(parents=True, exist_ok=True)
    _record_bootstrap_result(results, "dir", path, "created", root)


def _write_bootstrap_file(
    path: Path,
    content: str,
    *,
    force: bool,
    root: Path,
    results: List[Tuple[str, str, str]],
    dry_run: bool,
) -> None:
    existed = path.exists()
    if existed and not force:
        _record_bootstrap_result(results, "file", path, "existing", root)
        return
    if dry_run:
        _record_bootstrap_result(results, "file", path, "would-update" if existed else "would-create", root)
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    _record_bootstrap_result(results, "file", path, "updated" if existed else "created", root)


def handle_bootstrap_init(args: argparse.Namespace) -> None:
    target_root = Path(args.target_dir).expanduser()
    if not target_root.is_absolute():
        target_root = (REPO_ROOT / target_root).resolve()
    else:
        target_root = target_root.resolve()

    if not args.dry_run:
        target_root.mkdir(parents=True, exist_ok=True)

    target_config = target_root / ".codex" / "config.toml"
    bootstrap_values = _bootstrap_values_from_args(args)
    should_write_config = args.force or not target_config.exists()
    structure = _repo_structure_from_values(target_root, bootstrap_values) if should_write_config else load_repo_structure(target_root)

    results: List[Tuple[str, str, str]] = []

    _write_bootstrap_file(
        target_config,
        _render_bootstrap_config(bootstrap_values),
        force=args.force,
        root=target_root,
        results=results,
        dry_run=args.dry_run,
    )

    directories = [
        structure.templates_root,
        structure.template_metadata_policy_path.parent,
        structure.sessions_root,
        structure.plans_root,
        structure.plan_state_dir,
        structure.taskmaster_root,
        structure.taskmaster_tasks_dir,
        structure.taskmaster_root / "docs",
        structure.taskmaster_root / "reports",
        structure.work_tracking_root,
        structure.work_tracking_active_root,
        structure.work_tracking_archive_root,
        structure.reports_root,
        structure.drift_report_dir,
        structure.metrics_report_dir,
        structure.continuation_guard_dir,
        (target_root / BOOTSTRAP_SETUP_REL).parent,
    ]
    for directory in directories:
        _ensure_directory(directory, target_root, results, args.dry_run)

    policy_source = REPO_STRUCTURE.template_metadata_policy_path
    policy_content = policy_source.read_text(encoding="utf-8")
    _write_bootstrap_file(
        structure.template_metadata_policy_path,
        policy_content,
        force=args.force,
        root=target_root,
        results=results,
        dry_run=args.dry_run,
    )

    _write_bootstrap_file(
        target_root / BOOTSTRAP_SETUP_REL,
        _render_bootstrap_setup_doc(target_root, structure),
        force=args.force,
        root=target_root,
        results=results,
        dry_run=args.dry_run,
    )

    status_order = ("created", "updated", "existing", "would-create", "would-update")
    print(f"Bootstrap target: {target_root}")
    for status in status_order:
        matching = [(kind, rel) for kind, rel, item_status in results if item_status == status]
        if not matching:
            continue
        print(f"{status}:")
        for kind, rel in matching:
            print(f"  - {kind}: {rel}")


def _validate_branch_for_task(branch: str, task_id: str) -> None:
    expected = f"feat/task-{task_id}"
    if not branch.startswith(expected):
        raise TaskError(
            f"Current branch '{branch}' does not satisfy feature-required policy for task {task_id}; expected prefix '{expected}'"
        )


def _build_session_lines(
    session_id: str,
    now: datetime,
    task_id: str,
    title: str,
    branch: str,
    source: str,
    task_file_relative: str,
    work_context: str,
    tracker_relative: str,
) -> List[str]:
    date_iso = now.strftime("%Y-%m-%d")
    time_label = now.strftime("%H:%M %Z")
    timestamp_full = now.strftime("%Y-%m-%d %H:%M:%S %Z %z")
    session_value = now.strftime("%Y%m%d")
    pretty_title = f"Task {task_id} - {title}"
    return [
        "---",
        f"session_id: {session_id}",
        f"date: {date_iso}",
        f"time: {time_label}",
        f"title: {pretty_title}",
        "---",
        "",
        f"## Session: {date_iso} {time_label}",
        "**AI Assistant**: Codex GPT-5.4",
        "**Developer**: loucmane",
        f"**Task**: Start Task {task_id} via the guided kickoff flow and establish compliant session, plan, and work-tracking state for {title}.",
        f"**Task Source**: {source}",
        "",
        "### Session Validation",
        f"- [x] Date confirmed (`date '+%Y-%m-%d %H:%M:%S %Z %z'` -> `{timestamp_full}`)",
        f"- [x] Git branch checked (`{branch}`)",
        f"- [x] Taskmaster task reviewed (`{task_file_relative}`)",
        "",
        "### Session Goals",
        f"- [x] Start a fresh Task {task_id} session on the Task {task_id} branch.",
        f"- [x] Scaffold Task {task_id} work tracking.",
        f"- [x] Repoint `{SESSIONS_CURRENT_REL}` and `{PLANS_CURRENT_REL}` to Task {task_id}.",
        f"- [x] Mark Taskmaster Task {task_id} in progress.",
        f"- [ ] Review the design baseline and implementation boundary for {title}.",
        "- [ ] Capture implementation and verification evidence.",
        "",
        "### Starting Context",
        f"Task {task_id} was kicked off via `python3 scripts/codex-task wizard kickoff`, which created the session, plan, and work-tracking scaffolding in a guard-compliant state before implementation began.",
        "",
        "### 📝 Progress Log",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:shell:date|E:cmd`date \"+%Y-%m-%d %H:%M:%S %Z %z\"`] Confirmed current timestamp as `{timestamp_full}`",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:scripts/codex-task|E:{tracker_relative}] Scaffolded the Task {task_id} ACTIVE work-tracking folder through the guided kickoff flow",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:task-master:set-status|E:{TASKMASTER_TASKS_JSON_REL}] Marked Taskmaster Task {task_id} in progress and regenerated the task files",
        f"- **[{now.strftime('%H:%M')}]** — [S:{session_value}|W:{work_context}|H:{SESSIONS_CURRENT_REL}|E:{SESSIONS_CURRENT_REL}] Repointed `{SESSIONS_CURRENT_REL}`, `{PLANS_CURRENT_REL}`, and `{SESSION_STATE_REL}` to the new Task {task_id} kickoff",
    ]


def _build_tracker_entries(
    now: datetime,
    task_id: str,
    work_context: str,
    tracker_relative: str,
) -> List[str]:
    session_value = now.strftime("%Y%m%d")
    timestamp = now.strftime("%Y-%m-%d %H:%M")
    return [
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:shell:date|E:cmd`date \"+%Y-%m-%d %H:%M %Z\"`] Confirmed current timestamp as `{now.strftime('%Y-%m-%d %H:%M %Z')}`",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:scripts/codex-task|E:{tracker_relative}] Scaffolded the Task {task_id} ACTIVE work-tracking folder through the guided kickoff flow",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:task-master:set-status|E:{TASKMASTER_TASKS_JSON_REL}] Marked Taskmaster Task {task_id} in progress and regenerated the task files",
        f"- **{timestamp}** — [S:{session_value}|W:{work_context}|H:{SESSIONS_CURRENT_REL}|E:{SESSIONS_CURRENT_REL}] Repointed `{SESSIONS_CURRENT_REL}`, `{PLANS_CURRENT_REL}`, and `{SESSION_STATE_REL}` to the new Task {task_id} kickoff",
    ]


