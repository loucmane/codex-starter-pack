def _build_enhancement_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "phase5-enhancement-planning"
    candidates = [_enhancement_candidate(definition) for definition in _enhancement_candidate_definitions()]
    candidates.sort(
        key=lambda item: (
            ENHANCEMENT_READINESS_ORDER.get(str(item.get("readiness")), 9),
            ENHANCEMENT_PRIORITY_ORDER.get(str(item.get("priority")), 9),
            str(item.get("id")),
        )
    )
    counts = Counter(str(candidate.get("readiness")) for candidate in candidates)
    if counts.get("blocked"):
        aggregate_status = "blocked"
    elif counts.get("needs-evidence"):
        aggregate_status = "needs-evidence"
    elif counts.get("planned") and counts.get("ready"):
        aggregate_status = "ready-with-planned-candidates"
    elif counts.get("planned") and not counts.get("ready"):
        aggregate_status = "planned"
    else:
        aggregate_status = "ready"
    recommended_next = [
        {
            "candidate_id": candidate["id"],
            "title": candidate["title"],
            "priority": candidate["priority"],
            "readiness": candidate["readiness"],
            "required_action": candidate["required_action"],
        }
        for candidate in candidates
        if candidate.get("readiness") in {"ready", "needs-evidence"}
    ][:5]
    refresh_commands: List[str] = []
    for candidate in candidates:
        for command in candidate.get("refresh_commands", []):
            if command not in refresh_commands:
                refresh_commands.append(command)
    refresh_commands.extend(
        command
        for command in (
            "python3 scripts/codex-task enhancement phase5-plan --report-file reports/enhancement-planning/latest.json --runbook-file reports/enhancement-planning/latest.md",
            "python3 scripts/codex-guard validate --include-untracked",
        )
        if command not in refresh_commands
    )
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-phase5-enhancement-planning-packet",
        "executes_actions": False,
        "summary": {
            "aggregate_status": aggregate_status,
            "total_candidates": len(candidates),
            "ready": counts.get("ready", 0),
            "needs_evidence": counts.get("needs-evidence", 0),
            "planned": counts.get("planned", 0),
            "blocked": counts.get("blocked", 0),
        },
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "candidates": candidates,
        "recommended_next_actions": recommended_next,
        "recommended_refresh_commands": refresh_commands,
        "planning_guidance": list(ENHANCEMENT_PLANNING_GUIDANCE),
        "non_goals": list(ENHANCEMENT_PLANNING_NON_GOALS),
    }


def _render_enhancement_plan(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    lines = [
        "# Phase 5 Enhancement Planning Packet",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Summary",
        "",
        f"- Total candidates: {summary.get('total_candidates')}",
        f"- Ready: {summary.get('ready')}",
        f"- Needs evidence: {summary.get('needs_evidence')}",
        f"- Planned: {summary.get('planned')}",
        f"- Blocked: {summary.get('blocked')}",
        "",
        "## Enhancement Candidates",
        "",
        "| Candidate | Area | Priority | Readiness | Missing Evidence |",
        "| --- | --- | --- | --- | --- |",
    ]
    for candidate in report.get("candidates", []):
        if not isinstance(candidate, Mapping):
            continue
        missing = "<br>".join(candidate.get("missing_evidence_paths", [])) or "None"
        lines.append(
            f"| {_md_cell(candidate.get('title'))} | `{_md_cell(candidate.get('area'))}` | "
            f"`{_md_cell(candidate.get('priority'))}` | `{_md_cell(candidate.get('readiness'))}` | {_md_cell(missing)} |"
        )

    lines.extend(["", "## Candidate Details", ""])
    for candidate in report.get("candidates", []):
        if not isinstance(candidate, Mapping):
            continue
        lines.extend(
            [
                f"### {candidate.get('title')}",
                "",
                f"- ID: `{candidate.get('id')}`",
                f"- Area: `{candidate.get('area')}`",
                f"- Priority: `{candidate.get('priority')}`",
                f"- Readiness: `{candidate.get('readiness')}`",
                f"- Rationale: {candidate.get('rationale')}",
                f"- Required action: {candidate.get('required_action')}",
                f"- Boundary: {candidate.get('non_goal_boundary')}",
                "",
                "Evidence paths:",
            ]
        )
        for item in candidate.get("evidence_paths", []):
            if isinstance(item, Mapping):
                lines.append(f"- `{item.get('path')}` ({item.get('kind')})")
        lines.extend(["", "Refresh commands:"])
        for command in candidate.get("refresh_commands", []):
            lines.append(f"- `{command}`")
        lines.append("")

    lines.extend(["## Recommended Next Actions", ""])
    for action in report.get("recommended_next_actions", []):
        if not isinstance(action, Mapping):
            continue
        lines.append(
            f"- `{action.get('candidate_id')}` ({action.get('priority')}, {action.get('readiness')}): {action.get('required_action')}"
        )

    lines.extend(["", "## Planning Guidance", ""])
    for item in report.get("planning_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static Phase 5 enhancement planning artifact. It composes existing evidence and requested output files only; it does not install triggers, enable optional MCPs, generate templates with AI, apply optimizations, or mutate Taskmaster from candidate rows.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_enhancement_phase5_plan(args: argparse.Namespace) -> None:
    report = _build_enhancement_plan(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_enhancement_plan(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] == "blocked":
            raise TaskError("Phase 5 enhancement plan aggregate status is blocked")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote enhancement plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote enhancement runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] == "blocked":
        raise TaskError("Phase 5 enhancement plan aggregate status is blocked")


CONTINUOUS_IMPROVEMENT_NON_GOALS: Tuple[str, ...] = (
    "No hosted suggestion portal, feedback application, analytics database, live dashboard, scheduler, notification workflow, or external innovation platform is created.",
    "No A/B test runtime, feature flag service, rollout engine, telemetry collector, or experimentation backend is installed or contacted.",
    "No automatic Taskmaster task creation, owner assignment, prioritization decision, model-based scoring, ticket creation, PR creation, or external response workflow is performed.",
    "No change advisory decision, validation approval, deployment gate, release decision, or governance outcome is inferred by this packet.",
    "No Taskmaster, session, plan, work-tracking, Git, report-source, template, or external state is mutated beyond requested continuous-improvement packet artifacts.",
)

CONTINUOUS_IMPROVEMENT_GUIDANCE: Tuple[str, ...] = (
    "Treat this packet as the operating review for the improvement loop: capture, prioritize, validate, govern, learn, and publish.",
    "Refresh source packets before using this review to choose implementation work; stale or missing evidence must remain visible.",
    "Promote accepted improvement work through explicit Taskmaster tasks with scope reconciliation, not automatic task creation from review rows.",
    "Use the A/B and CAB evidence as planning and governance inputs; they do not authorize live experiments or change approvals by themselves.",
    "Record lessons and follow-up decisions in the active task's FINDINGS.md, DECISIONS.md, HANDOFF.md, or a scoped follow-up task.",
)


def _continuous_improvement_domain(definition: Mapping[str, Any]) -> Dict[str, Any]:
    evidence_paths = [_enhancement_path_state(str(path)) for path in definition.get("evidence_paths", ())]
    missing = [item["path"] for item in evidence_paths if not item["exists"]]
    status = "needs-evidence" if missing else "ready"
    if missing:
        required_action = f"Refresh or restore missing evidence before relying on {definition['title']}."
    else:
        required_action = str(definition.get("ready_action") or "Ready for continuous-improvement review.")
    return {
        "id": definition["id"],
        "title": definition["title"],
        "stage": definition["stage"],
        "cadence": definition["cadence"],
        "purpose": definition["purpose"],
        "status": status,
        "evidence_paths": evidence_paths,
        "missing_evidence_paths": missing,
        "refresh_commands": list(definition.get("refresh_commands", ())),
        "required_action": required_action,
        "improvement_use": definition["improvement_use"],
        "handoff_destination": definition["handoff_destination"],
    }


