def _summarise_production_verification(domains: Sequence[Mapping[str, Any]]) -> Dict[str, Any]:
    counts = Counter(str(domain.get("status")) for domain in domains)
    if counts.get("blocked"):
        aggregate_status = "blocked"
        verification_signal = "not-ready"
    elif counts.get("needs-evidence"):
        aggregate_status = "needs-evidence"
        verification_signal = "needs-evidence"
    elif counts.get("review"):
        aggregate_status = "review"
        verification_signal = "ready-with-manual-review"
    else:
        aggregate_status = "ready"
        verification_signal = "ready-for-final-signoff"
    total = len(domains)
    actionable = total - counts.get("not-applicable", 0)
    ready_like = counts.get("ready", 0)
    score = round((ready_like / actionable) * 100, 2) if actionable else 100.0
    return {
        "aggregate_status": aggregate_status,
        "verification_signal": verification_signal,
        "verification_score_pct": score,
        "total_domains": total,
        "ready": counts.get("ready", 0),
        "review": counts.get("review", 0),
        "needs_evidence": counts.get("needs-evidence", 0),
        "blocked": counts.get("blocked", 0),
        "not_applicable": counts.get("not-applicable", 0),
    }


def _production_verification_refresh_commands(domains: Sequence[Mapping[str, Any]]) -> List[str]:
    commands: List[str] = []
    for domain in domains:
        for command in domain.get("refresh_commands", []) or []:
            if isinstance(command, str) and command and command not in commands:
                commands.append(command)
    for command in (
        "python3 scripts/codex-task deployment verification --report-file reports/production-verification/latest.json --runbook-file reports/production-verification/latest.md",
        "python3 scripts/codex-task taskmaster health",
        "python3 scripts/codex-task plan sync",
        "python3 scripts/codex-task work-tracking audit",
        "python3 scripts/codex-guard validate --include-untracked",
        "git diff --check",
    ):
        if command not in commands:
            commands.append(command)
    return commands


def _production_verification_signoff_checklist(domains: Sequence[Mapping[str, Any]]) -> List[Dict[str, Any]]:
    checklist: List[Dict[str, Any]] = []
    for domain in domains:
        status = str(domain.get("status"))
        checklist.append(
            {
                "id": domain.get("id"),
                "title": domain.get("title"),
                "status": status,
                "blocks_final_signoff": status in {"blocked", "needs-evidence"},
                "requires_manual_review": status == "review" or bool(domain.get("manual_actions")),
                "message": domain.get("message"),
            }
        )
    checklist.append(
        {
            "id": "human-production-signoff",
            "title": "Human production sign-off",
            "status": "manual",
            "blocks_final_signoff": False,
            "requires_manual_review": True,
            "message": "A human reviewer must approve final production readiness; this command does not create or infer approval.",
        }
    )
    return checklist


def _production_verification_manual_next_steps(domains: Sequence[Mapping[str, Any]]) -> List[Dict[str, Any]]:
    steps: List[Dict[str, Any]] = []
    for domain in domains:
        for action in domain.get("manual_actions", []) or []:
            steps.append({"domain": domain.get("id"), "status": domain.get("status"), "action": action})
    if not steps:
        steps.append(
            {
                "domain": "production-verification",
                "status": "ready",
                "action": "Review the generated packet with a human owner before final sign-off.",
            }
        )
    return steps


def _build_production_verification_report(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "production-verification"
    domains = _build_production_verification_domains()
    summary = _summarise_production_verification(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-production-verification-packet",
        "executes_actions": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "domains": domains,
        "final_signoff_checklist": _production_verification_signoff_checklist(domains),
        "manual_next_steps": _production_verification_manual_next_steps(domains),
        "recommended_refresh_commands": _production_verification_refresh_commands(domains),
        "non_goals": list(PRODUCTION_VERIFICATION_NON_GOALS),
    }


def _render_production_verification_report(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    lines = [
        "# Production Verification Packet",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: `{summary.get('aggregate_status')}`",
        f"- Verification signal: `{summary.get('verification_signal')}`",
        f"- Verification score: {summary.get('verification_score_pct')}%",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Summary",
        "",
        f"- Total domains: {summary.get('total_domains')}",
        f"- Ready: {summary.get('ready')}",
        f"- Review: {summary.get('review')}",
        f"- Needs evidence: {summary.get('needs_evidence')}",
        f"- Blocked: {summary.get('blocked')}",
        f"- Not applicable: {summary.get('not_applicable')}",
        "",
        "## Verification Domains",
        "",
        "| Domain | Purpose | Status | Missing Evidence |",
        "| --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        missing = "<br>".join(domain.get("missing_evidence_paths", [])) or "None"
        lines.append(
            f"| {_md_cell(domain.get('title'))} | {_md_cell(domain.get('purpose'))} | "
            f"`{_md_cell(domain.get('status'))}` | {_md_cell(missing)} |"
        )

    lines.extend(["", "## Domain Details", ""])
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        lines.extend(
            [
                f"### {domain.get('title')}",
                "",
                f"- ID: `{domain.get('id')}`",
                f"- Status: `{domain.get('status')}`",
                f"- Message: {domain.get('message')}",
                "",
                "Evidence:",
            ]
        )
        for evidence in domain.get("evidence", []):
            if isinstance(evidence, Mapping):
                lines.append(f"- `{evidence.get('path')}` ({evidence.get('kind')}, exists={evidence.get('exists')})")
        lines.extend(["", "Refresh commands:"])
        for command in domain.get("refresh_commands", []):
            lines.append(f"- `{command}`")
        actions = domain.get("manual_actions", [])
        if actions:
            lines.extend(["", "Manual actions:"])
            for action in actions:
                lines.append(f"- {action}")
        lines.append("")

    lines.extend(["## Final Sign-Off Checklist", ""])
    for item in report.get("final_signoff_checklist", []):
        if isinstance(item, Mapping):
            lines.append(
                f"- `{item.get('id')}`: `{item.get('status')}` "
                f"(blocks={item.get('blocks_final_signoff')}, manual_review={item.get('requires_manual_review')}) - {item.get('message')}"
            )

    lines.extend(["", "## Manual Next Steps", ""])
    for item in report.get("manual_next_steps", []):
        if isinstance(item, Mapping):
            lines.append(f"- `{item.get('domain')}` ({item.get('status')}): {item.get('action')}")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is static and evidence-based. It composes repository-local validation, security, performance, cost, recovery, monitoring, documentation, stakeholder, and transition evidence; it does not deploy, certify compliance, run live DR, contact external services, or infer human approval.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_deployment_verification(args: argparse.Namespace) -> None:
    report = _build_production_verification_report(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_production_verification_report(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] in {"blocked", "needs-evidence"}:
            raise TaskError("Production verification has blocking or missing evidence")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote production verification packet to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote production verification runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] in {"blocked", "needs-evidence"}:
        raise TaskError("Production verification has blocking or missing evidence")


def _resolve_current_plan_path() -> Path:
    if not PLAN_CURRENT.exists() or not PLAN_CURRENT.is_symlink():
        raise TaskError(f"{PLANS_CURRENT_REL} symlink missing; compaction checkpoints require an active plan")
    plan_path = PLAN_CURRENT.resolve()
    if not plan_path.exists():
        raise TaskError(f"{PLANS_CURRENT_REL} target missing: {plan_path}")
    return plan_path


def _compaction_memory_name(task_id: str, slug: str, created_at: datetime) -> str:
    return f"compaction_{created_at.strftime('%Y-%m-%d')}_task{task_id}_{_slugify(slug).replace('-', '_')}"


def _compaction_resume_markdown(manifest: Dict[str, Any]) -> str:
    paths = manifest.get("paths", {})
    git_info = manifest.get("git", {})
    return "\n".join(
        [
            f"# Compaction Checkpoint - Task {manifest.get('task_id')} {manifest.get('slug')}",
            "",
            "## Current State",
            f"- Created at: {manifest.get('created_at')}",
            f"- Branch: {git_info.get('branch')}",
            f"- HEAD: {git_info.get('head')}",
            f"- Summary: {manifest.get('summary')}",
            f"- Next step: {manifest.get('next_step')}",
            "",
            "## Resume Instruction",
            "Continue from this compaction checkpoint.",
            f"Read `{paths.get('session')}`, `{paths.get('plan')}`, `{paths.get('tracker')}`, and Serena memory `{paths.get('memory_name')}`.",
            f"Resume Task {manifest.get('task_id')} at: {manifest.get('next_step')}",
            "",
            "## Evidence",
            f"- Manifest: `{paths.get('manifest')}`",
            f"- Resume message: `{paths.get('resume')}`",
            f"- Serena memory file: `{paths.get('memory_file')}`",
            f"- Active work tracking: `{paths.get('work_tracking')}`",
            "",
            "## Important",
            "- This is a compaction checkpoint, not a session end.",
            "- Do not archive work tracking.",
            "- Do not clear `sessions/current` or `plans/current`.",
            "- Continue with the same session and task state after context resumes.",
            "",
        ]
    )


def _compaction_memory_markdown(manifest: Dict[str, Any]) -> str:
    paths = manifest.get("paths", {})
    return "\n".join(
        [
            f"# Compaction Checkpoint: Task {manifest.get('task_id')} {manifest.get('slug')}",
            "",
            "## Exact State",
            f"- Created at: {manifest.get('created_at')}",
            f"- Branch: {manifest.get('git', {}).get('branch')}",
            f"- HEAD: {manifest.get('git', {}).get('head')}",
            f"- Summary: {manifest.get('summary')}",
            f"- Next step: {manifest.get('next_step')}",
            "",
            "## Files To Read On Resume",
            f"- Session: `{paths.get('session')}`",
            f"- Plan: `{paths.get('plan')}`",
            f"- Tracker: `{paths.get('tracker')}`",
            f"- Manifest: `{paths.get('manifest')}`",
            f"- Resume message: `{paths.get('resume')}`",
            "",
            "## Last Completed",
            *[f"- {item}" for item in manifest.get("last_completed", [])],
            "",
            "## Open Items",
            *[f"- {item}" for item in manifest.get("open_items", [])],
            "",
            "## Resume Instructions",
            "1. Confirm date, branch, and git status.",
            f"2. Read `{paths.get('session')}` and `{paths.get('plan')}`.",
            f"3. Read `{paths.get('tracker')}` and this memory.",
            f"4. Continue Task {manifest.get('task_id')} at: {manifest.get('next_step')}",
            "",
        ]
    )


def _append_compaction_handoff(work_folder: Path, manifest: Dict[str, Any], session_value: str, work: str) -> None:
    handoff_path = work_folder / "HANDOFF.md"
    if not handoff_path.exists():
        handoff_path.write_text(
            f"# Task {manifest.get('task_id')} {manifest.get('slug')} - Handoff Summary\n\n",
            encoding="utf-8",
        )
    lines = _load_file_lines(handoff_path)
    heading = "## Compaction Checkpoints"
    if heading not in (line.strip() for line in lines):
        if lines and lines[-1].strip():
            lines.append("")
        lines.extend([heading, ""])
    swhe = (
        f"[S:{session_value}|W:{work}|H:scripts/codex-task:compaction-checkpoint|"
        f"E:{manifest['paths']['manifest']}]"
    )
    lines = _insert_progress_entry(
        lines,
        heading,
        f"- {manifest.get('created_at')} — {swhe} Resume at: {manifest.get('next_step')}",
    )
    _write_file_lines(handoff_path, lines)


def handle_compaction_checkpoint(args: argparse.Namespace) -> None:
    session_path = _resolve_current_session(args.session_file)
    plan_path = _resolve_current_plan_path()
    work_folder = _resolve_active_work_tracking(args.folder)
    tracker_path = work_folder / "TRACKER.md"
    if not tracker_path.exists():
        raise TaskError(f"Active tracker missing: {_relative_to_root(tracker_path, REPO_ROOT)}")

    created_at = datetime.now().astimezone()
    task_id = str(args.task).strip()
    slug = _slugify(args.slug or f"task{task_id}-compaction")
    checkpoint_id = f"{created_at.strftime('%Y%m%d-%H%M%S')}-task{task_id}-{slug}"
    report_dir = Path(args.report_dir) if args.report_dir else work_folder / "reports" / "compaction-checkpoints"
    if not report_dir.is_absolute():
        report_dir = REPO_ROOT / report_dir
    manifest_path = report_dir / f"{checkpoint_id}.json"
    resume_path = report_dir / f"{checkpoint_id}-resume.md"
    memory_name = args.memory_name or _compaction_memory_name(task_id, slug, created_at)
    memory_file = REPO_ROOT / ".serena" / "memories" / f"{memory_name}.md"
    work = args.work or f"task{task_id}-{slug}"

    manifest: Dict[str, Any] = {
        "version": 1,
        "kind": "compaction-checkpoint",
        "created_at": created_at.isoformat(timespec="seconds"),
        "task_id": task_id,
        "slug": slug,
        "summary": args.summary,
        "next_step": args.next_step,
        "last_completed": tuple(args.last_completed or ()),
        "open_items": tuple(args.open_item or ()),
        "git": {
            "branch": _git_output(["branch", "--show-current"]),
            "head": _git_output(["rev-parse", "HEAD"]),
            "status": _git_status_snapshot(),
        },
        "workflow": _workflow_snapshot(),
        "taskmaster": _taskmaster_snapshot(),
        "serena": _serena_memory_snapshot(),
        "paths": {
            "manifest": _relative_to_root(manifest_path, REPO_ROOT),
            "resume": _relative_to_root(resume_path, REPO_ROOT),
            "memory_name": memory_name,
            "memory_file": _relative_to_root(memory_file, REPO_ROOT),
            "session": _relative_to_root(session_path, REPO_ROOT),
            "plan": _relative_to_root(plan_path, REPO_ROOT),
            "tracker": _relative_to_root(tracker_path, REPO_ROOT),
            "work_tracking": _relative_to_root(work_folder, REPO_ROOT),
        },
    }
    rendered_manifest = json.dumps(manifest, indent=2, sort_keys=True) + "\n"
    rendered_resume = _compaction_resume_markdown(manifest)
    rendered_memory = _compaction_memory_markdown(manifest)

    if args.dry_run:
        print(rendered_resume, end="")
        return

    report_dir.mkdir(parents=True, exist_ok=True)
    memory_file.parent.mkdir(parents=True, exist_ok=True)
    PLAN_STATE_DIR.mkdir(parents=True, exist_ok=True)
    manifest_path.write_text(rendered_manifest, encoding="utf-8")
    resume_path.write_text(rendered_resume, encoding="utf-8")
    memory_file.write_text(rendered_memory, encoding="utf-8")
    with COMPACTION_HISTORY_PATH.open("a", encoding="utf-8") as handle:
        handle.write(
            json.dumps(
                {
                    "created_at": manifest["created_at"],
                    "task_id": task_id,
                    "slug": slug,
                    "manifest": manifest["paths"]["manifest"],
                    "resume": manifest["paths"]["resume"],
                    "memory_name": memory_name,
                },
                sort_keys=True,
            )
            + "\n"
        )

    metadata = _parse_front_matter(session_path)
    session_value = args.session or _derive_session_value(metadata)
    session_entry = (
        f"- **[{created_at.strftime(DEFAULT_TIME_FORMAT_SESSION)}]** — "
        f"[S:{session_value}|W:{work}|H:scripts/codex-task:compaction-checkpoint|E:{manifest['paths']['manifest']}] "
        f"Created compaction checkpoint `{memory_name}`; resume at: {args.next_step}"
    )
    tracker_entry = (
        f"- **{created_at.strftime(DEFAULT_TIME_FORMAT_TRACKER)}** — "
        f"[S:{session_value}|W:{work}|H:scripts/codex-task:compaction-checkpoint|E:{manifest['paths']['manifest']}] "
        f"Created compaction checkpoint `{memory_name}`; resume at: {args.next_step}"
    )
    session_lines = _insert_progress_entry(_load_file_lines(session_path), PROGRESS_HEADING_SESSION, session_entry)
    tracker_lines = _insert_progress_entry(_load_file_lines(tracker_path), PROGRESS_HEADING_TRACKER, tracker_entry)
    _write_file_lines(session_path, session_lines)
    _write_file_lines(tracker_path, tracker_lines)
    _append_compaction_handoff(work_folder, manifest, session_value, work)

    print(f"Wrote compaction checkpoint manifest to {manifest['paths']['manifest']}")
    print(f"Wrote compaction resume message to {manifest['paths']['resume']}")
    print(f"Wrote compaction Serena memory file to {manifest['paths']['memory_file']}")
    print(f"Updated compaction history: {_relative_to_root(COMPACTION_HISTORY_PATH, REPO_ROOT)}")


def _load_json_document(path_value: str, label: str) -> Dict[str, Any]:
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    if not path.exists():
        raise TaskError(f"{label} not found: {_relative_to_root(path, REPO_ROOT)}")
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise TaskError(f"{label} is not valid JSON: {_relative_to_root(path, REPO_ROOT)}") from exc
    if not isinstance(payload, dict):
        raise TaskError(f"{label} must be a JSON object: {_relative_to_root(path, REPO_ROOT)}")
    return payload


def _normalise_roadmap_payload(path_value: str) -> Dict[str, Any]:
    raw = _load_json_document(path_value, "Migration roadmap")
    metadata = raw.get("metadata") if isinstance(raw.get("metadata"), dict) else None
    data = raw.get("data") if isinstance(raw.get("data"), dict) else raw
    if not isinstance(data, dict):
        raise TaskError("Migration roadmap data must be a JSON object")
    if "items" not in data or "summary_metrics" not in data:
        raise TaskError("Migration roadmap must include items and summary_metrics")
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "metadata": metadata,
        "data": data,
    }


def _simplify_rehearsal_item(item: Dict[str, Any]) -> Dict[str, Any]:
    source_files = item.get("source_files") if isinstance(item.get("source_files"), list) else []
    dependencies = item.get("dependencies") if isinstance(item.get("dependencies"), list) else []
    return {
        "id": item.get("id"),
        "priority": item.get("priority"),
        "category": item.get("category"),
        "title": item.get("title"),
        "effort": item.get("effort"),
        "risk": item.get("risk"),
        "finding_count": item.get("finding_count"),
        "source_files": source_files[:5],
        "dependencies": dependencies[:5],
    }


def _summarise_rehearsal_roadmap(roadmap: Dict[str, Any], max_items: int) -> Dict[str, Any]:
    data = roadmap["data"]
    items = data.get("items")
    if not isinstance(items, list):
        raise TaskError("Migration roadmap items must be a list")
    taskmaster_export = data.get("taskmaster_export")
    taskmaster_tasks = []
    if isinstance(taskmaster_export, dict) and isinstance(taskmaster_export.get("tasks"), list):
        taskmaster_tasks = taskmaster_export["tasks"]
    return {
        "path": roadmap["path"],
        "metadata": roadmap.get("metadata"),
        "generated_at": data.get("generated_at"),
        "version": data.get("migration_roadmap_version"),
        "summary_metrics": data.get("summary_metrics") if isinstance(data.get("summary_metrics"), dict) else {},
        "priority_counts": data.get("priority_counts") if isinstance(data.get("priority_counts"), dict) else {},
        "category_counts": data.get("category_counts") if isinstance(data.get("category_counts"), dict) else {},
        "phases": data.get("phases") if isinstance(data.get("phases"), list) else [],
        "total_items": len(items),
        "taskmaster_export_tasks": len(taskmaster_tasks),
        "first_items": [
            _simplify_rehearsal_item(item)
            for item in items[: max(0, max_items)]
            if isinstance(item, dict)
        ],
    }


def _summarise_rehearsal_checkpoint(checkpoint: Dict[str, Any], checkpoint_path: str) -> Dict[str, Any]:
    git_info = checkpoint.get("git") if isinstance(checkpoint.get("git"), dict) else {}
    workflow = checkpoint.get("workflow") if isinstance(checkpoint.get("workflow"), dict) else {}
    taskmaster = checkpoint.get("taskmaster") if isinstance(checkpoint.get("taskmaster"), dict) else {}
    status_entries = git_info.get("status") if isinstance(git_info.get("status"), list) else []
    path = Path(checkpoint_path)
    if not path.is_absolute():
        path = REPO_ROOT / path
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "label": checkpoint.get("label"),
        "created_at": checkpoint.get("created_at"),
        "git": {
            "branch": git_info.get("branch"),
            "head": git_info.get("head"),
            "tag": git_info.get("tag"),
            "status_count": len(status_entries),
        },
        "workflow": {
            "current_session": workflow.get("current_session", {}).get("resolved")
            if isinstance(workflow.get("current_session"), dict)
            else None,
            "current_plan": workflow.get("current_plan", {}).get("resolved")
            if isinstance(workflow.get("current_plan"), dict)
            else None,
            "active_work_tracking": workflow.get("active_work_tracking")
            if isinstance(workflow.get("active_work_tracking"), list)
            else [],
        },
        "taskmaster": {
            "sha256": taskmaster.get("sha256"),
            "summary": taskmaster.get("summary") if isinstance(taskmaster.get("summary"), dict) else None,
        },
    }


def _rehearsal_verification_commands() -> List[str]:
    return [
        "git status --short --branch",
        "python3 scripts/codex-task rollback checkpoint --label <label> --report-file <path>",
        "python3 scripts/template-ssot-scanner/migration_roadmap.py --data-dir scripts/template-ssot-scanner/output/data --json-out <path> --markdown-out <path>",
        "python3 scripts/codex-task rehearsal plan --roadmap <roadmap.json> --checkpoint <checkpoint.json> --report-file <plan.json> --runbook-file <runbook.md>",
        "python3 scripts/codex-task taskmaster health --report-file <path>",
        "python3 scripts/codex-task plan sync",
        "python3 scripts/codex-task work-tracking audit",
        "python3 scripts/codex-guard validate --include-untracked",
        "git diff --check",
    ]


def _build_migration_rehearsal_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    roadmap = _normalise_roadmap_payload(args.roadmap)
    checkpoint = _load_json_document(args.checkpoint, "Rollback checkpoint")
    roadmap_summary = _summarise_rehearsal_roadmap(roadmap, args.max_items)
    checkpoint_summary = _summarise_rehearsal_checkpoint(checkpoint, args.checkpoint)
    current_head = _git_output(["rev-parse", "HEAD"])
    current_branch = _git_output(["branch", "--show-current"])
    priority_counts = roadmap_summary.get("priority_counts", {})
    critical_count = int(priority_counts.get("critical", 0) or 0) if isinstance(priority_counts, dict) else 0
    dirty_count = len(_git_status_snapshot())
    abort_criteria = [
        "Stop if guard, plan sync, Taskmaster health, or required pytest suites fail.",
        "Stop if the rollback checkpoint is missing, unreadable, or points at an unexpected branch/head.",
        "Stop if rehearsal requires Docker, external API keys, agent simulators, load testing, or destructive Git commands; those are out of scope for this foundation task.",
    ]
    if critical_count:
        abort_criteria.append(
            f"Treat {critical_count} critical roadmap item(s) as pre-migration blockers unless explicitly waived in work tracking."
        )
    if dirty_count:
        abort_criteria.append(
            f"Review the current dirty working tree ({dirty_count} status entr{'y' if dirty_count == 1 else 'ies'}) before applying roadmap changes."
        )
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "non-destructive-local-rehearsal",
        "executes_mutations": False,
        "inputs": {
            "roadmap": roadmap_summary["path"],
            "checkpoint": checkpoint_summary["path"],
        },
        "current_state": {
            "git": {
                "branch": current_branch,
                "head": current_head,
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "checkpoint": checkpoint_summary,
        "roadmap": roadmap_summary,
        "rehearsal_environment": {
            "isolation_model": "manual-review-or-optional-worktree",
            "automatic_worktree_creation": False,
            "automatic_docker_setup": False,
            "external_api_keys_required": False,
            "agent_simulators_required": False,
            "load_testing_required": False,
            "guidance": [
                "Use the checkpoint commit as the rollback anchor before migration work.",
                "Use the roadmap priority order to select the next migration slice.",
                "If stronger isolation is needed, create a reviewed git worktree manually; this helper does not run that command.",
                "Capture fresh guard, audit, Taskmaster health, and diff-check evidence after each rehearsal slice.",
            ],
        },
        "recommended_verification_commands": _rehearsal_verification_commands(),
        "abort_criteria": abort_criteria,
        "non_goals": [
            "No Docker containers are created.",
            "No test API keys are read or written.",
            "No Claude/Codex agent simulators are launched.",
            "No k6/locust load test harness is invoked.",
            "No Taskmaster tasks are imported from roadmap data.",
            "No rollback, reset, clean, restore, or worktree command is executed.",
        ],
    }


def _md_cell(value: object) -> str:
    return str(value if value is not None else "").replace("|", "\\|")


def _render_migration_rehearsal_runbook(plan: Dict[str, Any]) -> str:
    roadmap = plan.get("roadmap", {})
    checkpoint = plan.get("checkpoint", {})
    current = plan.get("current_state", {})
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    checkpoint_git = checkpoint.get("git", {}) if isinstance(checkpoint.get("git"), dict) else {}
    lines = [
        "# Migration Rehearsal Runbook",
        "",
        f"- Label: {plan.get('label')}",
        f"- Created at: {plan.get('created_at')}",
        f"- Mode: {plan.get('mode')}",
        f"- Executes mutations: {plan.get('executes_mutations')}",
        "",
        "## Inputs",
        "",
        f"- Migration roadmap: {plan.get('inputs', {}).get('roadmap')}",
        f"- Rollback checkpoint: {plan.get('inputs', {}).get('checkpoint')}",
        "",
        "## Current State",
        "",
        f"- Current branch: {git_info.get('branch')}",
        f"- Current HEAD: {git_info.get('head')}",
        f"- Current dirty status entries: {len(git_info.get('status') or [])}",
        f"- Checkpoint branch: {checkpoint_git.get('branch')}",
        f"- Checkpoint HEAD: {checkpoint_git.get('head')}",
        "",
        "## Roadmap Summary",
        "",
        f"- Roadmap generated at: {roadmap.get('generated_at')}",
        f"- Roadmap version: {roadmap.get('version')}",
        f"- Total roadmap items: {roadmap.get('total_items')}",
        f"- Taskmaster draft items: {roadmap.get('taskmaster_export_tasks')}",
        "",
        "### Priority Counts",
        "",
    ]
    priority_counts = roadmap.get("priority_counts") if isinstance(roadmap.get("priority_counts"), dict) else {}
    if priority_counts:
        for priority in ("critical", "high", "medium", "low"):
            lines.append(f"- {priority}: {priority_counts.get(priority, 0)}")
    else:
        lines.append("- No priority counts available.")

    lines.extend(["", "### Phase Plan", ""])
    phases = roadmap.get("phases") if isinstance(roadmap.get("phases"), list) else []
    if phases:
        lines.append("| Phase | Priorities | Start Day | Duration |")
        lines.append("| --- | --- | --- | --- |")
        for phase in phases:
            if not isinstance(phase, dict):
                continue
            priorities = ", ".join(str(priority) for priority in phase.get("priorities", []))
            lines.append(
                f"| {_md_cell(phase.get('title'))} | {_md_cell(priorities)} | "
                f"{_md_cell(phase.get('start_day'))} | {_md_cell(phase.get('duration_days'))} days |"
            )
    else:
        lines.append("- No phase plan available.")

    lines.extend(["", "### First Rehearsal Items", ""])
    items = roadmap.get("first_items") if isinstance(roadmap.get("first_items"), list) else []
    if items:
        lines.append("| Priority | Category | Effort | Risk | Findings | Title |")
        lines.append("| --- | --- | --- | --- | --- | --- |")
        for item in items:
            if not isinstance(item, dict):
                continue
            lines.append(
                f"| {_md_cell(item.get('priority'))} | {_md_cell(item.get('category'))} | "
                f"{_md_cell(item.get('effort'))} | {_md_cell(item.get('risk'))} | "
                f"{_md_cell(item.get('finding_count'))} | {_md_cell(item.get('title'))} |"
            )
    else:
        lines.append("- No roadmap items available.")

    lines.extend(["", "## Rehearsal Steps", ""])
    lines.extend(
        [
            "1. Review the rollback checkpoint and current dirty Git status.",
            "2. Select the smallest roadmap item or coherent group of items to rehearse.",
            "3. If additional isolation is required, create a git worktree manually after reviewing the command; this runbook does not create it.",
            "4. Run the selected scanner or fix command in dry-run mode first.",
            "5. Capture guard, audit, Taskmaster health, plan sync, and diff-check evidence before marking the rehearsal slice complete.",
            "6. If any abort criterion triggers, stop and use the rollback checkpoint recovery plan for reviewed, non-destructive guidance.",
        ]
    )

    lines.extend(["", "## Recommended Verification Commands", ""])
    for command in plan.get("recommended_verification_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Abort Criteria", ""])
    for criterion in plan.get("abort_criteria", []):
        lines.append(f"- {criterion}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in plan.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(["", "No rehearsal commands were executed by this plan.", ""])
    return "\n".join(lines)


def handle_rehearsal_plan(args: argparse.Namespace) -> None:
    plan = _build_migration_rehearsal_plan(args)
    rendered_json = json.dumps(plan, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_migration_rehearsal_runbook(plan)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote migration rehearsal plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote migration rehearsal runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


