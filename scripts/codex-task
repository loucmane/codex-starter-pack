def _deprecation_path_state(path_value: str) -> Dict[str, Any]:
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    exists = path.exists()
    if path.is_dir():
        kind = "directory"
    elif path.is_file():
        kind = "file"
    else:
        kind = "missing"
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "exists": exists,
        "kind": kind,
    }


def _deprecation_domain_review(domain: Dict[str, Any]) -> Dict[str, Any]:
    required_paths = [_deprecation_path_state(path) for path in domain.get("required_paths", ())]
    evidence_paths = [_deprecation_path_state(path) for path in domain.get("evidence_paths", ())]
    missing_required = [item["path"] for item in required_paths if not item["exists"]]
    missing_evidence = [item["path"] for item in evidence_paths if not item["exists"]]
    if missing_required:
        status = "needs-implementation"
        required_action = "Implement or restore the missing deprecation-management surface before review."
    elif missing_evidence:
        status = "needs-evidence"
        required_action = "Run the refresh commands and capture the missing evidence before claiming this domain is ready."
    else:
        status = "ready"
        required_action = "Review the linked evidence and keep it referenced from Task 66 closeout."
    return {
        "id": domain["id"],
        "title": domain["title"],
        "purpose": domain["purpose"],
        "status": status,
        "source_tasks": list(domain.get("source_tasks", ())),
        "required_paths": required_paths,
        "evidence_paths": evidence_paths,
        "missing_required_paths": missing_required,
        "missing_evidence_paths": missing_evidence,
        "refresh_commands": list(domain.get("refresh_commands", ())),
        "required_action": required_action,
    }


def _summarise_deprecation_domains(domains: Sequence[Dict[str, Any]]) -> Dict[str, Any]:
    status_counts = Counter(str(domain.get("status")) for domain in domains)
    missing_required = sum(len(domain.get("missing_required_paths", [])) for domain in domains)
    missing_evidence = sum(len(domain.get("missing_evidence_paths", [])) for domain in domains)
    if missing_required:
        aggregate_status = "needs-implementation"
    elif missing_evidence:
        aggregate_status = "needs-evidence"
    else:
        aggregate_status = "ready"
    return {
        "aggregate_status": aggregate_status,
        "domains": len(domains),
        "ready": status_counts.get("ready", 0),
        "needs_evidence": status_counts.get("needs-evidence", 0),
        "needs_implementation": status_counts.get("needs-implementation", 0),
        "missing_required_paths": missing_required,
        "missing_evidence_paths": missing_evidence,
    }


def _lifecycle_audit_to_dict(audit: Any) -> Dict[str, Any]:
    return {
        "path": str(getattr(audit, "path", "")),
        "status": getattr(audit, "status", None),
        "canonical_status": getattr(audit, "canonical_status", None),
        "ok": bool(getattr(audit, "ok", False)),
        "issues": [
            {
                "severity": str(getattr(issue, "severity", "")),
                "code": str(getattr(issue, "code", "")),
                "message": str(getattr(issue, "message", "")),
            }
            for issue in getattr(audit, "issues", ())
        ],
    }


def _summarise_deprecation_audit_records(records: Sequence[Mapping[str, Any]]) -> Dict[str, Any]:
    status_counts: Counter[str] = Counter()
    severity_counts: Counter[str] = Counter()
    code_counts: Counter[str] = Counter()
    deprecated_records: list[Mapping[str, Any]] = []
    issue_records: list[Mapping[str, Any]] = []
    for record in records:
        canonical = str(record.get("canonical_status") or record.get("status") or "unknown")
        status_counts[canonical] += 1
        if canonical == "deprecated":
            deprecated_records.append(record)
        issues = record.get("issues", [])
        if issues:
            issue_records.append(record)
        for issue in issues if isinstance(issues, Sequence) and not isinstance(issues, (str, bytes)) else []:
            if not isinstance(issue, Mapping):
                continue
            severity_counts[str(issue.get("severity") or "unknown")] += 1
            code_counts[str(issue.get("code") or "unknown")] += 1
    return {
        "records": len(records),
        "ok_records": sum(1 for record in records if record.get("ok")),
        "issue_records": len(issue_records),
        "deprecated_records": len(deprecated_records),
        "status_counts": dict(sorted(status_counts.items())),
        "severity_counts": dict(sorted(severity_counts.items())),
        "issue_code_counts": dict(sorted(code_counts.items())),
        "grace_expired": code_counts.get("deprecation_grace_expired", 0),
        "archive_recommended": code_counts.get("archive_recommended", 0),
        "missing_migration_guidance": code_counts.get("missing_migration_notice", 0),
        "error_count": severity_counts.get("error", 0),
        "warning_count": severity_counts.get("warning", 0),
        "recommendation_count": severity_counts.get("recommendation", 0),
    }


def _build_deprecation_lifecycle_snapshot(today: date) -> Dict[str, Any]:
    try:
        from template_lifecycle import audit_registry, load_lifecycle_policy

        policy = load_lifecycle_policy(REPO_ROOT)
        audits = [_lifecycle_audit_to_dict(audit) for audit in audit_registry(REPO_ROOT, today=today)]
        metrics = _summarise_deprecation_audit_records(audits)
        issue_records = [record for record in audits if record.get("issues")]
        deprecated_records = [record for record in audits if record.get("canonical_status") == "deprecated"]
        return {
            "available": True,
            "today": today.isoformat(),
            "policy": {
                "version": policy.version,
                "states": list(policy.states),
                "compatibility_statuses": dict(policy.compatibility_statuses),
                "ignored_statuses": list(policy.ignored_statuses),
                "grace_days": policy.grace_days,
                "archive_after_days": policy.archive_after_days,
                "deprecated_since_key": policy.deprecated_since_key,
                "replacement_key": policy.replacement_key,
                "migration_notice_key": policy.migration_notice_key,
            },
            "metrics": metrics,
            "issue_records": issue_records[:25],
            "deprecated_records": deprecated_records[:25],
        }
    except Exception as exc:  # pragma: no cover - exercised by callers as a degraded snapshot
        return {
            "available": False,
            "today": today.isoformat(),
            "error": str(exc),
            "metrics": _summarise_deprecation_audit_records(()),
            "issue_records": [],
            "deprecated_records": [],
        }


def _parse_review_date(value: Optional[str], fallback: datetime) -> date:
    if value:
        return date.fromisoformat(value)
    return fallback.date()


def _build_deprecation_management_review(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    today = _parse_review_date(getattr(args, "today", None), now)
    label = args.label or "deprecation-management"
    domains = [_deprecation_domain_review(dict(domain)) for domain in DEPRECATION_MANAGEMENT_DOMAINS]
    domain_summary = _summarise_deprecation_domains(domains)
    lifecycle = _build_deprecation_lifecycle_snapshot(today)
    aggregate_status = domain_summary["aggregate_status"]
    if not lifecycle.get("available"):
        aggregate_status = "needs-implementation"
    elif lifecycle.get("metrics", {}).get("error_count"):
        aggregate_status = "needs-evidence"
    summary = {
        **domain_summary,
        "aggregate_status": aggregate_status,
        "lifecycle_audit_available": bool(lifecycle.get("available")),
        "lifecycle_records": lifecycle.get("metrics", {}).get("records", 0),
        "lifecycle_issue_records": lifecycle.get("metrics", {}).get("issue_records", 0),
        "deprecated_records": lifecycle.get("metrics", {}).get("deprecated_records", 0),
        "grace_expired": lifecycle.get("metrics", {}).get("grace_expired", 0),
        "archive_recommended": lifecycle.get("metrics", {}).get("archive_recommended", 0),
        "missing_migration_guidance": lifecycle.get("metrics", {}).get("missing_migration_guidance", 0),
    }
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-deprecation-management-review",
        "executes_actions": False,
        "review_date": today.isoformat(),
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "lifecycle_audit": lifecycle,
        "domains": domains,
        "action_guidance": list(DEPRECATION_MANAGEMENT_ACTIONS),
        "non_goals": list(DEPRECATION_MANAGEMENT_NON_GOALS),
    }


def _render_deprecation_management_review(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), dict) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), dict) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), dict) else {}
    lifecycle = report.get("lifecycle_audit", {}) if isinstance(report.get("lifecycle_audit"), dict) else {}
    lifecycle_metrics = lifecycle.get("metrics", {}) if isinstance(lifecycle.get("metrics"), dict) else {}
    lines = [
        "# Deprecation Management Review",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Review date: {report.get('review_date')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), dict) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), dict) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Lifecycle Audit Metrics",
        "",
        f"- Audit available: {lifecycle.get('available')}",
        f"- Records: {lifecycle_metrics.get('records')}",
        f"- Issue records: {lifecycle_metrics.get('issue_records')}",
        f"- Deprecated records: {lifecycle_metrics.get('deprecated_records')}",
        f"- Grace expired: {lifecycle_metrics.get('grace_expired')}",
        f"- Archive recommended: {lifecycle_metrics.get('archive_recommended')}",
        f"- Missing migration guidance: {lifecycle_metrics.get('missing_migration_guidance')}",
        "",
        "Status counts:",
    ]
    for status, count in (lifecycle_metrics.get("status_counts") or {}).items():
        lines.append(f"- `{status}`: {count}")

    lines.extend(
        [
            "",
            "## Domain Summary",
            "",
            "| Domain | Status | Missing Required | Missing Evidence |",
            "| --- | --- | --- | --- |",
        ]
    )
    for domain in report.get("domains", []):
        if not isinstance(domain, dict):
            continue
        missing_required = "<br>".join(domain.get("missing_required_paths", []))
        missing_evidence = "<br>".join(domain.get("missing_evidence_paths", []))
        lines.append(
            f"| {_md_cell(domain.get('title'))} | `{_md_cell(domain.get('status'))}` | "
            f"{_md_cell(missing_required or 'None')} | {_md_cell(missing_evidence or 'None')} |"
        )

    lines.extend(["", "## Domain Details", ""])
    for domain in report.get("domains", []):
        if not isinstance(domain, dict):
            continue
        lines.extend(
            [
                f"### {domain.get('title')}",
                "",
                f"- ID: `{domain.get('id')}`",
                f"- Status: `{domain.get('status')}`",
                f"- Source tasks: {', '.join(str(task) for task in domain.get('source_tasks', []))}",
                f"- Purpose: {domain.get('purpose')}",
                f"- Required action: {domain.get('required_action')}",
                "",
                "Refresh commands:",
            ]
        )
        for command in domain.get("refresh_commands", []):
            lines.append(f"- `{command}`")
        lines.extend(["", "Evidence paths:"])
        for item in domain.get("evidence_paths", []):
            if isinstance(item, dict):
                lines.append(f"- `{item.get('path')}` ({item.get('kind')})")
        lines.append("")

    lines.extend(["## Deprecation Action Guidance", ""])
    for item in report.get("action_guidance", []):
        if not isinstance(item, dict):
            continue
        lines.append(f"- **{item.get('action')}**: {item.get('evidence')}")

    issue_records = lifecycle.get("issue_records", []) if isinstance(lifecycle, dict) else []
    if issue_records:
        lines.extend(["", "## Current Lifecycle Issues", ""])
        for record in issue_records:
            if not isinstance(record, dict):
                continue
            lines.append(f"### `{record.get('path')}`")
            for issue in record.get("issues", []):
                if isinstance(issue, dict):
                    lines.append(f"- `{issue.get('severity')}` `{issue.get('code')}`: {issue.get('message')}")
            lines.append("")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static deprecation-management review artifact. It composes existing lifecycle, versioning, communication, operations, emergency, recovery, and validation evidence, but it does not instrument runtime logs, move files, send notifications, install schedulers, update dashboards, automate overrides, or contact external systems.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_deprecation_review(args: argparse.Namespace) -> None:
    report = _build_deprecation_management_review(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_deprecation_management_review(report)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote deprecation review to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote deprecation runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


TEMPLATE_USAGE_ANALYTICS_NON_GOALS: Tuple[str, ...] = (
    "No runtime decorators, counters, instrumentation hooks, or tracking code are added to templates.",
    "No database, warehouse, event stream, time-series backend, or long-running aggregation service is created.",
    "No live dashboard, WebSocket, Grafana board, hosted analytics page, or external observability service is contacted.",
    "No alert, notification, ticket, issue, webhook, or anomaly service is sent or configured.",
    "No predictive capacity-planning model is trained or executed.",
    "No template, Taskmaster, session, plan, work-tracking, Git, or external state is mutated beyond requested report artifacts.",
)

TEMPLATE_USAGE_SOURCE_PATTERNS: Tuple[Tuple[str, str, Tuple[str, ...]], ...] = (
    ("sessions", "sessions_root", ("*.md",)),
    ("plans", "plans_root", ("*.md",)),
    ("work_tracking_active", "work_tracking_active_root", ("*.md",)),
    ("taskmaster", "taskmaster_tasks_dir", ("task_*.txt", "task-*.md")),
)


def _template_usage_source_date(relative_path: str) -> Optional[str]:
    session_match = re.search(r"sessions/\d{4}/\d{2}/(\d{4}-\d{2}-\d{2})", relative_path)
    if session_match:
        return session_match.group(1)
    plan_match = re.search(r"plans/(\d{4}-\d{2}-\d{2})-", relative_path)
    if plan_match:
        return plan_match.group(1)
    work_tracking_match = re.search(r"work-tracking/(?:active|archive)/(\d{4})(\d{2})(\d{2})-", relative_path)
    if work_tracking_match:
        return "-".join(work_tracking_match.groups())
    return None


def _iter_template_usage_source_files(
    source_dir: Path,
    structure: RepoStructure,
    *,
    include_archive: bool,
) -> List[Tuple[str, Path]]:
    sources: List[Tuple[str, Path]] = []
    seen: set[Path] = set()

    def add_files(source_type: str, root: Path, patterns: Sequence[str]) -> None:
        if not root.exists():
            return
        for pattern in patterns:
            for path in sorted(root.rglob(pattern)):
                if path in seen or path.is_symlink() or not path.is_file():
                    continue
                seen.add(path)
                sources.append((source_type, path))

    for source_type, attr, patterns in TEMPLATE_USAGE_SOURCE_PATTERNS:
        add_files(source_type, getattr(structure, attr), patterns)
    if include_archive:
        add_files("work_tracking_archive", structure.work_tracking_archive_root, ("*.md",))
    return sorted(sources, key=lambda item: (_relative_to_root(item[1], source_dir), item[0]))


def _read_usage_source(path: Path) -> Optional[str]:
    try:
        return path.read_text(encoding="utf-8")
    except (OSError, UnicodeDecodeError):
        return None


def _template_usage_tokens(record: TemplateRecord) -> Dict[str, Tuple[str, ...]]:
    aliases = tuple(alias for alias in record.aliases if alias and alias != record.id)
    return {
        "id": (record.id,),
        "path": (record.path,),
        "alias": aliases,
    }


def _count_standalone_usage_token(text: str, token: str) -> int:
    if not token:
        return 0
    pattern = rf"(?<![A-Za-z0-9_./-]){re.escape(token)}(?![A-Za-z0-9_./-])"
    return len(re.findall(pattern, text))


def _empty_template_usage_record(record: TemplateRecord) -> Dict[str, Any]:
    return {
        "id": record.id,
        "path": record.path,
        "title": record.title,
        "type": record.type,
        "category": record.category,
        "status": record.status,
        "source": record.source,
        "aliases": list(record.aliases),
        "good_first_handler": record.good_first_handler,
        "good_first_workflow": record.good_first_workflow,
        "total_mentions": 0,
        "id_mentions": 0,
        "path_mentions": 0,
        "alias_mentions": 0,
        "source_counts": {},
        "first_seen": None,
        "latest_seen": None,
        "examples": [],
    }


def _count_template_usage_mentions(
    text: str,
    record: TemplateRecord,
) -> Tuple[int, int, int]:
    tokens = _template_usage_tokens(record)
    id_mentions = sum(text.count(token) for token in tokens["id"])
    path_mentions = sum(text.count(token) for token in tokens["path"])
    alias_mentions = sum(_count_standalone_usage_token(text, token) for token in tokens["alias"])
    return id_mentions, path_mentions, alias_mentions


def _template_usage_example(
    *,
    relative_path: str,
    source_type: str,
    source_date: Optional[str],
    id_mentions: int,
    path_mentions: int,
    alias_mentions: int,
) -> Dict[str, Any]:
    return {
        "path": relative_path,
        "source_type": source_type,
        "date": source_date,
        "id_mentions": id_mentions,
        "path_mentions": path_mentions,
        "alias_mentions": alias_mentions,
    }


def _build_template_usage_analytics(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    source_dir = _resolve_repo_directory(args.source_dir, "Source repository")
    structure = load_repo_structure(source_dir)
    registry = TemplateRegistry(repo_root=source_dir)
    records = sorted(registry.records(), key=lambda item: item.id)
    usage_records: Dict[str, Dict[str, Any]] = {
        record.id: _empty_template_usage_record(record)
        for record in records
    }
    source_counts: Dict[str, Dict[str, int]] = {}
    category_counts: Counter[str] = Counter()
    monthly_counts: Counter[str] = Counter()
    source_files = _iter_template_usage_source_files(source_dir, structure, include_archive=args.include_archive)
    files_with_matches: set[str] = set()
    unreadable_files: List[str] = []
    total_mentions = 0
    id_mentions_total = 0
    path_mentions_total = 0
    alias_mentions_total = 0

    for source_type, path in source_files:
        relative_path = _relative_to_root(path, source_dir)
        source_counts.setdefault(source_type, {"files_scanned": 0, "files_with_matches": 0, "mentions": 0})
        source_counts[source_type]["files_scanned"] += 1
        text = _read_usage_source(path)
        if text is None:
            unreadable_files.append(relative_path)
            continue
        source_date = _template_usage_source_date(relative_path)
        file_mentions = 0
        for record in records:
            id_mentions, path_mentions, alias_mentions = _count_template_usage_mentions(text, record)
            mentions = id_mentions + path_mentions + alias_mentions
            if mentions <= 0:
                continue
            stats = usage_records[record.id]
            stats["total_mentions"] += mentions
            stats["id_mentions"] += id_mentions
            stats["path_mentions"] += path_mentions
            stats["alias_mentions"] += alias_mentions
            stats["source_counts"][source_type] = stats["source_counts"].get(source_type, 0) + mentions
            if source_date:
                dates = [value for value in (stats["first_seen"], stats["latest_seen"]) if isinstance(value, str)]
                dates.append(source_date)
                stats["first_seen"] = min(dates)
                stats["latest_seen"] = max(dates)
                monthly_counts[source_date[:7]] += mentions
            if len(stats["examples"]) < args.max_examples:
                stats["examples"].append(
                    _template_usage_example(
                        relative_path=relative_path,
                        source_type=source_type,
                        source_date=source_date,
                        id_mentions=id_mentions,
                        path_mentions=path_mentions,
                        alias_mentions=alias_mentions,
                    )
                )
            category_counts[str(record.category or "uncategorized")] += mentions
            file_mentions += mentions
            total_mentions += mentions
            id_mentions_total += id_mentions
            path_mentions_total += path_mentions
            alias_mentions_total += alias_mentions
        if file_mentions:
            files_with_matches.add(relative_path)
            source_counts[source_type]["files_with_matches"] += 1
            source_counts[source_type]["mentions"] += file_mentions

    usage_list = sorted(
        usage_records.values(),
        key=lambda item: (-int(item["total_mentions"]), str(item["id"])),
    )
    observed = [item for item in usage_list if int(item["total_mentions"]) > 0]
    zero_observed = [item for item in usage_list if int(item["total_mentions"]) == 0]
    path_only = [
        item for item in observed
        if int(item["path_mentions"]) > 0 and int(item["id_mentions"]) == 0 and int(item["alias_mentions"]) == 0
    ]
    alias_observed = [item for item in observed if int(item["alias_mentions"]) > 0]

    top_templates = [
        {
            "id": item["id"],
            "path": item["path"],
            "category": item["category"],
            "total_mentions": item["total_mentions"],
            "id_mentions": item["id_mentions"],
            "path_mentions": item["path_mentions"],
            "alias_mentions": item["alias_mentions"],
        }
        for item in observed[: args.max_items]
    ]
    zero_summary = [
        {
            "id": item["id"],
            "path": item["path"],
            "category": item["category"],
            "status": item["status"],
        }
        for item in zero_observed[: args.max_items]
    ]
    path_only_summary = [
        {
            "id": item["id"],
            "path": item["path"],
            "category": item["category"],
            "path_mentions": item["path_mentions"],
            "examples": item["examples"][: args.max_examples],
        }
        for item in path_only[: args.max_items]
    ]
    alias_summary = [
        {
            "id": item["id"],
            "path": item["path"],
            "category": item["category"],
            "alias_mentions": item["alias_mentions"],
            "examples": item["examples"][: args.max_examples],
        }
        for item in alias_observed[: args.max_items]
    ]

    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label,
        "mode": "non-destructive-template-usage-analytics",
        "executes_mutations": False,
        "source": {
            "path": _relative_to_root(source_dir, REPO_ROOT),
            "include_archive": args.include_archive,
            "source_types": sorted(source_counts),
            "workflow_sources": (
                ["sessions", "plans", "work_tracking_active", "taskmaster"]
                + (["work_tracking_archive"] if args.include_archive else [])
            ),
        },
        "registry": {
            "template_count": len(records),
        },
        "source_summary": {
            "files_scanned": len(source_files),
            "files_with_matches": len(files_with_matches),
            "unreadable_files": unreadable_files,
            "by_type": source_counts,
        },
        "usage_summary": {
            "total_mentions": total_mentions,
            "id_mentions": id_mentions_total,
            "path_mentions": path_mentions_total,
            "alias_mentions": alias_mentions_total,
            "templates_with_observed_usage": len(observed),
            "templates_without_observed_usage": len(zero_observed),
            "category_mentions": dict(sorted(category_counts.items())),
            "monthly_mentions": dict(sorted(monthly_counts.items())),
            "top_templates": top_templates,
        },
        "review_queues": {
            "path_only_references": path_only_summary,
            "alias_references": alias_summary,
            "zero_observed_references": zero_summary,
        },
        "template_usage": usage_list,
        "recommended_actions": [
            "Review path-only references and prefer registry IDs where workflow portability matters.",
            "Use zero-observed-reference templates as candidates for documentation, lifecycle, or deprecation review.",
            "Review the highest-mentioned templates before changing shared workflow behavior.",
            "Rerun this report after major template registry, Taskmaster, session, or work-tracking migrations.",
        ],
        "display_limits": {
            "max_items": args.max_items,
            "max_examples": args.max_examples,
        },
        "non_goals": list(TEMPLATE_USAGE_ANALYTICS_NON_GOALS),
    }


def _render_template_usage_analytics(report: Dict[str, Any]) -> str:
    source_summary = report.get("source_summary", {}) if isinstance(report.get("source_summary"), dict) else {}
    usage_summary = report.get("usage_summary", {}) if isinstance(report.get("usage_summary"), dict) else {}
    review_queues = report.get("review_queues", {}) if isinstance(report.get("review_queues"), dict) else {}
    registry = report.get("registry", {}) if isinstance(report.get("registry"), dict) else {}
    source = report.get("source", {}) if isinstance(report.get("source"), dict) else {}
    lines = [
        "# Template Usage Analytics",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes mutations: {report.get('executes_mutations')}",
        f"- Source: `{source.get('path')}`",
        f"- Include archive: {source.get('include_archive')}",
        "",
        "## Summary",
        "",
        f"- Registered templates: {registry.get('template_count')}",
        f"- Workflow files scanned: {source_summary.get('files_scanned')}",
        f"- Workflow files with template references: {source_summary.get('files_with_matches')}",
        f"- Total mentions: {usage_summary.get('total_mentions')}",
        f"- ID mentions: {usage_summary.get('id_mentions')}",
        f"- Path mentions: {usage_summary.get('path_mentions')}",
        f"- Alias mentions: {usage_summary.get('alias_mentions')}",
        f"- Templates with observed usage: {usage_summary.get('templates_with_observed_usage')}",
        f"- Templates without observed usage: {usage_summary.get('templates_without_observed_usage')}",
        "",
        "## Source Coverage",
        "",
        "| Source type | Files scanned | Files with matches | Mentions |",
        "| --- | ---: | ---: | ---: |",
    ]
    by_type = source_summary.get("by_type") if isinstance(source_summary.get("by_type"), dict) else {}
    for source_type, stats in sorted(by_type.items()):
        if not isinstance(stats, dict):
            continue
        lines.append(
            f"| {_md_cell(source_type)} | {stats.get('files_scanned', 0)} | {stats.get('files_with_matches', 0)} | {stats.get('mentions', 0)} |"
        )

    lines.extend(["", "## Top Templates", "", "| Template | Category | Mentions | ID | Path | Alias |", "| --- | --- | ---: | ---: | ---: | ---: |"])
    for item in usage_summary.get("top_templates", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| `{_md_cell(item.get('id'))}` | {_md_cell(item.get('category'))} | {item.get('total_mentions', 0)} | "
            f"{item.get('id_mentions', 0)} | {item.get('path_mentions', 0)} | {item.get('alias_mentions', 0)} |"
        )
    if not usage_summary.get("top_templates"):
        lines.append("| _None_ |  | 0 | 0 | 0 | 0 |")

    lines.extend(["", "## Category Mentions", ""])
    category_mentions = usage_summary.get("category_mentions") if isinstance(usage_summary.get("category_mentions"), dict) else {}
    if category_mentions:
        for category, count in sorted(category_mentions.items(), key=lambda item: (-int(item[1]), item[0])):
            lines.append(f"- {category}: {count}")
    else:
        lines.append("- No category mentions observed.")

    lines.extend(["", "## Monthly Trend", ""])
    monthly_mentions = usage_summary.get("monthly_mentions") if isinstance(usage_summary.get("monthly_mentions"), dict) else {}
    if monthly_mentions:
        for month, count in sorted(monthly_mentions.items()):
            lines.append(f"- {month}: {count}")
    else:
        lines.append("- No dated workflow references observed.")

    lines.extend(["", "## Review Queues", "", "### Path-Only References", ""])
    path_only = review_queues.get("path_only_references") if isinstance(review_queues.get("path_only_references"), list) else []
    if path_only:
        for item in path_only:
            if isinstance(item, dict):
                lines.append(f"- `{item.get('id')}`: {item.get('path_mentions')} path mentions; prefer registry ID when practical.")
    else:
        lines.append("- No path-only reference candidates in the displayed set.")

    lines.extend(["", "### Alias References", ""])
    alias_references = review_queues.get("alias_references") if isinstance(review_queues.get("alias_references"), list) else []
    if alias_references:
        for item in alias_references:
            if isinstance(item, dict):
                lines.append(f"- `{item.get('id')}`: {item.get('alias_mentions')} alias mentions.")
    else:
        lines.append("- No alias reference candidates in the displayed set.")

    lines.extend(["", "### Zero Observed References", ""])
    zero_observed = review_queues.get("zero_observed_references") if isinstance(review_queues.get("zero_observed_references"), list) else []
    if zero_observed:
        for item in zero_observed:
            if isinstance(item, dict):
                lines.append(f"- `{item.get('id')}` ({item.get('category') or 'uncategorized'}, {item.get('status') or 'status unknown'})")
    else:
        lines.append("- No zero-observed-reference candidates in the displayed set.")

    lines.extend(["", "## Recommended Actions", ""])
    for action in report.get("recommended_actions", []):
        lines.append(f"- {action}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "No runtime tracker, database, live dashboard, alert, predictive service, template mutation, or external analytics action was executed by this report.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_template_usage_analytics(args: argparse.Namespace) -> None:
    report = _build_template_usage_analytics(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_template_usage_analytics(report)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote template usage analytics report to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote template usage analytics runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


TEMPLATE_QUALITY_NON_GOALS: Tuple[str, ...] = (
    "No live dashboard, hosted UI, WebSocket, database, trend backend, scheduler, daemon, or external analytics service is created.",
    "No CI quality gate, pre-commit hook, policy enforcement, notification, ticket, webhook, or stakeholder message is installed or sent.",
    "No template, registry, metadata, Taskmaster, session, plan, work-tracking, Git, scanner, report, or external state is mutated beyond requested quality scorecard artifacts.",
    "No performance benchmark, scanner refresh, security audit, usage analytics scan, or drift check is executed by this scorecard command.",
    "No predictive quality model, machine-learning service, automatic remediation, or template rewrite suggestion engine is trained or executed.",
)

TEMPLATE_QUALITY_DOMAIN_WEIGHTS: Tuple[Dict[str, Any], ...] = (
    {"id": "metadata-and-drift", "weight": 20},
    {"id": "registry-health", "weight": 15},
    {"id": "scanner-complexity", "weight": 15},
    {"id": "template-performance", "weight": 15},
    {"id": "usage-analytics", "weight": 10},
    {"id": "security-audit", "weight": 10},
    {"id": "workflow-continuity", "weight": 15},
)

TEMPLATE_QUALITY_REFRESH_COMMANDS: Tuple[str, ...] = (
    "python3 scripts/codex-task report generate --kind metrics",
    "python3 scripts/codex-guard drift-check",
    "python3 scripts/template-performance-harness --strict",
    "python3 scripts/codex-task template usage-analytics --include-archive --report-file reports/template-usage-analytics/latest.json --runbook-file reports/template-usage-analytics/latest.md",
    "python3 scripts/codex-task security audit --report-file reports/security-audit-process/latest.json --runbook-file reports/security-audit-process/latest.md",
    "python3 scripts/template-ssot-scanner/scanner.py --base . --out scripts/template-ssot-scanner/output/data/template_scan_results.json --no-checkpoints --profile ci",
    "python3 scripts/codex-task work-tracking audit",
    "python3 scripts/codex-guard validate --include-untracked",
)


def _template_quality_bound_score(value: object) -> float:
    try:
        numeric = float(value)
    except (TypeError, ValueError):
        numeric = 0.0
    return round(max(0.0, min(100.0, numeric)), 2)


def _template_quality_grade(score: float) -> str:
    if score >= 97:
        return "A+"
    if score >= 93:
        return "A"
    if score >= 90:
        return "A-"
    if score >= 87:
        return "B+"
    if score >= 83:
        return "B"
    if score >= 80:
        return "B-"
    if score >= 70:
        return "C"
    if score >= 60:
        return "D"
    return "F"


def _template_quality_status(score: float, *, missing: bool = False, invalid: bool = False) -> str:
    if missing:
        return "missing"
    if invalid or score < 60:
        return "fail"
    if score < 90:
        return "warn"
    return "pass"


def _template_quality_severity(status: str) -> str:
    if status == "fail":
        return "error"
    if status in {"warn", "missing"}:
        return "warning"
    return "info"


def _template_quality_domain(
    *,
    domain_id: str,
    title: str,
    weight: int,
    score: object,
    target: str,
    evidence: str,
    message: str,
    refresh_command: str,
    details: Optional[Mapping[str, Any]] = None,
    missing: bool = False,
    invalid: bool = False,
    suggestions: Optional[Sequence[str]] = None,
) -> Dict[str, Any]:
    bounded = _template_quality_bound_score(score)
    status = _template_quality_status(bounded, missing=missing, invalid=invalid)
    return {
        "id": domain_id,
        "title": title,
        "weight": weight,
        "score": bounded,
        "grade": _template_quality_grade(bounded),
        "status": status,
        "severity": _template_quality_severity(status),
        "target": target,
        "evidence": evidence,
        "message": message,
        "refresh_command": refresh_command,
        "details": dict(details or {}),
        "improvement_suggestions": list(suggestions or []),
    }


def _template_quality_missing_domain(
    *,
    domain_id: str,
    title: str,
    weight: int,
    evidence: str,
    refresh_command: str,
) -> Dict[str, Any]:
    return _template_quality_domain(
        domain_id=domain_id,
        title=title,
        weight=weight,
        score=50,
        target="source evidence present",
        evidence=evidence,
        message=f"{title} source evidence is missing.",
        refresh_command=refresh_command,
        missing=True,
        suggestions=[f"Run `{refresh_command}` and regenerate the quality scorecard."],
    )


def _template_quality_invalid_domain(
    *,
    domain_id: str,
    title: str,
    weight: int,
    evidence: str,
    message: str,
    refresh_command: str,
) -> Dict[str, Any]:
    return _template_quality_domain(
        domain_id=domain_id,
        title=title,
        weight=weight,
        score=0,
        target="valid source JSON",
        evidence=evidence,
        message=message,
        refresh_command=refresh_command,
        invalid=True,
        suggestions=[f"Regenerate valid source evidence with `{refresh_command}`."],
    )


def _template_quality_weight(domain_id: str) -> int:
    for entry in TEMPLATE_QUALITY_DOMAIN_WEIGHTS:
        if entry["id"] == domain_id:
            return int(entry["weight"])
    return 1


def _build_template_quality_metadata_domain() -> Dict[str, Any]:
    path = REPO_STRUCTURE.metrics_report_dir / "latest.json"
    source = _success_metrics_load_json(path)
    if source["status"] == "missing":
        return _template_quality_missing_domain(
            domain_id="metadata-and-drift",
            title="Metadata and drift",
            weight=_template_quality_weight("metadata-and-drift"),
            evidence=str(source["path"]),
            refresh_command="python3 scripts/codex-task report generate --kind metrics",
        )
    if source["status"] == "invalid":
        return _template_quality_invalid_domain(
            domain_id="metadata-and-drift",
            title="Metadata and drift",
            weight=_template_quality_weight("metadata-and-drift"),
            evidence=str(source["path"]),
            message=str(source["message"]),
            refresh_command="python3 scripts/codex-task report generate --kind metrics",
        )
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    metadata = payload.get("template_metadata") if isinstance(payload.get("template_metadata"), Mapping) else {}
    drift = payload.get("drift") if isinstance(payload.get("drift"), Mapping) else {}
    coverage = _template_quality_bound_score(metadata.get("coverage_pct"))
    drifted = int(metadata.get("drifted_file_count", 0) or 0)
    findings = int(drift.get("finding_count", 0) or 0)
    score = _template_quality_bound_score(coverage - (drifted * 10) - (findings * 5))
    suggestions = []
    if coverage < 100:
        suggestions.append("Close template metadata coverage gaps before claiming excellent quality.")
    if drifted or findings:
        suggestions.append("Resolve drift findings and regenerate the metrics report.")
    return _template_quality_domain(
        domain_id="metadata-and-drift",
        title="Metadata and drift",
        weight=_template_quality_weight("metadata-and-drift"),
        score=score,
        target="100% metadata coverage and 0 drift findings",
        evidence=str(source["path"]),
        message=f"Metadata coverage is {coverage}% with {drifted} drifted file(s) and {findings} drift finding(s).",
        refresh_command="python3 scripts/codex-task report generate --kind metrics",
        details={"template_metadata": metadata, "drift": drift},
        suggestions=suggestions,
    )


def _build_template_quality_registry_domain() -> Dict[str, Any]:
    try:
        registry = TemplateRegistry(repo_root=REPO_ROOT)
        records = tuple(registry.records())
    except Exception as exc:  # pragma: no cover - defensive reporting for operator-facing packet
        return _template_quality_domain(
            domain_id="registry-health",
            title="Registry health",
            weight=_template_quality_weight("registry-health"),
            score=0,
            target="registry loads and exposes template records",
            evidence="scripts/template_registry.py",
            message=f"Template registry failed to load: {exc}",
            refresh_command="python3 - <<'PY'\nfrom scripts.template_registry import TemplateRegistry\nprint(len(TemplateRegistry().records()))\nPY",
            invalid=True,
            suggestions=["Fix template registry loading before using quality scores."],
        )
    duplicate_ids = len(records) - len({record.id for record in records})
    missing_required = [
        record.path
        for record in records
        if not record.id or not record.path
    ]
    score = 100
    if not records:
        score = 0
    score -= duplicate_ids * 3
    score -= len(missing_required) * 10
    suggestions = []
    if duplicate_ids:
        suggestions.append("Resolve duplicate template registry IDs.")
    if missing_required:
        suggestions.append("Ensure every registry record has an ID and path.")
    if not records:
        suggestions.append("Restore template registry records before scoring quality.")
    return _template_quality_domain(
        domain_id="registry-health",
        title="Registry health",
        weight=_template_quality_weight("registry-health"),
        score=score,
        target="registry loads with unique IDs and non-empty paths",
        evidence="scripts/template_registry.py",
        message=f"Registry loaded {len(records)} template record(s) with {duplicate_ids} duplicate ID(s).",
        refresh_command="python3 - <<'PY'\nfrom scripts.template_registry import TemplateRegistry\nprint(len(TemplateRegistry().records()))\nPY",
        details={
            "template_count": len(records),
            "duplicate_ids": duplicate_ids,
            "missing_required_count": len(missing_required),
        },
        suggestions=suggestions,
    )


def _build_template_quality_scanner_domain() -> Dict[str, Any]:
    path = "scripts/template-ssot-scanner/output/data/template_scan_results.json"
    source = _success_metrics_load_json(path)
    if source["status"] == "missing":
        return _template_quality_missing_domain(
            domain_id="scanner-complexity",
            title="Scanner complexity",
            weight=_template_quality_weight("scanner-complexity"),
            evidence=str(source["path"]),
            refresh_command="python3 scripts/template-ssot-scanner/scanner.py --base . --out scripts/template-ssot-scanner/output/data/template_scan_results.json --no-checkpoints --profile ci",
        )
    if source["status"] == "invalid":
        return _template_quality_invalid_domain(
            domain_id="scanner-complexity",
            title="Scanner complexity",
            weight=_template_quality_weight("scanner-complexity"),
            evidence=str(source["path"]),
            message=str(source["message"]),
            refresh_command="python3 scripts/template-ssot-scanner/scanner.py --base . --out scripts/template-ssot-scanner/output/data/template_scan_results.json --no-checkpoints --profile ci",
        )
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    metadata = payload.get("metadata") if isinstance(payload.get("metadata"), Mapping) else {}
    stats = metadata.get("stats") if isinstance(metadata.get("stats"), Mapping) else {}
    data = payload.get("data") if isinstance(payload.get("data"), Mapping) else {}
    errors = data.get("errors") if isinstance(data.get("errors"), list) else []
    issues = int(stats.get("issues_detected", 0) or 0)
    files = int(stats.get("files_scanned", 0) or data.get("scan_metadata", {}).get("total_files", 0) or 0)
    total_lines = int(stats.get("total_lines", 0) or data.get("scan_metadata", {}).get("total_lines", 0) or 0)
    avg_lines = round(total_lines / files, 2) if files else 0.0
    score = 100 - (len(errors) * 25) - (issues * 5)
    if avg_lines > 250:
        score -= 5
    suggestions = []
    if errors:
        suggestions.append("Resolve scanner errors before using scanner complexity as quality evidence.")
    if issues:
        suggestions.append("Review scanner issues and regenerate scan output.")
    if avg_lines > 250:
        suggestions.append("Review high average template size for maintainability risk.")
    return _template_quality_domain(
        domain_id="scanner-complexity",
        title="Scanner complexity",
        weight=_template_quality_weight("scanner-complexity"),
        score=score,
        target="0 scanner errors, 0 scanner issues, average file size under review threshold",
        evidence=str(source["path"]),
        message=f"Scanner reports {files} file(s), {total_lines} line(s), {issues} issue(s), and {len(errors)} error(s).",
        refresh_command="python3 scripts/template-ssot-scanner/scanner.py --base . --out scripts/template-ssot-scanner/output/data/template_scan_results.json --no-checkpoints --profile ci",
        details={"files_scanned": files, "total_lines": total_lines, "average_lines_per_file": avg_lines, "issues_detected": issues, "errors": len(errors)},
        suggestions=suggestions,
    )


def _build_template_quality_performance_domain() -> Dict[str, Any]:
    path = REPO_STRUCTURE.performance_report_dir / "latest.json"
    source = _success_metrics_load_json(path)
    if source["status"] == "missing":
        return _template_quality_missing_domain(
            domain_id="template-performance",
            title="Template performance",
            weight=_template_quality_weight("template-performance"),
            evidence=str(source["path"]),
            refresh_command="python3 scripts/template-performance-harness --strict",
        )
    if source["status"] == "invalid":
        return _template_quality_invalid_domain(
            domain_id="template-performance",
            title="Template performance",
            weight=_template_quality_weight("template-performance"),
            evidence=str(source["path"]),
            message=str(source["message"]),
            refresh_command="python3 scripts/template-performance-harness --strict",
        )
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    summary = payload.get("summary") if isinstance(payload.get("summary"), Mapping) else {}
    total = int(summary.get("total", 0) or 0)
    passed = int(summary.get("passed", 0) or 0)
    warnings = int(summary.get("warnings", 0) or 0)
    errors = int(summary.get("errors", 0) or 0)
    score = (passed / total) * 100 if total else 0
    score -= warnings * 10
    score -= errors * 25
    suggestions = []
    if warnings or errors:
        suggestions.append("Review performance warnings/errors and rerun the harness.")
    if payload.get("status") != "pass":
        suggestions.append("Performance status must be `pass` before claiming full template quality.")
    return _template_quality_domain(
        domain_id="template-performance",
        title="Template performance",
        weight=_template_quality_weight("template-performance"),
        score=score,
        target="performance report status pass with all checks passing",
        evidence=str(source["path"]),
        message=f"Performance status is `{payload.get('status')}` with {passed}/{total} check(s) passing.",
        refresh_command="python3 scripts/template-performance-harness --strict",
        details={"status": payload.get("status"), "summary": summary, "policy_version": payload.get("policy_version")},
        suggestions=suggestions,
    )


def _build_template_quality_usage_domain() -> Dict[str, Any]:
    latest = _success_metrics_latest("*-task51-template-usage-analytics-COMPLETED/reports/template-usage-analytics/template-usage-analytics-*.json")
    if latest is None:
        return _template_quality_missing_domain(
            domain_id="usage-analytics",
            title="Usage analytics",
            weight=_template_quality_weight("usage-analytics"),
            evidence="*-task51-template-usage-analytics-COMPLETED/reports/template-usage-analytics/template-usage-analytics-*.json",
            refresh_command="python3 scripts/codex-task template usage-analytics --include-archive --report-file reports/template-usage-analytics/latest.json --runbook-file reports/template-usage-analytics/latest.md",
        )
    source = _success_metrics_load_json(latest)
    if source["status"] == "invalid":
        return _template_quality_invalid_domain(
            domain_id="usage-analytics",
            title="Usage analytics",
            weight=_template_quality_weight("usage-analytics"),
            evidence=str(source["path"]),
            message=str(source["message"]),
            refresh_command="python3 scripts/codex-task template usage-analytics --include-archive --report-file reports/template-usage-analytics/latest.json --runbook-file reports/template-usage-analytics/latest.md",
        )
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    usage = payload.get("usage_summary") if isinstance(payload.get("usage_summary"), Mapping) else {}
    total_mentions = int(usage.get("total_mentions", 0) or 0)
    observed = int(usage.get("templates_with_observed_usage", 0) or 0)
    zero_observed = int(usage.get("templates_without_observed_usage", 0) or 0)
    score = 100 if total_mentions > 0 else 70
    suggestions = []
    if zero_observed > observed:
        suggestions.append("Review zero-observed templates for documentation, lifecycle, or deprecation follow-up.")
    if not total_mentions:
        suggestions.append("Regenerate usage analytics with archive inclusion to improve adoption evidence.")
    return _template_quality_domain(
        domain_id="usage-analytics",
        title="Usage analytics",
        weight=_template_quality_weight("usage-analytics"),
        score=score,
        target="latest usage analytics artifact exists with observed template references",
        evidence=str(source["path"]),
        message=f"Usage analytics reports {total_mentions} mention(s) across {observed} observed template(s).",
        refresh_command="python3 scripts/codex-task template usage-analytics --include-archive --report-file reports/template-usage-analytics/latest.json --runbook-file reports/template-usage-analytics/latest.md",
        details={"usage_summary": usage},
        suggestions=suggestions,
    )


def _build_template_quality_security_domain() -> Dict[str, Any]:
    latest = _success_metrics_latest("*-task50-security-audit-process-COMPLETED/reports/security-audit-process/security-audit-*.json")
    if latest is None:
        return _template_quality_missing_domain(
            domain_id="security-audit",
            title="Security audit",
            weight=_template_quality_weight("security-audit"),
            evidence="*-task50-security-audit-process-COMPLETED/reports/security-audit-process/security-audit-*.json",
            refresh_command="python3 scripts/codex-task security audit --report-file reports/security-audit-process/latest.json --runbook-file reports/security-audit-process/latest.md",
        )
    source = _success_metrics_load_json(latest)
    if source["status"] == "invalid":
        return _template_quality_invalid_domain(
            domain_id="security-audit",
            title="Security audit",
            weight=_template_quality_weight("security-audit"),
            evidence=str(source["path"]),
            message=str(source["message"]),
            refresh_command="python3 scripts/codex-task security audit --report-file reports/security-audit-process/latest.json --runbook-file reports/security-audit-process/latest.md",
        )
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    controls = payload.get("controls") if isinstance(payload.get("controls"), list) else []
    available = sum(1 for control in controls if isinstance(control, Mapping) and control.get("status") == "available")
    total = len(controls)
    missing = [
        control.get("id")
        for control in controls
        if isinstance(control, Mapping) and control.get("status") != "available"
    ]
    score = (available / total) * 100 if total else 0
    suggestions = []
    if missing:
        suggestions.append(f"Review security controls with missing evidence: {', '.join(str(item) for item in missing)}.")
    return _template_quality_domain(
        domain_id="security-audit",
        title="Security audit",
        weight=_template_quality_weight("security-audit"),
        score=score,
        target="security audit controls available or intentionally documented",
        evidence=str(source["path"]),
        message=f"Security audit reports {available}/{total} available control(s).",
        refresh_command="python3 scripts/codex-task security audit --report-file reports/security-audit-process/latest.json --runbook-file reports/security-audit-process/latest.md",
        details={"available_controls": available, "total_controls": total, "non_available_controls": missing},
        suggestions=suggestions,
    )


def _build_template_quality_workflow_domain() -> Dict[str, Any]:
    workflow = _workflow_snapshot()
    current_session = workflow.get("current_session") if isinstance(workflow.get("current_session"), Mapping) else {}
    current_plan = workflow.get("current_plan") if isinstance(workflow.get("current_plan"), Mapping) else {}
    active = workflow.get("active_work_tracking") if isinstance(workflow.get("active_work_tracking"), list) else []
    blockers = []
    if not current_session.get("resolved"):
        blockers.append("sessions/current missing")
    if not current_plan.get("resolved"):
        blockers.append("plans/current missing")
    if len(active) != 1:
        blockers.append(f"expected 1 active work-tracking folder, found {len(active)}")
    score = 100 if not blockers else max(0, 100 - (len(blockers) * 25))
    return _template_quality_domain(
        domain_id="workflow-continuity",
        title="Workflow continuity",
        weight=_template_quality_weight("workflow-continuity"),
        score=score,
        target="one active task with current session and plan pointers",
        evidence=str(current_session.get("resolved") or current_session.get("path")),
        message="Workflow pointers are aligned." if not blockers else "; ".join(blockers),
        refresh_command="python3 scripts/codex-task work-tracking audit",
        details=workflow,
        suggestions=["Repair current session, plan, and active work-tracking pointers before relying on quality trend evidence."] if blockers else [],
    )


def _build_template_quality_domains() -> List[Dict[str, Any]]:
    return [
        _build_template_quality_metadata_domain(),
        _build_template_quality_registry_domain(),
        _build_template_quality_scanner_domain(),
        _build_template_quality_performance_domain(),
        _build_template_quality_usage_domain(),
        _build_template_quality_security_domain(),
        _build_template_quality_workflow_domain(),
    ]


def _summarise_template_quality(domains: Sequence[Mapping[str, Any]]) -> Dict[str, Any]:
    total_weight = sum(float(domain.get("weight", 0) or 0) for domain in domains)
    weighted_points = sum(float(domain.get("score", 0) or 0) * float(domain.get("weight", 0) or 0) for domain in domains)
    score = round(weighted_points / total_weight, 2) if total_weight else 0.0
    passed = sum(1 for domain in domains if domain.get("status") == "pass")
    warnings = sum(1 for domain in domains if domain.get("status") == "warn")
    missing = sum(1 for domain in domains if domain.get("status") == "missing")
    failures = sum(1 for domain in domains if domain.get("status") == "fail")
    if failures or score < 70:
        aggregate_status = "fail"
    elif missing or score < 90:
        aggregate_status = "warn"
    else:
        aggregate_status = "pass"
    return {
        "aggregate_status": aggregate_status,
        "quality_score_pct": score,
        "quality_grade": _template_quality_grade(score),
        "total_domains": len(domains),
        "passed": passed,
        "warnings": warnings,
        "missing": missing,
        "failures": failures,
        "total_weight": total_weight,
    }


def _template_quality_improvement_suggestions(domains: Sequence[Mapping[str, Any]]) -> List[Dict[str, Any]]:
    suggestions: List[Dict[str, Any]] = []
    for domain in domains:
        for item in domain.get("improvement_suggestions", []) or []:
            suggestions.append(
                {
                    "domain": domain.get("id"),
                    "severity": domain.get("severity"),
                    "suggestion": item,
                }
            )
    return suggestions


def _template_quality_gates(domains: Sequence[Mapping[str, Any]]) -> List[Dict[str, Any]]:
    return [
        {
            "gate": "metadata-coverage",
            "target": "100% metadata coverage and 0 drift findings",
            "source_domain": "metadata-and-drift",
            "status": next((domain.get("status") for domain in domains if domain.get("id") == "metadata-and-drift"), "missing"),
        },
        {
            "gate": "performance",
            "target": "template performance report status pass",
            "source_domain": "template-performance",
            "status": next((domain.get("status") for domain in domains if domain.get("id") == "template-performance"), "missing"),
        },
        {
            "gate": "scanner-complexity",
            "target": "0 scanner errors and 0 scanner issues",
            "source_domain": "scanner-complexity",
            "status": next((domain.get("status") for domain in domains if domain.get("id") == "scanner-complexity"), "missing"),
        },
        {
            "gate": "security-review",
            "target": "security audit evidence present with non-available controls reviewed",
            "source_domain": "security-audit",
            "status": next((domain.get("status") for domain in domains if domain.get("id") == "security-audit"), "missing"),
        },
        {
            "gate": "workflow-continuity",
            "target": "current session, plan, and active work-tracking state aligned",
            "source_domain": "workflow-continuity",
            "status": next((domain.get("status") for domain in domains if domain.get("id") == "workflow-continuity"), "missing"),
        },
    ]


def _build_template_quality_score(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    domains = _build_template_quality_domains()
    summary = _summarise_template_quality(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": args.label or "template-quality-score",
        "mode": "static-non-destructive-template-quality-scorecard",
        "executes_mutations": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "weights": list(TEMPLATE_QUALITY_DOMAIN_WEIGHTS),
        "domains": domains,
        "quality_gates": _template_quality_gates(domains),
        "improvement_suggestions": _template_quality_improvement_suggestions(domains),
        "recommended_refresh_commands": list(TEMPLATE_QUALITY_REFRESH_COMMANDS),
        "non_goals": list(TEMPLATE_QUALITY_NON_GOALS),
    }


def _render_template_quality_score(report: Dict[str, Any]) -> str:
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    lines = [
        "# Template Quality Scorecard",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes mutations: {report.get('executes_mutations')}",
        f"- Aggregate status: `{summary.get('aggregate_status')}`",
        f"- Quality score: {summary.get('quality_score_pct')}%",
        f"- Quality grade: {summary.get('quality_grade')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Domain Scores",
        "",
        "| Domain | Weight | Score | Grade | Status | Target | Evidence |",
        "| --- | ---: | ---: | --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        lines.append(
            f"| {_md_cell(domain.get('title'))} | {domain.get('weight')} | {domain.get('score')} | "
            f"`{_md_cell(domain.get('grade'))}` | `{_md_cell(domain.get('status'))}` | "
            f"{_md_cell(domain.get('target'))} | `{_md_cell(domain.get('evidence'))}` |"
        )

    lines.extend(["", "## Quality Gates", ""])
    for gate in report.get("quality_gates", []):
        if isinstance(gate, Mapping):
            lines.append(f"- `{gate.get('gate')}`: `{gate.get('status')}` - {gate.get('target')}")

    lines.extend(["", "## Improvement Suggestions", ""])
    suggestions = report.get("improvement_suggestions", [])
    if suggestions:
        for item in suggestions:
            if isinstance(item, Mapping):
                lines.append(f"- `{item.get('domain')}` ({item.get('severity')}): {item.get('suggestion')}")
    else:
        lines.append("- No improvement suggestions for the current scorecard inputs.")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This scorecard is static and evidence-based. It composes existing repository reports and requested output files only; it does not install dashboards, mutate templates, enforce CI gates, run benchmarks, send notifications, or contact external services.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_template_quality_score(args: argparse.Namespace) -> None:
    report = _build_template_quality_score(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_template_quality_score(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] != "pass":
            raise TaskError("Template quality scorecard aggregate status is not pass")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote template quality scorecard to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote template quality runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] != "pass":
        raise TaskError("Template quality scorecard aggregate status is not pass")


MAINTENANCE_NON_GOALS: Tuple[str, ...] = (
    "No cron job, scheduler, daemon, background worker, long-running maintenance service, or hosted monitor is installed.",
    "No Slack, email, PagerDuty, webhook, issue, PR, ticket, or notification is created or sent.",
    "No security patch, dependency update, cleanup action, rollback, remediation, formatting rewrite, or template mutation is applied.",
    "No live dashboard, time-series database, BI report, external observability service, vulnerability database, or package registry API is contacted.",
    "No Taskmaster, Git, session, plan, work-tracking, scanner, report, dependency manifest, or external state is mutated beyond requested maintenance packet artifacts.",
)

MAINTENANCE_REFRESH_COMMANDS: Tuple[str, ...] = (
    "python3 scripts/codex-task taskmaster health",
    "python3 scripts/codex-task work-tracking audit",
    "python3 scripts/codex-guard validate --include-untracked",
    "python3 scripts/codex-task operations runbook --label <label> --report-file reports/operational-runbook/<label>.json --runbook-file reports/operational-runbook/<label>.md",
    "python3 scripts/codex-task migration monitoring --metrics-report <migration-metrics.json> --migration-health-report reports/migration-health/latest.json --report-file reports/post-migration-monitoring/latest.json --runbook-file reports/post-migration-monitoring/latest.md",
    "python3 scripts/template-performance-harness --strict",
    "python3 scripts/codex-task template quality-score --report-file reports/template-quality/latest.json --runbook-file reports/template-quality/latest.md",
    "python3 scripts/codex-task cleanup plan --report-file reports/cleanup-automation/latest.json --runbook-file reports/cleanup-automation/latest.md",
    "python3 scripts/codex-task security audit --summary <summary> --report-file reports/security-audit-process/latest.json --runbook-file reports/security-audit-process/latest.md",
)

MAINTENANCE_STATUS_POINTS: Dict[str, int] = {
    "ready": 100,
    "review": 70,
    "missing": 40,
    "blocked": 0,
}


def _maintenance_path_state(path_value: Path | str) -> Dict[str, Any]:
    path = _success_metrics_path(path_value)
    if path.is_dir():
        kind = "directory"
    elif path.is_file():
        kind = "file"
    else:
        kind = "missing"
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "exists": path.exists(),
        "kind": kind,
    }


def _maintenance_source_status(payload: Mapping[str, Any]) -> str:
    candidates: List[object] = [
        payload.get("aggregate_status"),
        payload.get("status"),
        payload.get("overall_status"),
    ]
    summary = payload.get("summary")
    if isinstance(summary, Mapping):
        candidates.extend(
            [
                summary.get("aggregate_status"),
                summary.get("status"),
                summary.get("overall_status"),
            ]
        )
    for candidate in candidates:
        if candidate not in (None, ""):
            return _success_metrics_status(candidate)
    return "pass"


def _maintenance_status_from_source(status: str) -> str:
    if status in {"pass", "ready"}:
        return "ready"
    if status == "missing":
        return "missing"
    if status == "invalid":
        return "blocked"
    return "review"


def _maintenance_domain(
    *,
    domain_id: str,
    title: str,
    cadence: str,
    purpose: str,
    status: str,
    evidence: Sequence[Mapping[str, Any]],
    refresh_commands: Sequence[str],
    message: str,
    details: Optional[Mapping[str, Any]] = None,
    manual_actions: Optional[Sequence[str]] = None,
) -> Dict[str, Any]:
    return {
        "id": domain_id,
        "title": title,
        "cadence": cadence,
        "purpose": purpose,
        "status": status,
        "score": MAINTENANCE_STATUS_POINTS.get(status, 0),
        "evidence": [dict(item) for item in evidence],
        "refresh_commands": list(refresh_commands),
        "message": message,
        "details": dict(details or {}),
        "manual_actions": list(manual_actions or []),
    }


def _maintenance_source_domain(
    *,
    domain_id: str,
    title: str,
    cadence: str,
    purpose: str,
    evidence_path: Path | str,
    refresh_commands: Sequence[str],
    missing_message: str,
    manual_actions: Optional[Sequence[str]] = None,
) -> Dict[str, Any]:
    source = _success_metrics_load_json(evidence_path)
    evidence = [_maintenance_path_state(source["path"])]
    if source["status"] == "missing":
        return _maintenance_domain(
            domain_id=domain_id,
            title=title,
            cadence=cadence,
            purpose=purpose,
            status="missing",
            evidence=evidence,
            refresh_commands=refresh_commands,
            message=missing_message,
            details={"source_status": "missing"},
            manual_actions=[f"Regenerate evidence with `{refresh_commands[0]}`."] if refresh_commands else [],
        )
    if source["status"] == "invalid":
        return _maintenance_domain(
            domain_id=domain_id,
            title=title,
            cadence=cadence,
            purpose=purpose,
            status="blocked",
            evidence=evidence,
            refresh_commands=refresh_commands,
            message=str(source["message"]),
            details={"source_status": "invalid"},
            manual_actions=[f"Regenerate valid JSON with `{refresh_commands[0]}`."] if refresh_commands else [],
        )
    payload = source.get("payload") if isinstance(source.get("payload"), Mapping) else {}
    source_status = _maintenance_source_status(payload)
    status = _maintenance_status_from_source(source_status)
    actions = list(manual_actions or [])
    if status == "review" and not actions:
        actions.append("Review source report warnings/failures before claiming this maintenance domain is ready.")
    return _maintenance_domain(
        domain_id=domain_id,
        title=title,
        cadence=cadence,
        purpose=purpose,
        status=status,
        evidence=evidence,
        refresh_commands=refresh_commands,
        message=f"Source report status is `{source_status}`.",
        details={"source_status": source_status, "source_path": source["path"]},
        manual_actions=actions,
    )


def _build_maintenance_workflow_domain() -> Dict[str, Any]:
    workflow = _workflow_snapshot()
    taskmaster = _taskmaster_snapshot()
    current_session = workflow.get("current_session") if isinstance(workflow.get("current_session"), Mapping) else {}
    current_plan = workflow.get("current_plan") if isinstance(workflow.get("current_plan"), Mapping) else {}
    active = workflow.get("active_work_tracking") if isinstance(workflow.get("active_work_tracking"), list) else []
    invalid_refs = taskmaster.get("invalid_refs") if isinstance(taskmaster.get("invalid_refs"), list) else []
    review_items: List[str] = []
    if not current_session.get("resolved"):
        review_items.append("sessions/current is missing or unresolved.")
    if not current_plan.get("resolved"):
        review_items.append("plans/current is missing or unresolved.")
    if len(active) != 1:
        review_items.append(f"Expected exactly one ACTIVE work-tracking folder; found {len(active)}.")
    if invalid_refs:
        review_items.append("Taskmaster dependency graph has invalid references.")
    status = "ready" if not review_items else "blocked" if invalid_refs else "review"
    return _maintenance_domain(
        domain_id="workflow-health",
        title="Workflow health",
        cadence="daily",
        purpose="Confirm session, plan, work-tracking, guard, and Taskmaster state stay coherent.",
        status=status,
        evidence=[
            _maintenance_path_state(current_session.get("resolved") or current_session.get("path") or "sessions/current"),
            _maintenance_path_state(current_plan.get("resolved") or current_plan.get("path") or "plans/current"),
            _maintenance_path_state(TASKMASTER_TASKS_JSON),
        ],
        refresh_commands=(
            "python3 scripts/codex-task work-tracking audit",
            "python3 scripts/codex-task taskmaster health",
            "python3 scripts/codex-guard validate --include-untracked",
        ),
        message="Workflow pointers and Taskmaster graph are aligned." if not review_items else "Workflow maintenance review is needed.",
        details={"workflow": workflow, "taskmaster_summary": taskmaster.get("summary"), "invalid_refs": invalid_refs},
        manual_actions=review_items,
    )


