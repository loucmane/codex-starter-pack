        "refresh_commands": (
            "python3 scripts/codex-task validation final-suite --dry-run",
            "python3 scripts/codex-task validation final-suite --execute --report-dir reports/final-validation-suite",
        ),
    },
)

PHASE3_AUTOMATION_REVIEW_CHECKLIST: Tuple[Dict[str, str], ...] = (
    {
        "id": "scope-reconciled",
        "item": "Historical live deployment and monitoring wording is reconciled against the static portable foundation.",
        "evidence": "Task 56 scope reconciliation document",
    },
    {
        "id": "domain-evidence-current",
        "item": "Every Phase 3 automation domain is ready or has an explicit missing-evidence action.",
        "evidence": "phase3-review JSON domain statuses",
    },
    {
        "id": "verification-stack-run",
        "item": "Plan sync, work-tracking audit, Taskmaster health, guard, focused tests, and diff-check evidence are captured.",
        "evidence": "Task 56 verification reports",
    },
    {
        "id": "non-goals-visible",
        "item": "Production deployment, five-day monitoring, production auto-fix, traffic splitting, dashboards, alerts, and schedulers are listed as non-goals.",
        "evidence": "phase3-review Markdown runbook",
    },
)


def _phase3_path_state(path_value: str) -> Dict[str, Any]:
    path = Path(path_value)
    if not path.is_absolute():
        path = REPO_ROOT / path
    exists = path.exists()
    if path.is_dir():
        kind = "directory"
    elif path.is_file():
        kind = "file"
    else:
        kind = "missing"
    return {
        "path": _relative_to_root(path, REPO_ROOT),
        "exists": exists,
        "kind": kind,
    }


def _phase3_domain_review(domain: Dict[str, Any]) -> Dict[str, Any]:
    required_paths = [_phase3_path_state(path) for path in domain.get("required_paths", ())]
    evidence_paths = [_phase3_path_state(path) for path in domain.get("evidence_paths", ())]
    missing_required = [item["path"] for item in required_paths if not item["exists"]]
    missing_evidence = [item["path"] for item in evidence_paths if not item["exists"]]
    if missing_required:
        status = "needs-implementation"
        required_action = "Implement or restore the missing required files before Phase 3 review."
    elif missing_evidence:
        status = "needs-evidence"
        required_action = "Run the refresh commands and capture the missing evidence before claiming this domain is ready."
    else:
        status = "ready"
        required_action = "Review the current evidence and keep it linked from Task 56 closeout."
    return {
        "id": domain["id"],
        "title": domain["title"],
        "purpose": domain["purpose"],
        "status": status,
        "source_tasks": list(domain.get("source_tasks", ())),
        "required_paths": required_paths,
        "evidence_paths": evidence_paths,
        "missing_required_paths": missing_required,
        "missing_evidence_paths": missing_evidence,
        "refresh_commands": list(domain.get("refresh_commands", ())),
        "required_action": required_action,
    }


def _summarise_phase3_domains(domains: Sequence[Dict[str, Any]]) -> Dict[str, Any]:
    status_counts = Counter(str(domain.get("status")) for domain in domains)
    missing_required = sum(len(domain.get("missing_required_paths", [])) for domain in domains)
    missing_evidence = sum(len(domain.get("missing_evidence_paths", [])) for domain in domains)
    if missing_required:
        aggregate_status = "needs-implementation"
    elif missing_evidence:
        aggregate_status = "needs-evidence"
    else:
        aggregate_status = "ready"
    return {
        "aggregate_status": aggregate_status,
        "domains": len(domains),
        "ready": status_counts.get("ready", 0),
        "needs_evidence": status_counts.get("needs-evidence", 0),
        "needs_implementation": status_counts.get("needs-implementation", 0),
        "missing_required_paths": missing_required,
        "missing_evidence_paths": missing_evidence,
    }


def _build_phase3_automation_review(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "phase3-automation-review"
    domains = [_phase3_domain_review(dict(domain)) for domain in PHASE3_AUTOMATION_DOMAINS]
    summary = _summarise_phase3_domains(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-phase3-automation-integration-review",
        "executes_actions": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "domains": domains,
        "out_of_scope_requirements": list(PHASE3_AUTOMATION_OUT_OF_SCOPE),
        "gate_review_checklist": list(PHASE3_AUTOMATION_REVIEW_CHECKLIST),
        "non_goals": list(PHASE3_AUTOMATION_NON_GOALS),
    }


def _render_phase3_automation_review(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), dict) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), dict) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), dict) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), dict) else {}
    lines = [
        "# Phase 3 Automation Integration Review",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), dict) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), dict) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Domain Summary",
        "",
        "| Domain | Status | Missing Required | Missing Evidence |",
        "| --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, dict):
            continue
        missing_required = "<br>".join(domain.get("missing_required_paths", []))
        missing_evidence = "<br>".join(domain.get("missing_evidence_paths", []))
        lines.append(
            f"| {_md_cell(domain.get('title'))} | `{_md_cell(domain.get('status'))}` | "
            f"{_md_cell(missing_required or 'None')} | {_md_cell(missing_evidence or 'None')} |"
        )

    lines.extend(["", "## Domain Details", ""])
    for domain in report.get("domains", []):
        if not isinstance(domain, dict):
            continue
        lines.extend(
            [
                f"### {domain.get('title')}",
                "",
                f"- ID: `{domain.get('id')}`",
                f"- Status: `{domain.get('status')}`",
                f"- Source tasks: {', '.join(str(task) for task in domain.get('source_tasks', []))}",
                f"- Purpose: {domain.get('purpose')}",
                f"- Required action: {domain.get('required_action')}",
                "",
                "Refresh commands:",
            ]
        )
        for command in domain.get("refresh_commands", []):
            lines.append(f"- `{command}`")
        lines.extend(["", "Evidence paths:"])
        for item in domain.get("evidence_paths", []):
            if isinstance(item, dict):
                lines.append(f"- `{item.get('path')}` ({item.get('kind')})")
        lines.append("")

    lines.extend(
        [
            "## Historical Requirements Reconciled Out Of Scope",
            "",
            "| Historical Requirement | Current Boundary |",
            "| --- | --- |",
        ]
    )
    for item in report.get("out_of_scope_requirements", []):
        if not isinstance(item, dict):
            continue
        lines.append(
            f"| {_md_cell(item.get('historical_requirement'))} | {_md_cell(item.get('current_boundary'))} |"
        )

    lines.extend(["", "## Gate Review Checklist", ""])
    for item in report.get("gate_review_checklist", []):
        if not isinstance(item, dict):
            continue
        lines.append(f"- [ ] {item.get('item')} Evidence: {item.get('evidence')}")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static Phase 3 review artifact. It composes existing automation evidence and does not execute deployment, monitoring, auto-fix, canary, dashboard, scheduler, notification, or external service actions.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_phase3_automation_review(args: argparse.Namespace) -> None:
    report = _build_phase3_automation_review(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_phase3_automation_review(report)

    if args.dry_run:
        print(rendered_json, end="")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote Phase 3 automation review to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote Phase 3 automation runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")


