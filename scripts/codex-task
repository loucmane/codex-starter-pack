def _feedback_collection_domain(
    *,
    domain_id: str,
    title: str,
    purpose: str,
    evidence_paths: Sequence[str],
    refresh_command: str,
    details: Optional[Mapping[str, Any]] = None,
) -> Dict[str, Any]:
    evidence = [_enhancement_path_state(path) for path in evidence_paths]
    missing = [item["path"] for item in evidence if not item["exists"]]
    status = "needs-evidence" if missing else "ready"
    message = (
        f"{title} evidence is ready for feedback collection planning."
        if status == "ready"
        else f"{title} is missing evidence: {', '.join(missing)}."
    )
    return {
        "id": domain_id,
        "title": title,
        "purpose": purpose,
        "status": status,
        "evidence_paths": evidence,
        "missing_evidence_paths": missing,
        "message": message,
        "refresh_command": refresh_command,
        "details": dict(details or {}),
    }


def _build_feedback_collection_domains() -> List[Dict[str, Any]]:
    taskmaster = _taskmaster_snapshot()
    taskmaster_summary = taskmaster.get("summary") if isinstance(taskmaster.get("summary"), Mapping) else {}
    return [
        _feedback_collection_domain(
            domain_id="taskmaster-follow-up-health",
            title="Taskmaster follow-up health",
            purpose="Confirm feedback can become scoped follow-up work without dependency corruption.",
            evidence_paths=(".taskmaster/tasks/tasks.json",),
            refresh_command="python3 scripts/codex-task taskmaster health",
            details={"summary": taskmaster_summary, "invalid_refs": taskmaster.get("invalid_refs") or []},
        ),
        _feedback_collection_domain(
            domain_id="communication-feedback-template",
            title="Communication feedback template",
            purpose="Provide repository-native wording for feedback and follow-up capture.",
            evidence_paths=(
                "templates/guides/communication/foundation-communication-templates.md",
                "docs/ai/work-tracking/archive/20260508-task49-communication-templates-COMPLETED/",
            ),
            refresh_command="PYTHONDONTWRITEBYTECODE=1 python3 -m pytest tests/meta_workflow_guard/test_communication_templates.py",
        ),
        _feedback_collection_domain(
            domain_id="onboarding-feedback-guidance",
            title="Onboarding feedback guidance",
            purpose="Confirm training guidance tells operators where feedback belongs.",
            evidence_paths=(
                "templates/guides/training/foundation-onboarding.md",
                "docs/ai/work-tracking/archive/20260514-task54-knowledge-transfer-process-COMPLETED/reports/knowledge-transfer-process/knowledge-transfer-review-2026-05-14.json",
            ),
            refresh_command="PYTHONDONTWRITEBYTECODE=1 python3 -m pytest tests/meta_workflow_guard/test_training_materials.py",
        ),
        _feedback_collection_domain(
            domain_id="phase4-feedback-guidance",
            title="Phase 4 feedback guidance",
            purpose="Reuse documentation delivery guidance that treats feedback as repo evidence and follow-up prompts.",
            evidence_paths=(
                "docs/ai/work-tracking/archive/20260513-task63-phase4-documentation-delivery-COMPLETED/reports/phase4-documentation-delivery/phase4-review-2026-05-13.json",
                "reports/README.md",
            ),
            refresh_command="python3 scripts/codex-task documentation phase4-review --report-file reports/phase4-documentation-delivery/latest.json --runbook-file reports/phase4-documentation-delivery/latest.md",
        ),
        _feedback_collection_domain(
            domain_id="stakeholder-response-context",
            title="Stakeholder response context",
            purpose="Ground response and routing guidance in stakeholder-safe status reporting.",
            evidence_paths=(
                "docs/ai/work-tracking/archive/20260514-task73-stakeholder-reporting-COMPLETED/reports/stakeholder-reporting/stakeholder-report-2026-05-14-final.json",
                "docs/ai/work-tracking/archive/20260514-task76-celebration-planning-COMPLETED/reports/celebration-planning/celebration-plan-2026-05-14-final.json",
            ),
            refresh_command="python3 scripts/codex-task stakeholder report --report-file reports/stakeholder-reporting/latest.json --runbook-file reports/stakeholder-reporting/latest.md",
        ),
    ]


def _summarise_feedback_collection_domains(domains: Sequence[Mapping[str, Any]]) -> Dict[str, Any]:
    total = len(domains)
    ready = sum(1 for domain in domains if domain.get("status") == "ready")
    needs_evidence = sum(1 for domain in domains if domain.get("status") == "needs-evidence")
    blocked = sum(1 for domain in domains if domain.get("status") == "blocked")
    if blocked:
        aggregate_status = "blocked"
    elif needs_evidence:
        aggregate_status = "needs-evidence"
    else:
        aggregate_status = "ready"
    return {
        "aggregate_status": aggregate_status,
        "total_domains": total,
        "ready": ready,
        "needs_evidence": needs_evidence,
        "blocked": blocked,
    }


def _feedback_collection_refresh_commands(domains: Sequence[Mapping[str, Any]]) -> List[str]:
    commands: List[str] = []
    for domain in domains:
        command = domain.get("refresh_command")
        if isinstance(command, str) and command and command not in commands:
            commands.append(command)
    commands.extend(
        command
        for command in (
            "python3 scripts/codex-task feedback collection-plan --report-file reports/feedback-collection/latest.json --runbook-file reports/feedback-collection/latest.md",
            "python3 scripts/codex-task work-tracking audit",
            "python3 scripts/codex-guard validate --include-untracked",
        )
        if command not in commands
    )
    return commands


def _build_feedback_collection_plan(args: argparse.Namespace) -> Dict[str, Any]:
    now = datetime.now().astimezone()
    label = args.label or "feedback-collection"
    domains = _build_feedback_collection_domains()
    summary = _summarise_feedback_collection_domains(domains)
    return {
        "version": 1,
        "created_at": now.isoformat(timespec="seconds"),
        "label": label,
        "mode": "static-feedback-collection-planning-packet",
        "executes_actions": False,
        "summary": summary,
        "current_state": {
            "git": {
                "branch": _git_output(["branch", "--show-current"]),
                "head": _git_output(["rev-parse", "HEAD"]),
                "status": _git_status_snapshot(),
            },
            "workflow": _workflow_snapshot(),
            "taskmaster": _taskmaster_snapshot(),
            "serena": _serena_memory_snapshot(),
        },
        "domains": domains,
        "intake_schema": list(FEEDBACK_COLLECTION_INTAKE_SCHEMA),
        "categories": list(FEEDBACK_COLLECTION_CATEGORIES),
        "manual_sentiment_labels": list(FEEDBACK_COLLECTION_SENTIMENT_LABELS),
        "routing_matrix": list(FEEDBACK_COLLECTION_ROUTING_MATRIX),
        "metrics_checklist": list(FEEDBACK_COLLECTION_METRICS_CHECKLIST),
        "response_workflow": list(FEEDBACK_COLLECTION_RESPONSE_WORKFLOW),
        "archive_guidance": [
            "Store task-local feedback summaries in the active work-tracking FINDINGS.md, DECISIONS.md, HANDOFF.md, or reports directory.",
            "Link accepted implementation feedback to an existing or new Taskmaster task before editing product or workflow surfaces.",
            "Archive closed feedback with the work-tracking folder after the task PR merges.",
            "Keep private memory and external chats out of the evidence chain unless summarized into repository artifacts.",
        ],
        "manual_next_steps": [
            "Review the intake schema and routing matrix before collecting feedback.",
            "Capture feedback as repository evidence tied to an active task.",
            "Create or update Taskmaster tasks for accepted implementation feedback.",
            "Use communication templates for any human-facing response draft.",
            "Re-run this packet after major workflow, documentation, or stakeholder reporting changes.",
        ],
        "recommended_refresh_commands": _feedback_collection_refresh_commands(domains),
        "planning_guidance": list(FEEDBACK_COLLECTION_GUIDANCE),
        "non_goals": list(FEEDBACK_COLLECTION_NON_GOALS),
    }


def _render_feedback_collection_plan(report: Dict[str, Any]) -> str:
    current = report.get("current_state", {}) if isinstance(report.get("current_state"), Mapping) else {}
    git_info = current.get("git", {}) if isinstance(current.get("git"), Mapping) else {}
    workflow = current.get("workflow", {}) if isinstance(current.get("workflow"), Mapping) else {}
    summary = report.get("summary", {}) if isinstance(report.get("summary"), Mapping) else {}
    lines = [
        "# Feedback Collection Planning Packet",
        "",
        f"- Label: {report.get('label')}",
        f"- Created at: {report.get('created_at')}",
        f"- Mode: {report.get('mode')}",
        f"- Executes actions: {report.get('executes_actions')}",
        f"- Aggregate status: {summary.get('aggregate_status')}",
        "",
        "## Current State Snapshot",
        "",
        f"- Branch: `{git_info.get('branch')}`",
        f"- HEAD: `{git_info.get('head')}`",
        f"- Dirty status entries: {len(git_info.get('status') or [])}",
        f"- Current session: `{workflow.get('current_session', {}).get('resolved') if isinstance(workflow.get('current_session'), Mapping) else None}`",
        f"- Current plan: `{workflow.get('current_plan', {}).get('resolved') if isinstance(workflow.get('current_plan'), Mapping) else None}`",
        f"- Active work-tracking folders: {workflow.get('active_work_tracking')}",
        "",
        "## Summary",
        "",
        f"- Total domains: {summary.get('total_domains')}",
        f"- Ready: {summary.get('ready')}",
        f"- Needs evidence: {summary.get('needs_evidence')}",
        f"- Blocked: {summary.get('blocked')}",
        "",
        "## Evidence Domains",
        "",
        "| Domain | Purpose | Status | Missing Evidence |",
        "| --- | --- | --- | --- |",
    ]
    for domain in report.get("domains", []):
        if not isinstance(domain, Mapping):
            continue
        missing = "<br>".join(domain.get("missing_evidence_paths", [])) or "None"
        lines.append(
            f"| {_md_cell(domain.get('title'))} | {_md_cell(domain.get('purpose'))} | "
            f"`{_md_cell(domain.get('status'))}` | {_md_cell(missing)} |"
        )

    lines.extend(["", "## Intake Schema", ""])
    lines.extend(["| Field | Required | Purpose |", "| --- | --- | --- |"])
    for field in report.get("intake_schema", []):
        if isinstance(field, Mapping):
            lines.append(f"| `{_md_cell(field.get('field'))}` | {_md_cell(field.get('required'))} | {_md_cell(field.get('purpose'))} |")

    lines.extend(["", "## Categories", ""])
    for category in report.get("categories", []):
        if isinstance(category, Mapping):
            lines.append(f"- **{category.get('title')}** (`{category.get('id')}`): {category.get('description')}")

    lines.extend(["", "## Manual Sentiment Labels", ""])
    for label in report.get("manual_sentiment_labels", []):
        if isinstance(label, Mapping):
            lines.append(f"- `{label.get('label')}`: {label.get('meaning')}")

    lines.extend(["", "## Routing Matrix", ""])
    lines.extend(["| Category | Route To | Evidence Destination | Response Guidance |", "| --- | --- | --- | --- |"])
    for route in report.get("routing_matrix", []):
        if isinstance(route, Mapping):
            lines.append(
                f"| `{_md_cell(route.get('category'))}` | {_md_cell(route.get('route_to'))} | "
                f"{_md_cell(route.get('evidence_destination'))} | {_md_cell(route.get('response_guidance'))} |"
            )

    lines.extend(["", "## Metrics Checklist", ""])
    for metric in report.get("metrics_checklist", []):
        if isinstance(metric, Mapping):
            lines.append(f"- `{metric.get('metric')}`: {metric.get('review_question')}")

    lines.extend(["", "## Response Workflow", ""])
    for state in report.get("response_workflow", []):
        if isinstance(state, Mapping):
            lines.append(f"- `{state.get('state')}`: {state.get('definition')}")

    lines.extend(["", "## Archive Guidance", ""])
    for item in report.get("archive_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Manual Next Steps", ""])
    for step in report.get("manual_next_steps", []):
        lines.append(f"- {step}")

    lines.extend(["", "## Planning Guidance", ""])
    for item in report.get("planning_guidance", []):
        lines.append(f"- {item}")

    lines.extend(["", "## Recommended Refresh Commands", ""])
    for command in report.get("recommended_refresh_commands", []):
        lines.append(f"- `{command}`")

    lines.extend(["", "## Non-Goals", ""])
    for non_goal in report.get("non_goals", []):
        lines.append(f"- {non_goal}")

    lines.extend(
        [
            "",
            "This packet is a static feedback collection planning artifact. It composes existing repository evidence and requested output files only; it does not create hosted forms, API endpoints, dashboards, sentiment automation, notifications, tickets, external archives, or response delivery systems.",
            "",
        ]
    )
    return "\n".join(lines)


def handle_feedback_collection_plan(args: argparse.Namespace) -> None:
    report = _build_feedback_collection_plan(args)
    rendered_json = json.dumps(report, indent=2, sort_keys=True) + "\n"
    rendered_runbook = _render_feedback_collection_plan(report)

    if args.dry_run:
        print(rendered_json, end="")
        if args.strict and report["summary"]["aggregate_status"] != "ready":
            raise TaskError("Feedback collection plan aggregate status is not ready")
        return

    wrote = False
    if args.report_file:
        report_path = Path(args.report_file)
        if not report_path.is_absolute():
            report_path = REPO_ROOT / report_path
        report_path.parent.mkdir(parents=True, exist_ok=True)
        report_path.write_text(rendered_json, encoding="utf-8")
        print(f"Wrote feedback collection plan to {_relative_to_root(report_path, REPO_ROOT)}")
        wrote = True

    if args.runbook_file:
        runbook_path = Path(args.runbook_file)
        if not runbook_path.is_absolute():
            runbook_path = REPO_ROOT / runbook_path
        runbook_path.parent.mkdir(parents=True, exist_ok=True)
        runbook_path.write_text(rendered_runbook, encoding="utf-8")
        print(f"Wrote feedback collection runbook to {_relative_to_root(runbook_path, REPO_ROOT)}")
        wrote = True

    if not wrote:
        print(rendered_runbook, end="")

    if args.strict and report["summary"]["aggregate_status"] != "ready":
        raise TaskError("Feedback collection plan aggregate status is not ready")


