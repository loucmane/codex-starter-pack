    migrate.add_argument("--dolt-host", required=True)
    migrate.add_argument("--dolt-port", required=True, type=int)
    migrate.add_argument("--dolt-user", required=True)
    migrate.add_argument("--dolt-database", required=True)
    migrate.add_argument("--no-tls", action="store_true")
    migrate.add_argument("--tag", default="master")
    migrate.add_argument("--prefix", default="ags")

    reconcile = commands.add_parser("reconcile-taskmaster")
    reconcile.add_argument("--lock", type=Path, required=True)
    reconcile.add_argument("--snapshot", type=Path, required=True)
    reconcile.add_argument("--target-repo", type=Path, required=True)
    reconcile.add_argument("--evidence-dir", type=Path, required=True)
    reconcile.add_argument(
        "--bd", type=Path, default=Path.home() / "gas-city" / "bin" / "bd"
    )
    reconcile.add_argument(
        "--dolt", type=Path, default=Path.home() / "gas-city" / "bin" / "dolt"
    )
    reconcile.add_argument("--dolt-host", required=True)
    reconcile.add_argument("--dolt-port", required=True, type=int)
    reconcile.add_argument("--dolt-user", required=True)
    reconcile.add_argument("--dolt-database", required=True)
    reconcile.add_argument("--no-tls", action="store_true")
    reconcile.add_argument("--tag", default="master")
    reconcile.add_argument("--prefix", default="ags")
    return parser


def main(argv: list[str] | None = None) -> int:
    os.umask(0o077)
    args = build_parser().parse_args(argv)
    try:
        if args.command == "verify-lock":
            result = gas_city_ops.verify_installed_toolchain(
                args.city_root,
                args.lock,
                require_observed_models=args.require_observed_models,
            )
        elif args.command == "build-images":
            result = gas_city_ops.build_locked_images(
                args.lock,
                args.context,
                docker_binary=args.docker,
            )
        elif args.command == "promote-images":
            result = gas_city_ops.promote_locked_images(
                args.lock,
                docker_binary=args.docker,
            )
        elif args.command == "endpoint-transition-hq":
            password = gas_city_ops.read_private_secret_file_from_environment(
                os.environ,
                gas_city_endpoint.TRANSITION_SECRET_VARIABLE,
            )
            result = gas_city_endpoint.transition_hq_endpoint(
                args.city_root,
                args.lock,
                args.evidence_dir,
                password=password,
                environment=os.environ,
            )
        elif args.command == "initialize-hq-beads":
            password = gas_city_ops.read_private_secret_file_from_environment(
                os.environ,
                gas_city_endpoint.TRANSITION_SECRET_VARIABLE,
            )
            result = gas_city_endpoint.initialize_hq_beads(
                args.city_root,
                args.lock,
                args.evidence_dir,
                password=password,
                environment=os.environ,
            )
        elif args.command == "endpoint-rollback-hq":
            result = gas_city_endpoint.rollback_hq_endpoint(
                args.city_root,
                args.lock,
                args.transition_receipt,
                args.evidence_dir,
                environment=os.environ,
            )
        elif args.command == "endpoint-verify-hq":
            result = gas_city_endpoint.verify_hq_endpoint_transition(
                args.city_root,
                args.lock,
                args.transition_receipt,
                environment=os.environ,
            )
        elif args.command == "snapshot-taskmaster":
            repo = args.repo.expanduser().resolve()
            source_before = gas_city_ops.taskmaster_source_fingerprint(repo)
            head_before = _git(repo, "rev-parse", "HEAD").strip()
            dirty_before = _git(
                repo,
                "status",
                "--porcelain=v1",
                "--untracked-files=all",
            ).splitlines()
            health = _taskmaster_health(repo)
            source_after = gas_city_ops.taskmaster_source_fingerprint(repo)
            head_after = _git(repo, "rev-parse", "HEAD").strip()
            dirty_after = _git(
                repo,
                "status",
                "--porcelain=v1",
                "--untracked-files=all",
            ).splitlines()
            if (
                source_before != source_after
                or head_before != head_after
                or dirty_before != dirty_after
            ):
                raise gas_city_ops.GasCityOpsError(
                    "repository changed while cutover evidence was being collected"
                )
            result = gas_city_ops.capture_taskmaster_snapshot(
                repo,
                args.output,
                captured_at=dt.datetime.now(dt.timezone.utc)
                .replace(microsecond=0)
                .isoformat()
                .replace("+00:00", "Z"),
                git_head=head_after,
                dirty_paths=[line[3:] for line in dirty_after if len(line) >= 4],
                health_evidence=health,
                expected_source_sha256=source_after["sha256"],
            )
        elif args.command == "verify-model":
            lock_path = args.lock.expanduser().resolve(strict=True)
            lock = gas_city_ops.load_runtime_lock(lock_path)
            provider_lock = lock["providers"][args.provider]
            expected_model = provider_lock["requested_model"]
            expected_effort = provider_lock.get("reasoning_effort")
            receipt = gas_city_ops.verify_model_transcript(
                args.provider,
                args.transcript,
                expected_model=expected_model,
                expected_effort=expected_effort,
            )
            receipt_path = lock_path.parent / provider_lock["receipt_path"]
            receipt_digest = gas_city_ops.write_private_json_evidence(
                receipt_path,
                receipt,
                exclusive=True,
            )
            result = {
                "status": "pass",
                "provider": args.provider,
                "requested_model": expected_model,
                "reasoning_effort": expected_effort,
                "receipt_path": receipt_path.as_posix(),
                "receipt_sha256": receipt_digest,
            }
        elif args.command == "backup-restore-drill":
            locked_toolchain = gas_city_ops.locked_operation_toolchain_attestation(
                args.lock,
                {"bd": args.bd, "dolt": args.dolt},
                environment={},
            )
            source_password = gas_city_ops.read_private_secret_file_from_environment(
                os.environ,
                "GAS_CITY_SOURCE_DOLT_PASSWORD_FILE",
            )
            restore_password = gas_city_ops.read_private_secret_file_from_environment(
                os.environ,
                "GAS_CITY_RESTORE_DOLT_PASSWORD_FILE",
            )
            result = gas_city_ops.native_backup_restore_drill(
                args.source_repo,
                args.restore_repo,
                args.backup_dir,
                lock_path=args.lock,
                locked_toolchain=locked_toolchain,
                source_endpoint=_endpoint("source", args),
                restore_endpoint=_endpoint("restore", args),
                bd_binary=args.bd,
                docker_binary=args.docker,
                source_container=args.source_container,
                restore_container=args.restore_container,
                source_password=source_password,
                restore_password=restore_password,
            )
            result["evidence_sha256"] = gas_city_ops.write_private_json_evidence(
                args.evidence_output,
                result,
                exclusive=True,
            )
            result["evidence_path"] = args.evidence_output.expanduser().resolve().as_posix()
        elif args.command == "capture-cold-backup":
            result = gas_city_ops.capture_cold_dolt_backup(
                args.source_data_dir,
                args.output,
                lock_path=args.lock,
                dolt_binary=args.dolt,
                docker_binary=args.docker,
                database_relative_path=args.database_relative_path,
                endpoint_host=args.endpoint_host,
                endpoint_port=args.endpoint_port,
                container_name=args.container_name,
            )
        elif args.command == "capture-authority-evidence":
            result = gas_city_ops.capture_authority_evidence(
                args.lock,
                args.snapshot,
                args.output,
            )
        elif args.command == "capture-provider-evidence":
            result = gas_city_ops.capture_provider_evidence(
                args.lock,
                claude_supervisor_receipt=args.claude_supervisor_receipt,
                claude_transcript=args.claude_transcript,
                codex_supervisor_receipt=args.codex_supervisor_receipt,
                codex_transcript=args.codex_transcript,
                output_path=args.output,
            )
        elif args.command == "capture-obsidian-evidence":
            target_environment = _target_beads_environment()
            result = gas_city_ops.capture_obsidian_evidence(
                args.lock,
                target_repo=args.target_repo,
                first_vault=args.first_vault,
                second_vault=args.second_vault,
                output_path=args.output,
                source_root=args.target_repo,
                environment=target_environment,
            )
        elif args.command in {"start-controlled-canary", "capture-controlled-canary"}:
            github_token = gas_city_ops.read_private_secret_file_from_environment(
                os.environ,
                "GAS_CITY_GITHUB_TOKEN_FILE",
            )
            github_environment = dict(os.environ)
            github_environment["GH_TOKEN"] = github_token
            if args.command == "start-controlled-canary":
                result = gas_city_ops.start_controlled_canary(
                    args.lock,
                    target_repo=args.target_repo,
                    bead_id=args.bead_id,
                    git_binary=args.git,
                    gh_binary=args.gh,
                    environment=github_environment,
                )
            else:
                result = gas_city_ops.capture_controlled_canary(
                    args.lock,
                    intent_path=args.intent,
                    canary_worktree=args.canary_worktree,
                    git_binary=args.git,
                    gh_binary=args.gh,
                    environment=github_environment,
                )
        elif args.command == "authority-capture-stopped":
            authority_environment = _authority_gc_environment()
            result = gas_city_ops.capture_aegis_stopped_workers_evidence(
                args.city_root,
                args.lock,
                args.output,
                docker_binary=args.docker,
                environment=authority_environment,
            )
        elif args.command == "authority-initialize":
            authority_environment = _authority_gc_environment()
            receipt = gas_city_authority.initialize_production_authority(
                args.city_root,
                **AUTHORITY_IDENTITY,
                snapshot_dir=args.snapshot,
                migration_evidence_path=args.migration_evidence,
                recovery_evidence_path=args.recovery_evidence,
                expected_target_directory=args.target_repo,
                stopped_workers_path=args.stopped_evidence,
                stopped_workers_hook=_authority_hook(args, authority_environment),
            )
            result = {
                "status": "pass",
                "receipt": task_authority.receipt_mapping(receipt),
                "chain": _authority_report(args.city_root),
            }
        elif args.command == "authority-activate-beads":
            authority_environment = _authority_gc_environment()
            receipt = gas_city_authority.activate_beads_authority(
                args.city_root,
                **AUTHORITY_IDENTITY,
                stopped_workers_path=args.stopped_evidence,
                stopped_workers_hook=_authority_hook(args, authority_environment),
            )
            result = {
                "status": "pass",
                "receipt": task_authority.receipt_mapping(receipt),
                "chain": _authority_report(args.city_root),
            }
        elif args.command == "authority-verify":
            result = _authority_report(args.city_root)
        elif args.command == "authority-recover-history":
            gas_city_authority.recover_authority_history(
                args.city_root,
                **AUTHORITY_IDENTITY,
            )
            result = _authority_report(args.city_root)
        elif args.command == "authority-rollback-taskmaster":
            authority_environment = _authority_gc_environment()
            receipt = gas_city_authority.rollback_to_taskmaster_authority(
                args.city_root,
                **AUTHORITY_IDENTITY,
                stopped_workers_path=args.stopped_evidence,
                rollback_recovery_path=args.rollback_recovery,
                stopped_workers_hook=_authority_hook(args, authority_environment),
            )
            result = {
                "status": "pass",
                "receipt": task_authority.receipt_mapping(receipt),
                "chain": _authority_report(args.city_root),
            }
        elif args.command == "promote-canary":
            result = gas_city_ops.promote_canary_runtime(
                args.lock,
                {
                    kind: getattr(args, f"{kind}_evidence")
                    for kind in gas_city_ops.CANARY_EVIDENCE_KINDS
                },
            )
        elif args.command == "start-soak":
            result = gas_city_ops.start_soak(args.lock, args.output)
        elif args.command == "observe-soak":
            target_environment = _target_beads_environment()
            result = gas_city_ops.capture_soak_observation(
                args.lock,
                target_repo=args.target_repo,
                vault=args.vault,
                observations_path=args.observations,
                source_root=args.target_repo,
                environment=target_environment,
            )
        elif args.command == "finish-soak":
            result = gas_city_ops.finish_soak(
                args.lock,
                args.start_receipt,
                args.observations,
                args.output,
            )
        elif args.command == "promote-production":
            result = gas_city_ops.promote_runtime_production(
                args.lock,
                args.soak_evidence,
            )
        elif args.command == "initialize-aegis-beads":
            password = gas_city_ops.read_private_secret_file_from_environment(
                os.environ,
                "GAS_CITY_TARGET_DOLT_PASSWORD_FILE",
            )
            result = gas_city_ops.initialize_aegis_beads(
                args.target_repo,
                args.lock,
                bd_binary=args.bd,
                dolt_binary=args.dolt,
                git_binary=args.git,
                password=password,
            )
        elif args.command in {"migrate-taskmaster", "reconcile-taskmaster"}:
            source_bytes, snapshot = gas_city_ops.load_taskmaster_snapshot(args.snapshot)
            evidence_root = gas_city_ops.create_private_evidence_directory(
                args.evidence_dir
            )
            evidence_digests: dict[str, str] = {}
            locked_toolchain: dict[str, object] | None = None
            is_reconciliation = args.command == "reconcile-taskmaster"
            evidence_schema = (
                "taskmaster-beads-reconciliation-evidence/v1"
                if is_reconciliation
                else "taskmaster-beads-migration-evidence/v1"
            )
            report_name = (
                "reconciliation-report.json"
                if is_reconciliation
                else "migration-report.json"
            )

            def evidence_sink(relative_name: str, content: bytes) -> None:
                evidence_digests[relative_name] = (
                    gas_city_ops.write_private_evidence_bytes(
                        evidence_root,
                        relative_name,
                        content,
                    )
                )

            try:
                locked_toolchain = gas_city_ops.locked_operation_toolchain_attestation(
                    args.lock,
                    {"bd": args.bd, "dolt": args.dolt},
                    environment={},
                )
                password = gas_city_ops.read_private_secret_file_from_environment(
                    os.environ,
                    "GAS_CITY_TARGET_DOLT_PASSWORD_FILE",
                )
                connection = taskmaster_beads.DoltConnection(
                    host=args.dolt_host,
                    port=args.dolt_port,
                    user=args.dolt_user,
                    database=args.dolt_database,
                    no_tls=args.no_tls,
                )
                runner = taskmaster_beads.SubprocessMigrationCommandRunner(
                    {
                        "BEADS_DOLT_SERVER_HOST": connection.host,
                        "BEADS_DOLT_SERVER_PORT": str(connection.port),
                        "BEADS_DOLT_SERVER_USER": connection.user,
                        "BEADS_DOLT_SERVER_DATABASE": connection.database,
                        # Gas City owns attended recovery evidence. Do not let
                        # bd 1.1.0 opportunistically register another backup.
                        "BD_BACKUP_ENABLED": "false",
                        "BEADS_DOLT_PASSWORD": password,
                        "DOLT_CLI_PASSWORD": password,
                    }
                )
                operation = (
                    taskmaster_beads.run_operational_reconciliation
                    if is_reconciliation
                    else taskmaster_beads.run_operational_migration
                )
                operation_result = operation(
                    source_bytes,
                    expected_source_sha256=snapshot["source"]["sha256"],
                    target_directory=args.target_repo,
                    dolt=connection,
                    runner=runner,
                    locked_toolchain=locked_toolchain,
                    tag=args.tag,
                    prefix=args.prefix,
                    bd_executable=args.bd.as_posix(),
                    dolt_executable=args.dolt.as_posix(),
                    evidence_sink=evidence_sink,
                )
            except (
                gas_city_ops.GasCityOpsError,
                taskmaster_beads.ConversionError,
                taskmaster_beads.ReconciliationError,
                taskmaster_beads.OperationalMigrationError,
            ) as exc:
                failure = {
                    "schema_version": evidence_schema,
                    "status": "failed",
                    "error_type": type(exc).__name__,
                    "error": str(exc),
                    "source_sha256": snapshot["source"]["sha256"],
                    "locked_toolchain": locked_toolchain,
                    "artifacts_written": dict(sorted(evidence_digests.items())),
                }
                evidence_sink(
                    "failure.json",
                    (json.dumps(failure, indent=2, sort_keys=True) + "\n").encode(
                        "utf-8"
                    ),
                )
                raise
            report_bytes = (
                json.dumps(operation_result.report, indent=2, sort_keys=True) + "\n"
            ).encode("utf-8")
            evidence_sink(report_name, report_bytes)
            evidence_manifest = {
                "schema_version": evidence_schema,
                "status": "pass",
                "source_sha256": snapshot["source"]["sha256"],
                "artifacts": dict(sorted(evidence_digests.items())),
            }
            evidence_sink(
                "evidence-manifest.json",
                (
                    json.dumps(evidence_manifest, indent=2, sort_keys=True) + "\n"
                ).encode("utf-8"),
            )
            result = {
                **operation_result.report,
                "evidence_directory": evidence_root.as_posix(),
                "evidence_manifest_sha256": evidence_digests[
                    "evidence-manifest.json"
                ],
            }
        else:  # pragma: no cover - argparse constrains command names.
            raise gas_city_ops.GasCityOpsError(f"unsupported command: {args.command}")
    except (
        gas_city_authority.GasCityAuthorityError,
        gas_city_ops.GasCityOpsError,
        taskmaster_beads.ConversionError,
        taskmaster_beads.ReconciliationError,
        taskmaster_beads.OperationalMigrationError,
    ) as exc:
        print(f"gas-city-admin: {exc}", file=sys.stderr)
        return 1
    _print(result)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
