    endpoint_transition.add_argument("--evidence-dir", type=Path, required=True)

    hq_initialize = commands.add_parser("initialize-hq-beads")
    hq_initialize.add_argument(
        "--city-root", type=Path, default=Path.home() / "gas-city"
    )
    hq_initialize.add_argument("--lock", type=Path, required=True)
    hq_initialize.add_argument("--evidence-dir", type=Path, required=True)

    endpoint_rollback = commands.add_parser("endpoint-rollback-hq")
    endpoint_rollback.add_argument(
        "--city-root", type=Path, default=Path.home() / "gas-city"
