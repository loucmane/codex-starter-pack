#!/usr/bin/python3 -I
"""Guarded operator entrypoint for the shared Gas City deployment."""

from __future__ import annotations

import argparse
import datetime as dt
import hashlib
import importlib.machinery
import json
import os
from pathlib import Path
import subprocess
import sys
import types

sys.dont_write_bytecode = True

SOURCE_ROOT = Path(__file__).resolve().parents[1]
ADMIN_RUNTIME_DESTINATIONS = frozenset(
    {
        "bin/gas-city-admin",
        "aegis_foundation/__init__.py",
        "aegis_foundation/version.py",
        "aegis_foundation/gas_city_authority.py",
        "aegis_foundation/gas_city_endpoint.py",
        "aegis_foundation/gas_city_ops.py",
        "aegis_foundation/obsidian_vault.py",
        "aegis_foundation/task_authority.py",
        "aegis_foundation/taskmaster_beads.py",
    }
)


def _verify_deployed_admin_runtime() -> dict[str, bytes] | None:
    """Fail before imports if a deployed operator runtime is not manifest-exact."""

    lock_path = SOURCE_ROOT / "runtime-lock.json"
    manifest_path = SOURCE_ROOT / "control-plane-manifest.json"
    if not lock_path.exists() and not manifest_path.exists():
        return None
    if not sys.flags.isolated:
        raise SystemExit("gas-city-admin: deployed runtime requires isolated Python")
    if Path(sys.executable).resolve() != Path("/usr/bin/python3").resolve():
        raise SystemExit("gas-city-admin: deployed runtime requires /usr/bin/python3")
    if not lock_path.is_file() or not manifest_path.is_file():
        raise SystemExit("gas-city-admin: deployed runtime lock or manifest is missing")
    if lock_path.is_symlink() or manifest_path.is_symlink():
        raise SystemExit("gas-city-admin: deployed runtime metadata must not be symlinked")
    try:
        lock_bytes = lock_path.read_bytes()
        manifest_bytes = manifest_path.read_bytes()
        lock = json.loads(lock_bytes)
        manifest = json.loads(manifest_bytes)
    except (OSError, UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise SystemExit(f"gas-city-admin: cannot verify deployed runtime: {exc}") from exc
    binding = lock.get("control_plane_manifest") if type(lock) is dict else None
    if binding != {
        "path": "control-plane-manifest.json",
        "sha256": hashlib.sha256(manifest_bytes).hexdigest(),
    }:
        raise SystemExit("gas-city-admin: control-plane manifest binding is invalid")
    entries = manifest.get("entries") if type(manifest) is dict else None
    if type(entries) is not list:
        raise SystemExit("gas-city-admin: control-plane manifest entries are invalid")
    by_destination = {
        record.get("destination"): record
        for record in entries
        if type(record) is dict and type(record.get("destination")) is str
    }
    if set(by_destination) & ADMIN_RUNTIME_DESTINATIONS != ADMIN_RUNTIME_DESTINATIONS:
        raise SystemExit("gas-city-admin: control-plane manifest omits the admin runtime")
    package_root = SOURCE_ROOT / "aegis_foundation"
    expected_package_entries = {
        Path(relative).name
        for relative in ADMIN_RUNTIME_DESTINATIONS
        if relative.startswith("aegis_foundation/")
    }
    try:
        observed_package_entries = {path.name for path in package_root.iterdir()}
    except OSError as exc:
        raise SystemExit(f"gas-city-admin: cannot inspect admin package: {exc}") from exc
    if (
        package_root.is_symlink()
        or not package_root.is_dir()
        or observed_package_entries != expected_package_entries
    ):
        raise SystemExit(
            "gas-city-admin: admin package contains missing or unverified entries"
        )
    verified_sources: dict[str, bytes] = {}
    for relative in sorted(ADMIN_RUNTIME_DESTINATIONS):
        record = by_destination[relative]
        path = SOURCE_ROOT / relative
        try:
            expected_mode = int(record["destination_mode"], 8)
            expected_sha = record["sha256"]
            observed_mode = path.stat().st_mode & 0o7777
            observed_bytes = path.read_bytes()
            observed_sha = hashlib.sha256(observed_bytes).hexdigest()
        except (KeyError, OSError, TypeError, ValueError) as exc:
            raise SystemExit(
                f"gas-city-admin: cannot verify deployed admin file {relative}: {exc}"
            ) from exc
        if (
            path.is_symlink()
            or not path.is_file()
            or observed_mode != expected_mode
            or observed_sha != expected_sha
        ):
            raise SystemExit(f"gas-city-admin: deployed admin file drift: {relative}")
        if relative.startswith("aegis_foundation/"):
            verified_sources[relative] = observed_bytes
    if Path(__file__).is_symlink() or Path(__file__).resolve() != (
        SOURCE_ROOT / "bin" / "gas-city-admin"
    ):
        raise SystemExit("gas-city-admin: deployed entrypoint path is not canonical")
    return verified_sources


def _exec_verified_module(
    fullname: str,
    relative: str,
    source: bytes,
    *,
    package: bool = False,
) -> types.ModuleType:
    """Compile an already-verified source buffer without consulting bytecode caches."""

    origin = (SOURCE_ROOT / relative).as_posix()
    spec = importlib.machinery.ModuleSpec(
        fullname,
        loader=None,
        origin=origin,
        is_package=package,
    )
    if package:
        spec.submodule_search_locations = []
    module = types.ModuleType(fullname)
    module.__file__ = origin
    module.__loader__ = None
    module.__package__ = fullname if package else fullname.rpartition(".")[0]
    module.__spec__ = spec
    module.__cached__ = None
    if package:
        module.__path__ = []
    sys.modules[fullname] = module
    if "." in fullname:
        parent_name, _, child_name = fullname.rpartition(".")
        parent = sys.modules[parent_name]
        setattr(parent, child_name, module)
    try:
        code = compile(source, origin, "exec", dont_inherit=True)
        exec(code, module.__dict__)
    except BaseException:
        sys.modules.pop(fullname, None)
        raise
    return module


def _load_verified_admin_modules(
    sources: dict[str, bytes],
) -> tuple[types.ModuleType, ...]:
    package = _exec_verified_module(
        "aegis_foundation",
        "aegis_foundation/__init__.py",
        b"",
        package=True,
    )
    version = _exec_verified_module(
        "aegis_foundation.version",
        "aegis_foundation/version.py",
        sources["aegis_foundation/version.py"],
    )
    exec(
        compile(
            sources["aegis_foundation/__init__.py"],
            (SOURCE_ROOT / "aegis_foundation/__init__.py").as_posix(),
            "exec",
            dont_inherit=True,
        ),
        package.__dict__,
    )
    task_authority_module = _exec_verified_module(
        "aegis_foundation.task_authority",
        "aegis_foundation/task_authority.py",
        sources["aegis_foundation/task_authority.py"],
    )
    taskmaster_beads_module = _exec_verified_module(
        "aegis_foundation.taskmaster_beads",
        "aegis_foundation/taskmaster_beads.py",
        sources["aegis_foundation/taskmaster_beads.py"],
    )
    _exec_verified_module(
        "aegis_foundation.obsidian_vault",
        "aegis_foundation/obsidian_vault.py",
        sources["aegis_foundation/obsidian_vault.py"],
    )
    gas_city_ops_module = _exec_verified_module(
        "aegis_foundation.gas_city_ops",
        "aegis_foundation/gas_city_ops.py",
        sources["aegis_foundation/gas_city_ops.py"],
    )
    gas_city_authority_module = _exec_verified_module(
        "aegis_foundation.gas_city_authority",
        "aegis_foundation/gas_city_authority.py",
        sources["aegis_foundation/gas_city_authority.py"],
    )
    gas_city_endpoint_module = _exec_verified_module(
        "aegis_foundation.gas_city_endpoint",
        "aegis_foundation/gas_city_endpoint.py",
        sources["aegis_foundation/gas_city_endpoint.py"],
    )
    del version
    return (
        gas_city_authority_module,
        gas_city_endpoint_module,
        gas_city_ops_module,
        task_authority_module,
        taskmaster_beads_module,
    )


_DEPLOYED_ADMIN_SOURCES = _verify_deployed_admin_runtime()
if _DEPLOYED_ADMIN_SOURCES is None:
    if SOURCE_ROOT.as_posix() not in sys.path:
        sys.path.insert(0, SOURCE_ROOT.as_posix())
    from aegis_foundation import (  # noqa: E402
        gas_city_authority,
        gas_city_endpoint,
        gas_city_ops,
        task_authority,
        taskmaster_beads,
    )
else:
    (
        gas_city_authority,
        gas_city_endpoint,
        gas_city_ops,
        task_authority,
        taskmaster_beads,
    ) = _load_verified_admin_modules(_DEPLOYED_ADMIN_SOURCES)


AUTHORITY_IDENTITY = {
    "rig": "aegis",
    "beads_prefix": "ags",
    "database": "aegis_beads",
}


def _print(value: object) -> None:
    print(json.dumps(value, indent=2, sort_keys=True))


def _git(repo: Path, *args: str) -> str:
    result = subprocess.run(
        ("git", "-C", repo.as_posix(), *args),
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if result.returncode != 0:
        raise gas_city_ops.GasCityOpsError(result.stderr.strip())
    return result.stdout


def _taskmaster_health(repo: Path) -> str:
    result = subprocess.run(
        (sys.executable, "scripts/codex-task", "taskmaster", "health"),
        cwd=repo,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )
    if result.returncode != 0:
        raise gas_city_ops.GasCityOpsError("Taskmaster full-graph health failed:\n" + result.stdout)
    return result.stdout


def _endpoint(prefix: str, args: argparse.Namespace) -> gas_city_ops.DoltEndpoint:
    return gas_city_ops.DoltEndpoint(
        host=getattr(args, f"{prefix}_host"),
        port=getattr(args, f"{prefix}_port"),
        user=getattr(args, f"{prefix}_user"),
        database=getattr(args, f"{prefix}_database"),
    )


def _authority_gc_environment() -> dict[str, str]:
    """Load attended HQ auth for pinned gc without persisting it in the city."""

    password = gas_city_ops.read_private_secret_file_from_environment(
        os.environ,
        gas_city_endpoint.TRANSITION_SECRET_VARIABLE,
    )
    return {
        **os.environ,
        "BEADS_DOLT_PASSWORD": password,
        "DOLT_CLI_PASSWORD": password,
        "GC_DOLT_PASSWORD": password,
    }


def _target_beads_environment() -> dict[str, str]:
    """Load attended Aegis auth for read-only Beads evidence commands."""

    password = gas_city_ops.read_private_secret_file_from_environment(
        os.environ,
        "GAS_CITY_TARGET_DOLT_PASSWORD_FILE",
    )
    return {
        **os.environ,
        "BEADS_DOLT_SERVER_HOST": gas_city_ops.AEGIS_BEADS_INIT_HOST,
        "BEADS_DOLT_SERVER_PORT": str(gas_city_ops.AEGIS_BEADS_INIT_PORT),
        "BEADS_DOLT_SERVER_USER": gas_city_ops.AEGIS_BEADS_INIT_USER,
        "BEADS_DOLT_SERVER_DATABASE": gas_city_ops.AEGIS_BEADS_INIT_DATABASE,
        "BD_BACKUP_ENABLED": "false",
        "BEADS_DOLT_PASSWORD": password,
        "DOLT_CLI_PASSWORD": password,
    }


def _authority_hook(
    args: argparse.Namespace,
    environment: dict[str, str],
) -> gas_city_ops.AegisStoppedWorkersHook:
    return gas_city_ops.AegisStoppedWorkersHook(
        city_root=args.city_root,
        lock_path=args.lock,
        docker_binary=args.docker,
        environment=environment,
    )


def _authority_report(city_root: Path) -> dict[str, object]:
    report = gas_city_authority.verify_authority_chain(
        city_root,
        **AUTHORITY_IDENTITY,
    )
    current = (
        None
        if report.current is None
        else task_authority.receipt_mapping(report.current)
    )
    generations = []
    for record in report.generation_records:
        generation = int(record["generation"])
        path = report.layout.history_root / f"generation-{generation:08d}.json"
        generations.append(
            {
                "generation": generation,
                "transition": record["transition"],
                "created_at": record["created_at"],
                "mode": record["receipt"]["mode"],
                "path": path.as_posix(),
                "sha256": hashlib.sha256(path.read_bytes()).hexdigest(),
            }
        )
    return {
        "status": "pass",
        "receipt_path": report.layout.receipt_path.as_posix(),
        "current": current,
        "generation_records": generations,
        "current_record_sha256": report.current_record_sha256,
        "recoverable_attempt": report.recoverable_attempt is not None,
        "uncommitted_attempt_count": len(report.uncommitted_attempts),
    }


