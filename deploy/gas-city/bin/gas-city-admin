    drill.add_argument("--docker", type=Path, default=Path("/usr/bin/docker"))
    drill.add_argument("--source-container", required=True)
    drill.add_argument("--restore-container", required=True)
    drill.add_argument("--evidence-output", type=Path, required=True)
