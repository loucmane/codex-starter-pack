#!/usr/bin/python3
"""Issue one short-lived, repository-scoped GitHub App token per worker session."""

from __future__ import annotations

import argparse
import base64
import datetime as dt
import hashlib
import json
import os
from pathlib import Path
import re
import stat
import subprocess
import sys
import tempfile
import urllib.error
import urllib.request
from typing import Any, Mapping


API_ROOT = "https://api.github.com"
API_VERSION = "2022-11-28"
OPENSSL = Path("/usr/bin/openssl")
MAX_RESPONSE_BYTES = 8 * 1024 * 1024
SHA256_RE = re.compile(r"[0-9a-f]{64}\Z")
REPOSITORY_RE = re.compile(r"[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\Z")
REF_RE = re.compile(r"[A-Za-z0-9][A-Za-z0-9._/-]{0,199}\Z")
REQUIRED_PERMISSIONS = {
    "contents": "write",
    "metadata": "read",
    "pull_requests": "write",
}
REQUIRED_DEFAULT_RULES = {
    "deletion",
    "non_fast_forward",
    "pull_request",
    "required_status_checks",
}


class BrokerError(RuntimeError):
    """The GitHub delivery credential boundary is unsafe."""


def _now() -> dt.datetime:
    return dt.datetime.now(dt.timezone.utc)


def _format(value: dt.datetime) -> str:
    return value.astimezone(dt.timezone.utc).isoformat().replace("+00:00", "Z")


def _timestamp(value: Any, *, label: str) -> dt.datetime:
    if not isinstance(value, str) or not value.endswith("Z"):
        raise BrokerError(f"{label} is not one UTC timestamp")
    try:
        parsed = dt.datetime.fromisoformat(value[:-1] + "+00:00")
    except ValueError as exc:
        raise BrokerError(f"{label} is not one UTC timestamp") from exc
    return parsed.astimezone(dt.timezone.utc)


def _sha256(content: bytes) -> str:
    return hashlib.sha256(content).hexdigest()


def _strict_json(content: bytes, *, label: str) -> Any:
    def pairs(items: list[tuple[str, Any]]) -> dict[str, Any]:
        value: dict[str, Any] = {}
        for key, item in items:
            if key in value:
                raise BrokerError(f"{label} contains duplicate key {key!r}")
            value[key] = item
        return value

    try:
        return json.loads(
            content.decode("utf-8"),
            object_pairs_hook=pairs,
            parse_constant=lambda item: (_ for _ in ()).throw(
                BrokerError(f"{label} contains non-finite number {item}")
            ),
        )
    except (UnicodeDecodeError, json.JSONDecodeError, RecursionError) as exc:
        raise BrokerError(f"{label} is not strict UTF-8 JSON") from exc


def _json_bytes(value: Any) -> bytes:
    return (
        json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
        + "\n"
    ).encode("utf-8")


def _secure_secret(path: Path, *, label: str, maximum: int) -> bytes:
    if not path.is_absolute() or ".." in path.parts:
        raise BrokerError(f"{label} path is unsafe")
    flags = os.O_RDONLY | os.O_CLOEXEC | getattr(os, "O_NOFOLLOW", 0)
    try:
        descriptor = os.open(path, flags)
    except OSError as exc:
        raise BrokerError(f"{label} cannot be opened") from exc
    try:
        before = os.fstat(descriptor)
        if (
            not stat.S_ISREG(before.st_mode)
            or before.st_uid != os.geteuid()
            or stat.S_IMODE(before.st_mode) != 0o600
            or before.st_nlink != 1
            or before.st_size <= 0
            or before.st_size > maximum
        ):
            raise BrokerError(f"{label} has unsafe file metadata")
        content = os.read(descriptor, maximum + 1)
        after = os.fstat(descriptor)
    finally:
        os.close(descriptor)
    identity = lambda value: (
        value.st_dev,
        value.st_ino,
        value.st_size,
        value.st_mtime_ns,
        value.st_ctime_ns,
    )
    if identity(before) != identity(after) or len(content) != after.st_size:
        raise BrokerError(f"{label} changed while it was read")
    return content


def _owner_directory(path: Path, *, label: str, create: bool = False) -> Path:
    if not path.is_absolute() or ".." in path.parts:
        raise BrokerError(f"{label} path is unsafe")
    if create and not path.exists() and not path.is_symlink():
        path.mkdir(mode=0o700)
    try:
        metadata = path.lstat()
    except OSError as exc:
        raise BrokerError(f"{label} is missing") from exc
    if (
        stat.S_ISLNK(metadata.st_mode)
        or not stat.S_ISDIR(metadata.st_mode)
        or metadata.st_uid != os.geteuid()
        or stat.S_IMODE(metadata.st_mode) != 0o700
    ):
        raise BrokerError(f"{label} must be one owner-only real directory")
    return path.resolve(strict=True)


def _atomic_new(path: Path, content: bytes, *, mode: int) -> None:
    if path.exists() or path.is_symlink():
        raise BrokerError(f"refusing to replace existing {path.name}")
    descriptor, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    temporary_path = Path(temporary)
    try:
        os.fchmod(descriptor, mode)
        if os.write(descriptor, content) != len(content):
            raise BrokerError(f"short write for {path.name}")
        os.fsync(descriptor)
        os.close(descriptor)
        descriptor = -1
        os.link(temporary_path, path, follow_symlinks=False)
        os.chmod(path, mode, follow_symlinks=False)
        directory_fd = os.open(path.parent, os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC)
        try:
            os.fsync(directory_fd)
        finally:
            os.close(directory_fd)
    except OSError as exc:
        raise BrokerError(f"cannot commit {path.name}") from exc
    finally:
        if descriptor >= 0:
            os.close(descriptor)
        temporary_path.unlink(missing_ok=True)


def _b64url(content: bytes) -> str:
    return base64.urlsafe_b64encode(content).rstrip(b"=").decode("ascii")


def _openssl_binary() -> Path:
    try:
        metadata = OPENSSL.lstat()
    except OSError as exc:
        raise BrokerError("fixed OpenSSL executable is missing") from exc
    if (
        not stat.S_ISREG(metadata.st_mode)
        or metadata.st_uid != 0
        or stat.S_IMODE(metadata.st_mode) & 0o022
        or stat.S_IMODE(metadata.st_mode) & 0o111 == 0
    ):
        raise BrokerError("fixed OpenSSL executable is not root controlled")
    return OPENSSL


def _jwt(app_id: str, private_key: bytes, *, now: dt.datetime) -> str:
    issued = int(now.timestamp()) - 60
    header = _b64url(b'{"alg":"RS256","typ":"JWT"}')
    payload = _b64url(
        json.dumps(
            {"iat": issued, "exp": issued + 540, "iss": app_id},
            sort_keys=True,
            separators=(",", ":"),
        ).encode("ascii")
    )
    unsigned = f"{header}.{payload}".encode("ascii")
    if not hasattr(os, "memfd_create"):
        raise BrokerError("kernel-backed private-key transport is unavailable")
    key_fd = os.memfd_create("gas-city-github-app-key", flags=0)
    try:
        os.fchmod(key_fd, 0o600)
        if os.write(key_fd, private_key) != len(private_key):
            raise BrokerError("short in-memory GitHub App private-key write")
        os.lseek(key_fd, 0, os.SEEK_SET)
        try:
            result = subprocess.run(
                [
                    str(_openssl_binary()),
                    "dgst",
                    "-sha256",
                    "-sign",
                    f"/proc/self/fd/{key_fd}",
                ],
                input=unsigned,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                check=False,
                timeout=15,
                pass_fds=(key_fd,),
            )
        except (OSError, subprocess.TimeoutExpired) as exc:
            raise BrokerError("could not sign GitHub App JWT") from exc
    finally:
        os.close(key_fd)
    if result.returncode != 0 or not result.stdout or len(result.stdout) > 16384:
        raise BrokerError("could not sign GitHub App JWT")
    return f"{unsigned.decode('ascii')}.{_b64url(result.stdout)}"


def _request_json(
    method: str,
    endpoint: str,
    *,
    token: str,
    body: Mapping[str, Any] | None = None,
) -> tuple[bytes, Any]:
    if not endpoint.startswith("/") or ".." in endpoint:
        raise BrokerError("GitHub API endpoint is unsafe")
    content = None if body is None else json.dumps(body, separators=(",", ":")).encode()
    request = urllib.request.Request(
        API_ROOT + endpoint,
        data=content,
        method=method,
        headers={
            "Accept": "application/vnd.github+json",
            "Authorization": f"Bearer {token}",
            "X-GitHub-Api-Version": API_VERSION,
            "User-Agent": "gas-city-github-app-token-broker/1",
            **({"Content-Type": "application/json"} if content is not None else {}),
        },
    )
    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            raw = response.read(MAX_RESPONSE_BYTES + 1)
            status = response.status
    except (urllib.error.URLError, OSError) as exc:
        raise BrokerError("GitHub API request failed") from exc
    if status < 200 or status >= 300 or len(raw) > MAX_RESPONSE_BYTES:
        raise BrokerError("GitHub API returned an unsafe response")
    return raw, _strict_json(raw, label="GitHub API response")


def _validate_rules(rules: Any) -> tuple[list[dict[str, Any]], list[int]]:
    if not isinstance(rules, list) or not rules:
        raise BrokerError("default branch has no effective GitHub rules")
    normalized: list[dict[str, Any]] = []
    ruleset_ids: set[int] = set()
    by_type: dict[str, dict[str, Any]] = {}
    for rule in rules:
        if not isinstance(rule, dict) or not isinstance(rule.get("type"), str):
            raise BrokerError("default branch effective rules are malformed")
        rule_type = rule["type"]
        ruleset_id = rule.get("ruleset_id")
        if type(ruleset_id) is not int or ruleset_id < 1:
            raise BrokerError("default branch rule lacks one ruleset identity")
        ruleset_ids.add(ruleset_id)
        by_type[rule_type] = rule
        normalized.append(rule)
    if not REQUIRED_DEFAULT_RULES.issubset(by_type):
        missing = sorted(REQUIRED_DEFAULT_RULES - set(by_type))
        raise BrokerError(f"default branch is missing required rules: {missing}")
    pull = by_type["pull_request"].get("parameters")
    checks = by_type["required_status_checks"].get("parameters")
    required_checks = checks.get("required_status_checks") if isinstance(checks, dict) else None
    if (
        not isinstance(pull, dict)
        or type(pull.get("required_approving_review_count")) is not int
        or pull["required_approving_review_count"] < 0
        or not isinstance(checks, dict)
        or checks.get("strict_required_status_checks_policy") is not True
        or not isinstance(required_checks, list)
        or not required_checks
        or any(
            not isinstance(item, dict)
            or not isinstance(item.get("context"), str)
            or not item["context"]
            for item in required_checks
        )
    ):
        raise BrokerError("default branch PR or status-check rule is too weak")
    return normalized, sorted(ruleset_ids)


def issue(args: argparse.Namespace) -> dict[str, Any]:
    state_parent = _owner_directory(Path(args.state_dir).parent, label="broker state parent")
    state_path = Path(args.state_dir)
    if state_path.parent.resolve(strict=True) != state_parent:
        raise BrokerError("broker state escaped its owner-only parent")
    state = _owner_directory(state_path, label="GitHub delivery state", create=True)
    if any(state.iterdir()):
        raise BrokerError("GitHub delivery state is not empty")
    repository = args.repository
    default_branch = args.default_branch
    if REPOSITORY_RE.fullmatch(repository) is None or REF_RE.fullmatch(default_branch) is None:
        raise BrokerError("GitHub repository or default branch is unsafe")
    owner, name = repository.split("/", 1)
    app_id = _secure_secret(Path(args.app_id_file), label="GitHub App ID", maximum=64).decode().strip()
    installation_id = _secure_secret(
        Path(args.installation_id_file), label="GitHub App installation ID", maximum=64
    ).decode().strip()
    if not app_id.isdecimal() or not installation_id.isdecimal():
        raise BrokerError("GitHub App identities must be positive decimal integers")
    if int(app_id) < 1 or int(installation_id) < 1:
        raise BrokerError("GitHub App identities must be positive decimal integers")
    private_key = _secure_secret(
        Path(args.private_key_file), label="GitHub App private key", maximum=65536
    )
    issued_at = _now()
    app_jwt = _jwt(app_id, private_key, now=issued_at)
    _, token_response = _request_json(
        "POST",
        f"/app/installations/{installation_id}/access_tokens",
        token=app_jwt,
        body={"repositories": [name], "permissions": REQUIRED_PERMISSIONS},
    )
    if not isinstance(token_response, dict):
        raise BrokerError("GitHub token response is not one object")
    token = token_response.get("token")
    expires_at = _timestamp(token_response.get("expires_at"), label="GitHub token expiry")
    permissions = token_response.get("permissions")
    repositories = token_response.get("repositories")
    if (
        not isinstance(token, str)
        or len(token) < 20
        or len(token) > 4096
        or any(character.isspace() for character in token)
        or permissions != REQUIRED_PERMISSIONS
        or not isinstance(repositories, list)
        or len(repositories) != 1
        or not isinstance(repositories[0], dict)
        or str(repositories[0].get("full_name", "")).casefold() != repository.casefold()
        or repositories[0].get("default_branch") != default_branch
        or type(repositories[0].get("id")) is not int
        or repositories[0]["id"] < 1
    ):
        raise BrokerError("GitHub token is not restricted to the exact delivery contract")
    lifetime = int((expires_at - issued_at).total_seconds())
    if lifetime < 50 * 60 or lifetime > 65 * 60:
        raise BrokerError("GitHub installation token has an unexpected lifetime")
    rules_raw, rules_value = _request_json(
        "GET",
        f"/repos/{owner}/{name}/rules/branches/{default_branch}?per_page=100",
        token=token,
    )
    rules, ruleset_ids = _validate_rules(rules_value)
    rulesets: list[dict[str, Any]] = []
    for ruleset_id in ruleset_ids:
        _, ruleset = _request_json(
            "GET", f"/repos/{owner}/{name}/rulesets/{ruleset_id}", token=token
        )
        if (
            not isinstance(ruleset, dict)
            or ruleset.get("id") != ruleset_id
            or ruleset.get("enforcement") != "active"
            or ruleset.get("bypass_actors") != []
        ):
            raise BrokerError("default branch ruleset is inactive or bypassable")
        rulesets.append(ruleset)
    token_content = (token + "\n").encode("utf-8")
    receipt = {
        "schema_version": 1,
        "kind": "gas-city-github-app-delivery-token",
        "status": "verified",
        "repository": {
            "id": repositories[0]["id"],
            "name_with_owner": repositories[0]["full_name"],
            "default_branch": default_branch,
        },
        "permissions": permissions,
        "app_id_sha256": _sha256(app_id.encode()),
        "installation_id_sha256": _sha256(installation_id.encode()),
        "token_sha256": _sha256(token_content),
        "issued_at": _format(issued_at),
        "expires_at": _format(expires_at),
        "lifetime_seconds": lifetime,
        "effective_rules_sha256": _sha256(rules_raw),
        "effective_rule_types": sorted({rule["type"] for rule in rules}),
        "ruleset_ids": ruleset_ids,
        "rulesets_sha256": _sha256(_json_bytes(rulesets)),
        "api_version": API_VERSION,
    }
    _atomic_new(state / "token", token_content, mode=0o400)
    receipt_content = _json_bytes(receipt)
    _atomic_new(state / "receipt.json", receipt_content, mode=0o400)
    return {
        "status": "verified",
        "token_path": str(state / "token"),
        "receipt_path": str(state / "receipt.json"),
        "receipt_sha256": _sha256(receipt_content),
        "expires_at": receipt["expires_at"],
    }


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="github-app-token-broker")
    subparsers = parser.add_subparsers(dest="action", required=True)
    issue_parser = subparsers.add_parser("issue")
    issue_parser.add_argument("--state-dir", required=True)
    issue_parser.add_argument("--repository", required=True)
    issue_parser.add_argument("--default-branch", required=True)
    issue_parser.add_argument("--app-id-file", required=True)
    issue_parser.add_argument("--installation-id-file", required=True)
    issue_parser.add_argument("--private-key-file", required=True)
    return parser


def main(argv: list[str]) -> int:
    args = _parser().parse_args(argv[1:])
    try:
        result = issue(args)
    except Exception as exc:  # noqa: BLE001 - host credential broker fails closed.
        print(f"GitHub App token broker rejected {args.action}: {exc}", file=sys.stderr)
        return 1
    print(json.dumps(result, sort_keys=True, separators=(",", ":")))
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
