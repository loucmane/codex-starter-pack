{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/schemas/template-frontmatter.schema.json",
  "title": "Template Frontmatter",
  "description": "Portable baseline schema for governed template metadata. Repo-local policy controls required keys and scope.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "deprecated",
        "review",
        "archived",
        "draft",
        "experimental"
      ]
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?([-.+][0-9A-Za-z.-]+)?$"
    },
    "deprecated_since": {
      "type": "string",
      "format": "date"
    },
    "archive_after": {
      "type": "string",
      "format": "date"
    },
    "replacement": {
      "type": "string",
      "minLength": 1
    },
    "migration_notice": {
      "type": "string",
      "minLength": 1
    },
    "dependencies": {
      "$ref": "#/$defs/stringList"
    },
    "triggers": {
      "$ref": "#/$defs/stringList"
    },
    "exports": {
      "$ref": "#/$defs/stringList"
    },
    "tags": {
      "$ref": "#/$defs/stringList"
    },
    "tools": {
      "$ref": "#/$defs/stringList"
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
